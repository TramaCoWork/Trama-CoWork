---
  import EditorModal from '../../components/EditorModal.astro';
---

<div id="view-feed" class="flex-1 flex flex-col min-h-0">
  <div class="flex items-center gap-3 mb-4 shrink-0">
    <span id="channel-icon" class="material-symbols-outlined text-primary" aria-hidden="true">tag</span>
    <h2 id="channel-name" class="text-lg font-bold text-on-surface">general</h2>
  </div>

  <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/15 p-4 mb-4 shrink-0">
    <div class="flex justify-end">
      <button
        id="open-new-post-modal"
        type="button"
        class="px-5 py-3 bg-primary text-on-primary rounded-lg font-bold text-sm hover:brightness-110 active:scale-95 transition-all flex items-center gap-1.5"
      >
        <span class="material-symbols-outlined text-sm" aria-hidden="true">add</span>
        Crear post
      </button>
    </div>
  </div>

  <div id="posts-container" class="flex-1 overflow-y-auto space-y-3 pr-1">
    <div class="flex items-center justify-center py-16">
      <div class="text-center space-y-3">
        <span class="material-symbols-outlined text-3xl text-primary animate-spin" aria-hidden="true">schedule</span>
        <p class="text-sm text-on-surface-variant font-medium">Cargando..</p>
      </div>
    </div>
  </div>
  <div id="posts-load-more-wrapper" class="hidden shrink-0 pt-3 text-center">
    <button id="posts-load-more-btn" class="text-xs text-primary hover:text-primary/80 font-semibold transition-colors">
      Cargar más
    </button>
  </div>
</div>

<EditorModal />

<script>
  import {
    fetchPosts,
    fetchChannelPosts,
    createPost,
    createChannelPost,
    deletePost,
    type Channel,
    type Post,
  } from '../../services/communityService';
  import { associateCommunityImages } from '../../services/uploadService';
  import { escapeHtml, timeAgo } from '../../utils/helpers';
  import { renderMarkdown } from '../../utils/markdown';

  const channelIconEl = document.getElementById('channel-icon');
  const channelNameEl = document.getElementById('channel-name')!;
  const postsContainer = document.getElementById('posts-container')!;
  const postsLoadMoreWrapper = document.getElementById('posts-load-more-wrapper')!;
  const postsLoadMoreBtn = document.getElementById('posts-load-more-btn') as HTMLButtonElement;
  const openNewPostModalButton = document.getElementById('open-new-post-modal') as HTMLButtonElement;

  let userId: string | null = null;
  let currentChannel = 'general';
  let currentChannelObj: Channel | null = null;
  let feedCurrentPage = 1;
  let feedTotalPages = 1;
  let isLoadingMorePosts = false;
  let feedPosts: Post[] = [];
  let isSubmittingEditor = false;
  const FEED_PAGE_LIMIT = 20;

  function renderFeedPost(post: Post): string {
    const isOwner = post.userId === userId;
    const commentCount = post.commentCount ?? 0;
    const authorName = post.user?.profile?.name || post.user?.email || 'Usuario';
    const postType = post.type || (currentChannelObj?.type === 'channel' ? 'channel' : 'community');
    const postChannelSlug = post.channelSlug || (postType === 'community' ? currentChannel : '');
    const postChannelId = post.channelId || (postType === 'channel' ? currentChannel : '');

    return `
      <article
        class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 p-4 hover:border-outline-variant/25 transition-all cursor-pointer"
        data-post-id="${post.id}"
        data-post-type="${postType}"
        data-channel-type="${postType}"
        data-channel-slug="${escapeHtml(postChannelSlug)}"
        data-channel-id="${escapeHtml(postChannelId)}"
        role="link"
        tabindex="0"
      >
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-primary text-sm" aria-hidden="true">person</span>
            </div>
            <div>
              <span class="text-sm font-bold text-on-surface">${escapeHtml(authorName)}</span>
              <span class="text-xs text-on-surface-variant ml-2">${timeAgo(post.createdAt)}</span>
            </div>
          </div>
          ${isOwner ? `
            <button class="btn-delete-post text-on-surface-variant hover:text-error text-xs transition-colors p-1" data-post-id="${post.id}" title="Eliminar post">
              <span class="material-symbols-outlined text-base" aria-hidden="true">delete</span>
            </button>` : ''}
        </div>
        <div class="markdown-content text-sm text-on-surface leading-relaxed pl-11">${renderMarkdown(post.content)}</div>
        <div class="pl-11 mt-3 flex items-center gap-4">
          <button class="btn-open-comment-editor text-xs text-on-surface-variant hover:text-primary font-semibold flex items-center gap-1 transition-colors" data-post-id="${post.id}">
            <span class="material-symbols-outlined text-sm" aria-hidden="true">edit</span>
            Comentar
          </button>
          <button class="btn-open-comments text-xs text-on-surface-variant hover:text-primary font-semibold flex items-center gap-1 transition-colors" data-post-id="${post.id}">
            <span class="material-symbols-outlined text-sm" aria-hidden="true">comment</span>
            <span class="comment-count-label">${commentCount} ${commentCount === 1 ? 'comentario' : 'comentarios'}</span>
          </button>
        </div>
      </article>`;
  }

  function openEditorModal(detail: { title: string; placeholder: string; maxlength: number; context: string }) {
    document.dispatchEvent(new CustomEvent('open-editor-modal', { detail }));
  }

  function findPostData(postId: string): Post | undefined {
    return feedPosts.find(post => post.id === postId);
  }

  function normalizePaginatedPosts(result: unknown, fallbackPage: number, fallbackLimit: number) {
    if (Array.isArray(result)) {
      return { posts: result as Post[], page: fallbackPage, totalPages: 1 };
    }

    const paginated = result as { data?: Post[]; page?: number; total?: number; limit?: number };
    const posts = Array.isArray(paginated.data) ? paginated.data : [];
    const page = paginated.page ?? fallbackPage;
    const limit = paginated.limit ?? fallbackLimit;
    const total = paginated.total ?? posts.length;
    const totalPages = Math.max(1, Math.ceil(total / Math.max(1, limit)));

    return { posts, page, totalPages };
  }

  function updateFeedLoadMoreVisibility() {
    const hasMore = feedCurrentPage < feedTotalPages;
    postsLoadMoreWrapper.classList.toggle('hidden', !hasMore);
    postsLoadMoreBtn.disabled = isLoadingMorePosts;
  }

  async function loadPosts() {
    postsContainer.innerHTML = `
      <div class="flex items-center justify-center py-16">
        <div class="text-center space-y-3">
          <span class="material-symbols-outlined text-3xl text-primary animate-spin" aria-hidden="true">schedule</span>
          <p class="text-sm text-on-surface-variant font-medium">Cargando..</p>
        </div>
      </div>`;

    try {
      const result = currentChannelObj?.type === 'channel'
        ? await fetchChannelPosts(currentChannel, 1, FEED_PAGE_LIMIT)
        : await fetchPosts(currentChannel, 1, FEED_PAGE_LIMIT);
      const { posts, page, totalPages } = normalizePaginatedPosts(result, 1, FEED_PAGE_LIMIT);
      feedCurrentPage = page;
      feedTotalPages = totalPages;
      isLoadingMorePosts = false;
      feedPosts = posts;

      if (posts.length === 0) {
        postsContainer.innerHTML = `
          <div class="text-center py-16">
            <span class="material-symbols-outlined text-4xl text-outline mb-3 block" aria-hidden="true">forum</span>
            <p class="text-on-surface-variant font-medium">No hay posts en este canal todavía.</p>
            <p class="text-on-surface-variant text-sm mt-1">Se el primero en publicar algo.</p>
          </div>`;
        updateFeedLoadMoreVisibility();
        return;
      }

      postsContainer.innerHTML = posts.map(renderFeedPost).join('');
      bindPostActions();
      updateFeedLoadMoreVisibility();
    } catch (err) {
      console.error('Error cargando posts:', err);
      feedCurrentPage = 1;
      feedTotalPages = 1;
      isLoadingMorePosts = false;
      updateFeedLoadMoreVisibility();
      postsContainer.innerHTML = `
        <div class="text-center py-16">
          <span class="material-symbols-outlined text-4xl text-error mb-3 block" aria-hidden="true">error</span>
          <p class="text-on-surface-variant font-medium">Error al cargar los posts.</p>
        </div>`;
    }
  }

  async function loadMorePosts() {
    if (isLoadingMorePosts || feedCurrentPage >= feedTotalPages) {
      return;
    }

    const nextPage = feedCurrentPage + 1;
    isLoadingMorePosts = true;
    updateFeedLoadMoreVisibility();

    try {
      const result = currentChannelObj?.type === 'channel'
        ? await fetchChannelPosts(currentChannel, nextPage, FEED_PAGE_LIMIT)
        : await fetchPosts(currentChannel, nextPage, FEED_PAGE_LIMIT);
      const { posts, page, totalPages } = normalizePaginatedPosts(result, nextPage, FEED_PAGE_LIMIT);
      feedCurrentPage = page;
      feedTotalPages = totalPages;
      feedPosts = [...feedPosts, ...posts];

      postsContainer.insertAdjacentHTML('beforeend', posts.map(renderFeedPost).join(''));
      bindPostActions();
    } catch (err) {
      console.error('Error cargando más posts:', err);
    } finally {
      isLoadingMorePosts = false;
      updateFeedLoadMoreVisibility();
    }
  }

  async function handleEditorSubmit(content: string, imageIds: string[], context: string) {
    if (context !== 'post') {
      return;
    }

    let newPost: Post;
    if (currentChannelObj?.type === 'channel') {
      newPost = await createChannelPost(currentChannel, content);
    } else {
      newPost = await createPost(content, currentChannel);
    }

    if (imageIds.length > 0) {
      await associateCommunityImages(imageIds, newPost.id, 'POST');
    }

    await loadPosts();
  }

  function navigateToPostReader(postId: string, type: Channel['type']) {
    const query = type === 'community'
      ? `type=community&slug=${encodeURIComponent(currentChannel)}&postId=${encodeURIComponent(postId)}`
      : `type=channel&channelId=${encodeURIComponent(currentChannel)}&postId=${encodeURIComponent(postId)}`;

    window.location.href = `/dashboard/comunidad/post?${query}`;
  }

  function shouldIgnorePostNavigation(target: HTMLElement): boolean {
    return Boolean(target.closest('.btn-delete-post, .btn-open-comment-editor, .btn-open-comments, button, a, input, textarea, select, label'));
  }

  function bindPostActions() {
    postsContainer.querySelectorAll('.btn-delete-post').forEach(button => {
      if ((button as HTMLElement).dataset.bound) return;
      (button as HTMLElement).dataset.bound = 'true';
      button.addEventListener('click', () => {
        const postId = (button as HTMLElement).dataset.postId;
        if (!postId) {
          return;
        }

        const postType = findPostData(postId)?.type || (button as HTMLElement).closest('article')?.dataset.postType || 'community';
        if (postType === 'channel') {
          return;
        }

        (window as any).openConfirmModal({
          title: '¿Eliminar este post?',
          message: 'Esta acción no se puede deshacer.',
          iconBgClass: 'bg-red-50',
          iconHtml: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>',
          buttons: [
            {
              text: 'Eliminar',
              icon: '<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>',
              variant: 'danger',
              onClick: async () => {
                try {
                  await deletePost(postId);
                  await loadPosts();
                } catch (err) {
                  console.error('Error eliminando post:', err);
                }
              },
            },
            { text: 'Cancelar', variant: 'ghost' },
          ],
        });
      });
    });

    postsContainer.querySelectorAll('.btn-open-comment-editor').forEach(button => {
      if ((button as HTMLElement).dataset.bound) return;
      (button as HTMLElement).dataset.bound = 'true';
      button.addEventListener('click', () => {
        const postId = (button as HTMLElement).dataset.postId;
        if (!postId) {
          return;
        }

        openEditorModal({
          title: 'Comentar publicación',
          placeholder: 'Escribí tu comentario...',
          maxlength: 500,
          context: `comment-${postId}`,
        });
      });
    });

    postsContainer.querySelectorAll('.btn-open-comments').forEach(button => {
      if ((button as HTMLElement).dataset.bound) return;
      (button as HTMLElement).dataset.bound = 'true';
      button.addEventListener('click', () => {
        const postId = (button as HTMLElement).dataset.postId;
        if (!postId) {
          return;
        }

        const post = findPostData(postId);
        const channelType = post?.type === 'channel' ? 'channel' : 'community';
        const channelSlug = post?.channelSlug || (channelType === 'community' ? currentChannel : '');
        const channelId = post?.channelId || (channelType === 'channel' ? currentChannel : '');
        document.dispatchEvent(new CustomEvent('comunidad:modal-open-post', {
          detail: { postId, channelType, channelSlug, channelId },
        }));
      });
    });
  }

  postsLoadMoreBtn.addEventListener('click', async () => {
    await loadMorePosts();
  });

  postsContainer.addEventListener('click', (event) => {
    const target = event.target as HTMLElement;
    if (shouldIgnorePostNavigation(target)) {
      return;
    }

    const card = target.closest<HTMLElement>('article[data-post-id][data-post-type]');
    if (!card?.dataset.postId || !card.dataset.postType) {
      return;
    }

    const type = card.dataset.postType === 'channel' ? 'channel' : 'community';
    navigateToPostReader(card.dataset.postId, type);
  });

  postsContainer.addEventListener('keydown', (event) => {
    const keyboardEvent = event as KeyboardEvent;
    if (keyboardEvent.key !== 'Enter' && keyboardEvent.key !== ' ') {
      return;
    }

    const target = keyboardEvent.target as HTMLElement;
    if (shouldIgnorePostNavigation(target)) {
      return;
    }

    const card = target.closest<HTMLElement>('article[data-post-id][data-post-type]');
    if (!card?.dataset.postId || !card.dataset.postType) {
      return;
    }

    keyboardEvent.preventDefault();
    const type = card.dataset.postType === 'channel' ? 'channel' : 'community';
    navigateToPostReader(card.dataset.postId, type);
  });

  document.addEventListener('editor-modal-submit', async event => {
    if (isSubmittingEditor) return;

    const customEvent = event as CustomEvent<{ content?: string; imageIds?: string[]; context?: string }>;
    const content = customEvent.detail?.content?.trim() || '';
    const imageIds = Array.isArray(customEvent.detail?.imageIds) ? customEvent.detail.imageIds : [];
    const context = customEvent.detail?.context || '';

    if (!content || !context) {
      return;
    }

    isSubmittingEditor = true;
    try {
      await handleEditorSubmit(content, imageIds, context);
    } catch (err) {
      console.error('Error procesando envío del editor modal:', err);
    } finally {
      isSubmittingEditor = false;
    }
  });

  openNewPostModalButton.addEventListener('click', () => {
    const type = currentChannelObj?.type === 'channel' ? 'channel' : 'community';
    const params = new URLSearchParams({ type });
    if (type === 'channel') {
      params.set('channelId', currentChannel);
    } else {
      params.set('slug', currentChannel);
    }
    const name = currentChannelObj?.name || currentChannel;
    if (name) {
      params.set('name', name);
    }
    window.location.href = `/dashboard/comunidad/nuevo?${params.toString()}`;
  });

  document.addEventListener('comunidad:profile-loaded', (event) => {
    const customEvent = event as CustomEvent<{ userId?: string | null; token?: string }>;
    userId = customEvent.detail?.userId ? String(customEvent.detail.userId) : null;
    channelNameEl.textContent = currentChannel;
    if (channelIconEl) {
      channelIconEl.textContent = 'tag';
    }
    void loadPosts();
  });

  document.addEventListener('comunidad:channel-changed', (event) => {
    const customEvent = event as CustomEvent<{ channel?: string; channelObj?: Channel | null }>;
    const channelSlug = customEvent.detail?.channel;
    if (!channelSlug) {
      return;
    }

    currentChannel = channelSlug;
    currentChannelObj = customEvent.detail?.channelObj || null;
    channelNameEl.textContent = currentChannelObj?.name || currentChannel;
    if (channelIconEl) {
      channelIconEl.textContent = currentChannelObj?.type === 'channel' ? 'hub' : 'tag';
    }

    void loadPosts();
  });

  document.addEventListener('comunidad:tab-activated', (event) => {
    const customEvent = event as CustomEvent<{ tab?: 'feed' | 'myposts' | 'messages' }>;
    if (customEvent.detail?.tab === 'feed' && userId) {
      void loadPosts();
    }
  });
</script>
