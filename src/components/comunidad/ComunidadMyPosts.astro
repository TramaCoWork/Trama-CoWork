<div id="view-myposts" class="flex-1 flex flex-col min-h-0 hidden">
  <div class="flex items-center justify-between mb-4 shrink-0">
    <div class="flex items-center gap-3">
      <span class="material-symbols-outlined text-primary" aria-hidden="true">person</span>
      <h2 class="text-lg font-bold text-on-surface">Mis Posts</h2>
    </div>
    <div class="flex items-center gap-2">
      <label for="myposts-channel-filter" class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">Canal:</label>
      <select
        id="myposts-channel-filter"
        class="bg-surface-container-low border-none rounded-lg px-3 py-2 text-sm font-medium text-on-surface focus:ring-2 focus:ring-primary/20 cursor-pointer"
      >
        <option value="">Todos</option>
      </select>
    </div>
  </div>
  <div id="myposts-container" class="flex-1 overflow-y-auto space-y-4 pr-1">
    <div class="flex items-center justify-center py-16">
      <div class="text-center space-y-3">
        <span class="material-symbols-outlined text-3xl text-primary animate-spin" aria-hidden="true">schedule</span>
        <p class="text-sm text-on-surface-variant font-medium">Cargando..</p>
      </div>
    </div>
  </div>
</div>

<script>
  import {
    fetchMyPosts,
    deletePost,
    updatePostStatus,
    deleteChannelPost,
    updateChannelPostStatus,
    type Channel,
    type Post,
  } from '../../services/communityService';
  import { escapeHtml, formatDate, truncate, timeAgo } from '../../utils/helpers';
  import { renderMarkdown } from '../../utils/markdown';

  type ProfileLoadedDetail = {
    userId?: string | null;
    token?: string;
    channels?: Channel[];
  };

  const mypostsContainer = document.getElementById('myposts-container')!;
  const mypostsChannelSelect = document.getElementById('myposts-channel-filter') as HTMLSelectElement;

  let allMyPosts: Post[] = [];
  let myPostsChannelFilter = '';
  let knownChannels: Channel[] = [];
  let profileUserId: string | null = null;
  let hasLoadedMyPosts = false;

  function isOwnPost(post: Post): boolean {
    if (!profileUserId) return true; // "mis posts" ya devuelve solo los propios
    const authorId = post.userId ?? post.user?.id;
    return authorId ? String(authorId) === profileUserId : true;
  }

  function renderMyPost(post: Post): string {
    const isChannelPost = post.type === 'channel';
    const isOwner = isOwnPost(post);
    const commentCount = post.commentCount ?? 0;
    const isPaused = post.status === 'paused';
    const statusLabel = isPaused ? 'Pausado' : 'Publicado';
    const statusIcon = isPaused ? 'pause_circle' : 'check_circle';
    const badgeClass = isPaused ? 'bg-outline/10 text-outline' : 'bg-primary/10 text-primary';
    const cardOpacity = isPaused ? 'opacity-60' : '';
    const channelLabel = post.channelName || 'Grupo';
    const communitySlug = post.channelSlug;
    const communityLabel = post.channelName || communitySlug;
    const channelMeta = isChannelPost
      ? `<span class="inline-flex items-center gap-1 text-xs text-on-surface-variant"><span class="material-symbols-outlined text-xs" aria-hidden="true">hub</span>${escapeHtml(channelLabel)}</span>`
      : communityLabel ? `<span class="text-xs text-on-surface-variant">· #${escapeHtml(communityLabel)}</span>` : '';
    const statusBadge = `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider ${badgeClass}">
                <span class="material-symbols-outlined text-xs" aria-hidden="true">${statusIcon}</span>
                ${statusLabel}
              </span>`;
    const headerActions = !isOwner
      ? ''
      : `<div class="flex items-center gap-1 shrink-0">
            <button class="btn-edit-mypost text-on-surface-variant hover:text-primary text-xs transition-colors p-1.5" data-post-id="${post.id}" title="Editar post">
              <span class="material-symbols-outlined text-base" aria-hidden="true">edit</span>
            </button>
            <button
              class="btn-toggle-status px-2.5 py-1.5 rounded-lg text-xs font-bold transition-all flex items-center gap-1 ${isPaused ? 'text-primary hover:bg-primary/10' : 'text-outline hover:bg-outline/10'}"
              data-post-id="${post.id}"
              data-current-status="${post.status || 'published'}"
              title="${isPaused ? 'Publicar' : 'Pausar'}"
            >
              <span class="material-symbols-outlined text-sm" aria-hidden="true">${isPaused ? 'play_arrow' : 'pause'}</span>
              ${isPaused ? 'Publicar' : 'Pausar'}
            </button>
            <button class="btn-delete-mypost text-on-surface-variant hover:text-error text-xs transition-colors p-1.5" data-post-id="${post.id}" title="Eliminar post">
              <span class="material-symbols-outlined text-base" aria-hidden="true">delete</span>
            </button>
          </div>`;

    const postType = post.type || 'community';
    const postChannelSlug = post.channelSlug || '';
    const postChannelId = post.channelId || '';

    return `
      <article
        class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 p-5 transition-all cursor-pointer hover:border-outline-variant/25 ${cardOpacity}"
        data-post-id="${post.id}"
        data-post-type="${postType}"
        data-channel-type="${postType}"
        data-channel-slug="${escapeHtml(postChannelSlug)}"
        data-channel-id="${escapeHtml(postChannelId)}"
        role="link"
        tabindex="0"
      >
        <div class="flex items-start justify-between gap-3 mb-3">
          <div class="flex-1">
            <div class="markdown-content text-sm text-on-surface leading-relaxed font-medium">${renderMarkdown(post.content)}</div>
            <div class="flex items-center gap-2 mt-1.5 flex-wrap">
              <span class="text-xs text-on-surface-variant" title="${escapeHtml(formatDate(post.createdAt))}">${timeAgo(post.createdAt)}</span>
              ${channelMeta}
              ${statusBadge}
            </div>
          </div>
          ${headerActions}
        </div>
        <div class="border-t border-outline-variant/10 pt-3 mt-3">
          <div class="flex items-center gap-4">
            <button class="btn-open-comment-editor text-xs text-on-surface-variant hover:text-primary font-semibold flex items-center gap-1 transition-colors" data-post-id="${post.id}">
              <span class="material-symbols-outlined text-sm" aria-hidden="true">edit</span>
              Comentar
            </button>
            <button class="btn-open-comments text-xs text-on-surface-variant hover:text-primary font-semibold flex items-center gap-1 transition-colors" data-post-id="${post.id}">
              <span class="material-symbols-outlined text-sm" aria-hidden="true">comment</span>
              <span class="comment-count-label">${commentCount} ${commentCount === 1 ? 'comentario recibido' : 'comentarios recibidos'}</span>
            </button>
          </div>
        </div>
      </article>`;
  }

  function renderFilteredMyPosts() {
    const filtered = myPostsChannelFilter
      ? allMyPosts.filter((post) => {
          const key = post.type === 'channel' ? post.channelId : post.channelSlug;
          return key === myPostsChannelFilter;
        })
      : allMyPosts;

    if (filtered.length === 0) {
      mypostsContainer.innerHTML = `
        <div class="text-center py-16">
          <span class="material-symbols-outlined text-4xl text-outline mb-3 block" aria-hidden="true">edit_note</span>
          <p class="text-on-surface-variant font-medium">${myPostsChannelFilter ? 'No tenés posts en este canal.' : 'No has publicado nada todavía.'}</p>
        </div>`;
      return;
    }

    mypostsContainer.innerHTML = filtered.map(renderMyPost).join('');
    bindMyPostActions();
  }

  function resolveFilterLabel(post: Post): string | null {
    if (post.channelName) {
      return post.channelName;
    }

    if (post.type === 'channel' && post.channelId) {
      const match = knownChannels.find((channel) => channel.slug === post.channelId);
      return match?.name || 'Grupo';
    }

    if (post.channelSlug) {
      const match = knownChannels.find((channel) => channel.slug === post.channelSlug);
      return match?.name || post.channelSlug;
    }

    return null;
  }

  function populateMyPostsChannelFilterOptions() {
    const currentValue = mypostsChannelSelect.value;
    const optionsMap = new Map<string, string>();

    allMyPosts.forEach((post) => {
      const value = post.type === 'channel' ? post.channelId : post.channelSlug;
      if (!value || optionsMap.has(value)) {
        return;
      }

      const label = resolveFilterLabel(post);
      if (!label) {
        return;
      }

      optionsMap.set(value, truncate(label, 28));
    });

    mypostsChannelSelect.innerHTML = '';
    const allOption = document.createElement('option');
    allOption.value = '';
    allOption.textContent = 'Todos';
    mypostsChannelSelect.appendChild(allOption);

    optionsMap.forEach((label, value) => {
      const option = document.createElement('option');
      option.value = value;
      option.textContent = label;
      mypostsChannelSelect.appendChild(option);
    });

    if (currentValue && optionsMap.has(currentValue)) {
      mypostsChannelSelect.value = currentValue;
      return;
    }

    mypostsChannelSelect.value = '';
    myPostsChannelFilter = '';
  }

  async function loadMyPosts() {
    mypostsContainer.innerHTML = `
      <div class="flex items-center justify-center py-16">
        <div class="text-center space-y-3">
          <span class="material-symbols-outlined text-3xl text-primary animate-spin" aria-hidden="true">schedule</span>
          <p class="text-sm text-on-surface-variant font-medium">Cargando..</p>
        </div>
      </div>`;

    try {
      const result = await fetchMyPosts();
      allMyPosts = Array.isArray(result) ? result : (result as { data?: Post[] }).data || [];
      populateMyPostsChannelFilterOptions();
      renderFilteredMyPosts();
      hasLoadedMyPosts = true;
    } catch (err) {
      console.error('Error cargando mis posts:', err);
      mypostsContainer.innerHTML = `
        <div class="text-center py-16">
          <span class="material-symbols-outlined text-4xl text-error mb-3 block" aria-hidden="true">error</span>
          <p class="text-on-surface-variant font-medium">Error al cargar tus posts.</p>
        </div>`;
    }
  }

  function bindMyPostActions() {
    mypostsContainer.querySelectorAll('.btn-edit-mypost').forEach(button => {
      if ((button as HTMLElement).dataset.bound) return;
      (button as HTMLElement).dataset.bound = 'true';
      button.addEventListener('click', () => {
        const postId = (button as HTMLElement).dataset.postId;
        if (!postId) return;

        const post = allMyPosts.find((item) => item.id === postId);
        if (!post || !isOwnPost(post)) return;

        const type = post.type === 'channel' ? 'channel' : 'community';
        const query = type === 'community'
          ? `type=community&slug=${encodeURIComponent(post.channelSlug || '')}&postId=${encodeURIComponent(postId)}`
          : `type=channel&channelId=${encodeURIComponent(post.channelId || '')}&postId=${encodeURIComponent(postId)}`;
        window.location.href = `/dashboard/comunidad/editar?${query}`;
      });
    });

    mypostsContainer.querySelectorAll('.btn-toggle-status').forEach(button => {
      if ((button as HTMLElement).dataset.bound) return;
      (button as HTMLElement).dataset.bound = 'true';
      button.addEventListener('click', async () => {
        const postId = (button as HTMLElement).dataset.postId;
        if (!postId) return;

        const post = allMyPosts.find((item) => item.id === postId);
        if (!post || !isOwnPost(post)) {
          return;
        }

        const currentStatus = (button as HTMLElement).dataset.currentStatus as 'published' | 'paused';
        const newStatus = currentStatus === 'published' ? 'paused' : 'published';
        (button as HTMLButtonElement).disabled = true;

        try {
          if (post.type === 'channel') {
            await updateChannelPostStatus(post.channelId || '', postId, newStatus);
          } else {
            await updatePostStatus(postId, newStatus);
          }
          post.status = newStatus;
          renderFilteredMyPosts();
        } catch (err) {
          console.error('Error cambiando estado del post:', err);
        }
      });
    });

    mypostsContainer.querySelectorAll('.btn-delete-mypost').forEach(button => {
      if ((button as HTMLElement).dataset.bound) return;
      (button as HTMLElement).dataset.bound = 'true';
      button.addEventListener('click', () => {
        const postId = (button as HTMLElement).dataset.postId;
        if (!postId) return;

        const post = allMyPosts.find((item) => item.id === postId);
        if (!post || !isOwnPost(post)) {
          return;
        }

        (window as any).openConfirmModal({
          title: '¿Eliminar este post?',
          message: 'Esta acción no se puede deshacer.',
          iconBgClass: 'bg-red-50',
          iconHtml: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>',
          buttons: [
            {
              text: 'Eliminar',
              icon: '<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>',
              variant: 'danger',
              onClick: async () => {
                try {
                  if (post.type === 'channel') {
                    await deleteChannelPost(post.channelId || '', postId);
                  } else {
                    await deletePost(postId);
                  }
                  allMyPosts = allMyPosts.filter((item) => item.id !== postId);
                  renderFilteredMyPosts();
                } catch (err) {
                  console.error('Error eliminando post:', err);
                }
              },
            },
            { text: 'Cancelar', variant: 'ghost' },
          ],
        });
      });
    });

    mypostsContainer.querySelectorAll('.btn-open-comment-editor').forEach(button => {
      if ((button as HTMLElement).dataset.bound) return;
      (button as HTMLElement).dataset.bound = 'true';
      button.addEventListener('click', () => {
        const postId = (button as HTMLElement).dataset.postId;
        if (!postId) return;

        document.dispatchEvent(new CustomEvent('open-editor-modal', {
          detail: {
            title: 'Comentar publicación',
            placeholder: 'Escribí tu comentario...',
            maxlength: 500,
            context: `comment-${postId}`,
          },
        }));
      });
    });

    mypostsContainer.querySelectorAll('.btn-open-comments').forEach(button => {
      if ((button as HTMLElement).dataset.bound) return;
      (button as HTMLElement).dataset.bound = 'true';
      button.addEventListener('click', () => {
        const postId = (button as HTMLElement).dataset.postId;
        if (!postId) return;

        const post = allMyPosts.find((item) => item.id === postId);
        const channelType = post?.type === 'channel' ? 'channel' : 'community';
        const channelSlug = post?.channelSlug || '';
        const channelId = post?.channelId || '';
        document.dispatchEvent(new CustomEvent('comunidad:modal-open-post', {
          detail: { postId, channelType, channelSlug, channelId },
        }));
      });
    });
  }

  function shouldIgnorePostNavigation(target: HTMLElement): boolean {
    return Boolean(
      target.closest(
        '.btn-edit-mypost, .btn-toggle-status, .btn-delete-mypost, .btn-open-comment-editor, .btn-open-comments, button, a, input, textarea, select, label',
      ),
    );
  }

  function navigateToPostReader(card: HTMLElement): void {
    const postId = card.dataset.postId;
    if (!postId) return;

    const type = card.dataset.postType === 'channel' ? 'channel' : 'community';
    const query = type === 'community'
      ? `type=community&slug=${encodeURIComponent(card.dataset.channelSlug || '')}&postId=${encodeURIComponent(postId)}`
      : `type=channel&channelId=${encodeURIComponent(card.dataset.channelId || '')}&postId=${encodeURIComponent(postId)}`;

    window.location.href = `/dashboard/comunidad/post?${query}`;
  }

  mypostsContainer.addEventListener('click', (event) => {
    const target = event.target as HTMLElement;
    if (shouldIgnorePostNavigation(target)) return;

    const card = target.closest<HTMLElement>('article[data-post-id][data-post-type]');
    if (!card) return;
    navigateToPostReader(card);
  });

  mypostsContainer.addEventListener('keydown', (event) => {
    const keyboardEvent = event as KeyboardEvent;
    if (keyboardEvent.key !== 'Enter' && keyboardEvent.key !== ' ') return;

    const target = keyboardEvent.target as HTMLElement;
    if (shouldIgnorePostNavigation(target)) return;

    const card = target.closest<HTMLElement>('article[data-post-id][data-post-type]');
    if (!card) return;

    keyboardEvent.preventDefault();
    navigateToPostReader(card);
  });

  mypostsChannelSelect.addEventListener('change', () => {
    myPostsChannelFilter = mypostsChannelSelect.value;
    renderFilteredMyPosts();
  });

  document.addEventListener('comunidad:profile-loaded', (event) => {
    const customEvent = event as CustomEvent<ProfileLoadedDetail>;
    profileUserId = customEvent.detail?.userId ? String(customEvent.detail.userId) : null;
    knownChannels = Array.isArray(customEvent.detail?.channels) ? customEvent.detail.channels : [];
    if (!profileUserId) {
      return;
    }
    void loadMyPosts();
  });

  document.addEventListener('comunidad:myposts-open', () => {
    if (!hasLoadedMyPosts) {
      void loadMyPosts();
      return;
    }
    renderFilteredMyPosts();
  });

  document.addEventListener('comunidad:tab-activated', (event) => {
    const customEvent = event as CustomEvent<{ tab?: 'feed' | 'myposts' | 'messages' }>;
    if (customEvent.detail?.tab === 'myposts') {
      void loadMyPosts();
    }
  });

  document.addEventListener('comunidad:channel-changed', () => {
    if (allMyPosts.length === 0) {
      return;
    }
    populateMyPostsChannelFilterOptions();
  });
</script>
