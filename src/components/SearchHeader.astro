---

<header
  class="relative bg-surface-container-low py-12 px-6 bg-cover bg-center bg-no-repeat"
  style="background-image: url('/images/profesionales-hero.jpg');"
>
  <div class="absolute inset-0 bg-neutral-900/45" aria-hidden="true"></div>
  <div class="relative max-w-5xl mx-auto space-y-8">
    <div class="space-y-2">
      <h1 class="text-4xl font-extrabold tracking-tight text-white">
        Encontrá la experiencia
        <span class="text-accent-yellow italic">indicada</span>.
      </h1>
      <p class="text-white/90 font-medium">
        Explorá profesionales verificados en tu zona o especializados
        globalmente.
      </p>
    </div>

    <!-- Filtros -->
    <form id="search-form" role="search" aria-label="Buscar profesionales">
      <div class="relative group">
        <div
          class="absolute -inset-1 bg-gradient-to-r from-primary/20 to-secondary/20 rounded-2xl blur opacity-25 group-focus-within:opacity-100 transition duration-1000"
          aria-hidden="true"
        >
        </div>
        <div
          class="relative bg-surface-container-lowest p-4 md:p-5 rounded-2xl shadow-sm"
        >
          <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-4"
          >
            <!-- Búsqueda -->
            <div class="space-y-1.5">
              <label
                for="filter-q"
                class="text-xs font-bold text-on-surface-variant uppercase tracking-widest flex items-center gap-1.5"
              >
                <span
                  class="material-symbols-outlined text-primary text-sm"
                  aria-hidden="true">search</span
                >
                Búsqueda
              </label>
              <input
                id="filter-q"
                type="text"
                name="q"
                placeholder="Buscar por especialidad, habilidad o nombre"
                style="flex:1; border:1px solid #D9D9D9; border-radius:8px; padding:10px 14px; font-size:15px; color:#404040; outline:none;"
              />
            </div>

            <!-- País -->
            <div class="space-y-1.5">
              <label
                for="filter-country"
                class="text-xs font-bold text-on-surface-variant uppercase tracking-widest flex items-center gap-1.5"
              >
                <span
                  class="material-symbols-outlined text-primary text-sm"
                  aria-hidden="true">public</span
                >
                País
              </label>
              <select
                id="filter-country"
                name="countryId"
                class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-sm font-medium text-on-surface focus:ring-2 focus:ring-primary/30 transition-all cursor-pointer"
              >
                <option value="">Todos los países</option>
              </select>
            </div>

            <!-- Provincia -->
            <div class="space-y-1.5">
              <label
                for="filter-province"
                class="text-xs font-bold text-on-surface-variant uppercase tracking-widest flex items-center gap-1.5"
              >
                <span
                  class="material-symbols-outlined text-primary text-sm"
                  aria-hidden="true">location_on</span
                >
                Provincia
              </label>
              <select
                id="filter-province"
                name="provinceId"
                disabled
                class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-sm font-medium text-on-surface focus:ring-2 focus:ring-primary/30 transition-all cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <option value="">Selecciona un país primero</option>
              </select>
            </div>
          </div>

          <!-- Botón buscar -->
          <div class="flex justify-end">
            <button
              type="submit"
              class="bg-primary hover:bg-primary-container text-on-primary font-bold px-8 py-3 rounded-xl transition-all active:scale-95 flex items-center justify-center gap-2"
            >
              <span class="material-symbols-outlined text-xl" aria-hidden="true"
                >search</span
              >
              Buscar
            </button>
          </div>
        </div>
      </div>
    </form>
  </div>
</header>

<script>
  import { fetchCountries, fetchProvinces } from "../services/locationService";

  const queryInput = document.getElementById("filter-q") as HTMLInputElement;
  const countrySelect = document.getElementById(
    "filter-country",
  ) as HTMLSelectElement;
  const provinceSelect = document.getElementById(
    "filter-province",
  ) as HTMLSelectElement;

  // ─── Leer query params de la URL ──────────────────────────────
  const urlParams = new URLSearchParams(window.location.search);
  const preQ = urlParams.get("q") || "";
  const preCountryId = urlParams.get("countryId") || "";
  const preProvinceId = urlParams.get("provinceId") || "";

  // ─── Cargar países ────────────────────────────────────────────
  async function loadCountries() {
    try {
      const countries = await fetchCountries();
      countries.forEach((c) => {
        const opt = document.createElement("option");
        opt.value = String(c.id);
        opt.textContent = c.name;
        if (String(c.id) === preCountryId) opt.selected = true;
        countrySelect.appendChild(opt);
      });
      // Si hay país preseleccionado, cargar provincias
      if (preCountryId) {
        await loadProvinces();
      }
    } catch (err) {
      console.error("Error cargando países:", err);
    }
  }

  // ─── Cargar provincias (cascada desde país) ───────────────────
  async function loadProvinces() {
    const countryId = countrySelect.value;

    // Reset
    provinceSelect.innerHTML = '<option value="">Todas las provincias</option>';

    if (!countryId) {
      provinceSelect.disabled = true;
      provinceSelect.innerHTML =
        '<option value="">Selecciona un país primero</option>';
      return;
    }

    provinceSelect.disabled = false;

    try {
      const provinces = await fetchProvinces(Number(countryId));
      provinces.forEach((p) => {
        const opt = document.createElement("option");
        opt.value = String(p.id);
        opt.textContent = p.name;
        if (String(p.id) === preProvinceId) opt.selected = true;
        provinceSelect.appendChild(opt);
      });
    } catch (err) {
      console.error("Error cargando provincias:", err);
    }
  }

  countrySelect.addEventListener("change", () => {
    loadProvinces();
  });

  document.addEventListener("DOMContentLoaded", () => {
    queryInput.value = preQ;
  });

  // ─── Init: cargar países ──────────────────────────────────────
  loadCountries();
</script>

