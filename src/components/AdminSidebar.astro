---
const currentPath = Astro.url.pathname;

const sidebarLinks = [
  { href: '/admin/profesionales', icon: 'group', label: 'Profesionales' },
];

function isActive(href: string): boolean {
  return currentPath.startsWith(href);
}
---

<aside class="h-screen w-64 border-r border-outline-variant/15 bg-surface-container-low flex flex-col py-6 gap-2 sticky top-0 shrink-0">
  <!-- Header -->
  <div class="px-6 mb-8">
    <a href="/admin" class="text-lg font-bold text-on-surface tracking-tighter hover:text-primary transition-colors">
      TRAMA Admin
    </a>
    <p class="text-xs font-semibold text-error uppercase tracking-widest mt-1">
      Panel de administración
    </p>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 space-y-1" aria-label="Panel de administración">
    {sidebarLinks.map((link) => (
      <a
        href={link.href}
        class={isActive(link.href)
          ? 'bg-primary/10 text-primary rounded-lg mx-2 flex items-center px-4 py-3 gap-3 transition-transform duration-200 hover:translate-x-1 text-sm font-bold'
          : 'text-on-surface-variant hover:bg-surface-container mx-2 flex items-center px-4 py-3 gap-3 transition-transform duration-200 hover:translate-x-1 text-sm font-semibold rounded-lg'}
        aria-current={isActive(link.href) ? 'page' : undefined}
      >
        <span class="material-symbols-outlined" aria-hidden="true">{link.icon}</span>
        <span>{link.label}</span>
      </a>
    ))}
  </nav>

  <!-- Admin user card -->
  <div class="px-4 mt-auto">
    <div class="bg-surface-container-lowest p-4 rounded-xl shadow-sm border border-outline-variant/10">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-full bg-error/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-error text-xl" aria-hidden="true">admin_panel_settings</span>
        </div>
        <div>
          <p id="admin-sidebar-email" class="text-sm font-bold text-on-surface truncate max-w-[140px]">Admin</p>
          <p class="text-[10px] text-error uppercase tracking-tighter font-bold">Administrador</p>
        </div>
      </div>
      <button
        id="admin-logout-btn"
        type="button"
        class="block w-full text-center bg-error-container text-on-error-container text-xs font-bold py-2 rounded-lg hover:opacity-90 active:scale-95 transition-all"
      >
        Cerrar sesión
      </button>
    </div>
  </div>
</aside>

<script>
  import { getEmailFromToken, logout } from '../services/authService';

  const email = getEmailFromToken();
  const emailEl = document.getElementById('admin-sidebar-email');
  if (emailEl && email) emailEl.textContent = email;

  document.getElementById('admin-logout-btn')?.addEventListener('click', () => logout('/admin/login'));
</script>
