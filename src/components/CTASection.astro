---

<section class="py-24 max-w-7xl mx-auto px-6" aria-label="Llamada a la accion">
  <div class="bg-primary-container rounded-2xl p-12 md:p-20 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-12">
    <div class="relative z-10 max-w-xl">
      <h2 class="text-5xl font-extrabold text-on-primary-container tracking-tighter mb-6 leading-tight">
        &iquest;Listo para mostrar tu talento?
      </h2>
      <p class="text-on-primary-container/80 text-xl font-medium mb-10">
        Unite a nuestra red de profesionales de elite y llega a miles de clientes que buscan tu experiencia espec&iacute;fica.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="/registro"
          class="px-10 py-4 bg-surface-container-lowest text-primary font-black rounded-full hover:scale-105 transition-transform text-center"
        >
          Comenzar
        </a>
        <a
          href="/como-funciona"
          class="px-10 py-4 border-2 border-on-primary-container/30 text-on-primary-container font-black rounded-full hover:bg-on-primary-container/10 transition-colors text-center"
        >
          C&oacute;mo funciona
        </a>
      </div>
    </div>
    <div class="relative z-10 hidden lg:block" aria-hidden="true">
      <div class="w-64 h-64 bg-on-primary-container/10 backdrop-blur-3xl rounded-full border border-on-primary-container/20 flex items-center justify-center">
        <span class="material-symbols-outlined text-on-primary-container text-8xl">send</span>
      </div>
    </div>
    <!-- Gradiente abstracto -->
    <div class="absolute inset-0 bg-gradient-to-tr from-primary to-transparent opacity-50" aria-hidden="true"></div>
  </div>
</section>
