<section style="padding:48px 24px; background:white;" aria-label="Llamada a la accion">
  <div style="max-width:1200px; margin:0 auto; background:#F7F7F7; border:1px solid #EDEDED; border-radius:24px; padding:32px 48px; display:flex; align-items:center; gap:0;">

    <div style="flex:1.5; padding-right:40px;">
      <h2 style="font-size:22px; font-weight:700; color:#111827; margin:0 0 8px 0;">¿Listo para mostrar tu talento?</h2>
      <p style="font-size:14px; color:#5b6472; margin:0 0 20px 0; max-width:300px;">Unite a nuestra red de profesionales de élite y llegá a miles de clientes que buscan tu experiencia específica.</p>
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="/registro" style="background:#087781; color:white; padding:11px 24px; border-radius:10px; font-size:14px; font-weight:600; text-decoration:none; display:inline-block;">Crear mi perfil</a>
        <a href="/como-funciona" style="border:1.5px solid #087781; color:#087781; padding:11px 24px; border-radius:10px; font-size:14px; font-weight:600; text-decoration:none; background:white; display:inline-block;">Cómo funciona</a>
      </div>
    </div>

    <div style="flex:1; display:flex; justify-content:center; align-items:center; padding-left:40px;">
      <div style="position:relative; height:300px; aspect-ratio:9/16; border-radius:16px; overflow:hidden; box-shadow:0 6px 20px rgba(0,0,0,0.12);">
        <iframe
          src="https://www.youtube.com/embed/_H_C0dM-cqY?rel=0&modestbranding=1"
          title="TRAMA Cowork"
          style="position:absolute; inset:0; width:100%; height:100%; border:0;"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>

  </div>
</section>
