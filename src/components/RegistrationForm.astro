---
---

<section class="w-full md:w-1/2 lg:w-2/5 bg-surface-container-lowest p-5 sm:p-8 lg:p-16 flex flex-col justify-center relative min-h-screen">
  <!-- Back Link -->
  <a
    href="/"
    class="flex items-center gap-2 text-primary font-semibold hover:opacity-80 transition-opacity mb-8 self-start"
  >
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M10 19l-7-7m0 0l7-7m-7 7h18" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
    </svg>
    Volver al inicio
  </a>

  <div class="w-full max-w-lg mx-auto">
    <!-- Logo mobile -->
    <div class="md:hidden mb-8 flex items-center gap-3">
      <svg class="w-8 h-8 shrink-0" fill="none" viewBox="0 0 100 100" aria-hidden="true">
        <path d="M30 20L50 40L70 20" stroke="#00AFB9" stroke-linecap="round" stroke-width="8"/>
        <path d="M30 80L50 60L70 80" stroke="#F9C74F" stroke-linecap="round" stroke-width="8"/>
        <path d="M20 30L40 50L20 70" stroke="#F94144" stroke-linecap="round" stroke-width="8"/>
        <path d="M80 30L60 50L80 70" stroke="#90BE6D" stroke-linecap="round" stroke-width="8"/>
      </svg>
      <span class="text-xl font-extrabold tracking-widest uppercase text-on-surface">Trama</span>
    </div>

    <!-- Header -->
    <div class="mb-8">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-on-surface tracking-tight">Unite a <span class="text-primary">TRAMA</span></h2>
      <p class="text-on-surface-variant mt-2 font-medium">Creá tu perfil profesional en minutos.</p>
    </div>

    <!-- Form -->
    <form id="registration-form" class="space-y-4 sm:space-y-5" novalidate>
      <!-- Nombre Completo -->
      <div>
        <label class="block text-xs font-bold text-on-surface uppercase tracking-wider mb-2" for="name">Nombre Completo</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-outline pointer-events-none">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
          </span>
          <input
            class="w-full pl-12 pr-4 py-3.5 sm:py-4 border border-outline-variant/30 rounded-xl bg-surface-container-lowest text-on-surface placeholder:text-outline/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
            id="name"
            name="name"
            placeholder="Ej. Alejandro Martínez"
            required
            type="text"
            autocomplete="name"
          />
        </div>
      </div>

      <!-- Correo Electrónico -->
      <div>
        <label class="block text-xs font-bold text-on-surface uppercase tracking-wider mb-2" for="email">Correo Electrónico</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-outline pointer-events-none">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
          </span>
          <input
            class="w-full pl-12 pr-4 py-3.5 sm:py-4 border border-outline-variant/30 rounded-xl bg-surface-container-lowest text-on-surface placeholder:text-outline/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
            id="email"
            name="email"
            placeholder="ejemplo@correo.com"
            required
            type="email"
            autocomplete="email"
          />
        </div>
      </div>

      <!-- Contraseña -->
      <div>
        <label class="block text-xs font-bold text-on-surface uppercase tracking-wider mb-2" for="password">Contraseña</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-outline pointer-events-none">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
          </span>
          <input
            class="w-full pl-12 pr-12 py-3.5 sm:py-4 border border-outline-variant/30 rounded-xl bg-surface-container-lowest text-on-surface placeholder:text-outline/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
            id="password"
            name="password"
            placeholder="Mínimo 8 caracteres"
            required
            type="password"
            minlength="8"
            autocomplete="new-password"
          />
          <button
            id="btn-toggle-password"
            type="button"
            class="absolute inset-y-0 right-0 flex items-center pr-4 text-outline hover:text-primary transition-colors"
            aria-label="Mostrar contraseña"
          >
            <svg class="h-5 w-5" id="icon-eye-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
              <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
            <svg class="h-5 w-5 hidden" id="icon-eye-closed" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Rubro Profesional -->
      <div>
        <label class="block text-xs font-bold text-on-surface uppercase tracking-wider mb-2" for="rubro">Rubro Profesional</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-outline pointer-events-none">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
          </span>
          <select
            class="w-full pl-12 pr-10 py-3.5 sm:py-4 border border-outline-variant/30 rounded-xl bg-surface-container-lowest text-on-surface appearance-none cursor-pointer focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
            id="rubro"
            name="rubroId"
            required
          >
            <option disabled selected value="">Cargando rubros...</option>
          </select>
          <span class="absolute inset-y-0 right-0 flex items-center pr-4 text-outline pointer-events-none">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
          </span>
        </div>
      </div>

      <!-- Ciudad -->
      <div>
        <label class="block text-xs font-bold text-on-surface uppercase tracking-wider mb-2" for="city">Ciudad</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-outline pointer-events-none">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
              <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
          </span>
          <input
            class="w-full pl-12 pr-4 py-3.5 sm:py-4 border border-outline-variant/30 rounded-xl bg-surface-container-lowest text-on-surface placeholder:text-outline/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
            id="city"
            name="city"
            placeholder="Ej. Buenos Aires"
            required
            type="text"
          />
        </div>
      </div>

      <!-- Términos y Privacidad -->
      <div class="flex items-start gap-3 pt-1">
        <input
          class="mt-0.5 h-5 w-5 rounded border-outline-variant text-primary focus:ring-primary/20 shrink-0"
          id="terms"
          name="terms"
          required
          type="checkbox"
        />
        <label for="terms" class="text-xs text-on-surface-variant leading-relaxed">
          Acepto los <a class="text-primary font-semibold hover:underline" href="/terminos">Términos de Servicio</a> y la
          <a class="text-primary font-semibold hover:underline" href="/privacidad">Política de Privacidad</a> de TRAMA.
        </label>
      </div>

      <!-- Submit Button -->
      <button
        class="w-full py-3.5 sm:py-4 px-6 bg-primary text-on-primary font-bold rounded-xl shadow-lg shadow-primary/20 hover:brightness-110 active:scale-[0.98] transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:brightness-100 disabled:active:scale-100"
        type="submit"
        disabled
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
        </svg>
        Crear cuenta profesional
      </button>

      <!-- Login Link -->
      <p class="text-center text-sm font-medium text-on-surface-variant pt-6">
        ¿Ya tenés una cuenta? <a class="text-primary font-bold hover:underline" href="/login">Iniciá sesión</a>
      </p>
    </form>
  </div>
</section>

<script>
  import { fetchRubros } from '../services/professionCategoriesService';
  import { professionalRegister } from '../services/authService';

  // ─── Toggle password visibility ───────────────────────────────
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const toggleBtn = document.getElementById('btn-toggle-password')!;
  const iconOpen = document.getElementById('icon-eye-open')!;
  const iconClosed = document.getElementById('icon-eye-closed')!;

  toggleBtn.addEventListener('click', () => {
    const isPassword = passwordInput.type === 'password';
    passwordInput.type = isPassword ? 'text' : 'password';
    iconOpen.classList.toggle('hidden', !isPassword);
    iconClosed.classList.toggle('hidden', isPassword);
    toggleBtn.setAttribute('aria-label', isPassword ? 'Ocultar contraseña' : 'Mostrar contraseña');
  });

  // ─── Cargar rubros ────────────────────────────────────────────
  const rubroSelect = document.getElementById('rubro') as HTMLSelectElement;

  async function loadRubros() {
    try {
      const rubros = await fetchRubros();
      rubroSelect.innerHTML = '<option disabled selected value="">Seleccioná tu rubro</option>'
        + rubros.map(r => `<option value="${r.id}">${r.name}</option>`).join('');
    } catch (err) {
      console.error('Error cargando rubros:', err);
      rubroSelect.innerHTML = '<option disabled selected>Error al cargar rubros</option>';
    }
  }

  loadRubros();

  // ─── Referencias del form ────────────────────────────────────
  const form = document.getElementById('registration-form') as HTMLFormElement;
  const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  // ─── Validación en tiempo real ────────────────────────────────
  const nameInput = document.getElementById('name') as HTMLInputElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const cityInput = document.getElementById('city') as HTMLInputElement;
  const termsCheck = document.getElementById('terms') as HTMLInputElement;

  function validateForm() {
    const valid =
      nameInput.value.trim() !== '' &&
      emailInput.value.trim() !== '' &&
      /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim()) &&
      passwordInput.value.length >= 8 &&
      rubroSelect.value !== '' &&
      cityInput.value.trim() !== '' &&
      termsCheck.checked;

    submitBtn.disabled = !valid;
  }

  nameInput.addEventListener('input', validateForm);
  emailInput.addEventListener('input', validateForm);
  passwordInput.addEventListener('input', validateForm);
  cityInput.addEventListener('input', validateForm);
  rubroSelect.addEventListener('change', validateForm);
  termsCheck.addEventListener('change', validateForm);

  // ─── Submit ───────────────────────────────────────────────────
  const errorDiv = document.createElement('div');
  errorDiv.className = 'hidden bg-error-container text-on-error-container rounded-xl px-4 py-3 text-sm font-medium';
  form.insertBefore(errorDiv, submitBtn);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    const formData = new FormData(form);
    const rubroId = Number(formData.get('rubroId'));

    if (!rubroId) {
      errorDiv.textContent = 'Seleccioná un rubro profesional.';
      errorDiv.classList.remove('hidden');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<div class="w-5 h-5 border-2 border-on-primary/30 border-t-on-primary rounded-full animate-spin"></div> <span>Creando cuenta...</span>';

    try {
      await professionalRegister({
        name: formData.get('name') as string,
        email: formData.get('email') as string,
        password: formData.get('password') as string,
        city: formData.get('city') as string,
        rubroId,
      });
      window.location.href = '/dashboard';
    } catch (err: any) {
      console.error('Error en registro:', err);
      const msg = err.body?.message || 'Error al crear la cuenta. Intenta de nuevo.';
      errorDiv.textContent = Array.isArray(msg) ? msg.join('. ') : msg;
      errorDiv.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg> Crear cuenta profesional';
      validateForm();
    }
  });
</script>
