---
---

<section class="w-full md:w-1/2 flex items-center justify-center p-6 md:p-16 bg-surface relative">
  <a
    href="/"
    class="absolute top-6 left-6 md:top-8 md:left-8 flex items-center gap-1.5 text-sm font-medium text-on-surface-variant hover:text-primary transition-colors"
  >
    <span class="material-symbols-outlined text-lg" aria-hidden="true">arrow_back</span>
    Volver al inicio
  </a>

  <div class="w-full max-w-md">
    <!-- Logo mobile -->
    <div class="md:hidden mb-12 flex justify-center">
      <span class="font-headline text-2xl font-extrabold tracking-tighter text-primary">TRAMA</span>
    </div>

    <div class="mb-10 text-center md:text-left">
      <h2 class="font-headline text-3xl font-bold text-on-surface tracking-tight mb-2">Unite a TRAMA</h2>
      <p class="text-on-surface-variant font-light">Crea tu cuenta profesional hoy mismo.</p>
    </div>

    <form id="registration-form" class="space-y-6" novalidate>
      <!-- Nombre -->
      <div class="space-y-1.5">
        <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant font-semibold" for="name">
          Nombre Completo
        </label>
        <div class="relative group">
          <input
            class="w-full px-4 py-3 bg-surface-container-low border-none rounded-lg focus:ring-2 focus:ring-primary/20 transition-all placeholder:text-outline-variant/60"
            id="name"
            name="name"
            placeholder="Ej. Alejandro Martinez"
            required
            type="text"
            autocomplete="name"
          />
          <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-primary group-focus-within:w-full transition-all duration-300"></div>
        </div>
      </div>

      <!-- Email -->
      <div class="space-y-1.5">
        <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant font-semibold" for="email">
          Correo Electronico
        </label>
        <div class="relative group">
          <input
            class="w-full px-4 py-3 bg-surface-container-low border-none rounded-lg focus:ring-2 focus:ring-primary/20 transition-all placeholder:text-outline-variant/60"
            id="email"
            name="email"
            placeholder="nombre@empresa.com"
            required
            type="email"
            autocomplete="email"
          />
          <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-primary group-focus-within:w-full transition-all duration-300"></div>
        </div>
      </div>

      <!-- Contrasena -->
      <div class="space-y-1.5">
        <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant font-semibold" for="password">
          Contrasena
        </label>
        <div class="relative group">
          <input
            class="w-full px-4 py-3 bg-surface-container-low border-none rounded-lg focus:ring-2 focus:ring-primary/20 transition-all placeholder:text-outline-variant/60"
            id="password"
            name="password"
            placeholder="********"
            required
            type="password"
            minlength="8"
            autocomplete="new-password"
          />
          <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-primary group-focus-within:w-full transition-all duration-300"></div>
        </div>
        <p class="text-xs text-outline italic">Minimo 8 caracteres, incluye simbolos.</p>
      </div>

      <!-- Categoria Profesional -->
      <div class="space-y-1.5">
        <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant font-semibold" for="category">
          Categoria Profesional
        </label>
        <div class="relative group">
          <select
            class="w-full px-4 py-3 bg-surface-container-low border-none rounded-lg focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer"
            id="category"
            name="category"
            required
          >
            <option disabled selected value="">Selecciona tu especialidad</option>
            <option value="architecture">Arquitectura y Diseno</option>
            <option value="engineering">Ingenieria Estructural</option>
            <option value="management">Gestion de Proyectos</option>
            <option value="sustainability">Sostenibilidad Urbana</option>
            <option value="tech">Tecnologia y BIM</option>
          </select>
          <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none">
            <span class="material-symbols-outlined text-outline" aria-hidden="true">expand_more</span>
          </div>
          <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-primary group-focus-within:w-full transition-all duration-300"></div>
        </div>
      </div>

      <!-- Terminos y Privacidad -->
      <div class="flex items-start space-x-3 pt-2">
        <div class="flex items-center h-5">
          <input
            class="h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary/20"
            id="terms"
            name="terms"
            required
            type="checkbox"
          />
        </div>
        <label for="terms" class="text-xs text-on-surface-variant leading-relaxed">
          Acepto los <a class="text-primary font-bold hover:underline" href="/terminos">Terminos de Servicio</a> y la
          <a class="text-primary font-bold hover:underline" href="/privacidad">Politica de Privacidad</a> de TRAMA.
        </label>
      </div>

      <!-- Boton Submit -->
      <button
        class="w-full py-4 px-6 bg-gradient-to-br from-primary to-primary-container text-on-primary font-bold rounded-lg shadow-lg hover:shadow-xl hover:scale-[1.01] active:scale-95 transition-all duration-200 flex items-center justify-center space-x-2"
        type="submit"
      >
        <span class="material-symbols-outlined text-sm" aria-hidden="true">person_add</span>
        <span>Crear cuenta profesional</span>
      </button>

      <!-- Separador -->
      <div class="relative py-4 flex items-center" role="separator">
        <div class="flex-grow border-t border-outline-variant/30"></div>
        <span class="flex-shrink mx-4 text-xs font-label text-outline uppercase tracking-widest">o registrate con</span>
        <div class="flex-grow border-t border-outline-variant/30"></div>
      </div>

      <!-- Registro Social -->
      <div class="grid grid-cols-2 gap-4">
        <button
          class="flex items-center justify-center space-x-2 py-3 px-4 bg-surface-container-lowest border border-outline-variant/20 rounded-lg hover:bg-surface-container transition-colors text-sm font-medium"
          type="button"
          aria-label="Registrarse con Google"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="currentColor"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="currentColor"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="currentColor"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="currentColor"/>
          </svg>
          <span>Google</span>
        </button>
        <button
          class="flex items-center justify-center space-x-2 py-3 px-4 bg-surface-container-lowest border border-outline-variant/20 rounded-lg hover:bg-surface-container transition-colors text-sm font-medium"
          type="button"
          aria-label="Registrarse con LinkedIn"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
          </svg>
          <span>LinkedIn</span>
        </button>
      </div>

      <!-- Link a Login -->
      <div class="text-center pt-8">
        <p class="text-on-surface-variant text-sm">
          Ya tenes una cuenta profesional?
          <a class="text-primary font-bold hover:underline transition-all" href="/login">Inicia sesion</a>
        </p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('registration-form') as HTMLFormElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      password: formData.get('password'),
      category: formData.get('category'),
    };

    console.log('Registro:', data);

    // TODO: Reemplazar con fetch a API real
