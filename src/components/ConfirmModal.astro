---
/**
 * ConfirmModal
 * ------------
 * Generic reusable confirmation modal.
 *
 * Usage from JS:
 *   window.openConfirmModal({
 *     title: 'Confirmar acción',
 *     body: '¿Estás seguro?',
 *     confirmText: 'Sí, confirmar',
 *     cancelText: 'Cancelar',
 *     confirmStyle: 'primary',        // 'primary' | 'error'
 *     onConfirm: () => { ... },
 *     onCancel: () => { ... },         // optional
 *   });
 *
 *   window.closeConfirmModal();
 */
---

<div
  id="confirm-modal-overlay"
  class="fixed inset-0 z-[95] hidden items-center justify-center bg-black/50 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="confirm-modal-title"
>
  <div class="bg-surface rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl border border-outline-variant/10">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-4">
      <div id="confirm-modal-icon-wrap" class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0">
        <span id="confirm-modal-icon" class="material-symbols-outlined text-2xl" aria-hidden="true"></span>
      </div>
      <h3 id="confirm-modal-title" class="text-lg font-extrabold text-on-surface tracking-tight"></h3>
    </div>

    <!-- Body -->
    <p id="confirm-modal-body" class="text-sm text-on-surface-variant leading-relaxed mb-6"></p>

    <!-- Actions -->
    <div class="flex gap-3">
      <button
        id="confirm-modal-cancel-btn"
        type="button"
        class="flex-1 px-6 py-3 rounded-xl font-bold text-sm text-on-surface-variant bg-surface-container-low hover:bg-surface-container-high transition-colors"
      ></button>
      <button
        id="confirm-modal-confirm-btn"
        type="button"
        class="flex-1 px-6 py-3 rounded-xl font-bold text-sm hover:opacity-90 active:scale-[0.98] transition-all"
      ></button>
    </div>
  </div>
</div>

<script>
  interface ConfirmModalOptions {
    title: string;
    body: string;
    confirmText?: string;
    cancelText?: string;
    confirmStyle?: 'primary' | 'error';
    onConfirm?: () => void;
    onCancel?: () => void;
  }

  const overlay = document.getElementById('confirm-modal-overlay')!;
  const iconWrap = document.getElementById('confirm-modal-icon-wrap')!;
  const icon = document.getElementById('confirm-modal-icon')!;
  const titleEl = document.getElementById('confirm-modal-title')!;
  const bodyEl = document.getElementById('confirm-modal-body')!;
  const cancelBtn = document.getElementById('confirm-modal-cancel-btn')!;
  const confirmBtn = document.getElementById('confirm-modal-confirm-btn')!;

  let currentOnConfirm: (() => void) | null = null;
  let currentOnCancel: (() => void) | null = null;

  function openModal(opts: ConfirmModalOptions) {
    const style = opts.confirmStyle || 'primary';

    titleEl.textContent = opts.title;
    bodyEl.textContent = opts.body;
    cancelBtn.textContent = opts.cancelText || 'Cancelar';
    confirmBtn.textContent = opts.confirmText || 'Confirmar';

    // Style icon
    if (style === 'error') {
      iconWrap.className = 'w-11 h-11 rounded-xl flex items-center justify-center shrink-0 bg-error/10';
      icon.textContent = 'warning';
      icon.className = 'material-symbols-outlined text-2xl text-error';
      confirmBtn.className = 'flex-1 px-6 py-3 rounded-xl font-bold text-sm hover:opacity-90 active:scale-[0.98] transition-all bg-error text-on-error';
    } else {
      iconWrap.className = 'w-11 h-11 rounded-xl flex items-center justify-center shrink-0 bg-primary/10';
      icon.textContent = 'help';
      icon.className = 'material-symbols-outlined text-2xl text-primary';
      confirmBtn.className = 'flex-1 px-6 py-3 rounded-xl font-bold text-sm hover:opacity-90 active:scale-[0.98] transition-all bg-primary text-on-primary';
    }

    currentOnConfirm = opts.onConfirm || null;
    currentOnCancel = opts.onCancel || null;

    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    document.body.style.overflow = '';
    currentOnConfirm = null;
    currentOnCancel = null;
  }

  confirmBtn.addEventListener('click', () => {
    const cb = currentOnConfirm;
    closeModal();
    if (cb) cb();
  });

  cancelBtn.addEventListener('click', () => {
    const cb = currentOnCancel;
    closeModal();
    if (cb) cb();
  });

  // Close on backdrop click
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) {
      const cb = currentOnCancel;
      closeModal();
      if (cb) cb();
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay.classList.contains('hidden')) {
      const cb = currentOnCancel;
      closeModal();
      if (cb) cb();
    }
  });

  // Expose globally
  (window as any).openConfirmModal = openModal;
  (window as any).closeConfirmModal = closeModal;
</script>
