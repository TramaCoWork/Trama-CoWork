<div
  id="confirm-modal-overlay"
  class="fixed inset-0 z-[95] hidden items-center justify-center bg-black/30 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="confirm-modal-title"
>
  <div id="confirm-modal-card" class="bg-white rounded-2xl shadow-2xl p-8 max-w-sm w-full mx-4">
    <div id="confirm-modal-icon-wrap" class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center mx-auto">
      <span id="confirm-modal-icon" class="material-symbols-outlined text-red-500" aria-hidden="true">warning</span>
    </div>

    <h3 id="confirm-modal-title" class="text-xl font-bold text-gray-900 text-center mt-4"></h3>
    <p id="confirm-modal-message" class="text-sm text-gray-500 text-center mt-2 mb-6"></p>

    <div id="confirm-modal-actions" class="flex flex-col gap-3 w-full"></div>
  </div>
</div>

<script>
  type ConfirmButtonVariant = 'danger' | 'outline' | 'ghost';

  interface ConfirmModalButton {
    text: string;
    icon?: string;
    variant: ConfirmButtonVariant;
    onClick?: () => void;
  }

  interface ConfirmModalOptions {
    title: string;
    message?: string;
    body?: string;
    iconHtml?: string;
    iconBgClass?: string;
    buttons?: ConfirmModalButton[];
    confirmText?: string;
    secondaryText?: string;
    cancelText?: string;
    confirmStyle?: 'primary' | 'error';
    secondaryStyle?: 'outline' | 'primary' | 'error';
    onConfirm?: () => void;
    onSecondary?: () => void;
    onCancel?: () => void;
  }

  const overlay = document.getElementById('confirm-modal-overlay') as HTMLDivElement;
  const iconWrap = document.getElementById('confirm-modal-icon-wrap') as HTMLDivElement;
  const iconEl = document.getElementById('confirm-modal-icon') as HTMLSpanElement;
  const titleEl = document.getElementById('confirm-modal-title') as HTMLHeadingElement;
  const messageEl = document.getElementById('confirm-modal-message') as HTMLParagraphElement;
  const actionsEl = document.getElementById('confirm-modal-actions') as HTMLDivElement;
  let currentOnDismiss: (() => void) | null = null;

  const variantClassMap: Record<ConfirmButtonVariant, string> = {
    danger: 'bg-red-500 text-white hover:bg-red-600 w-full py-3 rounded-xl font-semibold',
    outline: 'border border-gray-200 text-gray-700 hover:bg-gray-100 w-full py-3 rounded-xl font-medium',
    ghost: 'text-gray-500 hover:bg-gray-50 w-full py-3 rounded-xl font-medium',
  };

  function toVariant(style?: string): ConfirmButtonVariant {
    if (style === 'error') {
      return 'danger';
    }

    if (style === 'outline') {
      return 'outline';
    }

    return 'ghost';
  }

  function getButtons(opts: ConfirmModalOptions): ConfirmModalButton[] {
    if (opts.buttons && opts.buttons.length > 0) {
      return opts.buttons;
    }

    const buttons: ConfirmModalButton[] = [];

    if (opts.confirmText) {
      buttons.push({
        text: opts.confirmText,
        variant: opts.confirmStyle === 'error' ? 'danger' : 'outline',
        onClick: opts.onConfirm,
      });
    }

    if (opts.secondaryText) {
      buttons.push({
        text: opts.secondaryText,
        variant: toVariant(opts.secondaryStyle),
        onClick: opts.onSecondary,
      });
    }

    buttons.push({
      text: opts.cancelText || 'Cancelar',
      variant: 'ghost',
      onClick: opts.onCancel,
    });

    return buttons;
  }

  function setIcon(opts: ConfirmModalOptions, buttons: ConfirmModalButton[]) {
    iconWrap.className = `w-12 h-12 rounded-full flex items-center justify-center mx-auto ${opts.iconBgClass || 'bg-red-50'}`;

    if (opts.iconHtml) {
      iconEl.className = '';
      iconEl.innerHTML = opts.iconHtml;
      return;
    }

    const hasDanger = buttons.some(button => button.variant === 'danger');
    iconEl.innerHTML = '';
    iconEl.textContent = hasDanger ? 'warning' : 'help';
    iconEl.className = `material-symbols-outlined ${hasDanger ? 'text-red-500' : 'text-gray-500'}`;
  }

  function closeModal() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    document.body.style.overflow = '';
    actionsEl.innerHTML = '';
    currentOnDismiss = null;
  }

  function openModal(opts: ConfirmModalOptions) {
    const buttons = getButtons(opts);
    currentOnDismiss = opts.onCancel || null;
    titleEl.textContent = opts.title;
    messageEl.textContent = opts.message || opts.body || '';
    actionsEl.innerHTML = '';
    setIcon(opts, buttons);

    buttons.forEach(button => {
      const action = document.createElement('button');
      action.type = 'button';
      action.className = `transition-colors flex items-center justify-center gap-2 ${variantClassMap[button.variant]}`;
      action.innerHTML = `${button.icon || ''}<span>${button.text}</span>`;
      action.addEventListener('click', () => {
        closeModal();
        if (button.onClick) {
          button.onClick();
        }
      });
      actionsEl.appendChild(action);
    });

    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  overlay.addEventListener('click', (event) => {
    if (event.target === overlay) {
      const dismissHandler = currentOnDismiss;
      closeModal();
      if (dismissHandler) {
        dismissHandler();
      }
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && !overlay.classList.contains('hidden')) {
      const dismissHandler = currentOnDismiss;
      closeModal();
      if (dismissHandler) {
        dismissHandler();
      }
    }
  });

  (window as any).openConfirmModal = openModal;
  (window as any).closeConfirmModal = closeModal;
</script>
