---
import type { Professional } from '../data/mock';

interface Props {
  professional: Professional;
}

const { professional } = Astro.props;

const fullStars = Math.floor(professional.rating);
const emptyStars = 5 - fullStars;
---

<article class="bg-surface-container-lowest rounded-xl overflow-hidden group hover:shadow-xl transition-all duration-500">
  <div class="aspect-[4/3] overflow-hidden relative">
    <img
      alt={`Foto de perfil de ${professional.name}`}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
      src={professional.image}
      loading="lazy"
    />
    {professional.topRated && (
      <div class="absolute top-4 right-4 bg-surface-container-lowest/90 backdrop-blur-md px-3 py-1 rounded-full text-xs font-black tracking-widest uppercase text-secondary">
        TOP RATED
      </div>
    )}
  </div>
  <div class="p-8">
    <div class="flex justify-between items-start mb-4">
      <div>
        <span class="text-xs font-bold text-primary tracking-widest uppercase mb-1 block">{professional.category}</span>
        <h3 class="text-xl font-bold text-on-surface">{professional.name}</h3>
      </div>
      <div class="text-right">
        <span class="text-xs text-outline block font-medium">Desde</span>
        <span class="text-lg font-black text-on-surface">
          ${professional.hourlyRate}<span class="text-sm font-medium text-outline">/hr</span>
        </span>
      </div>
    </div>
    <div class="flex items-center gap-1 mb-6" role="img" aria-label={`${professional.rating} de 5 estrellas`}>
      {Array.from({ length: fullStars }).map(() => (
        <span class="material-symbols-outlined text-sm filled text-star" aria-hidden="true">star</span>
      ))}
      {Array.from({ length: emptyStars }).map(() => (
        <span class="material-symbols-outlined text-sm text-star-empty" aria-hidden="true">star</span>
      ))}
      <span class="text-xs font-bold ml-2 text-on-surface-variant">
        {professional.rating} ({professional.reviewCount} rese&ntilde;as)
      </span>
    </div>
    <a
      href={`/profesionales/perfil?id=${professional.id}`}
      class="block w-full py-4 bg-surface-container-low text-on-surface font-bold rounded-lg hover:bg-primary hover:text-on-primary transition-all duration-300 text-center"
    >
      Ver perfil
    </a>
  </div>
</article>
