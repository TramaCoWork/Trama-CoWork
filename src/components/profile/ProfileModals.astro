<!-- Modal: Pending Review (blocking) -->
<div id="modal-pending" class="fixed inset-0 z-[70] hidden items-center justify-center">
  <div class="absolute inset-0 bg-on-surface/60 backdrop-blur-md"></div>
  <div class="relative bg-surface-container-lowest rounded-3xl p-10 max-w-md w-full mx-4 shadow-2xl text-center">
    <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
      <span class="material-symbols-outlined text-4xl text-primary" aria-hidden="true">hourglass_top</span>
    </div>
    <h3 class="text-2xl font-extrabold text-on-surface mb-3 tracking-tight">Estamos revisando tu documentación</h3>
    <p class="text-on-surface-variant text-sm leading-relaxed mb-6">Muy pronto se activará tu cuenta. Te notificaremos por email cuando el proceso finalice.</p>
    <div class="bg-surface-container-low rounded-xl px-5 py-4">
      <p class="text-xs text-on-surface-variant">Ante cualquier inconveniente, enviá un email a <a href="mailto:soporte@tramacowork.com" class="font-bold text-primary hover:underline">soporte@tramacowork.com</a></p>
    </div>
    <a href="/dashboard" class="mt-6 inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary font-bold text-sm rounded-xl hover:opacity-90 transition-all">
      <span class="material-symbols-outlined text-lg" aria-hidden="true">arrow_back</span>
      Volver al dashboard
    </a>
  </div>
</div>

<!-- Modal: Confirm submit (summary of locked fields) -->
<div id="modal-confirm-submit" class="fixed inset-0 z-[60] hidden items-center justify-center">
  <div id="modal-confirm-backdrop" class="absolute inset-0 bg-on-surface/50 backdrop-blur-sm"></div>
  <div class="relative bg-surface-container-lowest rounded-3xl p-8 max-w-3xl w-full mx-4 shadow-2xl">
    <div class="text-center mb-6">
      <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
        <span class="material-symbols-outlined text-3xl text-primary" aria-hidden="true">lock</span>
      </div>
      <h3 class="text-xl font-extrabold text-on-surface tracking-tight">Confirmar envío a revisión</h3>
      <p class="text-sm text-on-surface-variant mt-2">Al enviar, los siguientes datos se bloquearán hasta que nuestro equipo revise tu perfil:</p>
    </div>

    <div class="bg-surface-container-low rounded-xl p-5 space-y-3 mb-6">
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant">DNI</span>
        <span id="confirm-dni" class="font-bold text-on-surface">—</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant">Doc. frente</span>
        <span id="confirm-front" class="font-bold">—</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant">Doc. dorso</span>
        <span id="confirm-back" class="font-bold">—</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant">Rubro</span>
        <span id="confirm-rubro" class="font-bold text-on-surface">—</span>
      </div>
      <div class="text-sm">
        <span class="text-on-surface-variant">Profesiones</span>
        <div id="confirm-professions" class="mt-1 flex flex-wrap gap-1"></div>
      </div>
    </div>

    <p class="text-xs text-on-surface-variant text-center mb-6">Una vez enviado, no podrás modificar estos datos hasta que se complete la revisión.</p>

    <div class="flex gap-3">
      <button id="confirm-cancel" type="button" class="flex-1 px-6 py-3 rounded-xl font-bold text-sm text-on-surface-variant bg-surface-container-low hover:bg-surface-container-high transition-colors">Cancelar</button>
      <button id="confirm-send" type="button" class="flex-1 px-6 py-3 rounded-xl font-bold text-sm bg-gradient-to-br from-primary to-primary-container text-on-primary hover:opacity-90 active:scale-[0.98] transition-all shadow-md flex items-center justify-center gap-2">
        <span class="material-symbols-outlined text-lg">check</span>
        Confirmar envío
      </button>
    </div>
  </div>
</div>

<!-- Modal: Delete photo confirmation -->
<div id="modal-delete-photo" class="fixed inset-0 z-[60] hidden items-center justify-center">
  <div id="modal-delete-backdrop" class="absolute inset-0 bg-on-surface/50 backdrop-blur-sm"></div>
  <div class="relative bg-surface-container-lowest rounded-3xl p-8 max-w-sm w-full mx-4 shadow-2xl text-center">
    <div class="w-16 h-16 bg-error-container rounded-full flex items-center justify-center mx-auto mb-5">
      <span class="material-symbols-outlined text-3xl text-error" aria-hidden="true">delete</span>
    </div>
    <h3 class="text-xl font-extrabold text-on-surface mb-2 tracking-tight">Eliminar foto</h3>
    <p class="text-sm text-on-surface-variant mb-8">¿Estás seguro de que querés eliminar tu foto de perfil?</p>
    <div class="flex gap-3">
      <button id="modal-del-cancel" type="button" class="flex-1 px-6 py-3 rounded-xl font-bold text-sm text-on-surface-variant bg-surface-container-low hover:bg-surface-container-high transition-colors">Cancelar</button>
      <button id="modal-del-confirm" type="button" class="flex-1 px-6 py-3 rounded-xl font-bold text-sm bg-error text-on-error hover:opacity-90 active:scale-[0.98] transition-all shadow-md">Eliminar</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div id="toast" class="fixed top-6 right-6 z-[80] hidden transition-all duration-300 translate-y-[-1rem] opacity-0">
  <div id="toast-inner" class="flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm">
    <span id="toast-icon" class="material-symbols-outlined text-xl" aria-hidden="true"></span>
    <span id="toast-msg"></span>
  </div>
</div>
