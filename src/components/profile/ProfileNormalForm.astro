<!-- Normal Form View (active / suspended) -->
<div id="normal-view" class="hidden">
  <header class="mb-10">
    <div class="flex justify-between items-end">
      <div>
        <h1 class="text-4xl font-black text-on-surface tracking-tighter">Editar perfil</h1>
        <p class="text-on-surface-variant font-medium mt-2">Mantené tu información actualizada para que los clientes te encuentren.</p>
      </div>
      <div id="n-completion-badge">
        <div class="flex items-center gap-3 bg-surface-container-low px-5 py-3 rounded-2xl">
          <div class="relative w-12 h-12">
            <svg class="w-12 h-12 -rotate-90" viewBox="0 0 36 36">
              <circle cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" stroke-width="2" class="text-outline-variant/20"></circle>
              <circle id="n-completion-circle" cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-dasharray="97.4" stroke-dashoffset="97.4" stroke-linecap="round" class="text-primary transition-all duration-700"></circle>
            </svg>
            <span id="n-completion-text" class="absolute inset-0 flex items-center justify-center text-xs font-black text-on-surface">0%</span>
          </div>
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Completitud</p>
            <p id="n-completion-status" class="text-sm font-bold text-on-surface">—</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <form id="normal-form">
    <!-- Photo + Name -->
    <div class="bg-surface-container-low rounded-3xl p-8 mb-6">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="relative shrink-0 group">
          <img id="n-avatar-preview" src="/images/default-avatar.svg" alt="Foto de perfil"
            class="w-28 h-28 rounded-full object-cover border-4 border-surface-container-lowest shadow-lg" />
          <label for="n-photo-file"
            class="absolute inset-0 rounded-full flex items-center justify-center bg-on-surface/50 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer" title="Subir foto">
            <span class="material-symbols-outlined text-2xl text-white" aria-hidden="true">photo_camera</span>
          </label>
          <input id="n-photo-file" type="file" accept="image/jpeg,image/png,image/webp" class="hidden" />
          <button id="n-btn-delete-photo" type="button"
            class="hidden absolute -top-1 -right-1 w-7 h-7 bg-error text-on-error rounded-full flex items-center justify-center shadow-md hover:opacity-90 transition-opacity" title="Eliminar foto">
            <span class="material-symbols-outlined text-sm" aria-hidden="true">close</span>
          </button>
          <div id="n-photo-spinner" class="hidden absolute inset-0 rounded-full flex items-center justify-center bg-on-surface/60">
            <div class="w-8 h-8 border-3 border-white/30 border-t-white rounded-full animate-spin"></div>
          </div>
        </div>
        <div class="flex-1 w-full space-y-4">
          <div>
            <label for="n-name" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Nombre completo</label>
            <input id="n-name" type="text" placeholder="Tu nombre completo"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Email de cuenta</label>
            <div class="flex items-center gap-2 px-4 py-3 bg-surface-container-lowest border border-outline-variant/10 rounded-xl">
              <span class="material-symbols-outlined text-outline text-lg" aria-hidden="true">mail</span>
              <span id="n-display-email" class="text-on-surface font-medium text-sm">—</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Two columns -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Left: Datos personales (read-only DNI, editable rest) -->
      <div class="bg-surface-container-low rounded-3xl p-8 space-y-6">
        <div class="flex items-center gap-3 mb-2">
          <span class="material-symbols-outlined text-primary" aria-hidden="true">person</span>
          <h2 class="text-xl font-extrabold text-on-surface tracking-tight">Datos personales</h2>
        </div>

        <div>
          <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">DNI</label>
          <div class="flex items-center gap-2 px-4 py-3 bg-surface-container-lowest border border-outline-variant/10 rounded-xl">
            <span class="material-symbols-outlined text-outline text-lg" aria-hidden="true">badge</span>
            <span id="n-display-dni" class="text-on-surface font-medium text-sm">—</span>
          </div>
        </div>

        <div>
          <label for="n-country" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">País</label>
          <select id="n-country" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer">
            <option disabled selected value="">Cargando países...</option>
          </select>
        </div>
        <div>
          <label for="n-province" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Provincia</label>
          <select id="n-province" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" disabled>
            <option disabled selected value="">Seleccioná primero un país</option>
          </select>
        </div>
        <div>
          <label for="n-city" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Ciudad</label>
          <input id="n-city" type="text" placeholder="Buenos Aires" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
        </div>
        <div>
          <label for="n-whatsapp" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">WhatsApp</label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-lg" aria-hidden="true">phone</span>
            <input id="n-whatsapp" type="tel" placeholder="+54 11 1234-5678" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-12 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
          </div>
        </div>
        <div>
          <label for="n-linkedin" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">LinkedIn</label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-lg" aria-hidden="true">link</span>
            <input id="n-linkedin" type="url" placeholder="https://linkedin.com/in/tu-perfil" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-12 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
          </div>
        </div>
        <div>
          <label for="n-modality" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Modalidad</label>
          <select id="n-modality" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer">
            <option value="">Seleccionar...</option>
          </select>
        </div>
        <div>
          <label for="n-price-hour" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Precio por hora (USD)</label>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline font-bold">$</span>
            <input id="n-price-hour" type="number" min="0" step="0.01" placeholder="0.00" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-10 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
          </div>
        </div>
      </div>

      <!-- Right: Perfil publico + Rubro (read-only) -->
      <div class="space-y-6">
        <div class="bg-surface-container-low rounded-3xl p-8 space-y-6">
          <div class="flex items-center gap-3 mb-2">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">public</span>
            <h2 class="text-xl font-extrabold text-on-surface tracking-tight">Perfil público</h2>
          </div>
          <div>
            <label for="n-bio" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Bio <span id="n-bio-count" class="text-outline font-medium normal-case tracking-normal ml-2">(0/300)</span></label>
            <textarea id="n-bio" maxlength="300" rows="4" placeholder="Contá brevemente..."
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all resize-none"></textarea>
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Servicios</label>
            <div id="n-services-container" class="flex flex-wrap gap-2 mb-3 min-h-[2.5rem]"></div>
            <div class="relative">
              <input id="n-service-input" type="text" placeholder="Escribí un servicio y presioná Enter"
                class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
              <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-bold text-outline uppercase tracking-widest">Enter</span>
            </div>
          </div>
          <div>
            <label for="n-price-ars" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Precio por hora (ARS)</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline font-bold">$</span>
              <input id="n-price-ars" type="number" min="0" step="0.01" placeholder="0.00" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-10 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
            </div>
          </div>
        </div>

        <!-- Profesión read-only -->
        <div class="bg-surface-container-low rounded-3xl p-8 space-y-4">
          <div class="flex items-center gap-3 mb-2">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">work</span>
            <h2 class="text-xl font-extrabold text-on-surface tracking-tight">Profesión y especialidades</h2>
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Profesión</label>
            <div class="flex items-center gap-2 px-4 py-3 bg-surface-container-lowest border border-outline-variant/10 rounded-xl">
              <span class="material-symbols-outlined text-primary text-lg" aria-hidden="true">category</span>
              <span id="n-rubro-name" class="text-on-surface font-medium text-sm">—</span>
            </div>
          </div>
          <div id="n-profession-list" class="space-y-1"></div>
        </div>
      </div>
    </div>

    <!-- Save -->
    <div class="mt-8 flex justify-end gap-4">
      <a href="/dashboard" class="px-8 py-4 rounded-xl font-bold text-sm text-on-surface-variant bg-surface-container-low hover:bg-surface-container-high transition-colors">Cancelar</a>
      <button id="n-btn-save" type="submit"
        class="px-10 py-4 rounded-xl font-bold text-sm bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all flex items-center gap-2 shadow-lg">
        <span class="material-symbols-outlined text-lg" aria-hidden="true">save</span>
        Guardar cambios
      </button>
    </div>
  </form>
</div>
