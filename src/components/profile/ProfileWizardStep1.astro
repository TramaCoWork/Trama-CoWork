<!-- Step 1: Datos personales -->
<div id="wizard-step-1" class="wizard-step hidden">
  <div class="bg-surface-container-low rounded-3xl p-8 space-y-6">
    <div class="flex items-center gap-3 mb-2">
      <span class="material-symbols-outlined text-primary" aria-hidden="true">person</span>
      <h2 class="text-xl font-extrabold text-on-surface tracking-tight">Datos personales</h2>
    </div>

    <div>
      <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Email de cuenta</label>
      <div class="flex items-center gap-2 px-4 py-3 bg-surface-container-lowest border border-outline-variant/10 rounded-xl">
        <span class="material-symbols-outlined text-outline text-lg" aria-hidden="true">mail</span>
        <span id="w-display-email" class="text-on-surface font-medium text-sm">—</span>
      </div>
    </div>

    <div>
      <label for="w-name" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Nombre completo *</label>
      <input id="w-name" type="text" placeholder="Tu nombre completo" required
        class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
    </div>

    <div>
      <label for="w-country" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">País *</label>
      <select id="w-country"
        class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer">
        <option disabled selected value="">Cargando países...</option>
      </select>
    </div>

    <div>
      <label for="w-province" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Provincia *</label>
      <select id="w-province"
        class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" disabled>
        <option disabled selected value="">Seleccioná primero un país</option>
      </select>
    </div>

    <div>
      <label for="w-city" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Ciudad *</label>
      <input id="w-city" type="text" placeholder="Buenos Aires" required
        class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
    </div>

    <div>
      <label for="w-whatsapp" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">WhatsApp</label>
      <div class="relative">
        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-lg" aria-hidden="true">phone</span>
        <input id="w-whatsapp" type="tel" placeholder="+54 11 1234-5678"
          class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-12 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
      </div>
    </div>
  </div>
</div>
