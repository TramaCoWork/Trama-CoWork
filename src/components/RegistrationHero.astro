            stroke-width="2"></path>
        </svg>
        <p
          style="font-size:18px; font-weight:600; color:#FFF; margin-top:12px;"
        >
          Conectá con profesionales
        </p>
        <p style="font-size:15px; color:rgba(255,255,255,.88); margin-top:6px;">
          Expandí tu red y generá oportunidades reales.
        </p>
      </div>
      <div style="flex:1 1 180px; min-width:140px; text-align:center;">
        <svg
          width="56"
          height="56"
          style="display:block; margin:0 auto 12px;"
          fill="none"
          stroke="white"
          viewBox="0 0 24 24"
          stroke-linecap="round"
