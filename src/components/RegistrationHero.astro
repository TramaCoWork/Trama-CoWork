<section class="hidden md:flex md:w-1/2 relative overflow-hidden bg-primary-container items-center justify-center p-12">
  <!-- Imagen de fondo -->
  <div class="absolute inset-0 z-0 opacity-40">
    <img
      alt="Espacio de trabajo arquitectonico moderno"
      class="w-full h-full object-cover"
      src="https://lh3.googleusercontent.com/aida-public/AB6AXuBvF6NZVx-CINtfaCdKOoEDhQLpUywdbiPXDBrrVbcI2QeP0xb8P4nmHOX14_bSl2luiFf9yVjwElMAYvNPTcxC0f2XAfomW1qgsa2wK9FSMXksZLRN3vf-9-oYhmb5Xf5fzuOOF2AiZBnuhpFymCwmE8HpXPJcjPSqwuXHpzG9ob_Uu27LuJfucELYTBMcMBErHvykyfmhHRh2hoW8TuoI2H-F5wwvAOVkwG9q8R7qPcLDO5Z6Q5oJlmgQQXNY9nu5i5CZ4FWVBA"
      loading="eager"
    />
  </div>

  <!-- Patron geometrico sutil -->
  <div
    class="absolute inset-0 z-10 opacity-10 pointer-events-none"
    aria-hidden="true"
    style="background-image: radial-gradient(var(--color-on-primary) 1px, transparent 1px); background-size: 40px 40px;"
  ></div>

  <div class="relative z-20 max-w-lg text-on-primary">
    <div class="mb-12">
      <span class="font-headline text-3xl font-extrabold tracking-tighter">TRAMA</span>
    </div>

    <h1 class="font-headline text-5xl font-extrabold tracking-tighter leading-tight mb-6">
      Redisena tu futuro profesional.
    </h1>

    <p class="text-xl font-light leading-relaxed text-on-primary-container/90">
      Unite a la red exclusiva donde la precision tecnica y la vision creativa convergen para crear oportunidades de alto impacto.
    </p>

    <div class="mt-16 grid grid-cols-2 gap-8 border-t border-on-primary/10 pt-8">
      <div>
        <span class="text-secondary-fixed font-bold text-3xl">5k+</span>
        <p class="text-sm font-label uppercase tracking-widest mt-2 opacity-80">Empresas Lideres</p>
      </div>
      <div>
        <span class="text-secondary-fixed font-bold text-3xl">12k+</span>
        <p class="text-sm font-label uppercase tracking-widest mt-2 opacity-80">Conexiones Globales</p>
      </div>
    </div>
  </div>
</section>
