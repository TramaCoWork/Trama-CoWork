            stroke-linejoin="round"
            stroke-width="2"></path>
        </svg>
        <p
          style="font-size:18px; font-weight:600; color:#FFF; margin-top:12px;"
        >
          Crecé profesionalmente
        </p>
        <p style="font-size:15px; color:rgba(255,255,255,.88); margin-top:6px;">
          Accedé a recursos y oportunidades únicas.
        </p>
      </div>
    </div>
  </div>
