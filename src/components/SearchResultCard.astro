---
import type { Professional } from '../data/mock';

interface Props {
  professional: Professional;
}

const { professional } = Astro.props;

const fullStars = Math.floor(professional.rating);
---

<article class="group bg-surface-container-lowest hover:bg-surface-container-lowest rounded-3xl p-6 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 flex flex-col md:flex-row gap-8 relative overflow-hidden">
  <!-- Imagen -->
  <div class="w-full md:w-64 h-64 shrink-0 rounded-2xl overflow-hidden relative">
    <img
      class="w-full h-full object-cover"
      alt={`Foto de ${professional.name}`}
      src={professional.image}
      loading="lazy"
    />
    {professional.topRated && (
      <div class="absolute top-3 left-3 px-3 py-1 bg-surface-container-lowest/90 backdrop-blur-md rounded-full text-xs font-black uppercase tracking-wider text-primary shadow-sm">
        Top Rated
      </div>
    )}
  </div>

  <!-- Informacion -->
  <div class="flex-1 flex flex-col justify-between py-2">
    <div class="space-y-4">
      <div class="flex justify-between items-start">
        <div>
          <div class="flex items-center gap-2 text-secondary font-bold text-xs uppercase tracking-widest mb-1">
            <span class="material-symbols-outlined text-sm" aria-hidden="true">work</span>
            {professional.category}
          </div>
          <h2 class="text-2xl font-extrabold tracking-tight text-on-surface">{professional.name}</h2>
        </div>
        <div class="text-right">
          <div class="flex items-center justify-end gap-1 text-primary font-bold" role="img" aria-label={`${professional.rating} de 5 estrellas`}>
            <span class="material-symbols-outlined text-lg filled text-star" aria-hidden="true">star</span>
            <span>{professional.rating}</span>
            <span class="text-outline text-xs font-normal">({professional.reviewCount})</span>
          </div>
        </div>
      </div>

      {professional.bio && (
        <p class="text-on-surface-variant text-sm line-clamp-2 leading-relaxed font-medium">
          {professional.bio}
        </p>
      )}

      <!-- Competencias -->
      {professional.competencies && professional.competencies.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {professional.competencies.slice(0, 3).map((comp, i) => {
            const styles = [
              'bg-primary-fixed text-on-primary-fixed-variant',
              'bg-secondary-fixed text-on-secondary-fixed-variant',
              'bg-tertiary-fixed text-on-tertiary-fixed-variant',
            ];
            return (
              <span class={`px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-tight ${styles[i % styles.length]}`}>
                {comp}
              </span>
            );
          })}
        </div>
      )}
    </div>

    <div class="pt-6 mt-4 border-t border-surface-variant flex items-center justify-between">
      <div>
        <span class="text-outline text-xs block font-bold uppercase tracking-widest">Desde</span>
        <div class="flex items-baseline gap-1">
          <span class="text-3xl font-black text-on-surface">${professional.hourlyRate}</span>
          <span class="text-outline text-sm font-medium">/hr</span>
        </div>
      </div>
      <a
        href={`/profesionales/perfil?id=${professional.id}`}
        class="bg-primary hover:bg-primary-container text-on-primary px-8 py-3 rounded-xl font-bold transition-all active:scale-95 flex items-center gap-2"
      >
        Ver perfil
        <span class="material-symbols-outlined text-xl" aria-hidden="true">arrow_forward</span>
      </a>
    </div>
  </div>
</article>
