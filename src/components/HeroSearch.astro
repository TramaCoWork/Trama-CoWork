---
import heroImage from '../assets/images/hero-cowork.jpg';
---

<!-- Hero con imagen de fondo -->
<section class="relative" aria-label="Buscar profesionales">
  <!-- Imagen de fondo -->
  <div class="relative min-h-[520px] md:min-h-[560px] flex items-center">
    <img
      src={heroImage.src}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      aria-hidden="true"
    />
    <!-- Overlay gradiente para legibilidad del texto -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/40 to-transparent"></div>

    <!-- Contenido del hero -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 w-full">
      <div class="max-w-xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Encontrá al<br/>
          <span class="text-primary italic">profesional ideal</span><br/>
          para tu necesidad.
        </h1>
        <p class="text-white/80 text-base md:text-lg leading-relaxed max-w-md">
          Descubrí y contactá profesionales especializados, con la tranquilidad de saber que cada perfil fue revisado y validado por nuestro equipo.
        </p>
      </div>
    </div>
  </div>

  <!-- Tarjeta de búsqueda superpuesta -->
  <div class="relative z-20 max-w-4xl mx-auto px-6 -mt-16">
    <div class="bg-surface-container-lowest p-6 md:p-8 rounded-2xl shadow-xl border border-outline-variant/30">
      <div class="flex flex-col md:flex-row items-stretch md:items-center gap-3">
        <!-- Select de rubro -->
        <div class="flex-1 flex items-center gap-3 bg-surface-container-low px-5 py-3 rounded-xl border border-outline-variant/10">
          <span class="material-symbols-outlined text-primary text-xl" aria-hidden="true">category</span>
          <label for="hero-rubro" class="sr-only">Área profesional</label>
          <select
            id="hero-rubro"
            class="w-full bg-transparent border-none focus:ring-0 text-on-surface text-base font-medium cursor-pointer"
          >
            <option value="">Todas las áreas</option>
          </select>
        </div>

        <!-- Botón buscar -->
        <button
          id="btn-buscar"
          type="button"
          class="w-full md:w-auto px-12 py-4 bg-primary text-on-primary rounded-xl font-bold text-lg flex items-center justify-center gap-2 hover:brightness-110 transition-all shadow-lg active:scale-95"
        >
          Buscar
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  import { fetchRubros } from '../services/professionCategoriesService';

  const rubroSelect = document.getElementById('hero-rubro') as HTMLSelectElement;
  const btnBuscar = document.getElementById('btn-buscar');

  // Cargar rubros
  async function loadRubros() {
    try {
      const rubros = await fetchRubros();
      rubros.forEach(r => {
        const opt = document.createElement('option');
        opt.value = r.slug;
        opt.textContent = r.name;
        rubroSelect.appendChild(opt);
      });
    } catch (err) {
      console.error('Error cargando rubros:', err);
    }
  }

  loadRubros();

  // Buscar
  btnBuscar?.addEventListener('click', () => {
    const rubro = rubroSelect.value;
    const params = new URLSearchParams();
    if (rubro) params.set('rubro', rubro);
    const url = `/profesionales${params.toString() ? '?' + params.toString() : ''}`;
    window.location.href = url;
  });
</script>
