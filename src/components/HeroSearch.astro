---
---

<section aria-label="Buscar profesionales">
  <div style="position:relative; width:100%; height:480px; overflow:hidden;">
    <img
      src="/images/hero-cowork-2.jpg"
      alt=""
      style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center center; filter: saturate(85%) brightness(104%);"
      loading="eager"
      aria-hidden="true"
    />
    <div style="position:absolute; inset:0; background:linear-gradient(to right, rgba(255,255,255,1) 0%, rgba(255,255,255,0.92) 30%, rgba(255,255,255,0.4) 55%, rgba(255,255,255,0) 75%);"></div>
    <div style="position:relative; z-index:2; height:100%; display:flex; align-items:center; padding:0 64px;">
      <div style="max-width:480px;">
        <h1 style="font-size:44px; font-weight:800; line-height:1.15; color:#111827; margin:0 0 16px 0;">
          Descubrí<br>
          <span style="color:#087781;">profesionales confiables</span><br>
          para impulsar tus proyectos.
        </h1>
        <p style="font-size:15px; line-height:1.6; color:#5b6472; max-width:340px; margin:0;">
          En TRAMA validamos cada perfil para que puedas conectar con talento real, especializado y alineado a tus necesidades.
        </p>
      </div>
    </div>
  </div>

  <div style="display:flex; justify-content:center; margin-top:-28px; position:relative; z-index:10; padding:0 24px;">
    <div style="max-width:800px; width:100%; background:white; border-radius:16px; box-shadow:0 8px 32px rgba(0,0,0,0.12); padding:12px 16px; display:flex; align-items:center; gap:12px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#087781" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <select id="hero-rubro" style="flex:1; border:1px solid #D9D9D9; border-radius:8px; padding:10px 14px; font-size:15px; color:#404040; background:white; cursor:pointer;">
        <option value="">Todas las áreas</option>
      </select>
      <input id="hero-search-text" type="text" placeholder="Buscar por especialidad, habilidad o nombre" style="flex:2; border:1px solid #D9D9D9; border-radius:8px; padding:10px 14px; font-size:15px; color:#404040; outline:none;" />
      <button id="btn-buscar" type="button" style="background:#087781; color:white; border:none; border-radius:10px; padding:10px 28px; font-size:15px; font-weight:600; cursor:pointer; white-space:nowrap;">Buscar</button>
    </div>
  </div>
</section>

<script>
  import { fetchRubros } from "../services/professionCategoriesService";

  const rubroSelect = document.getElementById(
    "hero-rubro",
  ) as HTMLSelectElement;
  const btnBuscar = document.getElementById("btn-buscar");

  // Cargar rubros
  async function loadRubros() {
    try {
      const rubros = await fetchRubros();
      rubros.forEach((r) => {
        const opt = document.createElement("option");
        opt.value = r.slug;
        opt.textContent = r.name;
        rubroSelect.appendChild(opt);
      });
    } catch (err) {
      console.error("Error cargando rubros:", err);
    }
  }

  loadRubros();

  // Buscar
  btnBuscar?.addEventListener("click", () => {
    const rubro = rubroSelect.value;
    const params = new URLSearchParams();
    if (rubro) params.set("rubro", rubro);
    const url = `/profesionales${params.toString() ? "?" + params.toString() : ""}`;
    window.location.href = url;
  });
</script>
