---
---

<div class="login-panel" style="display:flex; justify-content:center; padding-top:48px; padding-left:96px; padding-right:96px;">
  <div class="login-wrapper" style="width:100%; max-width:620px;">
    <a
      href="/"
      style="display:flex; align-items:center; gap:8px; margin-bottom:72px; font-size:15px; font-weight:500; color:#0C7A82; text-decoration:none;"
    >
      <span aria-hidden="true">←</span>
      Volver al inicio
    </a>

    <div style="font-size:64px; font-weight:700; letter-spacing:-2px; color:#0C7A82;">TRAMA</div>
    <h2 style="margin-top:8px; margin-bottom:18px; font-size:52px; font-weight:700; line-height:1.05; color:#111827;">
      Bienvenido de nuevo
    </h2>
    <p style="margin-bottom:56px; font-size:18px; line-height:30px; color:#4B5563;">
      Accedé a tu panel profesional de TRAMA.
    </p>

    <form id="login-form" method="post" novalidate style="display:flex; flex-direction:column; gap:28px;">
      <div style="position:relative;">
        <svg
          aria-hidden="true"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          style="position:absolute; left:20px; top:50%; transform:translateY(-50%); color:#6B7280;"
        >
          <path d="M3 7.5A2.5 2.5 0 015.5 5h13A2.5 2.5 0 0121 7.5v9a2.5 2.5 0 01-2.5 2.5h-13A2.5 2.5 0 013 16.5v-9z" stroke="currentColor" stroke-width="1.8" />
          <path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <input
          id="login-email"
          name="email"
          type="email"
          autocomplete="email"
          placeholder="nombre@ejemplo.com"
          required
          style="width:100%; height:68px; border:1px solid #D7DEE4; border-radius:14px; padding:0 18px 0 58px; font-size:17px;"
        />
      </div>

      <div style="position:relative;">
        <svg
          aria-hidden="true"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          style="position:absolute; left:20px; top:50%; transform:translateY(-50%); color:#6B7280;"
        >
          <rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.8" />
          <path d="M8 11V8a4 4 0 118 0v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <input
          id="login-password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
          style="width:100%; height:68px; border:1px solid #D7DEE4; border-radius:14px; padding:0 18px 0 58px; font-size:17px;"
        />
      </div>

      <div style="display:flex; justify-content:space-between; align-items:center;">
        <label for="recordarme" style="display:flex; align-items:center; gap:10px; font-size:15px; color:#4B5563;">
          <input id="recordarme" name="recordarme" type="checkbox" style="width:16px; height:16px;" />
          Recordarme
        </label>
        <a href="/recuperar-contrasena" style="font-size:15px; font-weight:500; color:#0C7A82; text-decoration:none;">
          Recuperar contraseña
        </a>
      </div>

      <button
        id="btn-login"
        type="submit"
        style="width:100%; height:68px; margin-top:48px; border:0; border-radius:14px; background:linear-gradient(90deg,#006D75 0%,#0C7A82 100%); color:#FFF; font-size:18px; font-weight:600; letter-spacing:0.5px; box-shadow:0 16px 30px rgba(8,119,129,.24);"
      >
        <span id="btn-login-text">INICIAR SESIÓN</span>
      </button>
    </form>

    <div
      id="login-toast"
      class="fixed top-6 right-6 z-50 max-w-sm transform translate-x-[120%] transition-transform duration-300 ease-in-out"
      role="alert"
    >
      <div class="flex items-center gap-3 px-5 py-4 bg-error-container text-on-error-container rounded-xl shadow-2xl border border-error/20">
        <span class="material-symbols-outlined text-error text-2xl shrink-0" aria-hidden="true">error</span>
        <div>
          <p class="font-bold text-sm">No se pudo iniciar sesion</p>
          <p id="login-toast-message" class="text-xs opacity-80 mt-0.5">Verifique sus datos e intente nuevamente.</p>
        </div>
        <button
          id="login-toast-close"
          type="button"
          class="ml-2 shrink-0 text-on-error-container/60 hover:text-on-error-container transition-colors"
          aria-label="Cerrar"
        >
          <span class="material-symbols-outlined text-lg">close</span>
        </button>
      </div>
    </div>

    <p style="margin-top:72px; text-align:center; font-size:16px; color:#4B5563;">
      ¿No tenés una cuenta?
      <a href="/registro" style="color:#E91E63; font-weight:600; text-decoration:none; margin-left:4px;">Registrate gratis</a>
    </p>
  </div>
</div>

<script>
  import { login } from '../services/authService';

  const loginForm = document.getElementById('login-form') as HTMLFormElement | null;
  const btnLogin = document.getElementById('btn-login') as HTMLButtonElement | null;
  const btnLoginText = document.getElementById('btn-login-text');
  const toast = document.getElementById('login-toast');
  const toastMessage = document.getElementById('login-toast-message');
  const toastClose = document.getElementById('login-toast-close');

  let toastTimeout: ReturnType<typeof setTimeout>;

  function showToast(message: string) {
    if (toastMessage) toastMessage.textContent = message;
    toast?.classList.remove('translate-x-[120%]');
    toast?.classList.add('translate-x-0');
    clearTimeout(toastTimeout);
    toastTimeout = setTimeout(hideToast, 5000);
  }

  function hideToast() {
    toast?.classList.remove('translate-x-0');
    toast?.classList.add('translate-x-[120%]');
  }

  toastClose?.addEventListener('click', hideToast);

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(loginForm);
    const email = (formData.get('email') as string)?.trim();
    const password = formData.get('password') as string;

    if (!email || !password) {
      showToast('Complete todos los campos para continuar.');
      return;
    }

    if (btnLogin) btnLogin.disabled = true;
    if (btnLoginText) btnLoginText.textContent = 'Ingresando...';

    try {
      await login({ email, password });
      window.location.href = '/dashboard';
    } catch (err: any) {
      const message = err?.body?.error || 'Verifique sus datos e intente nuevamente.';
      showToast(message);
    } finally {
      if (btnLogin) btnLogin.disabled = false;
      if (btnLoginText) btnLoginText.textContent = 'Iniciar Sesion';
    }
  });
</script>

