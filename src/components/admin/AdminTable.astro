---
interface Column {
  key: string;
  label: string;
  width?: string;
}

interface Props {
  title: string;
  columns: Column[];
  emptyMessage?: string;
  showExportButtons?: boolean;
  tableBodyId?: string;
  paginationId?: string;
}

const {
  title,
  columns,
  emptyMessage = 'No hay datos para mostrar.',
  showExportButtons = false,
  tableBodyId = 'table-body',
  paginationId = 'pagination-container',
} = Astro.props;
---

<div class="bg-white border border-[var(--color-neutral-200)] rounded-2xl overflow-hidden mb-6">
  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-neutral-200)]">
    <h2 class="text-sm font-semibold text-[var(--color-neutral-900)]">{title}</h2>
    {showExportButtons && (
      <div class="flex items-center gap-2">
        <button
          class="w-8 h-8 flex items-center justify-center rounded hover:bg-[var(--color-neutral-100)] transition-colors"
          title="Descargar"
        >
          <span class="material-symbols-outlined text-base text-[var(--color-neutral-600)]">download</span>
        </button>
        <button
          class="w-8 h-8 flex items-center justify-center rounded hover:bg-[var(--color-neutral-100)] transition-colors"
          title="Imprimir"
        >
          <span class="material-symbols-outlined text-base text-[var(--color-neutral-600)]">print</span>
        </button>
      </div>
    )}
  </div>

  <!-- Table -->
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-[var(--color-neutral-200)] bg-[var(--color-neutral-100)]">
          {columns.map((col) => (
            <th
              class="text-left px-5 py-3 text-[10px] font-semibold uppercase tracking-widest text-[var(--color-neutral-600)] whitespace-nowrap"
              style={col.width ? `width: ${col.width}` : ''}
            >
              {col.label}
            </th>
          ))}
        </tr>
      </thead>
      <tbody
        id={tableBodyId}
        class="[&>tr]:border-b [&>tr]:border-[var(--color-neutral-200)] [&>tr:nth-child(even)]:bg-[var(--color-neutral-100)/30] [&>tr:hover]:bg-[var(--color-primary)/5]"
      >
        <!-- Populated by client-side JS -->
        <tr>
          <td colspan={columns.length} class="px-5 py-8 text-center text-sm text-[var(--color-neutral-400)]">
            {emptyMessage}
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <div
    id={paginationId}
    class="flex items-center justify-between px-5 py-4 border-t border-[var(--color-neutral-200)] min-h-[56px]"
  ></div>
</div>

