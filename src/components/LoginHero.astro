---
import logoTrama from '../assets/images/logo-trama-apaisado.png';
---

<section class="hidden md:flex md:w-1/2 lg:w-3/5 relative overflow-hidden flex-col justify-between p-16" style="background-color: #1a3a3a;">
  <!-- Patron de lineas diagonales decorativas -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <!-- Lineas diagonales con opacidad baja -->
    <div class="absolute -top-20 -right-20 w-[600px] h-[600px] opacity-[0.07]"
      style="background: repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 40px,
        rgba(255,255,255,0.5) 40px,
        rgba(255,255,255,0.5) 80px
      );"
    ></div>
    <div class="absolute top-1/4 right-0 w-[500px] h-[500px] opacity-[0.05]"
      style="background: repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 50px,
        rgba(255,255,255,0.4) 50px,
        rgba(255,255,255,0.4) 100px
      );"
    ></div>
    <!-- Elementos geometricos sutiles -->
    <div class="absolute top-[15%] right-[10%] w-72 h-72 rounded-full opacity-[0.04]" style="background: radial-gradient(circle, rgba(255,255,255,0.3), transparent 70%);"></div>
    <div class="absolute bottom-[20%] right-[20%] w-96 h-96 rounded-full opacity-[0.03]" style="background: radial-gradient(circle, rgba(255,255,255,0.3), transparent 70%);"></div>
  </div>

  <!-- Logo arriba a la izquierda -->
  <div class="relative z-10">
    <img src={logoTrama.src} alt="TRAMA COWORK" class="h-14 w-auto" loading="eager" />
  </div>

  <!-- Contenido central -->
  <div class="relative z-10 max-w-lg">
    <h1 class="text-4xl lg:text-5xl font-bold text-white leading-tight mb-4">
      Donde el talento se vuelve <span class="text-amber-400">Trama.</span>
    </h1>

    <!-- Linea decorativa bicolor -->
    <div class="flex gap-1 mb-8">
      <div class="w-12 h-1 rounded-full bg-teal-400"></div>
      <div class="w-6 h-1 rounded-full bg-pink-500"></div>
    </div>

    <p class="text-lg text-white/70 leading-relaxed max-w-md">
      En <span class="text-teal-300 font-medium">TRAMA</span> conectas con profesionales,<br/>
      proyectos y oportunidades reales.
    </p>
  </div>

  <!-- Footer -->
  <div class="relative z-10">
    <div class="flex justify-between items-center text-xs uppercase tracking-widest text-white/40">
      <p>&copy; 2025 TRAMA. TODOS LOS DERECHOS RESERVADOS.</p>
      <nav class="flex gap-6" aria-label="Enlaces legales">
        <a class="hover:text-white/70 transition-colors" href="/privacidad">Privacidad</a>
        <a class="hover:text-white/70 transition-colors" href="/terminos">Terminos</a>
        <a class="hover:text-white/70 transition-colors" href="/ayuda">Ayuda</a>
      </nav>
    </div>
  </div>
</section>
