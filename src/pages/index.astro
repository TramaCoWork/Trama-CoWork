---
import Layout from '../layouts/Layout.astro';
import HeroSearch from '../components/HeroSearch.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="TRAMA | Professional Network">
  <!-- Hero & Search Section -->
  <HeroSearch />

  <!-- Explora Profesionales Section -->
  <section class="bg-surface-container-low py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex justify-between items-end mb-16">
        <div>
          <h2 class="text-4xl font-black tracking-tighter text-on-surface mb-2">Explora profesionales</h2>
          <div class="h-1.5 w-24 bg-primary rounded-full" aria-hidden="true"></div>
        </div>
        <a class="text-primary font-bold flex items-center gap-2 hover:gap-4 transition-all group" href="/profesionales">
          Ver todos los expertos
          <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
      <div id="professionals-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <p class="text-on-surface-variant col-span-full text-center py-12">Cargando profesionales...</p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection />
</Layout>

<script>
  import { renderFeaturedProfessionals } from '../services/homeService';
  renderFeaturedProfessionals('professionals-grid');
</script>
