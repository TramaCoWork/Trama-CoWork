<Layout title="Especialidades | TRAMA" description="Explora las especialidades profesionales disponibles en la red TRAMA.">
  <section class="pt-12 pb-20">
    <!-- Hero -->
    <header class="max-w-7xl mx-auto px-8 mb-12">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 py-12">
        <div class="max-w-2xl">
          <span class="text-secondary tracking-widest uppercase text-sm font-bold mb-4 block">
            Red Profesional de Élite
          </span>
          <h1 class="text-5xl md:text-6xl font-extrabold text-on-surface tracking-tight leading-tight">
            Explora <span class="text-primary italic">Especialidades</span>
          </h1>
        </div>
        <div class="flex-1 max-w-xl w-full">
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline" aria-hidden="true">search</span>
            <label for="category-search" class="sr-only">Filtrar especialidades</label>
            <input
              id="category-search"
              class="w-full pl-12 pr-4 py-5 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/20 transition-all text-on-surface placeholder:text-outline/60 text-lg"
              placeholder="Filtrar por arquitectura, diseño o construcción..."
              type="text"
            />
          </div>
        </div>
      </div>
    </header>

    <!-- Category List -->
    <section class="max-w-7xl mx-auto px-8" aria-label="Lista de especialidades">
      <div class="flex flex-col gap-1" id="category-list">
        {categories.map((cat) => (
          <a
            href={`/profesionales?categoria=${cat.slug}`}
            class="category-row group flex flex-col md:flex-row md:items-center justify-between p-8 rounded-xl hover:bg-surface-container-lowest transition-all duration-300 border border-transparent hover:border-outline-variant/15"
            data-name={cat.name.toLowerCase()}
          >
            <div class="flex items-center gap-8">
              <div class="h-20 w-20 rounded-xl bg-surface-container overflow-hidden group-hover:scale-105 transition-transform duration-500 shrink-0">
                <img alt={cat.imageAlt} class="w-full h-full object-cover" src={cat.image} />
              </div>
              <div>
                <h2 class="text-2xl font-bold text-on-surface group-hover:text-primary transition-colors">
                  {cat.name}
                </h2>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-sm font-medium text-on-surface-variant">
                    {cat.experts.toLocaleString('es-AR')} expertos disponibles
                  </span>
                  {cat.badge && (
                    <>
                      <span class="h-1 w-1 rounded-full bg-outline-variant" aria-hidden="true"></span>
                      <span class={`text-xs uppercase tracking-wider font-bold ${cat.badgeColor}`}>
                        {cat.badge}
                      </span>
                    </>
                  )}
                </div>
              </div>
            </div>
            <div class="flex items-center gap-2 mt-6 md:mt-0 text-on-surface-variant font-medium text-sm group-hover:text-primary transition-colors">
              <span>Ver todos los perfiles</span>
              <span class="material-symbols-outlined text-lg translate-x-0 group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <aside class="max-w-7xl mx-auto px-8 mt-24">
      <div class="bg-surface-container-low rounded-3xl p-12 relative overflow-hidden flex flex-col lg:flex-row items-center justify-between gap-12">
        <div class="relative z-10 max-w-xl text-center lg:text-left">
          <h2 class="text-4xl font-extrabold text-on-surface tracking-tight mb-4">
            ¿No encuentras lo que buscas?
          </h2>
          <p class="text-on-surface-variant text-lg mb-8 leading-relaxed">
            Nuestra red cuenta con miles de profesionales especializados en nichos arquitectónicos. Crea una solicitud personalizada y deja que ellos te encuentren.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a
              href="/registro"
              class="px-8 py-4 bg-primary text-on-primary rounded-xl font-bold shadow-lg shadow-primary/20 hover:scale-[1.02] transition-all text-center"
            >
              Solicitar Profesional
            </a>
            <a
              href="/profesionales"
              class="px-8 py-4 bg-surface-container-lowest text-primary rounded-xl font-bold hover:bg-surface-container-high transition-all text-center"
            >
              Ver Directorio General
            </a>
          </div>
        </div>
        <div class="relative z-10 w-full lg:w-1/3 aspect-video lg:aspect-square bg-surface-container-lowest rounded-2xl shadow-xl overflow-hidden rotate-2 group hover:rotate-0 transition-transform duration-700">
          <img
            alt="Planos arquitectónicos sobre mesa de trabajo con herramientas de dibujo"
            class="w-full h-full object-cover"
            src={ctaImage}
          />
        </div>
      </div>
    </aside>
  </section>

  <script>
    const searchInput = document.getElementById('category-search') as HTMLInputElement;
    const rows = document.querySelectorAll('.category-row');

    searchInput?.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      rows.forEach((row) => {
        const name = (row as HTMLElement).dataset.name || '';
        (row as HTMLElement).style.display = name.includes(query) ? '' : 'none';
      });
    });
  </script>
</Layout>
