---
import '../styles/global.css';
import RegistrationForm from '../components/RegistrationForm.astro';
import RegistrationHero from '../components/RegistrationHero.astro';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <title>Registro | TRAMA</title>
    <meta name="description" content="Crea tu cuenta profesional en TRAMA y accede a una red exclusiva de talento." />
  </head>
  <body class="bg-surface font-body text-on-surface antialiased overflow-x-hidden">
    <main style="display:grid; grid-template-columns:auto 1fr; min-height:100vh; background:#FFFFFF;">
      <RegistrationForm />
      <RegistrationHero />
    </main>

    <style>
      @media (max-width: 1024px) {
        main {
          grid-template-columns: 1fr !important;
        }
      }
    </style>
  </body>
</html>
