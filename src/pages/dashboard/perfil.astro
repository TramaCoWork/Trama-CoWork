---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="TRAMA - Editar perfil">
  <!-- Header -->
  <header class="mb-10">
    <div class="flex justify-between items-end">
      <div>
        <h1 class="text-4xl font-black text-on-surface tracking-tighter">Editar perfil</h1>
        <p class="text-on-surface-variant font-medium mt-2">Mantené tu información actualizada para que los clientes te encuentren.</p>
      </div>
      <div id="completion-badge" class="hidden">
        <div class="flex items-center gap-3 bg-surface-container-low px-5 py-3 rounded-2xl">
          <div class="relative w-12 h-12">
            <svg class="w-12 h-12 -rotate-90" viewBox="0 0 36 36">
              <circle cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" stroke-width="2" class="text-outline-variant/20"></circle>
              <circle id="completion-circle" cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-dasharray="97.4" stroke-dashoffset="97.4" stroke-linecap="round" class="text-primary transition-all duration-700"></circle>
            </svg>
            <span id="completion-text" class="absolute inset-0 flex items-center justify-center text-xs font-black text-on-surface">0%</span>
          </div>
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Completitud</p>
            <p id="completion-status" class="text-sm font-bold text-on-surface">Cargando...</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Loading State -->
  <div id="profile-loading" class="flex items-center justify-center py-24">
    <div class="flex flex-col items-center gap-4">
      <div class="w-10 h-10 border-3 border-primary/30 border-t-primary rounded-full animate-spin"></div>
      <p class="text-sm font-medium text-on-surface-variant">Cargando perfil...</p>
    </div>
  </div>

  <!-- Error State -->
  <div id="profile-error" class="hidden">
    <div class="bg-error-container text-on-error-container rounded-3xl p-8 text-center">
      <span class="material-symbols-outlined text-4xl mb-4 block" aria-hidden="true">error</span>
      <h2 class="text-xl font-bold mb-2">Error al cargar el perfil</h2>
      <p id="profile-error-msg" class="text-sm opacity-80">No se pudo obtener la información del perfil.</p>
      <button onclick="location.reload()" class="mt-6 bg-error text-on-error px-6 py-3 rounded-xl font-bold text-sm hover:opacity-90 transition-opacity">
        Reintentar
      </button>
    </div>
  </div>

  <!-- Profile Form -->
  <form id="profile-form" class="hidden">
    <!-- Toast -->
    <div id="toast" class="fixed top-6 right-6 z-50 hidden transition-all duration-300 translate-y-[-1rem] opacity-0">
      <div id="toast-inner" class="flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm">
        <span id="toast-icon" class="material-symbols-outlined text-xl" aria-hidden="true"></span>
        <span id="toast-msg"></span>
      </div>
    </div>

    <!-- Photo + Name Header Card -->
    <div class="bg-surface-container-low rounded-3xl p-8 mb-6">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <!-- Avatar Preview -->
        <div class="relative shrink-0">
          <img
            id="avatar-preview"
            src="/images/default-avatar.svg"
            alt="Foto de perfil"
            class="w-28 h-28 rounded-full object-cover border-4 border-surface-container-lowest shadow-lg"
          />
          <div class="absolute -bottom-1 -right-1 w-8 h-8 bg-primary text-on-primary rounded-full flex items-center justify-center shadow-md">
            <span class="material-symbols-outlined text-sm" aria-hidden="true">edit</span>
          </div>
        </div>
        <!-- Photo URL + Name -->
        <div class="flex-1 w-full space-y-4">
          <div>
            <label for="field-name" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">
              Nombre completo
            </label>
            <input
              id="field-name"
              type="text"
              placeholder="Tu nombre completo"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
            />
          </div>
          <div>
            <label for="field-photo" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">
              URL de foto de perfil
            </label>
            <input
              id="field-photo"
              type="url"
              placeholder="https://ejemplo.com/mi-foto.jpg"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Two Column Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Left Column: Datos Personales -->
      <div class="bg-surface-container-low rounded-3xl p-8 space-y-6">
        <div class="flex items-center gap-3 mb-2">
          <span class="material-symbols-outlined text-primary" aria-hidden="true">person</span>
          <h2 class="text-xl font-extrabold text-on-surface tracking-tight">Datos personales</h2>
        </div>

        <div>
          <label for="field-city" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Ciudad</label>
          <input id="field-city" type="text" placeholder="Buenos Aires"
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
        </div>

        <div>
          <label for="field-whatsapp" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">WhatsApp</label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-lg" aria-hidden="true">phone</span>
            <input id="field-whatsapp" type="tel" placeholder="+54 11 1234-5678"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-12 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
          </div>
        </div>

        <div>
          <label for="field-linkedin" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">LinkedIn</label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-lg" aria-hidden="true">link</span>
            <input id="field-linkedin" type="url" placeholder="https://linkedin.com/in/tu-perfil"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-12 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
          </div>
        </div>

        <div>
          <label for="field-modality" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Modalidad de trabajo</label>
          <select id="field-modality"
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer">
            <option value="">Seleccionar...</option>
            <option value="presencial">Presencial</option>
            <option value="online">Online</option>
            <option value="ambas">Ambas</option>
          </select>
        </div>

        <div>
          <label for="field-price-hour" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Precio por hora (USD)</label>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline font-bold">$</span>
            <input id="field-price-hour" type="number" min="0" step="0.01" placeholder="0.00"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-10 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
          </div>
        </div>
      </div>

      <!-- Right Column: Datos Publicos -->
      <div class="bg-surface-container-low rounded-3xl p-8 space-y-6">
        <div class="flex items-center gap-3 mb-2">
          <span class="material-symbols-outlined text-primary" aria-hidden="true">public</span>
          <h2 class="text-xl font-extrabold text-on-surface tracking-tight">Perfil publico</h2>
        </div>

        <div>
          <label for="field-bio" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">
            Bio
            <span id="bio-count" class="text-outline font-medium normal-case tracking-normal ml-2">(0/300)</span>
          </label>
          <textarea id="field-bio" maxlength="300" rows="4" placeholder="Contá brevemente sobre vos y tu experiencia profesional..."
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all resize-none"></textarea>
        </div>

        <div>
          <label for="field-email-contact" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Email de contacto</label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-lg" aria-hidden="true">mail</span>
            <input id="field-email-contact" type="email" placeholder="contacto@ejemplo.com"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-12 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
          </div>
        </div>

        <div>
          <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Servicios</label>
          <div id="services-container" class="flex flex-wrap gap-2 mb-3 min-h-[2.5rem]"></div>
          <div class="relative">
            <input id="field-service-input" type="text" placeholder="Escribí un servicio y presioná Enter"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-bold text-outline uppercase tracking-widest">Enter</span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="field-price-min" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Precio min</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline font-bold">$</span>
              <input id="field-price-min" type="number" min="0" step="0.01" placeholder="0"
                class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-10 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
            </div>
          </div>
          <div>
            <label for="field-price-max" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Precio max</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline font-bold">$</span>
              <input id="field-price-max" type="number" min="0" step="0.01" placeholder="0"
                class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl pl-10 pr-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Submit -->
    <div class="mt-8 flex justify-end gap-4">
      <a href="/dashboard"
        class="px-8 py-4 rounded-xl font-bold text-sm text-on-surface-variant bg-surface-container-low hover:bg-surface-container-high transition-colors">
        Cancelar
      </a>
      <button
        id="btn-save"
        type="submit"
        class="px-10 py-4 rounded-xl font-bold text-sm bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all flex items-center gap-2 shadow-lg"
      >
        <span class="material-symbols-outlined text-lg" aria-hidden="true">save</span>
        Guardar cambios
      </button>
    </div>
  </form>

  <script>
    import { getUserIdFromToken, getToken, logout } from '../../services/authService';
    import { api } from '../../services/apiClient';
    import type { ProfessionalProfile } from '../../services/profileService';

    const DEFAULT_AVATAR = '/images/default-avatar.svg';

    // ─── State ──────────────────────────────────────────────────
    let profileId: string | null = null;
    let currentServices: string[] = [];

    // ─── DOM refs ───────────────────────────────────────────────
    const loadingEl = document.getElementById('profile-loading')!;
    const errorEl = document.getElementById('profile-error')!;
    const errorMsg = document.getElementById('profile-error-msg')!;
    const formEl = document.getElementById('profile-form') as HTMLFormElement;
    const completionBadge = document.getElementById('completion-badge')!;
    const completionCircle = document.getElementById('completion-circle')!;
    const completionText = document.getElementById('completion-text')!;
    const completionStatus = document.getElementById('completion-status')!;

    // Fields
    const fieldName = document.getElementById('field-name') as HTMLInputElement;
    const fieldPhoto = document.getElementById('field-photo') as HTMLInputElement;
    const fieldCity = document.getElementById('field-city') as HTMLInputElement;
    const fieldWhatsapp = document.getElementById('field-whatsapp') as HTMLInputElement;
    const fieldLinkedin = document.getElementById('field-linkedin') as HTMLInputElement;
    const fieldModality = document.getElementById('field-modality') as HTMLSelectElement;
    const fieldPriceHour = document.getElementById('field-price-hour') as HTMLInputElement;
    const fieldBio = document.getElementById('field-bio') as HTMLTextAreaElement;
    const fieldEmailContact = document.getElementById('field-email-contact') as HTMLInputElement;
    const fieldPriceMin = document.getElementById('field-price-min') as HTMLInputElement;
    const fieldPriceMax = document.getElementById('field-price-max') as HTMLInputElement;
    const fieldServiceInput = document.getElementById('field-service-input') as HTMLInputElement;
    const servicesContainer = document.getElementById('services-container')!;
    const bioCount = document.getElementById('bio-count')!;
    const avatarPreview = document.getElementById('avatar-preview') as HTMLImageElement;
    const btnSave = document.getElementById('btn-save')!;

    // ─── Toast ──────────────────────────────────────────────────
    function showToast(message: string, type: 'success' | 'error') {
      const toast = document.getElementById('toast')!;
      const inner = document.getElementById('toast-inner')!;
      const icon = document.getElementById('toast-icon')!;
      const msg = document.getElementById('toast-msg')!;

      msg.textContent = message;
      if (type === 'success') {
        inner.className = 'flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm bg-primary text-on-primary';
        icon.textContent = 'check_circle';
      } else {
        inner.className = 'flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm bg-error text-on-error';
        icon.textContent = 'error';
      }

      toast.classList.remove('hidden');
      requestAnimationFrame(() => {
        toast.classList.remove('translate-y-[-1rem]', 'opacity-0');
      });

      setTimeout(() => {
        toast.classList.add('translate-y-[-1rem]', 'opacity-0');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, 3500);
    }

    // ─── Services chips ─────────────────────────────────────────
    function renderServices() {
      servicesContainer.innerHTML = currentServices
        .map(
          (s, i) => `
          <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold bg-primary-fixed text-on-primary-fixed-variant uppercase tracking-tight">
            ${s}
            <button type="button" data-remove="${i}" class="ml-1 hover:text-error transition-colors" aria-label="Eliminar ${s}">
              <span class="material-symbols-outlined text-sm" aria-hidden="true">close</span>
            </button>
          </span>`,
        )
        .join('');

      servicesContainer.querySelectorAll('[data-remove]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const idx = Number((btn as HTMLElement).dataset.remove);
          currentServices.splice(idx, 1);
          renderServices();
        });
      });
    }

    fieldServiceInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const val = fieldServiceInput.value.trim();
        if (val && !currentServices.includes(val)) {
          currentServices.push(val);
          renderServices();
        }
        fieldServiceInput.value = '';
      }
    });

    // ─── Bio counter ────────────────────────────────────────────
    fieldBio.addEventListener('input', () => {
      bioCount.textContent = `(${fieldBio.value.length}/300)`;
    });

    // ─── Photo preview ──────────────────────────────────────────
    fieldPhoto.addEventListener('change', () => {
      const url = fieldPhoto.value.trim();
      avatarPreview.src = url || DEFAULT_AVATAR;
    });
    fieldPhoto.addEventListener('input', () => {
      const url = fieldPhoto.value.trim();
      if (url) avatarPreview.src = url;
    });

    // ─── Completion circle ──────────────────────────────────────
    function updateCompletion(pct: number) {
      const circumference = 97.4; // 2 * PI * 15.5
      const offset = circumference - (pct / 100) * circumference;
      completionCircle.style.strokeDashoffset = String(offset);
      completionText.textContent = `${pct}%`;

      if (pct >= 80) {
        completionStatus.textContent = 'Perfil completo';
        completionStatus.className = 'text-sm font-bold text-primary';
      } else if (pct >= 50) {
        completionStatus.textContent = 'Buen progreso';
        completionStatus.className = 'text-sm font-bold text-on-surface';
      } else {
        completionStatus.textContent = 'Por completar';
        completionStatus.className = 'text-sm font-bold text-outline';
      }

      completionBadge.classList.remove('hidden');
    }

    // ─── Populate form ──────────────────────────────────────────
    function populateForm(data: ProfessionalProfile) {
      profileId = data.id;
      fieldName.value = data.name || '';
      fieldPhoto.value = data.photo || '';
      fieldCity.value = data.city || '';
      fieldWhatsapp.value = data.whatsapp || '';
      fieldLinkedin.value = data.linkedin || '';
      fieldModality.value = data.workModality || '';
      fieldPriceHour.value = data.pricePerHour || '';
      fieldBio.value = data.bio || '';
      fieldEmailContact.value = data.emailContact || '';
      fieldPriceMin.value = data.priceMin || '';
      fieldPriceMax.value = data.priceMax || '';

      avatarPreview.src = data.photo || DEFAULT_AVATAR;
      bioCount.textContent = `(${(data.bio || '').length}/300)`;

      currentServices = [...(data.services || [])];
      renderServices();

      updateCompletion(data.completionPct);
    }

    // ─── Load profile ───────────────────────────────────────────
    async function loadProfile() {
      const userId = getUserIdFromToken();
      const token = getToken();

      if (!userId || !token) {
        logout();
        return;
      }

      api.setHeader('Authorization', `Bearer ${token}`);

      try {
        const data = await api.get<ProfessionalProfile>(`/professionals/by-user/${userId}`);
        loadingEl.classList.add('hidden');
        formEl.classList.remove('hidden');
        populateForm(data);

        // Update sidebar
        const sidebarName = document.getElementById('sidebar-user-name');
        if (sidebarName) sidebarName.textContent = data.name;
        const sidebarRole = document.getElementById('sidebar-user-role');
        if (sidebarRole && data.services.length > 0) sidebarRole.textContent = data.services[0];
        const sidebarAvatar = document.getElementById('sidebar-user-avatar') as HTMLImageElement | null;
        if (sidebarAvatar) {
          sidebarAvatar.src = data.photo || DEFAULT_AVATAR;
          sidebarAvatar.alt = `Foto de perfil de ${data.name}`;
        }
        const profileLink = document.getElementById('sidebar-profile-link') as HTMLAnchorElement | null;
        if (profileLink) profileLink.href = `/profesionales/perfil?id=${data.id}`;
      } catch (err: unknown) {
        const error = err as Error & { status?: number };
        if (error?.status === 401) {
          logout();
          return;
        }
        loadingEl.classList.add('hidden');
        errorEl.classList.remove('hidden');
        errorMsg.textContent = error?.message || 'No se pudo obtener la información del perfil.';
      }
    }

    // ─── Save profile ───────────────────────────────────────────
    formEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!profileId) return;

      btnSave.setAttribute('disabled', '');
      btnSave.innerHTML = '<div class="w-5 h-5 border-2 border-on-primary/30 border-t-on-primary rounded-full animate-spin"></div> Guardando...';

      try {
        // PATCH personal data
        await api.patch(`/professionals/${profileId}/personal`, {
          name: fieldName.value.trim() || undefined,
          city: fieldCity.value.trim() || undefined,
          whatsapp: fieldWhatsapp.value.trim() || undefined,
          linkedin: fieldLinkedin.value.trim() || undefined,
          pricePerHour: fieldPriceHour.value || undefined,
          workModality: fieldModality.value || undefined,
        });

        // PATCH general profile
        const updatedProfile = await api.patch<ProfessionalProfile>(`/professionals/${profileId}`, {
          name: fieldName.value.trim() || undefined,
          bio: fieldBio.value.trim() || undefined,
          photo: fieldPhoto.value.trim() || undefined,
          services: currentServices,
          priceMin: fieldPriceMin.value || undefined,
          priceMax: fieldPriceMax.value || undefined,
          city: fieldCity.value.trim() || undefined,
          emailContact: fieldEmailContact.value.trim() || undefined,
          whatsapp: fieldWhatsapp.value.trim() || undefined,
        });

        // Update completion
        if (updatedProfile?.completionPct !== undefined) {
          updateCompletion(updatedProfile.completionPct);
        }

        showToast('Perfil actualizado correctamente', 'success');
      } catch (err: unknown) {
        const error = err as Error & { status?: number };
        if (error?.status === 401) {
          logout();
          return;
        }
        showToast(error?.message || 'Error al guardar los cambios', 'error');
      } finally {
        btnSave.removeAttribute('disabled');
        btnSave.innerHTML = '<span class="material-symbols-outlined text-lg" aria-hidden="true">save</span> Guardar cambios';
      }
    });

    // ─── Init ───────────────────────────────────────────────────
    loadProfile();
  </script>
</DashboardLayout>
