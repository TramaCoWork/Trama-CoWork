---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Configuración | TRAMA">
  <div id="configuration-root" class="space-y-6 hidden">
    <header class="space-y-2">
      <h1 class="text-2xl font-bold text-on-surface">Configuración</h1>
      <p class="text-sm text-on-surface-variant">Administrá tus notificaciones y tu seguridad de cuenta.</p>
    </header>

    <div class="border-b border-outline-variant/20">
      <div class="flex gap-6" role="tablist" aria-label="Secciones de configuración">
        <button
          type="button"
          id="tab-notificaciones"
          role="tab"
          aria-controls="panel-notificaciones"
          aria-selected="false"
          data-tab="notificaciones"
          class="border-b-2 border-transparent px-1 py-3 text-sm font-semibold text-on-surface-variant transition-colors"
        >
          Notificaciones
        </button>
        <button
          type="button"
          id="tab-seguridad"
          role="tab"
          aria-controls="panel-seguridad"
          aria-selected="false"
          data-tab="seguridad"
          class="border-b-2 border-transparent px-1 py-3 text-sm font-semibold text-on-surface-variant transition-colors"
        >
          Seguridad
        </button>
      </div>
    </div>

    <section id="panel-notificaciones" role="tabpanel" aria-labelledby="tab-notificaciones" class="space-y-4 hidden">
      <div id="prefs-fetch-error" class="hidden rounded-xl border border-error/30 bg-error/10 px-4 py-3 text-sm font-medium text-error"></div>
      <div id="prefs-inline-error" class="hidden rounded-xl border border-error/30 bg-error/10 px-4 py-3 text-sm font-medium text-error"></div>

      <div id="prefs-loading" class="rounded-2xl border border-outline-variant/15 bg-surface-container-low p-5">
        <div class="space-y-3">
          <div class="h-4 w-40 animate-pulse rounded bg-surface-container-high"></div>
          <div class="h-12 animate-pulse rounded-xl bg-surface-container"></div>
          <div class="h-12 animate-pulse rounded-xl bg-surface-container"></div>
          <div class="h-12 animate-pulse rounded-xl bg-surface-container"></div>
        </div>
      </div>

      <p id="prefs-empty" class="hidden rounded-2xl border border-outline-variant/15 bg-surface-container-low px-5 py-4 text-sm text-on-surface-variant">
        No tenés canales disponibles
      </p>

      <div id="prefs-table-wrapper" class="hidden overflow-hidden rounded-2xl border border-outline-variant/15 bg-surface-container-low">
        <table class="w-full border-collapse text-sm">
          <thead class="bg-surface-container">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-on-surface">Canal</th>
              <th class="px-4 py-3 text-left font-semibold text-on-surface">Email</th>
              <th class="px-4 py-3 text-left font-semibold text-on-surface">Push</th>
            </tr>
          </thead>
          <tbody id="prefs-table-body"></tbody>
        </table>
      </div>
    </section>

    <section id="panel-seguridad" role="tabpanel" aria-labelledby="tab-seguridad" class="space-y-4 hidden">
      <div class="max-w-md rounded-2xl border border-outline-variant/15 bg-surface-container-low p-6">
        <p class="mb-5 text-sm text-on-surface-variant">Ingresá tu contraseña actual y elegí una nueva.</p>

        <div id="password-success" class="hidden mb-4 rounded-xl border border-success/30 bg-success/10 px-4 py-3 text-sm font-semibold text-success"></div>
        <div id="password-error" class="hidden mb-4 rounded-xl border border-error/30 bg-error/10 px-4 py-3 text-sm font-semibold text-error"></div>

        <form id="password-form" class="space-y-4" novalidate>
          <div>
            <label for="currentPassword" class="mb-1.5 block text-sm font-semibold text-on-surface">Contraseña actual</label>
            <input
              id="currentPassword"
              name="currentPassword"
              type="password"
              required
              class="w-full rounded-xl border border-outline-variant bg-surface-container-lowest px-4 py-3 text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
              placeholder="Tu contraseña actual"
            />
          </div>

          <div>
            <label for="newPassword" class="mb-1.5 block text-sm font-semibold text-on-surface">Nueva contraseña</label>
            <input
              id="newPassword"
              name="newPassword"
              type="password"
              required
              minlength="8"
              class="w-full rounded-xl border border-outline-variant bg-surface-container-lowest px-4 py-3 text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
              placeholder="Mínimo 8 caracteres"
            />
          </div>

          <div>
            <label for="confirmPassword" class="mb-1.5 block text-sm font-semibold text-on-surface">Repetir nueva contraseña</label>
            <input
              id="confirmPassword"
              name="confirmPassword"
              type="password"
              required
              minlength="8"
              class="w-full rounded-xl border border-outline-variant bg-surface-container-lowest px-4 py-3 text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
              placeholder="Repetí la nueva contraseña"
            />
          </div>

          <button
            id="password-submit"
            type="submit"
            disabled
            class="w-full rounded-xl bg-primary py-3 text-sm font-bold text-on-primary transition-all hover:opacity-90 active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-50"
          >
            Guardar cambios
          </button>
        </form>
      </div>
    </section>
  </div>
</DashboardLayout>

<script>
  import { apiURL } from '../../services/apiClient';
  import { getToken, isAuthenticated, restoreSession } from '../../services/authService';

  type TabName = 'notificaciones' | 'seguridad';
  type SourceType = 'community' | 'channel';
  type PreferenceKind = 'email' | 'push';

  interface Channel {
    slug: string;
    name: string;
    type?: SourceType;
  }

  interface NotificationPreference {
    sourceId: string;
    sourceType: SourceType;
    email: boolean;
    push: boolean;
  }

  interface PasswordApiError {
    message?: string;
  }

  const root = document.getElementById('configuration-root');
  const tabButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tab]'));
  const panelNotificaciones = document.getElementById('panel-notificaciones');
  const panelSeguridad = document.getElementById('panel-seguridad');

  const prefsLoading = document.getElementById('prefs-loading');
  const prefsEmpty = document.getElementById('prefs-empty');
  const prefsTableWrapper = document.getElementById('prefs-table-wrapper');
  const prefsTableBody = document.getElementById('prefs-table-body');
  const prefsFetchError = document.getElementById('prefs-fetch-error');
  const prefsInlineError = document.getElementById('prefs-inline-error');

  const passwordForm = document.getElementById('password-form') as HTMLFormElement | null;
  const passwordSubmit = document.getElementById('password-submit') as HTMLButtonElement | null;
  const passwordSuccess = document.getElementById('password-success');
  const passwordError = document.getElementById('password-error');
  const currentPasswordInput = document.getElementById('currentPassword') as HTMLInputElement | null;
  const newPasswordInput = document.getElementById('newPassword') as HTMLInputElement | null;
  const confirmPasswordInput = document.getElementById('confirmPassword') as HTMLInputElement | null;

  const prefsBySource = new Map<string, NotificationPreference>();
  const channelState = new Map<string, { email: boolean; push: boolean }>();

  let notificationsLoaded = false;
  let passwordSuccessTimeout: ReturnType<typeof setTimeout> | null = null;

  function getTabFromUrl(): TabName {
    const tab = new URLSearchParams(window.location.search).get('tab');
    return tab === 'seguridad' ? 'seguridad' : 'notificaciones';
  }

  function getSourceKey(sourceId: string, sourceType: SourceType): string {
    return `${sourceId}:${sourceType}`;
  }

  function getEffectivePref(sourceId: string, sourceType: SourceType): { email: boolean; push: boolean } {
    const key = getSourceKey(sourceId, sourceType);
    const pref = prefsBySource.get(key);
    if (pref) {
      return { email: pref.email, push: pref.push };
    }

    return { email: true, push: true };
  }

  function setTabStyles(activeTab: TabName): void {
    tabButtons.forEach((button) => {
      const isActive = button.dataset.tab === activeTab;
      button.setAttribute('aria-selected', isActive ? 'true' : 'false');
      button.classList.toggle('text-primary', isActive);
      button.classList.toggle('border-primary', isActive);
      button.classList.toggle('font-bold', isActive);
      button.classList.toggle('text-on-surface-variant', !isActive);
      button.classList.toggle('border-transparent', !isActive);
    });
  }

  function showPanel(activeTab: TabName): void {
    panelNotificaciones?.classList.toggle('hidden', activeTab !== 'notificaciones');
    panelSeguridad?.classList.toggle('hidden', activeTab !== 'seguridad');
    setTabStyles(activeTab);
  }

  function updateUrlForTab(tab: TabName): void {
    const nextUrl = new URL(window.location.href);
    nextUrl.searchParams.set('tab', tab);
    window.history.pushState({}, '', `${nextUrl.pathname}${nextUrl.search}`);
  }

  function hideElement(element: Element | null): void {
    element?.classList.add('hidden');
  }

  function showElement(element: Element | null): void {
    element?.classList.remove('hidden');
  }

  function updateSwitchButtonAppearance(button: HTMLButtonElement, enabled: boolean): void {
    button.setAttribute('aria-checked', enabled ? 'true' : 'false');
    button.classList.toggle('bg-primary', enabled);
    button.classList.toggle('bg-surface-container-high', !enabled);

    const thumb = button.querySelector('span');
    thumb?.classList.toggle('translate-x-6', enabled);
    thumb?.classList.toggle('translate-x-1', !enabled);

    const prefLabel = button.dataset.prefType === 'push' ? 'Push' : 'Email';
    const statusLabel = enabled ? 'activado' : 'silenciado';
    button.title = `${prefLabel}: ${statusLabel}`;

    const srLabel = button.querySelector('.sr-only');
    if (srLabel) {
      srLabel.textContent = `${prefLabel} ${statusLabel}`;
    }
  }

  function setInlinePreferenceError(message: string): void {
    if (!prefsInlineError) return;
    prefsInlineError.textContent = message;
    showElement(prefsInlineError);
  }

  function clearInlinePreferenceError(): void {
    hideElement(prefsInlineError);
  }

  async function togglePreference(button: HTMLButtonElement): Promise<void> {
    const sourceId = button.dataset.sourceId;
    const sourceType = button.dataset.sourceType as SourceType | undefined;
    const prefType = button.dataset.prefType as PreferenceKind | undefined;

    if (!sourceId || !sourceType || !prefType) return;

    const token = getToken();
    if (!token) {
      setInlinePreferenceError('Tu sesión expiró. Volvé a iniciar sesión.');
      return;
    }

    clearInlinePreferenceError();

    const key = getSourceKey(sourceId, sourceType);
    const previous = channelState.get(key) ?? { email: true, push: true };
    const next = { ...previous, [prefType]: !previous[prefType] };
    channelState.set(key, next);

    const pairButtons = document.querySelectorAll<HTMLButtonElement>(`button[data-source-id="${sourceId}"][data-source-type="${sourceType}"]`);
    pairButtons.forEach((switchButton) => {
      const switchType = switchButton.dataset.prefType as PreferenceKind;
      updateSwitchButtonAppearance(switchButton, next[switchType]);
      switchButton.disabled = true;
    });

    try {
      const headers = {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${token}`,
      };

      if (next.email && next.push) {
        const deletePath = apiURL(`/notifications/preferences/${encodeURIComponent(sourceId)}/${encodeURIComponent(sourceType)}`);
        const deleteResponse = await fetch(deletePath, { method: 'DELETE', headers });
        if (!deleteResponse.ok) {
          throw new Error('No se pudo actualizar la preferencia');
        }
        prefsBySource.delete(key);
      } else {
        const patchResponse = await fetch(apiURL('/notifications/preferences'), {
          method: 'PATCH',
          headers,
          body: JSON.stringify({
            sourceId,
            sourceType,
            email: next.email,
            push: next.push,
          }),
        });

        if (!patchResponse.ok) {
          throw new Error('No se pudo actualizar la preferencia');
        }

        prefsBySource.set(key, { sourceId, sourceType, email: next.email, push: next.push });
      }
    } catch {
      channelState.set(key, previous);
      pairButtons.forEach((switchButton) => {
        const switchType = switchButton.dataset.prefType as PreferenceKind;
        updateSwitchButtonAppearance(switchButton, previous[switchType]);
      });
      setInlinePreferenceError('No se pudo guardar el cambio. Reintentá.');
    } finally {
      pairButtons.forEach((switchButton) => {
        switchButton.disabled = false;
      });
    }
  }

  function renderPreferenceRow(channel: Channel): string {
    const sourceType: SourceType = channel.type === 'channel' ? 'channel' : 'community';
    const sourceId = channel.slug;
    const key = getSourceKey(sourceId, sourceType);
    const effective = getEffectivePref(sourceId, sourceType);
    channelState.set(key, effective);

    const iconName = sourceType === 'community' ? 'tag' : 'hub';

    return `
      <tr class="border-t border-outline-variant/15">
        <td class="px-4 py-3 text-on-surface">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-base text-on-surface-variant" aria-hidden="true">${iconName}</span>
            <span class="font-medium">${channel.name}</span>
          </div>
        </td>
        <td class="px-4 py-3">
          <button
            type="button"
            role="switch"
            aria-checked="${effective.email ? 'true' : 'false'}"
            data-source-id="${sourceId}"
            data-source-type="${sourceType}"
            data-pref-type="email"
            class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${effective.email ? 'bg-primary' : 'bg-surface-container-high'}"
            title="Email: ${effective.email ? 'activado' : 'silenciado'}"
          >
            <span class="inline-block h-[18px] w-[18px] transform rounded-full bg-white shadow transition-transform ${effective.email ? 'translate-x-6' : 'translate-x-1'}"></span>
            <span class="sr-only">Email ${effective.email ? 'activado' : 'silenciado'}</span>
          </button>
        </td>
        <td class="px-4 py-3">
          <button
            type="button"
            role="switch"
            aria-checked="${effective.push ? 'true' : 'false'}"
            data-source-id="${sourceId}"
            data-source-type="${sourceType}"
            data-pref-type="push"
            class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${effective.push ? 'bg-primary' : 'bg-surface-container-high'}"
            title="Push: ${effective.push ? 'activado' : 'silenciado'}"
          >
            <span class="inline-block h-[18px] w-[18px] transform rounded-full bg-white shadow transition-transform ${effective.push ? 'translate-x-6' : 'translate-x-1'}"></span>
            <span class="sr-only">Push ${effective.push ? 'activado' : 'silenciado'}</span>
          </button>
        </td>
      </tr>
    `;
  }

  async function loadNotificationsTab(): Promise<void> {
    if (notificationsLoaded) return;

    notificationsLoaded = true;
    clearInlinePreferenceError();
    hideElement(prefsFetchError);
    hideElement(prefsEmpty);
    hideElement(prefsTableWrapper);
    showElement(prefsLoading);

    const token = getToken();
    if (!token) {
      hideElement(prefsLoading);
      if (prefsFetchError) {
        prefsFetchError.textContent = 'Tu sesión expiró. Volvé a iniciar sesión.';
      }
      showElement(prefsFetchError);
      return;
    }

    const headers = { Authorization: `Bearer ${token}` };

    const channelsPromise = fetch(apiURL('/community/channels'), { headers }).then(async (response) => {
      if (!response.ok) {
        throw new Error('No se pudieron cargar los canales');
      }
      return response.json() as Promise<Channel[] | { data?: Channel[] }>;
    });

    const prefsPromise = fetch(apiURL('/notifications/preferences'), { headers }).then(async (response) => {
      if (!response.ok) {
        throw new Error('No se pudieron cargar las preferencias');
      }
      return response.json() as Promise<NotificationPreference[] | { data?: NotificationPreference[] }>;
    });

    const [channelsResult, prefsResult] = await Promise.allSettled([channelsPromise, prefsPromise]);
    hideElement(prefsLoading);

    if (channelsResult.status === 'rejected') {
      if (prefsFetchError) {
        prefsFetchError.textContent = 'No se pudieron cargar tus canales.';
      }
      showElement(prefsFetchError);
      return;
    }

    const channelsRaw = channelsResult.value;
    const channels = Array.isArray(channelsRaw) ? channelsRaw : (channelsRaw.data ?? []);

    prefsBySource.clear();
    if (prefsResult.status === 'fulfilled') {
      const prefsRaw = prefsResult.value;
      const prefs = Array.isArray(prefsRaw) ? prefsRaw : (prefsRaw.data ?? []);
      prefs.forEach((pref) => {
        prefsBySource.set(getSourceKey(pref.sourceId, pref.sourceType), pref);
      });
    }

    if (channels.length === 0) {
      showElement(prefsEmpty);
      return;
    }

    if (!prefsTableBody) return;

    prefsTableBody.innerHTML = channels.map((channel) => renderPreferenceRow(channel)).join('');
    showElement(prefsTableWrapper);

    prefsTableBody.querySelectorAll<HTMLButtonElement>('button[role="switch"]').forEach((button) => {
      button.addEventListener('click', () => {
        void togglePreference(button);
      });
    });
  }

  function showPasswordError(message: string): void {
    if (!passwordError || !passwordSuccess) return;
    hideElement(passwordSuccess);
    passwordError.textContent = message;
    showElement(passwordError);
  }

  function showPasswordSuccess(message: string): void {
    if (!passwordSuccess || !passwordError) return;
    hideElement(passwordError);
    passwordSuccess.textContent = message;
    showElement(passwordSuccess);
  }

  function hidePasswordMessages(): void {
    hideElement(passwordSuccess);
    hideElement(passwordError);
  }

  function validatePasswordForm(): string | null {
    const currentPassword = currentPasswordInput?.value.trim() ?? '';
    const newPassword = newPasswordInput?.value.trim() ?? '';
    const confirmPassword = confirmPasswordInput?.value.trim() ?? '';

    if (!currentPassword || !newPassword || !confirmPassword) {
      return 'Todos los campos son obligatorios';
    }

    if (newPassword.length < 8) {
      return 'La nueva contraseña debe tener al menos 8 caracteres';
    }

    if (newPassword !== confirmPassword) {
      return 'Las contraseñas no coinciden';
    }

    return null;
  }

  function updatePasswordSubmitState(isLoading = false): void {
    if (!passwordSubmit) return;
    if (isLoading) {
      passwordSubmit.disabled = true;
      passwordSubmit.textContent = 'Guardando...';
      return;
    }

    const validationError = validatePasswordForm();
    passwordSubmit.disabled = validationError !== null;
    passwordSubmit.textContent = 'Guardar cambios';
  }

  async function handlePasswordSubmit(event: SubmitEvent): Promise<void> {
    event.preventDefault();
    hidePasswordMessages();

    const validationError = validatePasswordForm();
    if (validationError) {
      showPasswordError(validationError);
      updatePasswordSubmitState(false);
      return;
    }

    const token = getToken();
    if (!token) {
      showPasswordError('Tu sesión expiró. Volvé a iniciar sesión.');
      updatePasswordSubmitState(false);
      return;
    }

    const currentPassword = currentPasswordInput?.value.trim() ?? '';
    const newPassword = newPasswordInput?.value.trim() ?? '';
    const confirmPassword = confirmPasswordInput?.value.trim() ?? '';

    updatePasswordSubmitState(true);

    try {
      const response = await fetch(apiURL('/auth/me/password'), {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify({ currentPassword, newPassword, confirmPassword }),
      });

      if (response.ok) {
        passwordForm?.reset();
        showPasswordSuccess('Contraseña actualizada correctamente');
        if (passwordSuccessTimeout) {
          clearTimeout(passwordSuccessTimeout);
        }
        passwordSuccessTimeout = setTimeout(() => {
          hideElement(passwordSuccess);
        }, 4000);
        updatePasswordSubmitState(false);
        return;
      }

      if (response.status === 400 || response.status === 401) {
        showPasswordError('Contraseña actual incorrecta');
      } else if (response.status === 422) {
        const body = await response.json().catch(() => null) as PasswordApiError | null;
        showPasswordError(body?.message || 'Error al actualizar la contraseña. Intentá de nuevo.');
      } else {
        showPasswordError('Error al actualizar la contraseña. Intentá de nuevo.');
      }
    } catch {
      showPasswordError('Error al actualizar la contraseña. Intentá de nuevo.');
    } finally {
      updatePasswordSubmitState(false);
    }
  }

  async function activateTab(tab: TabName, pushUrl = false): Promise<void> {
    showPanel(tab);
    if (pushUrl) {
      updateUrlForTab(tab);
    }

    if (tab === 'notificaciones') {
      await loadNotificationsTab();
    }
  }

  function initTabs(initialTab: TabName): void {
    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const targetTab = button.dataset.tab === 'seguridad' ? 'seguridad' : 'notificaciones';
        void activateTab(targetTab, true);
      });
    });

    window.addEventListener('popstate', () => {
      const tab = getTabFromUrl();
      void activateTab(tab, false);
    });

    void activateTab(initialTab, false);
  }

  function initSecurityForm(): void {
    if (!passwordForm) return;

    const updateState = () => {
      hidePasswordMessages();
      updatePasswordSubmitState(false);
    };

    currentPasswordInput?.addEventListener('input', updateState);
    newPasswordInput?.addEventListener('input', updateState);
    confirmPasswordInput?.addEventListener('input', updateState);
    passwordForm.addEventListener('submit', (event) => {
      void handlePasswordSubmit(event);
    });
    updatePasswordSubmitState(false);
  }

  restoreSession();
  if (!isAuthenticated()) {
    window.location.href = '/login';
  } else {
    showElement(root);
    const initialTab = getTabFromUrl();
    initTabs(initialTab);
    initSecurityForm();
  }
</script>

