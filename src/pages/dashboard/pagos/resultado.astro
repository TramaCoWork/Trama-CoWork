---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="TRAMA - Resultado del pago">
  <div class="flex items-center justify-center py-16">
    <div id="result-card" class="bg-surface-container-low rounded-3xl p-10 max-w-lg w-full text-center">
      <!-- Loading while we parse -->
      <div id="result-loading">
        <div class="w-10 h-10 border-3 border-primary/30 border-t-primary rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-sm font-medium text-on-surface-variant">Procesando resultado...</p>
      </div>

      <!-- Approved -->
      <div id="result-approved" class="hidden">
        <div class="w-20 h-20 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center mx-auto mb-6">
          <span class="material-symbols-outlined text-green-600 dark:text-green-400 text-4xl" aria-hidden="true">check_circle</span>
        </div>
        <h1 class="text-2xl font-black text-on-surface tracking-tight mb-2">Pago aprobado</h1>
        <p id="approved-message" class="text-sm text-on-surface-variant leading-relaxed">Tu suscripcion fue activada correctamente. Ya podes disfrutar de todos los beneficios de tu plan.</p>
        <div id="approved-details" class="mt-6 bg-surface-container-lowest rounded-2xl p-5 space-y-2 text-left"></div>
      </div>

      <!-- Pending -->
      <div id="result-pending" class="hidden">
        <div class="w-20 h-20 rounded-full bg-yellow-100 dark:bg-yellow-900/30 flex items-center justify-center mx-auto mb-6">
          <span class="material-symbols-outlined text-yellow-600 dark:text-yellow-400 text-4xl" aria-hidden="true">schedule</span>
        </div>
        <h1 class="text-2xl font-black text-on-surface tracking-tight mb-2">Pago pendiente</h1>
        <p id="pending-message" class="text-sm text-on-surface-variant leading-relaxed">Tu pago esta siendo procesado. Te notificaremos cuando se confirme. Esto puede demorar unos minutos.</p>
        <div id="pending-details" class="mt-6 bg-surface-container-lowest rounded-2xl p-5 space-y-2 text-left"></div>
      </div>

      <!-- Rejected -->
      <div id="result-rejected" class="hidden">
        <div class="w-20 h-20 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center mx-auto mb-6">
          <span class="material-symbols-outlined text-red-600 dark:text-red-400 text-4xl" aria-hidden="true">cancel</span>
        </div>
        <h1 class="text-2xl font-black text-on-surface tracking-tight mb-2">Pago rechazado</h1>
        <p id="rejected-message" class="text-sm text-on-surface-variant leading-relaxed">No se pudo procesar tu pago. Podes intentar nuevamente con otro medio de pago.</p>
        <div id="rejected-details" class="mt-6 bg-surface-container-lowest rounded-2xl p-5 space-y-2 text-left"></div>
      </div>

      <!-- Unknown -->
      <div id="result-unknown" class="hidden">
        <div class="w-20 h-20 rounded-full bg-gray-100 dark:bg-gray-900/30 flex items-center justify-center mx-auto mb-6">
          <span class="material-symbols-outlined text-gray-600 dark:text-gray-400 text-4xl" aria-hidden="true">help</span>
        </div>
        <h1 class="text-2xl font-black text-on-surface tracking-tight mb-2">Estado desconocido</h1>
        <p class="text-sm text-on-surface-variant leading-relaxed">No pudimos determinar el resultado del pago. Revisa tu historial de pagos para verificar el estado.</p>
      </div>

      <!-- Action button -->
      <a href="/dashboard/pagos"
        class="inline-flex items-center justify-center gap-2 mt-8 px-8 py-4 rounded-2xl font-bold text-sm bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all">
        <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_back</span>
        Volver a Pagos
      </a>
    </div>
  </div>

  <script>
    import { logout } from '../../../services/authService';
    import { getMySubscription } from '../../../services/subscriptionService';

    const PENDING_SUBSCRIPTION_KEY = 'trama_subscription_pending';
    const POLL_INTERVAL_MS = 3000;
    const MAX_POLL_ATTEMPTS = 20;

    function detailRow(label: string, value: string): string {
      return `<div class="flex items-baseline gap-3">
        <span class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant w-28 shrink-0">${label}</span>
        <span class="text-sm font-medium text-on-surface">${value}</span>
      </div>`;
    }

    function showSection(sectionId: 'result-approved' | 'result-pending' | 'result-rejected' | 'result-unknown') {
      const sections = ['result-approved', 'result-pending', 'result-rejected', 'result-unknown'];
      for (const id of sections) {
        document.getElementById(id)!.classList.add('hidden');
      }
      document.getElementById(sectionId)!.classList.remove('hidden');
    }

    function clearPendingSubscription() {
      localStorage.removeItem(PENDING_SUBSCRIPTION_KEY);
    }

    function navigateToPayments(delayMs = 0) {
      if (delayMs <= 0) {
        window.location.href = '/dashboard/pagos';
        return;
      }
      setTimeout(() => {
        window.location.href = '/dashboard/pagos';
      }, delayMs);
    }

    function sleep(ms: number): Promise<void> {
      return new Promise((resolve) => {
        setTimeout(resolve, ms);
      });
    }

    async function pollUntilActive(initialStatus: string) {
      const pendingMessage = document.getElementById('pending-message')!;
      const pendingDetails = document.getElementById('pending-details')!;

      pendingMessage.textContent = 'Estamos activando tu suscripción. Esto puede demorar unos segundos.';
      pendingDetails.innerHTML = detailRow('Estado MP', initialStatus || 'pendiente');

      showSection('result-pending');

      for (let attempt = 1; attempt <= MAX_POLL_ATTEMPTS; attempt++) {
        pendingDetails.innerHTML = `${detailRow('Estado MP', initialStatus || 'pendiente')}${detailRow('Intento', `${attempt}/${MAX_POLL_ATTEMPTS}`)}`;

        try {
          const subscription = await getMySubscription();
          if (subscription.status === 'active') {
            clearPendingSubscription();
            const approvedMessage = document.getElementById('approved-message')!;
            const approvedDetails = document.getElementById('approved-details')!;
            approvedMessage.textContent = 'Tu suscripción fue activada correctamente. Te redirigimos a Pagos.';
            approvedDetails.innerHTML = detailRow('Suscripción', 'Activa');
            showSection('result-approved');
            navigateToPayments(1500);
            return;
          }
        } catch (err: unknown) {
          const error = err as Error & { status?: number };
          if (error?.status === 401) {
            clearPendingSubscription();
            logout();
            return;
          }
        }

        if (attempt < MAX_POLL_ATTEMPTS) {
          await sleep(POLL_INTERVAL_MS);
        }
      }

      clearPendingSubscription();
      const rejectedMessage = document.getElementById('rejected-message')!;
      const rejectedDetails = document.getElementById('rejected-details')!;
      rejectedMessage.textContent = 'No pudimos confirmar la activación a tiempo. Te redirigimos para que revises tu estado.';
      rejectedDetails.innerHTML = detailRow('Resultado', 'Tiempo de espera agotado');
      showSection('result-rejected');
      navigateToPayments(2000);
    }

    async function init() {
      const params = new URLSearchParams(window.location.search);
      const pendingSubscription = localStorage.getItem(PENDING_SUBSCRIPTION_KEY);

      if (!pendingSubscription) {
        navigateToPayments();
        return;
      }

      const status = (params.get('status') || '').toLowerCase();
      const detail = params.get('detail') || params.get('status_detail') || '';
      const message = params.get('msg') || '';
      const preapprovalId = params.get('preapproval_id') || '';

      const loadingEl = document.getElementById('result-loading')!;
      loadingEl.classList.add('hidden');

      if (status === 'failure' || status === 'rejected') {
        clearPendingSubscription();
        const rejectedMessage = document.getElementById('rejected-message')!;
        const rejectedDetails = document.getElementById('rejected-details')!;
        rejectedMessage.textContent = message || 'Hubo un problema con el pago.';
        rejectedDetails.innerHTML = detail ? detailRow('Detalle', detail) : '';
        showSection('result-rejected');
        return;
      }

      if (status === 'cancelled') {
        clearPendingSubscription();
        const rejectedMessage = document.getElementById('rejected-message')!;
        const rejectedDetails = document.getElementById('rejected-details')!;
        rejectedMessage.textContent = 'Cancelaste el proceso de pago.';
        rejectedDetails.innerHTML = detail ? detailRow('Detalle', detail) : '';
        showSection('result-rejected');
        return;
      }

      if (!['approved', 'pending', 'in_process'].includes(status)) {
        clearPendingSubscription();
        const rejectedMessage = document.getElementById('rejected-message')!;
        const rejectedDetails = document.getElementById('rejected-details')!;
        rejectedMessage.textContent = 'Hubo un problema con el pago.';
        rejectedDetails.innerHTML = status ? detailRow('Estado', status) : '';
        showSection('result-rejected');
        return;
      }

      if (preapprovalId) {
        const pendingDetails = document.getElementById('pending-details')!;
        pendingDetails.innerHTML = detailRow('Preapproval', preapprovalId);
      }

      await pollUntilActive(status);
    }

    init();
  </script>
</DashboardLayout>

