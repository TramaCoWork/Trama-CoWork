---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="TRAMA - Estudios">
  <!-- Header -->
  <header class="mb-10">
    <div class="flex justify-between items-end">
      <div>
        <h1 class="text-4xl font-black text-on-surface tracking-tighter">Formación y certificaciones</h1>
        <p class="text-on-surface-variant font-medium mt-2">Cargá tus estudios y adjuntá los comprobantes en PDF.</p>
      </div>
      <div id="counter-badge" class="hidden">
        <div class="flex items-center gap-2 bg-surface-container-low px-5 py-3 rounded-2xl">
          <span class="material-symbols-outlined text-primary" aria-hidden="true">school</span>
          <span id="counter-text" class="text-sm font-bold text-on-surface">0 registros</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Loading State -->
  <div id="estudios-loading" class="flex items-center justify-center py-24">
    <div class="flex flex-col items-center gap-4">
      <div class="w-10 h-10 border-3 border-primary/30 border-t-primary rounded-full animate-spin"></div>
      <p class="text-sm font-medium text-on-surface-variant">Cargando estudios...</p>
    </div>
  </div>

  <!-- Error State -->
  <div id="estudios-error" class="hidden">
    <div class="bg-error-container text-on-error-container rounded-3xl p-8 text-center">
      <span class="material-symbols-outlined text-4xl mb-4 block" aria-hidden="true">error</span>
      <h2 class="text-xl font-bold mb-2">Error al cargar los estudios</h2>
      <p id="estudios-error-msg" class="text-sm opacity-80">No se pudo obtener la información.</p>
      <button onclick="location.reload()" class="mt-6 bg-error text-on-error px-6 py-3 rounded-xl font-bold text-sm hover:opacity-90 transition-opacity">
        Reintentar
      </button>
    </div>
  </div>

  <!-- Main Content -->
  <div id="estudios-content" class="hidden">
    <!-- Toast -->
    <div id="toast" class="fixed top-6 right-6 z-50 hidden transition-all duration-300 translate-y-[-1rem] opacity-0">
      <div id="toast-inner" class="flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm">
        <span id="toast-icon" class="material-symbols-outlined text-xl" aria-hidden="true"></span>
        <span id="toast-msg"></span>
      </div>
    </div>

    <!-- Single Column -->
    <div class="space-y-6">
      <div class="bg-surface-container-low rounded-3xl p-8">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">school</span>
            <h2 class="text-xl font-extrabold text-on-surface tracking-tight">Estudios</h2>
          </div>
          <button id="btn-add" type="button"
            class="flex items-center gap-1 px-4 py-2 rounded-xl text-xs font-bold bg-primary text-on-primary hover:opacity-90 active:scale-95 transition-all">
            <span class="material-symbols-outlined text-sm" aria-hidden="true">add</span>
            Agregar
          </button>
        </div>

        <!-- Add Form (hidden by default) -->
        <div id="add-form" class="hidden mb-6">
          <div class="bg-surface-container-lowest rounded-2xl p-6 border border-outline-variant/15 space-y-4">
            <h3 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">Nuevo registro</h3>

            <div>
              <label for="edu-level" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Nivel</label>
              <select id="edu-level" required
                class="w-full bg-surface-container-low border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer">
                <option value="">Seleccionar...</option>
              </select>
            </div>

            <div>
              <label for="edu-title" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Título / Nombre del curso</label>
              <input id="edu-title" type="text" required placeholder="Ej: Licenciatura en Psicología"
                class="w-full bg-surface-container-low border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
            </div>

            <div>
              <label for="edu-institution" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Institución</label>
              <input id="edu-institution" type="text" required placeholder="Ej: Universidad de Buenos Aires"
                class="w-full bg-surface-container-low border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
            </div>

            <div>
              <label for="edu-year" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Año de egreso (opcional)</label>
              <input id="edu-year" type="number" min="1950" max="2099" placeholder="2024"
                class="w-full bg-surface-container-low border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
            </div>

            <div>
              <label for="edu-profession" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Profesión relacionada (opcional)</label>
              <select id="edu-profession"
                class="w-full bg-surface-container-low border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer">
                <option value="">Sin profesión asociada</option>
              </select>
            </div>

            <div>
              <label for="edu-file" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Comprobante PDF (opcional, max 5MB)</label>
              <input id="edu-file" type="file" accept=".pdf,.jpg,.jpeg,.png"
                class="w-full text-sm text-on-surface-variant file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-primary-container file:text-on-primary-container file:cursor-pointer hover:file:opacity-90" />
            </div>

            <div class="flex gap-3 pt-2">
              <button id="btn-cancel" type="button" class="flex-1 px-4 py-3 rounded-xl font-bold text-sm text-on-surface-variant bg-surface-container hover:bg-surface-container-high transition-colors">
                Cancelar
              </button>
              <button id="btn-preview" type="button" class="flex-1 px-4 py-3 rounded-xl font-bold text-sm bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm" aria-hidden="true">visibility</span>
                Revisar
              </button>
            </div>
          </div>
        </div>

        <!-- Preview (hidden by default) -->
        <div id="preview-wrapper" class="hidden mb-6">
          <div class="bg-surface-container-lowest rounded-2xl p-6 border-2 border-primary/30 space-y-3">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-primary text-lg" aria-hidden="true">preview</span>
              <h3 class="text-sm font-bold uppercase tracking-widest text-primary">Resumen antes de guardar</h3>
            </div>
            <div id="preview-content"></div>
            <div class="flex gap-3 pt-3">
              <button id="btn-preview-back" type="button" class="flex-1 px-4 py-3 rounded-xl font-bold text-sm text-on-surface-variant bg-surface-container hover:bg-surface-container-high transition-colors flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm" aria-hidden="true">edit</span>
                Volver a editar
              </button>
              <button id="btn-save" type="button" class="flex-1 px-4 py-3 rounded-xl font-bold text-sm bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm" aria-hidden="true">check_circle</span>
                Confirmar y guardar
              </button>
            </div>
          </div>
        </div>

        <!-- List -->
        <div id="records-list" class="space-y-4"></div>

        <!-- Empty State -->
        <div id="records-empty" class="hidden text-center py-8">
          <span class="material-symbols-outlined text-4xl text-outline/40 mb-3 block" aria-hidden="true">menu_book</span>
          <p class="text-sm font-medium text-on-surface-variant">No tenés estudios cargados</p>
          <p class="text-xs text-outline mt-1">Hacé click en "Agregar" para sumar tu primer registro.</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { getUserIdFromToken, getToken, logout } from '../../services/authService';
    import { api } from '../../services/apiClient';
    import { fetchCatalog, getCatalogLabel, populateSelect } from '../../services/catalogService';
    import type { Education, EducationLevel, DocumentVerificationStatus } from '../../services/educationService';
    import type { ProfessionalProfile } from '../../services/profileService';

    const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB

    // ─── State ──────────────────────────────────────────────────
    let profileId: string | null = null;
    let records: Education[] = [];
    let professions: { id: number; name: string }[] = [];

    // ─── DOM refs ───────────────────────────────────────────────
    const loadingEl = document.getElementById('estudios-loading')!;
    const errorEl = document.getElementById('estudios-error')!;
    const errorMsg = document.getElementById('estudios-error-msg')!;
    const contentEl = document.getElementById('estudios-content')!;
    const counterBadge = document.getElementById('counter-badge')!;
    const counterText = document.getElementById('counter-text')!;

    // Form
    const addFormWrapper = document.getElementById('add-form')!;
    const eduLevel = document.getElementById('edu-level') as HTMLSelectElement;
    const eduTitle = document.getElementById('edu-title') as HTMLInputElement;
    const eduInstitution = document.getElementById('edu-institution') as HTMLInputElement;
    const eduYear = document.getElementById('edu-year') as HTMLInputElement;
    const eduProfession = document.getElementById('edu-profession') as HTMLSelectElement;
    const eduFile = document.getElementById('edu-file') as HTMLInputElement;
    const previewWrapper = document.getElementById('preview-wrapper')!;
    const previewContent = document.getElementById('preview-content')!;
    const recordsList = document.getElementById('records-list')!;
    const recordsEmpty = document.getElementById('records-empty')!;

    // ─── Toast ──────────────────────────────────────────────────
    function showToast(message: string, type: 'success' | 'error') {
      const toast = document.getElementById('toast')!;
      const inner = document.getElementById('toast-inner')!;
      const icon = document.getElementById('toast-icon')!;
      const msg = document.getElementById('toast-msg')!;

      msg.textContent = message;
      if (type === 'success') {
        inner.className = 'flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm bg-primary text-on-primary';
        icon.textContent = 'check_circle';
      } else {
        inner.className = 'flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm bg-error text-on-error';
        icon.textContent = 'error';
      }

      toast.classList.remove('hidden');
      requestAnimationFrame(() => {
        toast.classList.remove('translate-y-[-1rem]', 'opacity-0');
      });

      setTimeout(() => {
        toast.classList.add('translate-y-[-1rem]', 'opacity-0');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, 3500);
    }

    // ─── Counter ────────────────────────────────────────────────
    function updateCounter() {
      const total = records.length;
      counterText.textContent = `${total} registro${total !== 1 ? 's' : ''}`;
      counterBadge.classList.remove('hidden');
    }

    // ─── Helpers ────────────────────────────────────────────────
    function formatSize(bytes: number): string {
      if (bytes < 1024) return `${bytes} B`;
      if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
      return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
    }

    function verificationBadge(status: DocumentVerificationStatus, notes: string | null): string {
      const config: Record<DocumentVerificationStatus, { icon: string; label: string; cls: string }> = {
        pending: {
          icon: 'schedule',
          label: 'Pendiente',
          cls: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300',
        },
        approved: {
          icon: 'verified',
          label: 'Verificado',
          cls: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300',
        },
        rejected: {
          icon: 'cancel',
          label: 'Rechazado',
          cls: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300',
        },
      };

      const c = config[status] || config.pending;
      const safeNotes = notes ? notes.replaceAll('"', '&quot;') : '';
      const tooltip = status === 'rejected' && notes ? ` title="${safeNotes}"` : '';

      let html = `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold uppercase tracking-wide ${c.cls}"${tooltip}>
        <span class="material-symbols-outlined text-xs" aria-hidden="true">${c.icon}</span>
        ${c.label}
      </span>`;

      if (status === 'rejected' && notes) {
        html += `<p class="text-[10px] text-error mt-1 truncate" title="${safeNotes}">${notes}</p>`;
      }

      return html;
    }

    function detailRow(label: string, value: string): string {
      return `<div class="flex items-baseline gap-3">
        <span class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant w-24 shrink-0">${label}</span>
        <span class="text-sm font-medium text-on-surface">${value}</span>
      </div>`;
    }

    function previewRow(label: string, value: string): string {
      return detailRow(label, value);
    }

    // ─── Authenticated download ─────────────────────────────────
    async function downloadDocument(docId: string, fileName: string) {
      const token = getToken();
      if (!token) { logout(); return; }

      try {
        const res = await fetch(api.downloadUrl(`/uploads/document/${docId}`), {
          headers: { 'Authorization': `Bearer ${token}` },
        });

        if (!res.ok) {
          if (res.status === 401) { logout(); return; }
          throw new Error(`Error ${res.status}`);
        }

        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      } catch {
        showToast('Error al descargar el documento', 'error');
      }
    }

    function bindDownloadButtons(container: HTMLElement) {
      container.querySelectorAll<HTMLElement>('[data-download-doc]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const docId = btn.dataset.downloadDoc!;
          const name = btn.dataset.downloadName || 'documento';
          downloadDocument(docId, name);
        });
      });
    }

    // ─── Document preview (authenticated) ───────────────────────
    const activeBlobUrls = new Map<string, string>();

    async function fetchDocumentPreview(docId: string, mimeType: string, container: HTMLElement) {
      container.innerHTML = `<div class="flex items-center justify-center py-8">
        <div class="w-6 h-6 border-2 border-primary/30 border-t-primary rounded-full animate-spin"></div>
        <span class="ml-3 text-xs text-on-surface-variant">Cargando preview...</span>
      </div>`;

      const token = getToken();
      if (!token) { logout(); return; }

      try {
        const res = await fetch(api.downloadUrl(`/uploads/document/${docId}`), {
          headers: { 'Authorization': `Bearer ${token}` },
        });

        if (!res.ok) {
          if (res.status === 401) { logout(); return; }
          throw new Error(`Error ${res.status}`);
        }

        const blob = await res.blob();
        const blobUrl = URL.createObjectURL(blob);
        activeBlobUrls.set(docId, blobUrl);

        if (mimeType === 'application/pdf') {
          container.innerHTML = `<iframe src="${blobUrl}" class="w-full h-80 rounded-xl border border-outline-variant/15" title="Preview del documento"></iframe>`;
        } else if (mimeType.startsWith('image/')) {
          container.innerHTML = `<img src="${blobUrl}" alt="Preview del documento" class="max-w-full max-h-80 rounded-xl border border-outline-variant/15 object-contain mx-auto" />`;
        } else {
          container.innerHTML = `<p class="text-xs text-on-surface-variant text-center py-4">No se puede previsualizar este tipo de archivo. Usá el botón de descarga.</p>`;
        }
      } catch {
        container.innerHTML = `<p class="text-xs text-error text-center py-4">Error al cargar el preview del documento.</p>`;
      }
    }

    function revokePreview(docId: string) {
      const url = activeBlobUrls.get(docId);
      if (url) {
        URL.revokeObjectURL(url);
        activeBlobUrls.delete(docId);
      }
    }

    function bindExpandButtons(container: HTMLElement) {
      container.querySelectorAll<HTMLElement>('[data-expand]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.expand!;
          const expandEl = container.querySelector(`[data-expand-panel="${id}"]`) as HTMLElement | null;
          if (!expandEl) return;

          const isHidden = expandEl.classList.contains('hidden');

          // Collapse all other panels first
          container.querySelectorAll<HTMLElement>('[data-expand-panel]').forEach((panel) => {
            if (panel !== expandEl && !panel.classList.contains('hidden')) {
              panel.classList.add('hidden');
              const panelId = panel.dataset.expandPanel!;
              revokePreview(panelId);
            }
          });

          if (isHidden) {
            expandEl.classList.remove('hidden');
            const previewContainer = expandEl.querySelector('[data-preview-area]') as HTMLElement | null;
            const docId = expandEl.dataset.docId;
            const docMime = expandEl.dataset.docMime;
            if (previewContainer && docId && docMime) {
              fetchDocumentPreview(docId, docMime, previewContainer);
            }
          } else {
            expandEl.classList.add('hidden');
            const docId = expandEl.dataset.docId;
            if (docId) revokePreview(docId);
          }
        });
      });

      container.querySelectorAll<HTMLElement>('[data-collapse]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.collapse!;
          const expandEl = container.querySelector(`[data-expand-panel="${id}"]`) as HTMLElement | null;
          if (expandEl) {
            expandEl.classList.add('hidden');
            const docId = expandEl.dataset.docId;
            if (docId) revokePreview(docId);
          }
        });
      });
    }

    // ─── Render list ────────────────────────────────────────────
    function renderList() {
      if (records.length === 0) {
        recordsList.innerHTML = '';
        recordsEmpty.classList.remove('hidden');
        return;
      }
      recordsEmpty.classList.add('hidden');

      recordsList.innerHTML = records.map((rec) => {
        const doc = rec.documents?.[0];
        const levelLabel = getCatalogLabel('education-levels', rec.level);
        const yearStr = rec.year ? ` · ${rec.year}` : '';
        const profName = rec.professionId
          ? professions.find(p => p.id === rec.professionId)?.name || ''
          : '';

        const docHtml = doc
          ? `<div class="flex items-center gap-2 mt-3 p-3 bg-surface-container rounded-xl">
              <span class="material-symbols-outlined text-error text-lg" aria-hidden="true">picture_as_pdf</span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <p class="text-xs font-bold text-on-surface truncate">${doc.originalName}</p>
                  ${verificationBadge(doc.verificationStatus, doc.verificationNotes)}
                </div>
                <p class="text-[10px] text-outline">${formatSize(doc.sizeBytes)}</p>
              </div>
              <button type="button" data-download-doc="${doc.id}" data-download-name="${doc.originalName}"
                class="p-1.5 rounded-lg hover:bg-surface-container-high transition-colors" title="Descargar">
                <span class="material-symbols-outlined text-sm text-primary" aria-hidden="true">download</span>
              </button>
            </div>`
          : '';

        const docPreviewArea = doc
          ? `<div class="mt-4"><p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2">Documento adjunto</p><div data-preview-area></div></div>`
          : '';

        const verStatusRow = doc
          ? detailRow('Estado', verificationBadge(doc.verificationStatus, doc.verificationNotes))
          : '';

        const profRow = profName ? detailRow('Profesión', profName) : '';

        const expandPanel = `<div data-expand-panel="${rec.id}" ${doc ? `data-doc-id="${doc.id}" data-doc-mime="${doc.mimeType}"` : ''} class="hidden mt-4 pt-4 border-t border-outline-variant/15 space-y-2">
          ${detailRow('Nivel', `<span class="inline-block px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-widest bg-primary-fixed text-on-primary-fixed-variant">${levelLabel}</span>`)}
          ${detailRow('Título', rec.title)}
          ${detailRow('Institución', rec.institution)}
          ${rec.year ? detailRow('Año', String(rec.year)) : ''}
          ${profRow}
          ${verStatusRow}
          ${docPreviewArea}
          <div class="flex justify-end pt-2">
            <button type="button" data-collapse="${rec.id}" class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold text-on-surface-variant hover:bg-surface-container transition-colors">
              <span class="material-symbols-outlined text-sm" aria-hidden="true">expand_less</span>
              Cerrar
            </button>
          </div>
        </div>`;

        return `<div class="bg-surface-container-lowest rounded-2xl p-5 border border-outline-variant/10 hover:border-outline-variant/25 transition-colors">
          <div class="flex items-start justify-between">
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-bold text-on-surface">${rec.title}</h3>
              <p class="text-sm text-on-surface-variant mt-1">${rec.institution}</p>
              <div class="flex items-center gap-2 mt-2 flex-wrap">
                <span class="inline-block px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-widest bg-primary-fixed text-on-primary-fixed-variant">${levelLabel}</span>
                <span class="text-xs text-outline">${yearStr}</span>
                ${profName ? `<span class="text-xs text-on-surface-variant">· ${profName}</span>` : ''}
              </div>
            </div>
            <div class="flex items-center gap-1 shrink-0 ml-3">
              <button type="button" data-expand="${rec.id}"
                class="p-2 rounded-xl hover:bg-surface-container transition-colors" title="Ver detalle">
                <span class="material-symbols-outlined text-primary" aria-hidden="true">visibility</span>
              </button>
            </div>
          </div>
          ${docHtml}
          ${expandPanel}
        </div>`;
      }).join('');

      bindDownloadButtons(recordsList);
      bindExpandButtons(recordsList);
    }

    // ─── Toggle form ────────────────────────────────────────────
    function resetForm() {
      eduLevel.value = '';
      eduTitle.value = '';
      eduInstitution.value = '';
      eduYear.value = '';
      eduProfession.value = '';
      eduFile.value = '';
    }

    document.getElementById('btn-add')!.addEventListener('click', () => {
      resetForm();
      addFormWrapper.classList.toggle('hidden');
      previewWrapper.classList.add('hidden');
    });

    document.getElementById('btn-cancel')!.addEventListener('click', () => {
      addFormWrapper.classList.add('hidden');
      previewWrapper.classList.add('hidden');
    });

    // ─── Validate file ──────────────────────────────────────────
    function validateFile(input: HTMLInputElement): File | null {
      const file = input.files?.[0];
      if (!file) return null;
      if (file.size > MAX_FILE_SIZE) {
        showToast('El archivo supera los 5MB permitidos', 'error');
        return null;
      }
      return file;
    }

    // ─── Preview rendering ──────────────────────────────────────
    function renderPreview() {
      const level = eduLevel.value;
      const title = eduTitle.value.trim();
      const institution = eduInstitution.value.trim();
      const year = eduYear.value;
      const file = eduFile.files?.[0];
      const levelLabel = getCatalogLabel('education-levels', level);
      const profId = eduProfession.value;
      const profName = profId ? professions.find(p => p.id === Number(profId))?.name || '' : '';

      let html = previewRow('Nivel', levelLabel);
      html += previewRow('Título', title);
      html += previewRow('Institución', institution);
      if (year) html += previewRow('Año', year);
      if (profName) html += previewRow('Profesión', profName);
      if (file) html += previewRow('Documento', `${file.name} (${formatSize(file.size)})`);
      else html += previewRow('Documento', '<span class="text-outline italic">Sin adjunto</span>');

      previewContent.innerHTML = html;
    }

    // ─── Preview flow ───────────────────────────────────────────
    document.getElementById('btn-preview')!.addEventListener('click', () => {
      const level = eduLevel.value;
      const title = eduTitle.value.trim();
      const institution = eduInstitution.value.trim();

      if (!level || !title || !institution) {
        showToast('Completá nivel, título e institución', 'error');
        return;
      }

      const file = eduFile.files?.[0] ? validateFile(eduFile) : undefined;
      if (eduFile.files?.[0] && file === null) return;

      renderPreview();
      addFormWrapper.classList.add('hidden');
      previewWrapper.classList.remove('hidden');
    });

    document.getElementById('btn-preview-back')!.addEventListener('click', () => {
      previewWrapper.classList.add('hidden');
      addFormWrapper.classList.remove('hidden');
    });

    // ─── Save (from preview confirm) ────────────────────────────
    const btnSave = document.getElementById('btn-save')!;

    btnSave.addEventListener('click', async () => {
      if (!profileId) return;

      const level = eduLevel.value as EducationLevel;
      const title = eduTitle.value.trim();
      const institution = eduInstitution.value.trim();
      const year = eduYear.value ? Number(eduYear.value) : undefined;
      const professionId = eduProfession.value ? Number(eduProfession.value) : undefined;

      if (!level || !title || !institution) {
        showToast('Completá nivel, título e institución', 'error');
        return;
      }

      const file = eduFile.files?.[0] ? validateFile(eduFile) : undefined;
      if (eduFile.files?.[0] && file === null) return;

      btnSave.setAttribute('disabled', '');
      btnSave.innerHTML = '<div class="w-4 h-4 border-2 border-on-primary/30 border-t-on-primary rounded-full animate-spin"></div> Guardando...';

      try {
        const body: Record<string, unknown> = { level, title, institution };
        if (year) body.year = year;
        if (professionId) body.professionId = professionId;

        const newRec = await api.post<Education>(`/professionals/${profileId}/education`, body);

        if (file) {
          const formData = new FormData();
          formData.append('file', file);
          formData.append('type', level === 'certificacion' ? 'certificate' : 'title');
          formData.append('educationId', newRec.id);
          const doc = await api.upload<Education['documents']>('/uploads/document', formData);
          newRec.documents = Array.isArray(doc) ? doc : [doc as unknown as NonNullable<Education['documents']>[0]];
        }

        records.unshift(newRec);
        renderList();
        updateCounter();
        previewWrapper.classList.add('hidden');
        addFormWrapper.classList.add('hidden');
        resetForm();
        showToast('Registro agregado', 'success');
      } catch (err: unknown) {
        const error = err as Error & { status?: number };
        if (error?.status === 401) { logout(); return; }
        showToast(error?.message || 'Error al guardar', 'error');
      } finally {
        btnSave.removeAttribute('disabled');
        btnSave.innerHTML = '<span class="material-symbols-outlined text-sm" aria-hidden="true">check_circle</span> Confirmar y guardar';
      }
    });

    // ─── Load data ──────────────────────────────────────────────
    async function loadData() {
      const userId = getUserIdFromToken();
      const token = getToken();

      if (!userId || !token) {
        logout();
        return;
      }

      api.setHeader('Authorization', `Bearer ${token}`);

      try {
        // Get profile
        const profile = await api.get<ProfessionalProfile>(`/professionals/by-user/${userId}`);
        profileId = profile.id;

        // Extract professions from profile for the select
        if (profile.professionCategories && profile.professionCategories.length > 0) {
          professions = profile.professionCategories.map(pc => ({ id: pc.id, name: pc.name }));
          // Populate profession select
          while (eduProfession.options.length > 1) eduProfession.remove(1);
          professions.forEach(p => {
            const opt = document.createElement('option');
            opt.value = String(p.id);
            opt.textContent = p.name;
            eduProfession.appendChild(opt);
          });
        }

        // Populate level select from catalog
        const levelItems = await fetchCatalog('education-levels');
        populateSelect(eduLevel, levelItems);

        // Load education records
        const eduData = await api.get<Education[]>(`/professionals/${profileId}/education`);
        records = eduData;

        loadingEl.classList.add('hidden');
        contentEl.classList.remove('hidden');

        renderList();
        updateCounter();
      } catch (err: unknown) {
        const error = err as Error & { status?: number };
        if (error?.status === 401) {
          logout();
          return;
        }
        loadingEl.classList.add('hidden');
        errorEl.classList.remove('hidden');
        errorMsg.textContent = error?.message || 'No se pudo obtener la información.';
      }
    }

    // ─── Init ───────────────────────────────────────────────────
    loadData();
  </script>
</DashboardLayout>
