---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import EditorModal from '../../components/EditorModal.astro';
---

<DashboardLayout title="Comunidad | TRAMA">
  <div class="flex flex-col h-[calc(100vh-6rem)]">
    <!-- Header -->
    <header class="flex items-center justify-between pb-6 border-b border-outline-variant/15 shrink-0">
      <div>
        <h1 class="text-2xl font-extrabold text-on-surface tracking-tight">Comunidad</h1>
        <p class="text-sm text-on-surface-variant font-medium mt-1">Conecta con otros profesionales de la red.</p>
      </div>
      <div class="flex items-center gap-2">
        <button
          id="btn-view-feed"
          type="button"
          class="px-4 py-2 rounded-lg text-sm font-bold bg-primary text-on-primary transition-all"
        >
          <span class="material-symbols-outlined text-sm align-middle mr-1" aria-hidden="true">forum</span>
          Feed
        </button>
        <button
          id="btn-view-myposts"
          type="button"
          class="px-4 py-2 rounded-lg text-sm font-bold text-on-surface-variant bg-surface-container-low hover:bg-surface-container transition-all"
        >
          <span class="material-symbols-outlined text-sm align-middle mr-1" aria-hidden="true">person</span>
          Mis Posts
        </button>
      </div>
    </header>

    <!-- Content area -->
    <div class="flex flex-1 gap-6 pt-6 min-h-0">
      <!-- Channel sidebar -->
      <aside id="channels-sidebar" class="w-56 shrink-0 flex flex-col gap-1">
        <p class="text-[10px] font-black text-on-surface-variant uppercase tracking-[0.2em] px-3 mb-2">Canales</p>
        <div id="channels-list" class="space-y-0.5">
          <div class="flex items-center justify-center py-8">
            <span class="material-symbols-outlined text-2xl text-primary animate-spin" aria-hidden="true">schedule</span>
          </div>
        </div>
      </aside>

      <!-- Main content -->
      <div class="flex-1 flex flex-col min-h-0">
        <!-- Feed view -->
        <div id="view-feed" class="flex-1 flex flex-col min-h-0">
          <!-- Channel name -->
          <div class="flex items-center gap-3 mb-4 shrink-0">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">tag</span>
            <h2 id="channel-name" class="text-lg font-bold text-on-surface">general</h2>
          </div>

          <!-- New post action -->
          <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/15 p-4 mb-4 shrink-0">
            <div class="flex justify-end">
              <button
                id="open-new-post-modal"
                type="button"
                class="px-5 py-3 bg-primary text-on-primary rounded-lg font-bold text-sm hover:brightness-110 active:scale-95 transition-all flex items-center gap-1.5"
              >
                <span class="material-symbols-outlined text-sm" aria-hidden="true">add</span>
                Crear post
              </button>
            </div>
          </div>

          <!-- Posts list -->
          <div id="posts-container" class="flex-1 overflow-y-auto space-y-3 pr-1">
            <div class="flex items-center justify-center py-16">
              <div class="text-center space-y-3">
                <span class="material-symbols-outlined text-3xl text-primary animate-spin" aria-hidden="true">schedule</span>
                <p class="text-sm text-on-surface-variant font-medium">Cargando..</p>
              </div>
            </div>
          </div>
        </div>

        <!-- My Posts view (hidden by default) -->
        <div id="view-myposts" class="flex-1 flex flex-col min-h-0 hidden">
          <div class="flex items-center justify-between mb-4 shrink-0">
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary" aria-hidden="true">person</span>
              <h2 class="text-lg font-bold text-on-surface">Mis Posts</h2>
            </div>
            <div class="flex items-center gap-2">
              <label for="myposts-channel-filter" class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">Canal:</label>
              <select
                id="myposts-channel-filter"
                class="bg-surface-container-low border-none rounded-lg px-3 py-2 text-sm font-medium text-on-surface focus:ring-2 focus:ring-primary/20 cursor-pointer"
              >
                <option value="">Todos</option>
              </select>
            </div>
          </div>
          <div id="myposts-container" class="flex-1 overflow-y-auto space-y-4 pr-1">
            <div class="flex items-center justify-center py-16">
              <div class="text-center space-y-3">
                <span class="material-symbols-outlined text-3xl text-primary animate-spin" aria-hidden="true">schedule</span>
                <p class="text-sm text-on-surface-variant font-medium">Cargando..</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Comments Modal -->
  <div id="comments-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="modal-post-author">
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <!-- Card -->
    <div class="relative w-full max-w-lg max-h-[85vh] bg-surface-container rounded-2xl shadow-2xl flex flex-col overflow-hidden border border-outline-variant/15">
      <!-- Header -->
      <div class="shrink-0 px-5 py-4 border-b border-outline-variant/15">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-primary text-base" aria-hidden="true">person</span>
            </div>
            <div class="min-w-0">
              <p id="modal-post-author" class="text-sm font-bold text-on-surface truncate"></p>
              <p id="modal-post-date" class="text-[10px] text-on-surface-variant"></p>
            </div>
          </div>
          <button id="modal-close-btn" class="p-1.5 rounded-lg text-on-surface-variant hover:text-on-surface hover:bg-surface-container-low transition-colors" aria-label="Cerrar">
            <span class="material-symbols-outlined text-xl" aria-hidden="true">close</span>
          </button>
        </div>
        <div id="modal-post-content" class="markdown-content text-sm text-on-surface leading-relaxed mt-3"></div>
      </div>
      <!-- Comments list (scrollable) -->
      <div id="modal-comments-wrapper" class="flex-1 overflow-y-auto px-5 py-3 space-y-2 min-h-0">
        <div id="modal-comments-list" class="space-y-2"></div>
        <div id="modal-load-more-wrapper" class="hidden text-center py-2">
          <button id="modal-load-more-btn" class="text-xs text-primary hover:text-primary/80 font-semibold transition-colors">
            Cargar más comentarios...
          </button>
        </div>
      </div>
    </div>
  </div>

  <EditorModal />
</DashboardLayout>

<script>
  import {
    fetchChannels,
    fetchPosts,
    fetchMyPosts,
    fetchPostComments,
    createPost,
    deletePost,
    updatePostStatus,
    createComment,
    deleteComment,
    type Channel,
    type Post,
    type Comment,
  } from '../../services/communityService';
  import { associateCommunityImages } from '../../services/uploadService';
  import { getUserIdFromToken, getToken } from '../../services/authService';
  import { api } from '../../services/apiClient';
  import { renderMarkdown } from '../../utils/markdown';

  // ─── Auth ─────────────────────────────────────────────────────
  const token = getToken();
  const userId = getUserIdFromToken();
  if (!token) {
    window.location.href = '/login';
  } else {
    api.setHeader('Authorization', `Bearer ${token}`);
  }

  // ─── DOM refs ─────────────────────────────────────────────────
  const channelsList = document.getElementById('channels-list')!;
  const channelNameEl = document.getElementById('channel-name')!;
  const postsContainer = document.getElementById('posts-container')!;
  const mypostsContainer = document.getElementById('myposts-container')!;
  const openNewPostModalButton = document.getElementById('open-new-post-modal') as HTMLButtonElement;
  const btnViewFeed = document.getElementById('btn-view-feed')!;
  const btnViewMyposts = document.getElementById('btn-view-myposts')!;
  const viewFeed = document.getElementById('view-feed')!;
  const viewMyposts = document.getElementById('view-myposts')!;
  const channelsSidebar = document.getElementById('channels-sidebar')!;

  // ─── State ────────────────────────────────────────────────────
  let currentChannel = 'general';
  let channels: Channel[] = [];
  let allMyPosts: Post[] = [];
  let myPostsChannelFilter = '';
  const mypostsChannelSelect = document.getElementById('myposts-channel-filter') as HTMLSelectElement;

  // ─── Helpers ──────────────────────────────────────────────────
  function timeAgo(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'ahora';
    if (mins < 60) return `hace ${mins}m`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `hace ${hrs}h`;
    const days = Math.floor(hrs / 24);
    return `hace ${days}d`;
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // ─── Render channels ─────────────────────────────────────────
  function renderChannels() {
    channelsList.innerHTML = channels.map(ch => {
      const isActive = ch.slug === currentChannel;
      return `
        <button
          data-channel="${ch.slug}"
          class="channel-btn w-full text-left px-3 py-2.5 rounded-lg text-sm font-semibold flex items-center gap-2.5 transition-all ${
            isActive
              ? 'bg-primary/10 text-primary font-bold'
              : 'text-on-surface-variant hover:bg-surface-container-low hover:text-on-surface'
          }"
        >
          <span class="material-symbols-outlined text-base" aria-hidden="true">tag</span>
          ${escapeHtml(ch.name)}
        </button>`;
    }).join('');

    // Bind clicks
    channelsList.querySelectorAll('.channel-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentChannel = (btn as HTMLElement).dataset.channel!;
        renderChannels();
        channelNameEl.textContent = channels.find(c => c.slug === currentChannel)?.name || currentChannel;
        loadPosts();
      });
    });
  }

  // ─── Render feed post ─────────────────────────────────────────
  function renderFeedPost(post: Post): string {
    const isOwner = post.userId === userId;
    const commentCount = post.commentCount ?? 0;
    const authorName = post.user?.profile?.name || post.user?.email || 'Usuario';

    return `
      <article class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 p-4 hover:border-outline-variant/25 transition-all" data-post-id="${post.id}">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-primary text-sm" aria-hidden="true">person</span>
            </div>
            <div>
              <span class="text-sm font-bold text-on-surface">${escapeHtml(authorName)}</span>
              <span class="text-xs text-on-surface-variant ml-2">${timeAgo(post.createdAt)}</span>
            </div>
          </div>
          ${isOwner ? `
            <button class="btn-delete-post text-on-surface-variant hover:text-error text-xs transition-colors p-1" data-post-id="${post.id}" title="Eliminar post">
              <span class="material-symbols-outlined text-base" aria-hidden="true">delete</span>
            </button>` : ''}
        </div>
        <div class="markdown-content text-sm text-on-surface leading-relaxed pl-11">${renderMarkdown(post.content)}</div>
        <div class="pl-11 mt-3 flex items-center gap-4">
          <button class="btn-open-comment-editor text-xs text-on-surface-variant hover:text-primary font-semibold flex items-center gap-1 transition-colors" data-post-id="${post.id}">
            <span class="material-symbols-outlined text-sm" aria-hidden="true">edit</span>
            Comentar
          </button>
          <button class="btn-open-comments text-xs text-on-surface-variant hover:text-primary font-semibold flex items-center gap-1 transition-colors" data-post-id="${post.id}">
            <span class="material-symbols-outlined text-sm" aria-hidden="true">comment</span>
            <span class="comment-count-label">${commentCount} ${commentCount === 1 ? 'comentario' : 'comentarios'}</span>
          </button>
        </div>
      </article>`;
  }

  // ─── Render my post (with count, click opens modal) ────────────
  function renderMyPost(post: Post): string {
    const commentCount = post.commentCount ?? 0;
    const isPaused = post.status === 'paused';
    const statusLabel = isPaused ? 'Pausado' : 'Publicado';
    const statusIcon = isPaused ? 'pause_circle' : 'check_circle';
    const badgeClass = isPaused
      ? 'bg-outline/10 text-outline'
      : 'bg-primary/10 text-primary';
    const cardOpacity = isPaused ? 'opacity-60' : '';

    return `
      <article class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 p-5 transition-all ${cardOpacity}" data-post-id="${post.id}">
        <div class="flex items-start justify-between gap-3 mb-3">
          <div class="flex-1">
            <div class="markdown-content text-sm text-on-surface leading-relaxed font-medium">${renderMarkdown(post.content)}</div>
            <div class="flex items-center gap-2 mt-1.5 flex-wrap">
              <span class="text-xs text-on-surface-variant">${timeAgo(post.createdAt)}</span>
              ${post.channelSlug ? `<span class="text-xs text-on-surface-variant">· #${escapeHtml(post.channelSlug)}</span>` : ''}
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider ${badgeClass}">
                <span class="material-symbols-outlined text-xs" aria-hidden="true">${statusIcon}</span>
                ${statusLabel}
              </span>
            </div>
          </div>
          <div class="flex items-center gap-1 shrink-0">
            <button
              class="btn-toggle-status px-2.5 py-1.5 rounded-lg text-xs font-bold transition-all flex items-center gap-1 ${isPaused ? 'text-primary hover:bg-primary/10' : 'text-outline hover:bg-outline/10'}"
              data-post-id="${post.id}"
              data-current-status="${post.status || 'published'}"
              title="${isPaused ? 'Publicar' : 'Pausar'}"
            >
              <span class="material-symbols-outlined text-sm" aria-hidden="true">${isPaused ? 'play_arrow' : 'pause'}</span>
              ${isPaused ? 'Publicar' : 'Pausar'}
            </button>
            <button class="btn-delete-mypost text-on-surface-variant hover:text-error text-xs transition-colors p-1.5" data-post-id="${post.id}" title="Eliminar post">
              <span class="material-symbols-outlined text-base" aria-hidden="true">delete</span>
            </button>
          </div>
        </div>
        <div class="border-t border-outline-variant/10 pt-3 mt-3">
          <div class="flex items-center gap-4">
            <button class="btn-open-comment-editor text-xs text-on-surface-variant hover:text-primary font-semibold flex items-center gap-1 transition-colors" data-post-id="${post.id}">
              <span class="material-symbols-outlined text-sm" aria-hidden="true">edit</span>
              Comentar
            </button>
            <button class="btn-open-comments text-xs text-on-surface-variant hover:text-primary font-semibold flex items-center gap-1 transition-colors" data-post-id="${post.id}">
              <span class="material-symbols-outlined text-sm" aria-hidden="true">comment</span>
              <span class="comment-count-label">${commentCount} ${commentCount === 1 ? 'comentario recibido' : 'comentarios recibidos'}</span>
            </button>
          </div>
        </div>
      </article>`;
  }

  function openEditorModal(detail: { title: string; placeholder: string; maxlength: number; context: string }) {
    document.dispatchEvent(
      new CustomEvent('open-editor-modal', {
        detail,
      }),
    );
  }

  async function handleEditorSubmit(content: string, imageIds: string[], context: string) {
    if (context === 'post') {
      const newPost = await createPost(content, currentChannel);
      if (imageIds.length > 0) {
        await associateCommunityImages(imageIds, newPost.id, 'POST');
      }
      await loadPosts();
      return;
    }

    if (!context.startsWith('comment-')) {
      return;
    }

    const postId = context.slice('comment-'.length);
    if (!postId) {
      return;
    }

    const newComment = await createComment(postId, content);
    if (imageIds.length > 0) {
      await associateCommunityImages(imageIds, newComment.id, 'COMMENT');
    }

    if (modalPostId === postId) {
      const emptyMsg = modalCommentsList.querySelector('p.italic');
      if (emptyMsg) {
        emptyMsg.remove();
      }

      modalCommentsList.insertAdjacentHTML('afterbegin', renderCommentHtml(newComment));
      bindModalDeleteButtons();
      modalCommentsWrapper.scrollTop = 0;
    }

    updateCommentCountLabel(postId, 1);
  }

  let isSubmittingEditor = false;

  document.addEventListener('editor-modal-submit', async event => {
    if (isSubmittingEditor) return;

    const customEvent = event as CustomEvent<{ content?: string; imageIds?: string[]; context?: string }>;
    const content = customEvent.detail?.content?.trim() || '';
    const imageIds = Array.isArray(customEvent.detail?.imageIds) ? customEvent.detail.imageIds : [];
    const context = customEvent.detail?.context || '';

    if (!content || !context) {
      return;
    }

    isSubmittingEditor = true;
    try {
      await handleEditorSubmit(content, imageIds, context);
    } catch (err) {
      console.error('Error procesando envío del editor modal:', err);
    } finally {
      isSubmittingEditor = false;
    }
  });

  openNewPostModalButton.addEventListener('click', () => {
    openEditorModal({
      title: 'Crear publicación',
      placeholder: '¿Qué querés compartir?',
      maxlength: 5000,
      context: 'post',
    });
  });

  // ─── Render a single comment HTML ──────────────────────────────
  function renderCommentHtml(c: Comment): string {
    const commenterName = c.user?.profile?.name || c.user?.email || 'Usuario';
    return `
      <div class="flex items-start gap-2 bg-surface-container-low rounded-lg p-3" data-comment-id="${c.id}">
        <div class="w-6 h-6 rounded-full bg-secondary/10 flex items-center justify-center shrink-0">
          <span class="material-symbols-outlined text-secondary text-xs" aria-hidden="true">person</span>
        </div>
        <div class="flex-1">
          <div class="flex items-center gap-2">
            <span class="text-xs font-bold text-on-surface">${escapeHtml(commenterName)}</span>
            <span class="text-[10px] text-on-surface-variant">${timeAgo(c.createdAt)}</span>
          </div>
          <div class="markdown-content text-xs text-on-surface-variant mt-0.5">${renderMarkdown(c.content)}</div>
        </div>
        ${c.userId === userId ? `
          <button class="btn-delete-comment text-on-surface-variant hover:text-error transition-colors p-0.5" data-comment-id="${c.id}" title="Eliminar comentario">
            <span class="material-symbols-outlined text-xs" aria-hidden="true">close</span>
          </button>` : ''}
      </div>`;
  }

  // ─── Comments Modal logic ─────────────────────────────────────
  const commentsModal = document.getElementById('comments-modal')!;
  const modalBackdrop = document.getElementById('modal-backdrop')!;
  const modalCloseBtn = document.getElementById('modal-close-btn')!;
  const modalPostAuthor = document.getElementById('modal-post-author')!;
  const modalPostDate = document.getElementById('modal-post-date')!;
  const modalPostContent = document.getElementById('modal-post-content')!;
  const modalCommentsList = document.getElementById('modal-comments-list')!;
  const modalLoadMoreWrapper = document.getElementById('modal-load-more-wrapper')!;
  const modalLoadMoreBtn = document.getElementById('modal-load-more-btn')!;
  const modalCommentsWrapper = document.getElementById('modal-comments-wrapper')!;

  let modalPostId: string | null = null;
  let modalCurrentPage = 1;
  let modalTotalPages = 1;
  let feedPosts: Post[] = [];

  function findPostData(postId: string): Post | undefined {
    return feedPosts.find(p => p.id === postId) || allMyPosts.find(p => p.id === postId);
  }

  async function openCommentsModal(postId: string) {
    modalPostId = postId;
    modalCurrentPage = 1;
    modalTotalPages = 1;

    const post = findPostData(postId);
    const authorName = post?.user?.profile?.name || post?.user?.email || 'Usuario';
    modalPostAuthor.textContent = authorName;
    modalPostDate.textContent = post ? timeAgo(post.createdAt) : '';
    modalPostContent.innerHTML = post?.content ? renderMarkdown(post.content) : '';

    modalCommentsList.innerHTML = `
      <div class="flex items-center justify-center py-6">
        <span class="material-symbols-outlined text-2xl text-primary animate-spin" aria-hidden="true">schedule</span>
      </div>`;
    modalLoadMoreWrapper.classList.add('hidden');

    commentsModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    await loadModalComments(1);
  }

  function closeCommentsModal() {
    commentsModal.classList.add('hidden');
    document.body.style.overflow = '';
    modalPostId = null;
    modalCommentsList.innerHTML = '';
  }

  async function loadModalComments(page: number) {
    if (!modalPostId) return;

    try {
      const result = await fetchPostComments(modalPostId, page, 10);
      const comments = result.data || [];
      const meta = result.meta;
      modalCurrentPage = meta.page;
      modalTotalPages = meta.totalPages;

      if (page === 1) {
        modalCommentsList.innerHTML = '';
      }

      if (page === 1 && comments.length === 0) {
        modalCommentsList.innerHTML = '<p class="text-xs text-on-surface-variant italic text-center py-4">Sin comentarios aún. Sé el primero en comentar.</p>';
      } else {
        comments.forEach(c => {
          modalCommentsList.insertAdjacentHTML('beforeend', renderCommentHtml(c));
        });
        bindModalDeleteButtons();
      }

      // Show/hide load more
      if (meta.page < meta.totalPages) {
        modalLoadMoreWrapper.classList.remove('hidden');
      } else {
        modalLoadMoreWrapper.classList.add('hidden');
      }
    } catch (err) {
      console.error('Error cargando comentarios:', err);
      if (page === 1) {
        modalCommentsList.innerHTML = '<p class="text-xs text-error text-center py-4">Error al cargar comentarios.</p>';
      }
    }
  }

  function bindModalDeleteButtons() {
    modalCommentsList.querySelectorAll('.btn-delete-comment').forEach(btn => {
      if ((btn as HTMLElement).dataset.bound) return;
      (btn as HTMLElement).dataset.bound = 'true';
      btn.addEventListener('click', async () => {
        const commentId = (btn as HTMLElement).dataset.commentId!;
        if (!confirm('¿Eliminar este comentario?')) return;
        try {
          await deleteComment(commentId);
          const el = modalCommentsList.querySelector(`[data-comment-id="${commentId}"]`);
          if (el) el.remove();
          if (modalPostId) updateCommentCountLabel(modalPostId, -1);

          // Check if list is now empty
          if (modalCommentsList.children.length === 0) {
            modalCommentsList.innerHTML = '<p class="text-xs text-on-surface-variant italic text-center py-4">Sin comentarios aún. Sé el primero en comentar.</p>';
          }
        } catch (err) {
          console.error('Error eliminando comentario:', err);
        }
      });
    });
  }

  function updateCommentCountLabel(postId: string, delta: number) {
    // Update in both feed and myposts containers
    document.querySelectorAll(`article[data-post-id="${postId}"] .comment-count-label`).forEach(label => {
      const text = label.textContent || '0';
      const current = parseInt(text) || 0;
      const newCount = Math.max(0, current + delta);
      // Detect if it's a "recibido" label
      const isMyPost = text.includes('recibido');
      if (isMyPost) {
        label.textContent = `${newCount} ${newCount === 1 ? 'comentario recibido' : 'comentarios recibidos'}`;
      } else {
        label.textContent = `${newCount} ${newCount === 1 ? 'comentario' : 'comentarios'}`;
      }
    });
  }

  // Modal event listeners
  modalCloseBtn.addEventListener('click', closeCommentsModal);
  modalBackdrop.addEventListener('click', closeCommentsModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modalPostId) closeCommentsModal();
  });

  modalLoadMoreBtn.addEventListener('click', async () => {
    if (modalCurrentPage < modalTotalPages) {
      await loadModalComments(modalCurrentPage + 1);
    }
  });

  // ─── Load & render posts ──────────────────────────────────────
  async function loadPosts() {
    postsContainer.innerHTML = `
      <div class="flex items-center justify-center py-16">
        <div class="text-center space-y-3">
          <span class="material-symbols-outlined text-3xl text-primary animate-spin" aria-hidden="true">schedule</span>
          <p class="text-sm text-on-surface-variant font-medium">Cargando..</p>
        </div>
      </div>`;

    try {
      const result = await fetchPosts(currentChannel);
      const posts = Array.isArray(result) ? result : (result as any).data || [];
      feedPosts = posts;

      if (posts.length === 0) {
        postsContainer.innerHTML = `
          <div class="text-center py-16">
            <span class="material-symbols-outlined text-4xl text-outline mb-3 block" aria-hidden="true">forum</span>
            <p class="text-on-surface-variant font-medium">No hay posts en este canal todavía.</p>
            <p class="text-on-surface-variant text-sm mt-1">Se el primero en publicar algo.</p>
          </div>`;
        return;
      }

      postsContainer.innerHTML = posts.map(renderFeedPost).join('');
      bindPostActions();
    } catch (err) {
      console.error('Error cargando posts:', err);
      postsContainer.innerHTML = `
        <div class="text-center py-16">
          <span class="material-symbols-outlined text-4xl text-error mb-3 block" aria-hidden="true">error</span>
          <p class="text-on-surface-variant font-medium">Error al cargar los posts.</p>
        </div>`;
    }
  }

  // ─── Load my posts ────────────────────────────────────────────
  async function loadMyPosts() {
    mypostsContainer.innerHTML = `
      <div class="flex items-center justify-center py-16">
        <div class="text-center space-y-3">
          <span class="material-symbols-outlined text-3xl text-primary animate-spin" aria-hidden="true">schedule</span>
          <p class="text-sm text-on-surface-variant font-medium">Cargando..</p>
        </div>
      </div>`;

    try {
      const result = await fetchMyPosts();
      allMyPosts = Array.isArray(result) ? result : (result as any).data || [];
      renderFilteredMyPosts();
    } catch (err) {
      console.error('Error cargando mis posts:', err);
      mypostsContainer.innerHTML = `
        <div class="text-center py-16">
          <span class="material-symbols-outlined text-4xl text-error mb-3 block" aria-hidden="true">error</span>
          <p class="text-on-surface-variant font-medium">Error al cargar tus posts.</p>
        </div>`;
    }
  }

  // ─── Render filtered my posts (client-side channel filter) ────
  function renderFilteredMyPosts() {
    const filtered = myPostsChannelFilter
      ? allMyPosts.filter(p => p.channelSlug === myPostsChannelFilter)
      : allMyPosts;

    if (filtered.length === 0) {
      mypostsContainer.innerHTML = `
        <div class="text-center py-16">
          <span class="material-symbols-outlined text-4xl text-outline mb-3 block" aria-hidden="true">edit_note</span>
          <p class="text-on-surface-variant font-medium">${myPostsChannelFilter ? 'No tenés posts en este canal.' : 'No has publicado nada todavía.'}</p>
        </div>`;
      return;
    }

    mypostsContainer.innerHTML = filtered.map(renderMyPost).join('');
    bindMyPostActions();
  }

  // ─── Channel filter for my posts ──────────────────────────────
  mypostsChannelSelect.addEventListener('change', () => {
    myPostsChannelFilter = mypostsChannelSelect.value;
    renderFilteredMyPosts();
  });

  // ─── Bind actions on feed posts ───────────────────────────────
  function bindPostActions() {
    // Delete post
    postsContainer.querySelectorAll('.btn-delete-post').forEach(btn => {
      btn.addEventListener('click', async () => {
        const postId = (btn as HTMLElement).dataset.postId!;
        if (!confirm('¿Eliminar este post?')) return;
        try {
          await deletePost(postId);
          loadPosts();
        } catch (err) {
          console.error('Error eliminando post:', err);
        }
      });
    });

    postsContainer.querySelectorAll('.btn-open-comment-editor').forEach(btn => {
      btn.addEventListener('click', () => {
        const postId = (btn as HTMLElement).dataset.postId!;
        openEditorModal({
          title: 'Comentar publicación',
          placeholder: 'Escribí tu comentario...',
          maxlength: 500,
          context: `comment-${postId}`,
        });
      });
    });

    // Open comments modal
    postsContainer.querySelectorAll('.btn-open-comments').forEach(btn => {
      btn.addEventListener('click', () => {
        const postId = (btn as HTMLElement).dataset.postId!;
        openCommentsModal(postId);
      });
    });
  }

  // ─── Bind actions on my posts ─────────────────────────────────
  function bindMyPostActions() {
    // Toggle status (published/paused)
    mypostsContainer.querySelectorAll('.btn-toggle-status').forEach(btn => {
      btn.addEventListener('click', async () => {
        const postId = (btn as HTMLElement).dataset.postId!;
        const currentStatus = (btn as HTMLElement).dataset.currentStatus as 'published' | 'paused';
        const newStatus = currentStatus === 'published' ? 'paused' : 'published';

        (btn as HTMLButtonElement).disabled = true;
        try {
          await updatePostStatus(postId, newStatus);
          const post = allMyPosts.find(p => p.id === postId);
          if (post) post.status = newStatus;
          renderFilteredMyPosts();
        } catch (err) {
          console.error('Error cambiando estado del post:', err);
        }
      });
    });

    // Delete post
    mypostsContainer.querySelectorAll('.btn-delete-mypost').forEach(btn => {
      btn.addEventListener('click', async () => {
        const postId = (btn as HTMLElement).dataset.postId!;
        if (!confirm('¿Eliminar este post?')) return;
        try {
          await deletePost(postId);
          allMyPosts = allMyPosts.filter(p => p.id !== postId);
          renderFilteredMyPosts();
        } catch (err) {
          console.error('Error eliminando post:', err);
        }
      });
    });

    mypostsContainer.querySelectorAll('.btn-open-comment-editor').forEach(btn => {
      btn.addEventListener('click', () => {
        const postId = (btn as HTMLElement).dataset.postId!;
        openEditorModal({
          title: 'Comentar publicación',
          placeholder: 'Escribí tu comentario...',
          maxlength: 500,
          context: `comment-${postId}`,
        });
      });
    });

    // Open comments modal
    mypostsContainer.querySelectorAll('.btn-open-comments').forEach(btn => {
      btn.addEventListener('click', () => {
        const postId = (btn as HTMLElement).dataset.postId!;
        openCommentsModal(postId);
      });
    });
  }

  // ─── View toggle ──────────────────────────────────────────────
  btnViewFeed.addEventListener('click', () => {
    viewFeed.classList.remove('hidden');
    viewMyposts.classList.add('hidden');
    channelsSidebar.classList.remove('hidden');
    btnViewFeed.className = 'px-4 py-2 rounded-lg text-sm font-bold bg-primary text-on-primary transition-all';
    btnViewMyposts.className = 'px-4 py-2 rounded-lg text-sm font-bold text-on-surface-variant bg-surface-container-low hover:bg-surface-container transition-all';
  });

  btnViewMyposts.addEventListener('click', () => {
    viewFeed.classList.add('hidden');
    viewMyposts.classList.remove('hidden');
    channelsSidebar.classList.add('hidden');
    btnViewMyposts.className = 'px-4 py-2 rounded-lg text-sm font-bold bg-primary text-on-primary transition-all';
    btnViewFeed.className = 'px-4 py-2 rounded-lg text-sm font-bold text-on-surface-variant bg-surface-container-low hover:bg-surface-container transition-all';
    loadMyPosts();
  });

  // ─── Init ─────────────────────────────────────────────────────
  async function init() {
    try {
      channels = await fetchChannels();
      renderChannels();

      // Populate my-posts channel filter
      channels.forEach(ch => {
        const opt = document.createElement('option');
        opt.value = ch.slug;
        opt.textContent = ch.name;
        mypostsChannelSelect.appendChild(opt);
      });

      // Set initial channel name
      const ch = channels.find(c => c.slug === currentChannel);
      if (ch) channelNameEl.textContent = ch.name;

      loadPosts();
    } catch (err) {
      console.error('Error inicializando comunidad:', err);
      channelsList.innerHTML = `
        <p class="text-xs text-error px-3">Error al cargar canales</p>`;
      postsContainer.innerHTML = `
        <div class="text-center py-16">
          <span class="material-symbols-outlined text-4xl text-error mb-3 block" aria-hidden="true">error</span>
          <p class="text-on-surface-variant font-medium">Error al cargar la comunidad.</p>
        </div>`;
    }
  }

  init();
</script>

