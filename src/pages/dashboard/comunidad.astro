---
  import DashboardLayout from '../../layouts/DashboardLayout.astro';
  import ComunidadPostModal from '../../components/comunidad/ComunidadPostModal.astro';
  import ComunidadMyPosts from '../../components/comunidad/ComunidadMyPosts.astro';
  import ComunidadChannelsSidebar from '../../components/comunidad/ComunidadChannelsSidebar.astro';
  import ComunidadFeed from '../../components/comunidad/ComunidadFeed.astro';
  import ComunidadMessages from '../../components/comunidad/ComunidadMessages.astro';
---

<DashboardLayout title="Comunidad | TRAMA">
  <div class="flex flex-col h-[calc(100vh-6rem)]">
    <!-- Header -->
    <header class="flex items-center justify-between pb-6 border-b border-outline-variant/15 shrink-0">
      <div>
        <h1 class="text-2xl font-extrabold text-on-surface tracking-tight">Comunidad</h1>
        <p class="text-sm text-on-surface-variant font-medium mt-1">Conecta con otros profesionales de la red.</p>
      </div>
      <div class="flex items-center gap-2">
        <button
          id="btn-view-feed"
          type="button"
          class="px-4 py-2 rounded-lg text-sm font-bold bg-primary text-on-primary transition-all"
        >
          <span class="material-symbols-outlined text-sm align-middle mr-1" aria-hidden="true">forum</span>
          Feed
        </button>
        <button
          id="btn-view-myposts"
          type="button"
          class="px-4 py-2 rounded-lg text-sm font-bold text-on-surface-variant bg-surface-container-low hover:bg-surface-container transition-all"
        >
          <span class="material-symbols-outlined text-sm align-middle mr-1" aria-hidden="true">person</span>
          Mis Posts
        </button>
        <button
          id="btn-view-messages"
          type="button"
          class="px-4 py-2 rounded-lg text-sm font-bold text-on-surface-variant bg-surface-container-low hover:bg-surface-container transition-all relative"
        >
          <span class="material-symbols-outlined text-sm align-middle mr-1" aria-hidden="true">chat</span>
          Mensajes
          <span
            id="messages-unread-badge"
            class="hidden absolute -top-1.5 -right-1.5 min-w-5 h-5 px-1 rounded-full bg-accent-magenta text-on-primary text-[10px] leading-5 font-black text-center"
          ></span>
        </button>
      </div>
    </header>

    <!-- Content area -->
    <div class="flex flex-1 gap-6 pt-6 min-h-0">
      <ComunidadChannelsSidebar />

      <!-- Main content -->
      <div class="flex-1 flex flex-col min-h-0">
        <ComunidadFeed />

        <ComunidadMyPosts />

        <ComunidadMessages />
      </div>
    </div>

  </div>

  <ComunidadPostModal />

</DashboardLayout>

<script>
  import { getUserIdFromToken, getToken, restoreSession } from '../../services/authService';
  import { api } from '../../services/apiClient';

  const token = getToken();
  const userId = getUserIdFromToken();

  if (!token) {
    restoreSession();
  }

  const safeToken = getToken();
  const safeUserId = getUserIdFromToken();
  if (!safeToken) {
    window.location.href = '/login';
  } else {
    api.setHeader('Authorization', `Bearer ${safeToken}`);
  }

  const btnViewFeed = document.getElementById('btn-view-feed')!;
  const btnViewMyposts = document.getElementById('btn-view-myposts')!;
  const btnViewMessages = document.getElementById('btn-view-messages')!;
  const viewFeed = document.getElementById('view-feed')!;
  const viewMyposts = document.getElementById('view-myposts')!;
  const viewMessages = document.getElementById('view-messages')!;
  const channelsSidebar = document.getElementById('comunidad-channels-sidebar')!;

  let currentView: 'feed' | 'myposts' | 'messages' = 'feed';

  const ACTIVE_BUTTON_CLASS = 'px-4 py-2 rounded-lg text-sm font-bold bg-primary text-on-primary transition-all relative';
  const INACTIVE_BUTTON_CLASS = 'px-4 py-2 rounded-lg text-sm font-bold text-on-surface-variant bg-surface-container-low hover:bg-surface-container transition-all relative';

  function setActiveView(view: 'feed' | 'myposts' | 'messages') {
    currentView = view;

    const isFeedView = view === 'feed';
    const isMyPostsView = view === 'myposts';
    const isMessagesView = view === 'messages';

    viewFeed.classList.toggle('hidden', !isFeedView);
    viewMyposts.classList.toggle('hidden', !isMyPostsView);
    viewMessages.classList.toggle('hidden', !isMessagesView);
    channelsSidebar.classList.toggle('hidden', isMyPostsView || isMessagesView);

    btnViewFeed.className = isFeedView ? ACTIVE_BUTTON_CLASS : INACTIVE_BUTTON_CLASS;
    btnViewMyposts.className = isMyPostsView ? ACTIVE_BUTTON_CLASS : INACTIVE_BUTTON_CLASS;
    btnViewMessages.className = isMessagesView ? ACTIVE_BUTTON_CLASS : INACTIVE_BUTTON_CLASS;

    document.dispatchEvent(new CustomEvent('comunidad:view-changed', {
      detail: { view: currentView },
    }));

    if (isMyPostsView) {
      document.dispatchEvent(new CustomEvent('comunidad:myposts-open'));
    }
  }

  btnViewFeed.addEventListener('click', () => {
    setActiveView('feed');
    document.dispatchEvent(new CustomEvent('comunidad:tab-activated', {
      detail: { tab: 'feed' },
    }));
  });

  btnViewMyposts.addEventListener('click', () => {
    setActiveView('myposts');
    document.dispatchEvent(new CustomEvent('comunidad:tab-activated', {
      detail: { tab: 'myposts' },
    }));
  });

  btnViewMessages.addEventListener('click', () => {
    setActiveView('messages');
    document.dispatchEvent(new CustomEvent('comunidad:tab-activated', {
      detail: { tab: 'messages' },
    }));
  });

  setActiveView('feed');
  document.dispatchEvent(new CustomEvent('comunidad:profile-loaded', {
    detail: { userId: safeUserId || userId, token: safeToken || token },
  }));
</script>

