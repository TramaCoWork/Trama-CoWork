---
import '../styles/global.css';
import LoginHero from '../components/LoginHero.astro';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Restablecer Contraseña | TRAMA</title>
    <meta name="description" content="Restablecé tu contraseña de TRAMA." />
  </head>
  <body class="bg-surface font-body text-on-surface antialiased overflow-x-hidden">
    <main class="min-h-screen flex flex-col md:flex-row overflow-hidden">
      <LoginHero />

      <section class="w-full md:w-1/2 lg:w-2/5 flex items-center justify-center p-6 sm:p-12 md:p-20 bg-surface relative">
        <!-- Link para volver -->
        <a
          href="/"
          class="absolute top-6 left-6 md:top-8 md:left-8 flex items-center gap-1.5 text-sm font-medium text-on-surface-variant hover:text-primary transition-colors"
        >
          <span class="material-symbols-outlined text-lg" aria-hidden="true">arrow_back</span>
          Volver al inicio
        </a>

        <div class="w-full max-w-md space-y-12">
          <!-- Logo y titulo -->
          <div class="flex flex-col items-center md:items-start space-y-4">
            <span class="font-headline text-3xl font-extrabold tracking-tighter text-primary mb-2">TRAMA</span>
            <div class="space-y-1 text-center md:text-left">
              <h2 class="text-3xl font-bold tracking-tight text-on-surface">Nueva contraseña</h2>
              <p class="text-on-surface-variant text-sm">Ingresá tu nueva contraseña para restablecer el acceso a tu cuenta.</p>
            </div>
          </div>

          <!-- Error: token/params invalidos -->
          <div id="invalid-state" class="hidden space-y-6">
            <div class="flex flex-col items-center text-center space-y-4 py-8">
              <div class="w-16 h-16 rounded-full bg-error/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-3xl text-error">link_off</span>
              </div>
              <h3 class="text-xl font-bold text-on-surface">Enlace inválido</h3>
              <p class="text-on-surface-variant text-sm max-w-sm">
                El enlace de recuperación es inválido o ha expirado. Solicitá uno nuevo.
              </p>
              <a href="/recuperar-contrasena" class="mt-4 inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary font-bold text-sm tracking-widest uppercase rounded-xl hover:opacity-90 transition-all">
                Solicitar nuevo enlace
              </a>
            </div>
          </div>

          <!-- Formulario -->
          <form id="reset-form" class="space-y-8" novalidate>
            <div class="space-y-6">
              <!-- Nueva contraseña -->
              <div class="space-y-2">
                <label class="block text-xs font-bold tracking-widest uppercase text-on-surface-variant" for="reset-password">
                  Nueva contraseña
                </label>
                <div class="group relative">
                  <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-outline">
                    <span class="material-symbols-outlined text-xl" aria-hidden="true">lock</span>
                  </div>
                  <input
                    autocomplete="new-password"
                    class="block w-full pl-12 pr-12 py-4 bg-surface-container-low border border-outline-variant/30 focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all rounded-xl text-on-surface placeholder:text-outline/50"
                    id="reset-password"
                    name="password"
                    placeholder="Mínimo 6 caracteres"
                    required
                    type="password"
                    minlength="6"
                  />
                  <button
                    type="button"
                    class="toggle-password absolute inset-y-0 right-0 pr-4 flex items-center text-outline hover:text-on-surface transition-colors"
                    data-target="reset-password"
                    aria-label="Mostrar contraseña"
                  >
                    <span class="material-symbols-outlined text-xl">visibility</span>
                  </button>
                </div>
              </div>

              <!-- Confirmar contraseña -->
              <div class="space-y-2">
                <label class="block text-xs font-bold tracking-widest uppercase text-on-surface-variant" for="reset-confirm">
                  Confirmar contraseña
                </label>
                <div class="group relative">
                  <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-outline">
                    <span class="material-symbols-outlined text-xl" aria-hidden="true">lock</span>
                  </div>
                  <input
                    autocomplete="new-password"
                    class="block w-full pl-12 pr-12 py-4 bg-surface-container-low border border-outline-variant/30 focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all rounded-xl text-on-surface placeholder:text-outline/50"
                    id="reset-confirm"
                    name="confirmPassword"
                    placeholder="Repetí tu contraseña"
                    required
                    type="password"
                    minlength="6"
                  />
                  <button
                    type="button"
                    class="toggle-password absolute inset-y-0 right-0 pr-4 flex items-center text-outline hover:text-on-surface transition-colors"
                    data-target="reset-confirm"
                    aria-label="Mostrar contraseña"
                  >
                    <span class="material-symbols-outlined text-xl">visibility</span>
                  </button>
                </div>
                <p id="match-error" class="hidden text-xs text-error font-medium mt-1">Las contraseñas no coinciden.</p>
              </div>
            </div>

            <!-- Boton principal -->
            <button
              id="btn-reset"
              class="w-full py-4 px-6 bg-gradient-to-br from-primary to-primary-container text-on-primary font-bold text-sm tracking-widest uppercase rounded-xl shadow-lg hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 group disabled:opacity-50 disabled:cursor-not-allowed"
              type="submit"
            >
              <span id="btn-reset-text">Cambiar contraseña</span>
              <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
            </button>
          </form>

          <!-- Estado de exito (oculto por defecto) -->
          <div id="success-state" class="hidden space-y-6">
            <div class="flex flex-col items-center text-center space-y-4 py-8">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-3xl text-primary">check_circle</span>
              </div>
              <h3 class="text-xl font-bold text-on-surface">Contraseña restablecida</h3>
              <p class="text-on-surface-variant text-sm max-w-sm">
                Tu contraseña fue cambiada exitosamente. Ya podés iniciar sesión con tu nueva contraseña.
              </p>
              <a href="/login" class="mt-4 inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-br from-primary to-primary-container text-on-primary font-bold text-sm tracking-widest uppercase rounded-xl shadow-lg hover:opacity-90 transition-all">
                Iniciar sesión
                <span class="material-symbols-outlined text-lg">arrow_forward</span>
              </a>
            </div>
          </div>

          <!-- Toast de error -->
          <div
            id="reset-toast"
            class="fixed top-6 right-6 z-50 max-w-sm transform translate-x-[120%] transition-transform duration-300 ease-in-out"
            role="alert"
          >
            <div class="flex items-center gap-3 px-5 py-4 bg-error-container text-on-error-container rounded-xl shadow-2xl border border-error/20">
              <span class="material-symbols-outlined text-error text-2xl shrink-0" aria-hidden="true">error</span>
              <div>
                <p class="font-bold text-sm">No se pudo cambiar la contraseña</p>
                <p id="reset-toast-message" class="text-xs opacity-80 mt-0.5">El enlace es inválido o ha expirado.</p>
              </div>
              <button
                id="reset-toast-close"
                type="button"
                class="ml-2 shrink-0 text-on-error-container/60 hover:text-on-error-container transition-colors"
                aria-label="Cerrar"
              >
                <span class="material-symbols-outlined text-lg">close</span>
              </button>
            </div>
          </div>

          <!-- Link a login -->
          <div class="pt-4">
            <p class="text-center text-sm text-on-surface-variant">
              <a class="font-bold text-secondary hover:underline" href="/login">Volver a iniciar sesión</a>
            </p>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<script>
  import { resetPassword } from '../services/authService';

  // Read URL params
  const params = new URLSearchParams(window.location.search);
  const userId = params.get('userId');
  const token = params.get('token');

  const form = document.getElementById('reset-form') as HTMLFormElement | null;
  const invalidState = document.getElementById('invalid-state');
  const successState = document.getElementById('success-state');
  const btn = document.getElementById('btn-reset') as HTMLButtonElement | null;
  const btnText = document.getElementById('btn-reset-text');
  const matchError = document.getElementById('match-error');
  const toast = document.getElementById('reset-toast');
  const toastMessage = document.getElementById('reset-toast-message');
  const toastClose = document.getElementById('reset-toast-close');

  let toastTimeout: ReturnType<typeof setTimeout>;

  // If no userId or token, show invalid state
  if (!userId || !token) {
    form?.classList.add('hidden');
    invalidState?.classList.remove('hidden');
  }

  // Toggle password visibility
  document.querySelectorAll('.toggle-password').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.target;
      if (!targetId) return;
      const input = document.getElementById(targetId) as HTMLInputElement | null;
      if (!input) return;
      const icon = btn.querySelector('.material-symbols-outlined');
      if (input.type === 'password') {
        input.type = 'text';
        if (icon) icon.textContent = 'visibility_off';
      } else {
        input.type = 'password';
        if (icon) icon.textContent = 'visibility';
      }
    });
  });

  function showToast(message: string) {
    if (toastMessage) toastMessage.textContent = message;
    toast?.classList.remove('translate-x-[120%]');
    toast?.classList.add('translate-x-0');
    clearTimeout(toastTimeout);
    toastTimeout = setTimeout(hideToast, 5000);
  }

  function hideToast() {
    toast?.classList.remove('translate-x-0');
    toast?.classList.add('translate-x-[120%]');
  }

  toastClose?.addEventListener('click', hideToast);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!userId || !token) return;

    const formData = new FormData(form);
    const password = (formData.get('password') as string) || '';
    const confirmPassword = (formData.get('confirmPassword') as string) || '';

    // Validate
    if (password.length < 6) {
      showToast('La contraseña debe tener al menos 6 caracteres.');
      return;
    }

    if (password !== confirmPassword) {
      matchError?.classList.remove('hidden');
      return;
    }
    matchError?.classList.add('hidden');

    if (btn) btn.disabled = true;
    if (btnText) btnText.textContent = 'Cambiando...';

    try {
      await resetPassword(userId, token, password);
      // Hide form, show success
      form.classList.add('hidden');
      successState?.classList.remove('hidden');
    } catch (err: any) {
      const message = err?.body?.message || err?.body?.error || 'El enlace es inválido o ha expirado.';
      showToast(message);
    } finally {
      if (btn) btn.disabled = false;
      if (btnText) btnText.textContent = 'Cambiar contraseña';
    }
  });
</script>
