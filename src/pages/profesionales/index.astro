---
import Layout from '../../layouts/Layout.astro';
import SearchHeader from '../../components/SearchHeader.astro';
---

<Layout title="Profesionales | TRAMA" description="Explora profesionales verificados en diseno, arquitectura y tecnologia.">
  <SearchHeader />

  <section class="max-w-5xl mx-auto px-6 py-12 space-y-6">
    <!-- Contador de resultados -->
    <p id="pro-count" class="text-sm text-on-surface-variant font-medium"></p>

    <!-- Loading -->
    <div id="pro-loading" class="flex items-center justify-center py-16">
      <div class="text-center space-y-4">
        <span class="material-symbols-outlined text-primary text-5xl animate-spin">progress_activity</span>
        <p class="text-on-surface-variant font-medium">Cargando profesionales...</p>
      </div>
    </div>

    <!-- Error -->
    <div id="pro-error" class="hidden flex items-center justify-center py-16">
      <div class="text-center space-y-4">
        <span class="material-symbols-outlined text-error text-5xl">error</span>
        <p class="text-on-surface-variant font-medium text-lg">No se pudieron cargar los profesionales</p>
      </div>
    </div>

    <!-- Lista de resultados -->
    <div id="pro-list" class="space-y-6"></div>

    <!-- Paginación -->
    <div id="pro-pagination"></div>
  </section>
</Layout>

<script>
  import { renderProfessionalsList } from '../../services/professionalsService';

  renderProfessionalsList('pro-list', 'pro-count', 'pro-pagination', 'pro-loading', 'pro-error');
</script>
