---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Perfil Profesional | TRAMA" description="Perfil de profesional en TRAMA.">
  <!-- Loading state -->
  <div id="profile-loading" class="flex items-center justify-center py-32">
    <div class="text-center space-y-4">
      <span class="material-symbols-outlined text-primary text-5xl animate-spin">progress_activity</span>
      <p class="text-on-surface-variant font-medium">Cargando perfil...</p>
    </div>
  </div>

  <!-- Error state -->
  <div id="profile-error" class="hidden flex items-center justify-center py-32">
    <div class="text-center space-y-4">
      <span class="material-symbols-outlined text-error text-5xl">error</span>
      <p class="text-on-surface-variant font-medium text-lg">Profesional no encontrado</p>
      <a href="/profesionales" class="inline-block px-6 py-3 bg-primary text-on-primary rounded-lg font-bold hover:opacity-90 transition-all">
        Ver todos los profesionales
      </a>
    </div>
  </div>

  <!-- Profile content (hidden until loaded) -->
  <div id="profile-content" class="hidden">
    <!-- Hero -->
    <section class="w-full px-8 py-16 bg-surface-container-low">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-12 items-end">
        <div class="relative group">
          <div class="w-64 h-80 rounded-xl overflow-hidden shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]">
            <img id="pro-image" alt="" class="w-full h-full object-cover" src="" loading="eager" />
          </div>
          <div id="pro-badge" class="hidden absolute -bottom-4 -right-4 bg-secondary-container text-on-secondary-container px-4 py-1 rounded-full text-xs font-bold tracking-widest uppercase font-label shadow-lg">
            Expert
          </div>
        </div>
        <div class="flex-grow space-y-4">
          <div id="pro-category-badge" class="inline-flex items-center gap-2 px-3 py-1 bg-secondary-fixed text-on-secondary-fixed-variant rounded-full text-xs font-bold uppercase tracking-wider font-label"></div>
          <h1 id="pro-name" class="text-5xl md:text-6xl font-extrabold tracking-tighter text-on-surface font-headline leading-tight"></h1>
          <div class="flex items-center gap-2">
            <div id="pro-stars" class="flex items-center gap-0.5"></div>
            <span id="pro-rating-text" class="text-sm font-bold text-on-surface-variant"></span>
          </div>
          <p id="pro-bio-hero" class="text-lg text-on-surface-variant max-w-2xl font-light"></p>
          <div class="flex gap-4 pt-4">
            <button
              id="open-contact-modal"
              type="button"
              class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-8 py-3 rounded-lg font-bold shadow-lg active:opacity-80 transition-all hover:shadow-xl"
            >
              Contactar
            </button>
            <button class="bg-surface-container-highest text-on-surface px-8 py-3 rounded-lg font-bold transition-all hover:bg-surface-variant/30" type="button">
              Compartir perfil
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Content grid -->
    <section class="max-w-7xl mx-auto px-8 mt-16 mb-24 grid grid-cols-1 md:grid-cols-12 gap-8">
      <!-- Sidebar -->
      <aside class="md:col-span-4 space-y-8">
        <div class="bg-surface-container-lowest p-8 rounded-xl shadow-sm border border-outline-variant/10">
          <h3 class="text-xs font-bold uppercase tracking-widest text-secondary mb-6 font-label">Informacion</h3>
          <div id="pro-info" class="space-y-6"></div>
        </div>
        <div id="pro-competencies-section" class="hidden bg-surface-container-low p-8 rounded-xl">
          <h3 class="text-xs font-bold uppercase tracking-widest text-on-surface mb-6 font-label">Competencias</h3>
          <div id="pro-competencies" class="flex flex-wrap gap-2"></div>
        </div>
      </aside>

      <!-- Main content -->
      <div class="md:col-span-8 space-y-12">
        <section id="pro-bio-section" class="hidden space-y-4">
          <h2 class="text-3xl font-bold tracking-tight font-headline">Sobre mi</h2>
          <p id="pro-bio-full" class="text-on-surface-variant leading-relaxed text-lg"></p>
        </section>
        <section id="pro-services-section" class="hidden space-y-6">
          <h2 class="text-3xl font-bold tracking-tight font-headline">Servicios</h2>
          <div id="pro-services" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div>
        </section>
        <section id="pro-portfolio-section" class="hidden space-y-8">
          <h2 class="text-3xl font-bold tracking-tight font-headline">Portafolio</h2>
          <div id="pro-portfolio" class="grid grid-cols-2 gap-6"></div>
        </section>
      </div>
    </section>
  </div>

  <div
    id="contact-modal"
    class="fixed inset-0 z-[90] hidden items-center justify-center bg-black/50 backdrop-blur-sm px-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="contact-modal-title"
  >
    <div class="w-full max-w-2xl rounded-2xl bg-surface-container-lowest shadow-2xl border border-outline-variant/20">
      <div class="flex items-center justify-between border-b border-outline-variant/20 px-6 py-4">
        <h2 id="contact-modal-title" class="text-xl font-bold text-on-surface">Contactar profesional</h2>
        <button
          id="close-contact-modal-icon"
          type="button"
          class="rounded-lg p-1 text-on-surface-variant hover:bg-surface-container-high transition-colors"
          aria-label="Cerrar modal"
        >
          <span class="material-symbols-outlined" aria-hidden="true">close</span>
        </button>
      </div>

      <div class="px-6 py-5">
        <div id="contact-modal-success" class="hidden mb-4 rounded-xl bg-primary-container px-4 py-3 text-sm font-semibold text-on-primary-container"></div>
        <div id="contact-modal-error" class="hidden mb-4 rounded-xl bg-error-container px-4 py-3 text-sm font-semibold text-on-error-container"></div>

        <form id="contact-modal-form" class="space-y-4" novalidate>
          <div>
            <label for="contact-modal-email" class="mb-1.5 block text-sm font-semibold text-on-surface">Email *</label>
            <input
              id="contact-modal-email"
              name="email"
              type="email"
              required
              class="w-full rounded-xl border border-outline-variant bg-surface-container-low px-4 py-3 text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/40"
              placeholder="tu@email.com"
            />
          </div>

          <div>
            <label for="contact-modal-message" class="mb-1.5 block text-sm font-semibold text-on-surface">Mensaje * <span class="text-outline font-medium">(mínimo 10 caracteres)</span></label>
            <textarea
              id="contact-modal-message"
              name="message"
              required
              minlength="10"
              rows="5"
              class="w-full resize-none rounded-xl border border-outline-variant bg-surface-container-low px-4 py-3 text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/40"
              placeholder="Escribí tu mensaje para este profesional..."
            ></textarea>
          </div>

          <div
            class="cf-turnstile"
            data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}
            data-theme="light"
          ></div>

          <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
            <button
              id="close-contact-modal"
              type="button"
              class="rounded-xl border border-outline-variant bg-surface-container-low px-5 py-2.5 text-sm font-bold text-on-surface transition-colors hover:bg-surface-container-high"
            >
              Cerrar
            </button>
            <button
              id="submit-contact-modal"
              type="submit"
              class="rounded-xl bg-primary px-5 py-2.5 text-sm font-bold text-on-primary transition-all hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50"
            >
              Enviar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script
  is:inline
  src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  async
  defer></script>

<script>
  import { api } from '../../services/apiClient';
  const API_BASE = (import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:3000').replace(/\/+$/, '');

  const DEFAULT_AVATAR = '/images/default-avatar.svg';
  const isDev = import.meta.env.DEV;

  const contactModal = document.getElementById('contact-modal') as HTMLDivElement;
  const openContactModalBtn = document.getElementById('open-contact-modal') as HTMLButtonElement;
  const closeContactModalBtn = document.getElementById('close-contact-modal') as HTMLButtonElement;
  const closeContactModalIconBtn = document.getElementById('close-contact-modal-icon') as HTMLButtonElement;
  const contactModalForm = document.getElementById('contact-modal-form') as HTMLFormElement;
  const submitContactModalBtn = document.getElementById('submit-contact-modal') as HTMLButtonElement;
  const contactModalEmail = document.getElementById('contact-modal-email') as HTMLInputElement;
  const contactModalMessage = document.getElementById('contact-modal-message') as HTMLTextAreaElement;
  const contactModalSuccess = document.getElementById('contact-modal-success') as HTMLDivElement;
  const contactModalError = document.getElementById('contact-modal-error') as HTMLDivElement;

interface ProfessionalData {
    id: number;
    userId: string;
    name: string;
    bio: string;
    photo: string;
    services: string[];
    priceMin: number;
    priceMax: number;
    city: string;
    whatsapp: string;
    emailContact: string;
    professionCategories: { name: string }[];
  categories: { id: number; slug: string; name: string }[];
}

  function openContactModal() {
    hideContactModalMessages();
    contactModal.classList.remove('hidden');
    contactModal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeContactModal() {
    contactModal.classList.add('hidden');
    contactModal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function hideContactModalMessages() {
    contactModalSuccess.classList.add('hidden');
    contactModalError.classList.add('hidden');
  }

  function showContactModalError(message: string) {
    contactModalSuccess.classList.add('hidden');
    contactModalError.textContent = message;
    contactModalError.classList.remove('hidden');
  }

  function showContactModalSuccess(message: string) {
    contactModalError.classList.add('hidden');
    contactModalSuccess.textContent = message;
    contactModalSuccess.classList.remove('hidden');
  }

  function getProfessionalIdFromQuery(): string | null {
    const params = new URLSearchParams(window.location.search);
    return params.get('id');
  }

  function getTurnstileToken(): string | null {
    if (isDev) {
      return 'dev-mode-bypass';
    }

    return (window as any).turnstile?.getResponse() || null;
  }

  function resetTurnstile() {
    if (!isDev) {
      (window as any).turnstile?.reset();
    }
  }

  function setSubmitLoading(isLoading: boolean) {
    submitContactModalBtn.disabled = isLoading;
    submitContactModalBtn.textContent = isLoading ? 'Enviando...' : 'Enviar';
  }

  async function submitContactForm(event: SubmitEvent) {
    event.preventDefault();
    hideContactModalMessages();

    const professionalId = getProfessionalIdFromQuery();
    const email = contactModalEmail.value.trim();
    const message = contactModalMessage.value.trim();

    if (!professionalId) {
      showContactModalError('No se pudo identificar al profesional.');
      return;
    }

    if (!email || !message) {
      showContactModalError('Completá todos los campos obligatorios.');
      return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      showContactModalError('Ingresá un email válido.');
      return;
    }

    if (message.length < 10) {
      showContactModalError('El mensaje debe tener al menos 10 caracteres.');
      return;
    }

    const turnstileToken = getTurnstileToken();
    if (!turnstileToken) {
      showContactModalError('Por favor, completá la verificación de seguridad.');
      return;
    }

    setSubmitLoading(true);

    try {
      await api.post('/contact/professional', { email, message, professionalId, turnstileToken });
      showContactModalSuccess('¡Mensaje enviado exitosamente!');
      contactModalForm.reset();
      resetTurnstile();
    } catch (error: any) {
      if (error?.status === 400) {
        showContactModalError('Captcha inválido. Intentá nuevamente.');
      } else if (error?.status === 404) {
        showContactModalError('Profesional no encontrado.');
      } else {
        showContactModalError(error?.body?.message || 'Error al enviar el mensaje. Intentá nuevamente.');
      }
      resetTurnstile();
    } finally {
      setSubmitLoading(false);
    }
  }

  function setupContactModalEvents() {
    openContactModalBtn.addEventListener('click', openContactModal);
    closeContactModalBtn.addEventListener('click', closeContactModal);
    closeContactModalIconBtn.addEventListener('click', closeContactModal);
    contactModalForm.addEventListener('submit', submitContactForm);

    contactModal.addEventListener('click', (event) => {
      if (event.target === contactModal) {
        closeContactModal();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !contactModal.classList.contains('hidden')) {
        closeContactModal();
      }
    });
  }

  function sanitizeWhatsappNumber(value: string): string {
    return value.replace(/\D/g, '');
  }

  function upsertMetaTag(selector: string, attributeName: string, attributeValue: string, content: string) {
    let tag = document.querySelector(selector) as HTMLMetaElement | null;

    if (!tag) {
      tag = document.createElement('meta');
      tag.setAttribute(attributeName, attributeValue);
      document.head.appendChild(tag);
    }

    tag.setAttribute('content', content);
  }

  async function loadProfile() {
    const params = new URLSearchParams(window.location.search);
    const id = params.get('id');

    if (!id) {
      showError();
      return;
    }

    try {
      const pro = await api.get<ProfessionalData>(`/professionals/${id}`);

      // SEO
      const professionalCategory = pro.rubro?.name || pro.categories?.[0]?.name || 'Profesional';
      const pageTitle = `${pro.name} — ${professionalCategory} | TRAMA`;
      const description = (pro.bio || '').trim().slice(0, 160);

      document.title = pageTitle;
      upsertMetaTag('meta[name="description"]', 'name', 'description', description);
      upsertMetaTag('meta[property="og:title"]', 'property', 'og:title', pageTitle);
      upsertMetaTag('meta[property="og:description"]', 'property', 'og:description', description);
      upsertMetaTag('meta[property="og:image"]', 'property', 'og:image', `${API_BASE}/uploads/photo/${pro.id}`);
      upsertMetaTag('meta[property="og:url"]', 'property', 'og:url', window.location.href);

      // Hero image
      const img = document.getElementById('pro-image') as HTMLImageElement;
      const photoUrl = `${API_BASE}/uploads/photo/${pro.id}`;
      img.src = photoUrl;
      img.onerror = () => { img.onerror = null; img.src = DEFAULT_AVATAR; };
      img.alt = `Foto de perfil de ${pro.name}`;

      // Name & category badge
      document.getElementById('pro-name')!.textContent = pro.name;

      const categoryBadge = document.getElementById('pro-category-badge')!;
      if (pro.categories?.length) {
        categoryBadge.textContent = pro.categories[0].name;
      } else {
        categoryBadge.classList.add('hidden');
      }

      // Bio hero
      document.getElementById('pro-bio-hero')!.textContent = pro.bio || '';

      // Hide stars/rating (API doesn't provide these)
      document.getElementById('pro-stars')!.classList.add('hidden');
      document.getElementById('pro-rating-text')!.classList.add('hidden');

      // Sidebar info
      const infoItems: string[] = [];

      if (pro.city) {
        infoItems.push(`
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">location_on</span>
            <div><p class="text-sm font-bold">Ubicación</p><p class="text-on-surface-variant text-sm">${pro.city}</p></div>
          </div>
        `);
      }

      if (pro.priceMin != null || pro.priceMax != null) {
        const priceText = pro.priceMin != null && pro.priceMax != null
          ? `$${pro.priceMin} - $${pro.priceMax}`
          : pro.priceMin != null ? `Desde $${pro.priceMin}` : `Hasta $${pro.priceMax}`;
        infoItems.push(`
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">payments</span>
            <div><p class="text-sm font-bold">Rango de precios</p><p class="text-on-surface-variant text-sm">${priceText}</p></div>
          </div>
        `);
      }

      if (pro.professionCategories?.length > 0) {
        const professionTags = pro.professionCategories
          .map((cat) =>
            `<span class="badge badge-soft-primary">${cat.name}</span>`
          )
          .join('');

        infoItems.push(`
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">category</span>
            <div>
              <p class="text-sm font-bold">Especialidades</p>
              <div class="mt-1 flex flex-wrap gap-2">${professionTags}</div>
            </div>
          </div>
        `);
      }

      if (pro.whatsapp) {
        const sanitizedWhatsapp = sanitizeWhatsappNumber(pro.whatsapp);
        const whatsappMessage = encodeURIComponent('Desde Tramacowork.com nos estamos conectando...');
        const whatsappUrl = `https://wa.me/${sanitizedWhatsapp}?text=${whatsappMessage}`;

        if (sanitizedWhatsapp) {
        infoItems.push(`
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">chat</span>
            <div class="min-w-0">
              <p class="text-sm font-bold">WhatsApp</p>
              <a href="${whatsappUrl}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center mt-1 rounded-lg px-3 py-2 text-sm font-semibold text-white bg-primary hover:opacity-90 transition-opacity">
                Contactar por WhatsApp
              </a>
            </div>
          </div>
        `);
        }
      }

      if (pro.emailContact) {
        infoItems.push(`
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">mail</span>
            <div><p class="text-sm font-bold">Email</p><p class="text-on-surface-variant text-sm">${pro.emailContact}</p></div>
          </div>
        `);
      }

      document.getElementById('pro-info')!.innerHTML = infoItems.join('');

      // Categories as competencies
      if (pro.categories?.length) {
        const styles = [
          'bg-primary-fixed text-on-primary-fixed-variant',
          'bg-secondary-fixed text-on-secondary-fixed-variant',
          'bg-tertiary-fixed text-on-tertiary-fixed-variant',
          'bg-surface-container-highest text-on-surface-variant',
        ];
        document.getElementById('pro-competencies')!.innerHTML = pro.categories.map((c, i) =>
          `<span class="px-4 py-2 rounded-full text-xs font-medium ${styles[i % styles.length]}">${c.name}</span>`
        ).join('');
        document.getElementById('pro-competencies-section')!.classList.remove('hidden');
      }

      // Bio
      if (pro.bio) {
        document.getElementById('pro-bio-full')!.textContent = pro.bio;
        document.getElementById('pro-bio-section')!.classList.remove('hidden');
      }

      // Services (array of strings)
      if (pro.services?.length) {
        const serviceIcons = ['design_services', 'architecture', 'engineering', 'construction', 'brush', 'draw'];
        document.getElementById('pro-services')!.innerHTML = pro.services.map((s, i) => `
          <div class="p-6 bg-surface-container-lowest rounded-xl border border-outline-variant/10 hover:shadow-md transition-shadow">
            <span class="material-symbols-outlined text-tertiary mb-4 text-3xl" aria-hidden="true">${serviceIcons[i % serviceIcons.length]}</span>
            <h4 class="font-bold text-lg">${s}</h4>
          </div>
        `).join('');
        document.getElementById('pro-services-section')!.classList.remove('hidden');
      }

      // Show content, hide loading
      document.getElementById('profile-loading')!.classList.add('hidden');
      document.getElementById('profile-content')!.classList.remove('hidden');

    } catch (err) {
      console.error('Error cargando perfil:', err);
      showError();
    }
  }

  function showError() {
    document.getElementById('profile-loading')!.classList.add('hidden');
    document.getElementById('profile-error')!.classList.remove('hidden');
  }

  setupContactModalEvents();
  loadProfile();
</script>
