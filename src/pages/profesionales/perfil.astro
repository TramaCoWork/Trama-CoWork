---
import { buildProfileSlug } from '../../utils/helpers';

const id = Astro.url.searchParams.get('id');

if (!id) {
  return Astro.redirect('/profesionales');
}

const apiBase = (import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:3000').replace(/\/+$/, '');

try {
  const res = await fetch(`${apiBase}/professionals/${id}`);
  if (!res.ok) return Astro.redirect('/profesionales');

  const pro = await res.json();
  if (!pro || !pro.publicId) return Astro.redirect('/profesionales');

  const slug = buildProfileSlug(pro.name, pro.publicId);
  return Astro.redirect(`/profesionales/${slug}`, 301);
} catch {
  return Astro.redirect('/profesionales');
}
---
