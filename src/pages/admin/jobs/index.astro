---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ConfirmModal from '../../../components/ConfirmModal.astro';
---

<AdminLayout title="TRAMA Admin - Jobs">
  <header class="mb-8">
    <h1 class="text-3xl font-black text-on-surface tracking-tighter">Jobs</h1>
    <p class="text-on-surface-variant font-medium mt-1 text-sm">Ejecuciones de tareas programadas.</p>
  </header>

  <div class="mb-6 border-b border-outline-variant/20">
    <div class="flex items-center gap-6">
      <button
        id="tab-ejecuciones"
        type="button"
        data-tab="ejecuciones"
        class="border-b-2 border-primary px-1 py-3 text-sm font-bold text-primary transition-colors"
      >
        Ejecuciones
      </button>
      <button
        id="tab-configuracion"
        type="button"
        data-tab="configuracion"
        class="border-b-2 border-transparent px-1 py-3 text-sm font-medium text-on-surface-variant transition-colors"
      >
        Configuración
      </button>
    </div>
  </div>

  <section id="panel-ejecuciones">
    <section class="bg-surface-container-low rounded-2xl border border-outline-variant/10 p-6 mb-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:gap-4">
        <div class="w-full md:max-w-sm">
          <label for="f-job-name" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">
            Job
          </label>
          <select
            id="f-job-name"
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer"
          >
            <option value="">Todos los jobs</option>
          </select>
        </div>
        <div class="flex flex-col gap-1">
          <button
            id="run-selected-job"
            type="button"
            class="inline-flex items-center gap-1 px-4 py-2.5 rounded-xl text-xs font-bold uppercase tracking-wider bg-primary text-on-primary hover:opacity-90 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <span class="material-symbols-outlined text-sm" aria-hidden="true">play_arrow</span>
            Ejecutar
          </button>
          <p id="job-run-inline-hint" class="hidden text-xs font-semibold text-error" aria-live="polite"></p>
        </div>
      </div>
    </section>

    <div class="flex items-center justify-between mb-4 gap-3 flex-wrap">
      <p id="results-info" class="text-sm text-on-surface-variant font-medium">Cargando...</p>
      <div id="pagination" class="flex items-center gap-2"></div>
    </div>
    <p id="job-run-status" class="mb-4 hidden text-sm font-semibold" aria-live="polite"></p>

    <section class="bg-surface-container-low rounded-2xl overflow-hidden border border-outline-variant/10">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-outline-variant/15 bg-surface-container">
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Job</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Inicio</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Duración</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Estado</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Procesados</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Error</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Acciones</th>
            </tr>
          </thead>
          <tbody id="jobs-table-body">
            <tr>
              <td colspan="7" class="text-center py-12 text-on-surface-variant">
                <div class="flex flex-col items-center gap-3">
                  <div class="w-8 h-8 border-3 border-primary/30 border-t-primary rounded-full animate-spin"></div>
                  <span class="text-sm font-medium">Cargando jobs...</span>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <div
      id="job-error-modal"
      class="fixed inset-0 z-[90] hidden items-center justify-center bg-black/30 backdrop-blur-sm p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="job-error-title"
    >
      <div class="w-full max-w-3xl rounded-2xl bg-surface-container-low border border-outline-variant/15 shadow-2xl">
        <div class="flex items-center justify-between border-b border-outline-variant/15 px-6 py-4">
          <h2 id="job-error-title" class="text-lg font-extrabold text-on-surface tracking-tight">Detalle de error</h2>
          <button id="job-error-close" type="button" class="text-on-surface-variant hover:text-on-surface" aria-label="Cerrar">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>

        <div class="p-6 space-y-3">
          <p id="job-error-name" class="text-sm font-bold text-on-surface"></p>
          <pre id="job-error-content" class="max-h-[50vh] overflow-auto rounded-xl bg-surface-container-lowest border border-outline-variant/20 p-4 text-xs text-on-surface-variant whitespace-pre-wrap"></pre>
        </div>
      </div>
    </div>
  </section>

  <section id="panel-configuracion" class="hidden">
    <section class="bg-surface-container-low rounded-2xl overflow-hidden border border-outline-variant/10">
      <div id="config-loading" class="p-6">
        <div class="space-y-3 animate-pulse">
          <div class="h-12 rounded-xl bg-surface-container-high"></div>
          <div class="h-12 rounded-xl bg-surface-container-high"></div>
          <div class="h-12 rounded-xl bg-surface-container-high"></div>
        </div>
      </div>

      <div id="config-error" class="hidden px-6 py-12 text-center">
        <span class="material-symbols-outlined text-3xl mb-2 block text-error" aria-hidden="true">error</span>
        <p id="config-error-message" class="text-sm font-bold text-error mb-4">Error al cargar la configuración</p>
        <button
          id="config-retry-button"
          type="button"
          class="inline-flex items-center gap-1 rounded-lg bg-surface-container px-3 py-2 text-xs font-bold uppercase tracking-wider text-on-surface-variant hover:bg-surface-container-high transition-colors"
        >
          Reintentar
        </button>
      </div>

      <div id="config-empty" class="hidden px-6 py-16 text-center text-on-surface-variant">
        <p class="text-sm font-medium">No hay jobs configurados</p>
      </div>

      <div id="config-table-container" class="hidden overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-outline-variant/15 bg-surface-container">
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Job</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Schedule</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Activo</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">En memoria</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Próxima ejecución</th>
              <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Acciones</th>
            </tr>
          </thead>
          <tbody id="config-table-body"></tbody>
        </table>
      </div>
    </section>
  </section>

  <ConfirmModal />

  <script>
    import { isAdmin, isAuthenticated, restoreSession } from '../../../services/authService';
    import {
      listCronJobs,
      listJobExecutions,
      listRunningJobs,
      restartJob,
      runJob,
      updateCronJob,
    } from '../../../services/cronJobsService';

    type JobStatus = 'running' | 'completed' | 'failed';
    type TabKey = 'ejecuciones' | 'configuracion';

    type JobExecution = {
      jobName: string;
      startedAt: string | null;
      durationMs: number | null;
      status: JobStatus;
      processedCount: number | null;
      errorMessage: string | null;
      errorStack: string | null;
    };

    type JobMetadata = {
      key: string;
      name: string;
      schedule: string | null;
      active: boolean;
    };

    type JobsResponse = {
      data: JobExecution[];
      total: number;
      page: number;
      sizePage: number;
    };

    type CronJob = {
      id: string;
      key: string;
      name: string;
      schedule: string | null;
      active: boolean;
    };

    type EnrichedCronJob = CronJob & {
      isRunning: boolean;
      nextRun: string | null;
      needsRestart: boolean;
    };

    const PAGE_SIZE = 20;
    let currentPage = 1;
    let totalPages = 1;
    let currentJobFilter = '';
    let isLoading = false;
    let configLoaded = false;
    let isConfigLoading = false;
    let editingCellKey = '';

    const executionsTabButton = document.getElementById('tab-ejecuciones') as HTMLButtonElement;
    const configTabButton = document.getElementById('tab-configuracion') as HTMLButtonElement;
    const executionsPanel = document.getElementById('panel-ejecuciones') as HTMLElement;
    const configPanel = document.getElementById('panel-configuracion') as HTMLElement;

    const tableBody = document.getElementById('jobs-table-body') as HTMLTableSectionElement;
    const pagination = document.getElementById('pagination') as HTMLDivElement;
    const resultsInfo = document.getElementById('results-info') as HTMLParagraphElement;
    const jobFilter = document.getElementById('f-job-name') as HTMLSelectElement;
    const errorModal = document.getElementById('job-error-modal') as HTMLDivElement;
    const errorName = document.getElementById('job-error-name') as HTMLParagraphElement;
    const errorContent = document.getElementById('job-error-content') as HTMLPreElement;
    const runSelectedJobButton = document.getElementById('run-selected-job') as HTMLButtonElement;
    const jobRunInlineHint = document.getElementById('job-run-inline-hint') as HTMLParagraphElement;
    const jobRunStatus = document.getElementById('job-run-status') as HTMLParagraphElement;

    const configLoading = document.getElementById('config-loading') as HTMLDivElement;
    const configError = document.getElementById('config-error') as HTMLDivElement;
    const configErrorMessage = document.getElementById('config-error-message') as HTMLParagraphElement;
    const configRetryButton = document.getElementById('config-retry-button') as HTMLButtonElement;
    const configEmpty = document.getElementById('config-empty') as HTMLDivElement;
    const configTableContainer = document.getElementById('config-table-container') as HTMLDivElement;
    const configTableBody = document.getElementById('config-table-body') as HTMLTableSectionElement;

    let runStatusTimeoutId: number | null = null;
    let runReloadTimeoutId: number | null = null;

    const BADGE_PALETTE = [
      'bg-blue-100 text-blue-800',
      'bg-purple-100 text-purple-800',
      'bg-teal-100 text-teal-800',
      'bg-orange-100 text-orange-800',
      'bg-pink-100 text-pink-800',
      'bg-yellow-100 text-yellow-800',
      'bg-indigo-100 text-indigo-800',
      'bg-green-100 text-green-800',
    ] as const;

    const jobMetaMap = new Map<string, JobMetadata>();
    const jobBadgeClassMap = new Map<string, string>();
    const enrichedCronJobsMap = new Map<string, EnrichedCronJob>();

    const STATUS_BADGE_CLASS: Record<JobStatus, string> = {
      completed: 'badge-soft-success',
      failed: 'badge-soft-error',
      running: 'badge-soft-warning',
    };

    function escapeHtml(value: string): string {
      return value
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getErrorMessage(error: unknown, fallback: string): string {
      const normalized = error as Error & { body?: { message?: string } };
      return normalized.body?.message || normalized.message || fallback;
    }

    function formatDuration(durationMs: number | null): string {
      if (durationMs === null) return '—';
      if (durationMs === 0) return '0ms';
      if (durationMs < 1000) return `${durationMs}ms`;
      if (durationMs < 60000) return `${(durationMs / 1000).toFixed(1)}s`;
      const minutes = Math.floor(durationMs / 60000);
      const seconds = Math.floor((durationMs % 60000) / 1000);
      return `${minutes}m ${seconds}s`;
    }

    function formatStartedAt(startedAt: string | null): string {
      if (!startedAt) return '—';
      const date = new Date(startedAt);
      if (Number.isNaN(date.getTime())) return '—';
      return date.toLocaleString('es-AR');
    }

    function formatProcessedCount(processedCount: number | null): string {
      if (processedCount === null) return '—';
      if (processedCount === 0) return '0';
      return String(processedCount);
    }

    function formatErrorPreview(errorMessage: string | null): string {
      if (errorMessage === null) return '—';
      return errorMessage.length > 40 ? `${errorMessage.slice(0, 40)}...` : errorMessage;
    }

    function formatNextRun(nextRun: string | null): string {
      if (!nextRun) return '—';
      const parsed = new Date(nextRun);
      if (Number.isNaN(parsed.getTime())) return '—';
      return parsed.toLocaleString('es-AR');
    }

    function showJobRunStatus(message: string, tone: 'success' | 'error'): void {
      if (runStatusTimeoutId !== null) {
        window.clearTimeout(runStatusTimeoutId);
      }

      jobRunStatus.textContent = message;
      jobRunStatus.classList.remove('hidden', 'text-success', 'text-error');
      jobRunStatus.classList.add(tone === 'success' ? 'text-success' : 'text-error');

      runStatusTimeoutId = window.setTimeout(() => {
        jobRunStatus.classList.add('hidden');
        jobRunStatus.textContent = '';
        runStatusTimeoutId = null;
      }, 3000);
    }

    function showInlineHint(message: string): void {
      jobRunInlineHint.textContent = message;
      jobRunInlineHint.classList.remove('hidden');
    }

    function clearInlineHint(): void {
      jobRunInlineHint.textContent = '';
      jobRunInlineHint.classList.add('hidden');
    }


    function getTabFromUrl(): TabKey {
      const tab = new URLSearchParams(window.location.search).get('tab');
      return tab === 'configuracion' ? 'configuracion' : 'ejecuciones';
    }

    function updateTabStyles(tab: TabKey): void {
      const isExecutionsActive = tab === 'ejecuciones';
      executionsTabButton.className = isExecutionsActive
        ? 'border-b-2 border-primary px-1 py-3 text-sm font-bold text-primary transition-colors'
        : 'border-b-2 border-transparent px-1 py-3 text-sm font-medium text-on-surface-variant transition-colors';
      configTabButton.className = isExecutionsActive
        ? 'border-b-2 border-transparent px-1 py-3 text-sm font-medium text-on-surface-variant transition-colors'
        : 'border-b-2 border-primary px-1 py-3 text-sm font-bold text-primary transition-colors';
    }

    function setActiveTab(tab: TabKey, pushHistory: boolean): void {
      const showExecutions = tab === 'ejecuciones';
      executionsPanel.classList.toggle('hidden', !showExecutions);
      configPanel.classList.toggle('hidden', showExecutions);
      updateTabStyles(tab);

      if (pushHistory) {
        const url = new URL(window.location.href);
        url.searchParams.set('tab', tab);
        window.history.pushState({}, '', `${url.pathname}${url.search}${url.hash}`);
      }

      if (tab === 'configuracion' && !configLoaded) {
        void loadConfigTab();
      }
    }

    function setConfigPanelState(state: 'loading' | 'error' | 'empty' | 'table'): void {
      configLoading.classList.toggle('hidden', state !== 'loading');
      configError.classList.toggle('hidden', state !== 'error');
      configEmpty.classList.toggle('hidden', state !== 'empty');
      configTableContainer.classList.toggle('hidden', state !== 'table');
    }

    function getMemoryCellContent(job: EnrichedCronJob): string {
      const stateLabel = job.isRunning ? '✅ Registrado' : '⏸ No registrado';
      const restartBadge = job.needsRestart
        ? `<span class="badge bg-warning/10 text-warning border border-warning/20 text-[10px]"><span class="material-symbols-outlined text-xs">warning</span> Requiere reinicio</span>`
        : '';
      return `<div class="flex flex-col gap-1"><span class="text-xs text-on-surface-variant">${stateLabel}</span>${restartBadge}</div>`;
    }

    function setToggleVisual(button: HTMLButtonElement, isActive: boolean): void {
      const thumb = button.querySelector<HTMLElement>('[data-toggle-thumb]');
      button.dataset.active = String(isActive);
      button.className = `relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${isActive ? 'bg-primary' : 'bg-surface-container-high'}`;
      if (thumb) {
        thumb.className = `h-4 w-4 rounded-full bg-white transition-transform ${isActive ? 'translate-x-6' : 'translate-x-1'}`;
      }
      button.setAttribute('aria-checked', String(isActive));
    }

    function showConfigRowMessage(jobId: string, message: string, tone: 'error' | 'info'): void {
      const rowError = configTableBody.querySelector<HTMLParagraphElement>(`[data-row-error="${CSS.escape(jobId)}"]`);
      if (!rowError) return;
      rowError.textContent = message;
      rowError.classList.remove('hidden', 'text-error', 'text-on-surface-variant');
      rowError.classList.add(tone === 'error' ? 'text-error' : 'text-on-surface-variant');
    }

    function showConfigRowError(jobId: string, message: string): void {
      showConfigRowMessage(jobId, message, 'error');
    }

    function showConfigRowInfo(jobId: string, message: string): void {
      showConfigRowMessage(jobId, message, 'info');
    }

    function clearConfigRowError(jobId: string): void {
      const rowError = configTableBody.querySelector<HTMLParagraphElement>(`[data-row-error="${CSS.escape(jobId)}"]`);
      if (!rowError) return;
      rowError.textContent = '';
      rowError.classList.add('hidden');
      rowError.classList.remove('text-on-surface-variant');
      rowError.classList.add('text-error');
    }

    function getCronJobByKey(jobKey: string): EnrichedCronJob | null {
      for (const job of enrichedCronJobsMap.values()) {
        if (job.key === jobKey) {
          return job;
        }
      }
      return null;
    }

    function renderConfigRows(rows: EnrichedCronJob[]): void {
      if (rows.length === 0) {
        configTableBody.innerHTML = '';
        setConfigPanelState('empty');
        return;
      }

      configTableBody.innerHTML = rows
        .map((job) => {
          const safeId = escapeHtml(job.id);
          const safeKey = escapeHtml(job.key);
          const safeName = escapeHtml(job.name);
          const encodedName = escapeHtml(encodeURIComponent(job.name));
          const encodedSchedule = escapeHtml(encodeURIComponent(job.schedule || ''));
          const scheduleLabel = job.schedule || '—';
          const activeClass = job.active ? 'bg-primary' : 'bg-surface-container-high';
          const thumbClass = job.active ? 'translate-x-6' : 'translate-x-1';
          return `
            <tr class="border-b border-outline-variant/10 hover:bg-surface-container/50 transition-colors" data-config-row-id="${safeId}">
              <td class="px-5 py-3.5 align-top">
                <button
                  type="button"
                  data-editable-cell="true"
                  data-field="name"
                  data-job-id="${safeId}"
                  data-original="${encodedName}"
                  class="text-left text-xs font-semibold text-on-surface hover:text-primary"
                >
                  ${safeName}
                </button>
                <p data-row-error="${safeId}" class="mt-1 hidden text-xs font-semibold text-error"></p>
              </td>
              <td class="px-5 py-3.5 align-top">
                <button
                  type="button"
                  data-editable-cell="true"
                  data-field="schedule"
                  data-job-id="${safeId}"
                  data-original="${encodedSchedule}"
                  class="text-left text-xs text-on-surface-variant hover:text-primary"
                >
                  ${escapeHtml(scheduleLabel)}
                </button>
              </td>
              <td class="px-5 py-3.5 align-top">
                <button
                  type="button"
                  role="switch"
                  aria-checked="${String(job.active)}"
                  data-toggle-active="true"
                  data-job-id="${safeId}"
                  data-active="${String(job.active)}"
                  class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${activeClass}"
                >
                  <span data-toggle-thumb="true" class="h-4 w-4 rounded-full bg-white transition-transform ${thumbClass}"></span>
                </button>
              </td>
              <td class="px-5 py-3.5 align-top" data-memory-cell="${safeId}">
                ${getMemoryCellContent(job)}
              </td>
              <td class="px-5 py-3.5 align-top text-xs text-on-surface-variant">${escapeHtml(formatNextRun(job.nextRun))}</td>
              <td class="px-5 py-3.5 align-top">
                <div class="flex items-center gap-2 flex-wrap">
                  <button
                    type="button"
                    data-config-run="${safeKey}"
                    class="inline-flex items-center gap-1 rounded-lg bg-surface-container px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider text-on-surface-variant hover:bg-surface-container-high transition-colors"
                  >
                    <span class="material-symbols-outlined text-sm">play_arrow</span>
                    Ejecutar
                  </button>
                  <button
                    type="button"
                    data-config-restart="${safeKey}"
                    class="inline-flex items-center gap-1 rounded-lg border border-outline-variant px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider text-on-surface-variant hover:bg-surface-container transition-colors"
                  >
                    <span class="material-symbols-outlined text-sm">restart_alt</span>
                    Restart
                  </button>
                </div>
              </td>
            </tr>`;
        })
        .join('');

      setConfigPanelState('table');
    }

    function setPaginationDisabled(disabled: boolean): void {
      pagination.querySelectorAll<HTMLButtonElement>('button').forEach((button) => {
        button.disabled = disabled;
      });
    }

    function renderPagination(): void {
      pagination.innerHTML = `
        <button
          type="button"
          data-action="prev"
          class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
          ${currentPage <= 1 || isLoading ? 'disabled' : ''}
        >
          <span class="material-symbols-outlined text-sm" aria-hidden="true">chevron_left</span>
          Prev
        </button>
        <span class="text-xs font-bold text-on-surface-variant px-1">${currentPage} / ${totalPages}</span>
        <button
          type="button"
          data-action="next"
          class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
          ${currentPage >= totalPages || isLoading ? 'disabled' : ''}
        >
          Next
          <span class="material-symbols-outlined text-sm" aria-hidden="true">chevron_right</span>
        </button>`;
    }

    function updateSummary(total: number): void {
      if (total === 0) {
        resultsInfo.textContent = 'Mostrando 0–0 de 0 ejecuciones encontradas';
        return;
      }

      const start = (currentPage - 1) * PAGE_SIZE + 1;
      const end = Math.min(currentPage * PAGE_SIZE, total);
      resultsInfo.textContent = `Mostrando ${start}–${end} de ${total} ejecuciones encontradas`;
    }

    function openErrorModal(jobName: string, errorMessage: string, errorStack: string): void {
      errorName.textContent = `Job: ${jobName}`;
      errorContent.textContent = `Error: ${errorMessage}\n\nStack:\n${errorStack}`;
      errorModal.classList.remove('hidden');
      errorModal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeErrorModal(): void {
      errorModal.classList.add('hidden');
      errorModal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function renderLoadingRow(): void {
      tableBody.innerHTML = `
        <tr>
          <td colspan="7" class="text-center py-12 text-on-surface-variant">
            <div class="flex flex-col items-center gap-3">
              <div class="w-8 h-8 border-3 border-primary/30 border-t-primary rounded-full animate-spin"></div>
              <span class="text-sm font-medium">Cargando jobs...</span>
            </div>
          </td>
        </tr>`;
    }

    function renderEmptyRow(): void {
      tableBody.innerHTML = `
        <tr>
          <td colspan="7" class="text-center py-16 text-on-surface-variant">
            <p class="text-sm font-medium">No se encontraron ejecuciones</p>
          </td>
        </tr>`;
    }

    function renderErrorRow(): void {
      tableBody.innerHTML = `
        <tr>
          <td colspan="7" class="text-center py-12 text-error">
            <span class="material-symbols-outlined text-3xl mb-2 block" aria-hidden="true">error</span>
            <p class="text-sm font-bold">Error al cargar los jobs</p>
          </td>
        </tr>`;
    }

    function renderRows(items: JobExecution[]): void {
      if (items.length === 0) {
        renderEmptyRow();
        return;
      }

      tableBody.innerHTML = items
        .map((job, index) => {
          const jobMeta = jobMetaMap.get(job.jobName);
          const safeJobName = escapeHtml(jobMeta?.name || job.jobName);
          const jobBadgeClass = jobBadgeClassMap.get(job.jobName) || 'bg-surface-container text-on-surface-variant';
          const statusClass = STATUS_BADGE_CLASS[job.status] || 'badge-soft-warning';
          const safeDuration = escapeHtml(formatDuration(job.durationMs));
          const safeStartedAt = escapeHtml(formatStartedAt(job.startedAt));
          const safeProcessedCount = escapeHtml(formatProcessedCount(job.processedCount));
          const safeErrorPreview = escapeHtml(formatErrorPreview(job.errorMessage));
          const safeErrorMessage = escapeHtml(job.errorMessage ?? '—');
          const safeErrorStack = escapeHtml(job.errorStack ?? '—');

          return `
            <tr class="border-b border-outline-variant/10 hover:bg-surface-container/50 transition-colors">
              <td class="px-5 py-3.5">
                <span class="inline-block px-2.5 py-1 rounded-lg text-[11px] font-bold tracking-wide ${jobBadgeClass}">${safeJobName}</span>
              </td>
              <td class="px-5 py-3.5 text-on-surface-variant text-xs">${safeStartedAt}</td>
              <td class="px-5 py-3.5 text-on-surface-variant text-xs">${safeDuration}</td>
              <td class="px-5 py-3.5">
                <span class="badge ${statusClass}">${escapeHtml(job.status)}</span>
              </td>
              <td class="px-5 py-3.5 text-on-surface-variant text-xs">${safeProcessedCount}</td>
              <td class="px-5 py-3.5 text-on-surface-variant text-xs">${safeErrorPreview}</td>
              <td class="px-5 py-3.5">
                <div class="flex items-center gap-2 flex-wrap">
                  ${
                    job.errorMessage !== null
                      ? `<button
                          type="button"
                          data-action="show-error"
                          data-row-index="${index}"
                          data-job-name="${safeJobName}"
                          data-error-message="${safeErrorMessage}"
                          data-error-stack="${safeErrorStack}"
                          class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors"
                        >
                          Ver error
                        </button>`
                      : '<span class="text-on-surface-variant">—</span>'
                  }
                </div>
              </td>
            </tr>`;
        })
        .join('');
    }

    async function loadAvailableJobs(): Promise<void> {
      jobFilter.innerHTML = '<option value="">Todos los jobs</option>';

      try {
        const availableJobs = (await listCronJobs()) as JobMetadata[];

        jobMetaMap.clear();
        jobBadgeClassMap.clear();

        availableJobs.forEach((job, index) => {
          jobMetaMap.set(job.key, job);
          jobBadgeClassMap.set(job.key, BADGE_PALETTE[index % BADGE_PALETTE.length]);

          const option = document.createElement('option');
          option.value = job.key;
          option.textContent = job.name;
          jobFilter.append(option);
        });
      } catch {
        // Keep default option only if available jobs cannot be loaded.
      }
    }

    async function runJobWithFeedback(jobName: string, triggerButton: HTMLButtonElement): Promise<void> {
      const originalContent = triggerButton.innerHTML;
      triggerButton.disabled = true;

      try {
        await runJob(jobName);

        triggerButton.innerHTML = '<span class="material-symbols-outlined text-sm">check</span> Iniciado';
        showJobRunStatus('Job iniciado', 'success');

        window.setTimeout(() => {
          triggerButton.disabled = false;
          triggerButton.innerHTML = originalContent;
        }, 2000);

        if (runReloadTimeoutId !== null) {
          window.clearTimeout(runReloadTimeoutId);
        }

        runReloadTimeoutId = window.setTimeout(() => {
          loadJobs();
          runReloadTimeoutId = null;
        }, 3000);
      } catch (error) {
        const typedError = error as Error & { status?: number };
        if (typedError.status === 404) {
          showJobRunStatus('Job no encontrado', 'error');
          triggerButton.disabled = false;
          return;
        }
        showJobRunStatus('Error al iniciar el job', 'error');
        triggerButton.disabled = false;
      }
    }

    async function loadJobs(): Promise<void> {
      isLoading = true;
      renderPagination();
      renderLoadingRow();

      try {
        const response = await listJobExecutions(currentPage, PAGE_SIZE, currentJobFilter || undefined);
        const total = Number(response.total || 0);
        const sizePage = Number(response.sizePage || PAGE_SIZE);
        totalPages = Math.max(1, Math.ceil(total / sizePage));
        if (currentPage > totalPages) currentPage = totalPages;

        renderRows(response.data || []);
        updateSummary(total);
      } catch {
        totalPages = 1;
        renderErrorRow();
        resultsInfo.textContent = 'Error al cargar los jobs';
      } finally {
        isLoading = false;
        renderPagination();
      }
    }

    async function loadConfigTab(forceReload = false): Promise<void> {
      if (isConfigLoading || (configLoaded && !forceReload)) {
        return;
      }

      isConfigLoading = true;
      setConfigPanelState('loading');

      try {
        const [dbJobs, runningJobs] = await Promise.all([listCronJobs(), listRunningJobs()]);
        const runningMap = new Map(runningJobs.map((job) => [job.key, job]));
        const enriched = dbJobs.map((job) => ({
          ...job,
          schedule: job.schedule || null,
          isRunning: runningMap.get(job.key)?.running ?? false,
          nextRun: runningMap.get(job.key)?.nextRun ?? null,
          needsRestart: job.active !== (runningMap.get(job.key)?.running ?? false),
        }));

        enrichedCronJobsMap.clear();
        enriched.forEach((job) => {
          enrichedCronJobsMap.set(job.id, job);
        });

        configLoaded = true;
        renderConfigRows(enriched);
      } catch (error) {
        configLoaded = false;
        configErrorMessage.textContent = getErrorMessage(error, 'Error al cargar la configuración');
        setConfigPanelState('error');
      } finally {
        isConfigLoading = false;
      }
    }

    async function reloadConfigTab(): Promise<void> {
      await loadConfigTab(true);
    }

    async function restartJobWithConfirm(jobKey: string, triggerButton: HTMLButtonElement): Promise<void> {
      const cronJob = getCronJobByKey(jobKey);
      const jobDisplayName = cronJob?.name || jobKey;
      const rowId = cronJob?.id || '';

      (window as any).openConfirmModal({
        title: 'Reiniciar job',
        body: `¿Reiniciar el job '${jobDisplayName}'? El timer se detendrá y se re-registrará con el schedule actual de la DB. Útil después de cambiar el schedule sin reiniciar la app.`,
        confirmText: 'Reiniciar',
        cancelText: 'Cancelar',
        onConfirm: async () => {
          if (rowId) {
            clearConfigRowError(rowId);
          }

          const originalContent = triggerButton.innerHTML;
          triggerButton.disabled = true;

          try {
            await restartJob(jobKey);

            triggerButton.innerHTML = '<span class="material-symbols-outlined text-sm">check</span> ✓ Reiniciado';
            window.setTimeout(() => {
              triggerButton.disabled = false;
              triggerButton.innerHTML = originalContent;
              void reloadConfigTab();
            }, 2000);
          } catch (error) {
            const typedError = error as Error & { status?: number };
            if (typedError.status === 400) {
              if (rowId) {
                showConfigRowInfo(rowId, 'El job estaba inactivo y se detuvo');
              }

              window.setTimeout(() => {
                triggerButton.disabled = false;
                triggerButton.innerHTML = originalContent;
                void reloadConfigTab();
              }, 1200);
              return;
            }

            if (typedError.status === 404) {
              if (rowId) {
                showConfigRowError(rowId, 'Job no encontrado');
              }
              triggerButton.disabled = false;
              return;
            }
            if (rowId) {
              showConfigRowError(rowId, 'Error al reiniciar el job');
            }
            triggerButton.disabled = false;
          }
        },
      });
    }

    function startInlineEdit(cellButton: HTMLButtonElement): void {
      const field = cellButton.dataset.field;
      const jobId = cellButton.dataset.jobId;
      const original = decodeURIComponent(cellButton.dataset.original || '');
      if (!field || !jobId) {
        return;
      }

      const editKey = `${jobId}:${field}`;
      if (editingCellKey === editKey) {
        return;
      }

      const cell = cellButton.parentElement as HTMLTableCellElement;
      if (cell.querySelector('input[data-inline-editor="true"]')) {
        return;
      }

      const input = document.createElement('input');
      input.type = 'text';
      input.value = original;
      input.dataset.inlineEditor = 'true';
      input.className =
        'w-full rounded-lg border border-outline-variant/30 bg-surface-container-lowest px-2.5 py-1.5 text-xs text-on-surface focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20';

      cellButton.classList.add('hidden');
      cell.append(input);
      input.focus();
      input.setSelectionRange(input.value.length, input.value.length);
      editingCellKey = editKey;

      let finished = false;
      const finish = (mode: 'commit' | 'cancel') => {
        if (finished) {
          return;
        }
        finished = true;

        const nextValue = input.value.trim();
        input.remove();
        editingCellKey = '';

        if (mode === 'cancel' || nextValue === original) {
          cellButton.classList.remove('hidden');
          return;
        }

        const payload = { [field]: nextValue } as Record<string, string>;
        cellButton.disabled = true;

        void updateCronJob(jobId, payload)
          .then(() => {
            const job = enrichedCronJobsMap.get(jobId);
            if (job) {
              if (field === 'name') {
                job.name = nextValue;
              }
              if (field === 'schedule') {
                job.schedule = nextValue;
              }
              enrichedCronJobsMap.set(jobId, job);
            }

            cellButton.dataset.original = encodeURIComponent(nextValue);
            cellButton.textContent = field === 'schedule' ? nextValue || '—' : nextValue;
            clearConfigRowError(jobId);
            cellButton.classList.remove('hidden');
          })
          .catch((error) => {
            cellButton.classList.remove('hidden');
            showConfigRowError(jobId, getErrorMessage(error, 'No se pudo guardar el cambio.'));
          })
          .finally(() => {
            cellButton.disabled = false;
          });
      };

      input.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          event.preventDefault();
          finish('cancel');
        }
        if (event.key === 'Enter') {
          event.preventDefault();
          finish('commit');
        }
      });

      input.addEventListener('blur', () => {
        finish('commit');
      });
    }

    function handleToggleActive(toggleButton: HTMLButtonElement): void {
      const jobId = toggleButton.dataset.jobId;
      if (!jobId) {
        return;
      }

      const job = enrichedCronJobsMap.get(jobId);
      if (!job) {
        return;
      }

      const nextActive = !job.active;
      (window as any).openConfirmModal({
        title: 'Cambiar activación',
        body: `¿Cambiar estado de activación de "${job.name}"? Este cambio aplica en el próximo reinicio o deploy de la aplicación.`,
        confirmText: 'Confirmar',
        cancelText: 'Cancelar',
        onConfirm: async () => {
          toggleButton.disabled = true;
          try {
            await updateCronJob(job.id, { active: nextActive });
            job.active = nextActive;
            job.needsRestart = job.active !== job.isRunning;
            enrichedCronJobsMap.set(jobId, job);

            setToggleVisual(toggleButton, job.active);
            const memoryCell = configTableBody.querySelector<HTMLTableCellElement>(`[data-memory-cell="${CSS.escape(jobId)}"]`);
            if (memoryCell) {
              memoryCell.innerHTML = getMemoryCellContent(job);
            }
            clearConfigRowError(jobId);
          } catch (error) {
            showConfigRowError(jobId, getErrorMessage(error, 'No se pudo cambiar la activación.'));
          } finally {
            toggleButton.disabled = false;
          }
        },
      });
    }

    function setupAuthGuard(): boolean {
      restoreSession();

      if (!isAuthenticated() || !isAdmin()) {
        window.location.href = '/admin';
        return false;
      }

      return true;
    }

    executionsTabButton.addEventListener('click', () => {
      setActiveTab('ejecuciones', true);
    });

    configTabButton.addEventListener('click', () => {
      setActiveTab('configuracion', true);
    });

    pagination.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const button = target.closest<HTMLButtonElement>('button[data-action]');
      if (!button || isLoading) return;

      const action = button.dataset.action;
      if (action === 'prev' && currentPage > 1) {
        currentPage -= 1;
        void loadJobs();
      }

      if (action === 'next' && currentPage < totalPages) {
        currentPage += 1;
        void loadJobs();
      }
    });

    jobFilter.addEventListener('change', () => {
      currentJobFilter = jobFilter.value;
      currentPage = 1;
      clearInlineHint();
      void loadJobs();
    });

    runSelectedJobButton.addEventListener('click', () => {
      const jobName = jobFilter.value.trim();
      if (!jobName) {
        showInlineHint('Seleccioná un job primero');
        return;
      }

      clearInlineHint();
      const jobDisplayName = jobMetaMap.get(jobName)?.name || jobName;
      (window as any).openConfirmModal({
        title: 'Ejecutar job',
        body: `¿Querés ejecutar manualmente el job "${jobDisplayName}"? Esta acción corre inmediatamente en background.`,
        buttons: [
          {
            text: 'Ejecutar',
            variant: 'primary',
            onClick: () => {
              void runJobWithFeedback(jobName, runSelectedJobButton);
            },
          },
          {
            text: 'Cancelar',
            variant: 'ghost',
          },
        ],
      });
    });

    configRetryButton.addEventListener('click', () => {
      void loadConfigTab();
    });

    tableBody.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const button = target.closest<HTMLButtonElement>('button[data-action]');
      if (!button) return;

      if (button.dataset.action !== 'show-error') return;

      const jobName = button.dataset.jobName || '';
      const errorMessage = button.dataset.errorMessage || '—';
      const errorStack = button.dataset.errorStack || '—';
      openErrorModal(jobName, errorMessage, errorStack);
    });

    configTableBody.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;

      const runButton = target.closest<HTMLButtonElement>('button[data-config-run]');
      if (runButton) {
        const jobKey = runButton.dataset.configRun;
        if (jobKey) {
          void runJobWithFeedback(jobKey, runButton);
        }
        return;
      }

      const restartButton = target.closest<HTMLButtonElement>('button[data-config-restart]');
      if (restartButton) {
        const jobKey = restartButton.dataset.configRestart;
        if (jobKey) {
          void restartJobWithConfirm(jobKey, restartButton);
        }
        return;
      }

      const toggleButton = target.closest<HTMLButtonElement>('button[data-toggle-active]');
      if (toggleButton) {
        handleToggleActive(toggleButton);
        return;
      }

      const editableButton = target.closest<HTMLButtonElement>('button[data-editable-cell]');
      if (editableButton) {
        startInlineEdit(editableButton);
      }
    });

    document.getElementById('job-error-close')?.addEventListener('click', closeErrorModal);
    errorModal.addEventListener('click', (event) => {
      if (event.target === errorModal) {
        closeErrorModal();
      }
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !errorModal.classList.contains('hidden')) {
        closeErrorModal();
      }
    });

    if (setupAuthGuard()) {
      setPaginationDisabled(false);
      void loadAvailableJobs();
      void loadJobs();
      setActiveTab(getTabFromUrl(), false);
    }
  </script>
</AdminLayout>

