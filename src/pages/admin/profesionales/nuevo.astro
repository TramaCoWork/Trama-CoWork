---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="TRAMA Admin - Nuevo profesional">
  <header class="mb-8 flex flex-wrap items-center justify-between gap-4">
    <div>
      <p class="text-xs font-bold uppercase tracking-widest text-primary">INICIO › PROFESIONALES › NUEVO</p>
      <h1 class="text-3xl font-black text-on-surface tracking-tight mt-2">Nuevo profesional</h1>
      <p class="text-on-surface-variant font-medium mt-1 text-sm">
        Cargá los datos para registrar un nuevo profesional.
      </p>
    </div>
    <a
      href="/admin/profesionales"
      class="px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors"
    >
      ← Volver
    </a>
  </header>

  <section class="bg-surface-container-low rounded-2xl border border-outline-variant/10 p-6">
    <form id="professionalForm" class="space-y-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div>
          <label for="name" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Nombre</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
          />
        </div>
        <div>
          <label for="email" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
          />
        </div>
        <div>
          <label for="password" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Contraseña</label>
          <input
            id="password"
            name="password"
            type="password"
            minlength="8"
            required
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
          />
        </div>
        <div>
          <label for="whatsapp" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">WhatsApp (opcional)</label>
          <input
            id="whatsapp"
            name="whatsapp"
            type="text"
            placeholder="Opcional"
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
          />
        </div>
        <div>
          <label for="document" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">DNI / Documento</label>
          <input
            id="document"
            name="document"
            type="text"
            required
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
          />
        </div>
        <div>
          <label for="city" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Ciudad</label>
          <input
            id="city"
            name="city"
            type="text"
            required
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
          />
        </div>
        <div>
          <label for="address" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Dirección</label>
          <input
            id="address"
            name="address"
            type="text"
            placeholder="Ej: Av. Corrientes 1234, Piso 5"
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
          />
        </div>
        <div>
          <label for="countryId" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">País</label>
          <select
            id="countryId"
            name="countryId"
            required
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer"
          >
            <option value="">Seleccionar país</option>
          </select>
        </div>
        <div>
          <label for="provinceId" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Provincia</label>
          <select
            id="provinceId"
            name="provinceId"
            required
            disabled
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer disabled:opacity-50"
          >
            <option value="">Seleccionar provincia</option>
          </select>
        </div>
        <div>
          <label for="rubroId" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Rubro</label>
          <select
            id="rubroId"
            name="rubroId"
            required
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer"
          >
            <option value="">Seleccionar rubro</option>
          </select>
        </div>
        <div>
          <label for="subrubroId" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Subrubro</label>
          <select
            id="subrubroId"
            name="subrubroId"
            required
            disabled
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer disabled:opacity-50"
          >
            <option value="">Seleccionar subrubro</option>
          </select>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Profesiones (máximo 3)</label>
          <span id="professionCount" class="text-xs font-bold text-on-surface-variant">0 / 3</span>
        </div>
        <div
          id="professionCategories"
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 rounded-xl border border-outline-variant/20 bg-surface-container-lowest p-4"
        >
          <p class="text-sm text-on-surface-variant">Seleccioná un subrubro para cargar profesiones.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div>
          <label for="trialEndDate" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Fecha de prueba (opcional)</label>
          <input
            id="trialEndDate"
            name="trialEndDate"
            type="date"
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
          />
        </div>
        <div>
          <label for="profileStatus" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Estado del perfil</label>
          <select
            id="profileStatus"
            name="profileStatus"
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none cursor-pointer"
          >
            <option value="incomplete">Incompleto</option>
            <option value="onboarding">Onboarding</option>
            <option value="pending_review">Pendiente revisión</option>
            <option value="active" selected>Activo</option>
            <option value="rejected">Rechazado</option>
            <option value="suspended">Suspendido</option>
            <option value="waiting_payment">Esperando pago</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <input id="emailVerified" name="emailVerified" type="checkbox" checked class="w-4 h-4 accent-primary rounded" />
          <label for="emailVerified" class="text-sm text-on-surface-variant font-medium">Email verificado</label>
        </div>
        <div>
          <label for="photo" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Foto (opcional)</label>
          <input
            id="photo"
            name="photo"
            type="file"
            accept="image/*"
            class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium file:mr-3 file:rounded-lg file:border-0 file:bg-primary file:px-3 file:py-1.5 file:text-xs file:font-bold file:uppercase file:tracking-widest file:text-on-primary hover:file:opacity-90"
          />
        </div>
      </div>

      <p id="form-error" class="hidden text-sm font-semibold text-error"></p>

      <div class="flex justify-end">
        <button
          id="submitBtn"
          type="submit"
          class="px-6 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all disabled:opacity-60 disabled:cursor-not-allowed"
        >
          Crear profesional
        </button>
      </div>
    </form>
  </section>

  <div id="toast" class="fixed top-6 right-6 z-[80] hidden transition-all duration-300 translate-y-[-1rem] opacity-0">
    <div id="toast-inner" class="flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm">
      <span id="toast-icon" class="material-symbols-outlined text-xl" aria-hidden="true"></span>
      <span id="toast-msg"></span>
    </div>
  </div>

  <!-- Error Alert Modal -->
  <div id="error-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 overflow-hidden">
      <div class="flex items-center gap-3 px-6 py-4 border-b border-[var(--color-neutral-200)]">
        <span class="material-symbols-outlined text-2xl text-[var(--color-error)]">error</span>
        <h3 id="error-modal-title" class="text-base font-semibold text-[var(--color-neutral-900)]">Error</h3>
      </div>
      <div class="px-6 py-5">
        <p id="error-modal-message" class="text-sm text-[var(--color-neutral-600)] whitespace-pre-line"></p>
      </div>
      <div class="flex justify-end px-6 py-4 border-t border-[var(--color-neutral-200)]">
        <button
          id="error-modal-close"
          class="inline-flex items-center gap-2 bg-[var(--color-primary)] hover:bg-[var(--color-primary-alt)] text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors"
        >
          Entendido
        </button>
      </div>
    </div>
  </div>

  <script>
    import { getToken, restoreSession } from '../../../services/authService';
    import { api } from '../../../services/apiClient';
    import { fetchCountries, fetchProvinces } from '../../../services/locationService';
    import { getProfesiones, getRubros, getSubrubros } from '../../../services/adminProfessionCategoriesService';
    import { registerProfessional, uploadProfessionalPhoto } from '../../../services/adminService';

    restoreSession();
    const token = getToken();
    if (token) api.setHeader('Authorization', `Bearer ${token}`);

    const form = document.getElementById('professionalForm') as HTMLFormElement;
    const countrySelect = document.getElementById('countryId') as HTMLSelectElement;
    const provinceSelect = document.getElementById('provinceId') as HTMLSelectElement;
    const rubroSelect = document.getElementById('rubroId') as HTMLSelectElement;
    const subrubroSelect = document.getElementById('subrubroId') as HTMLSelectElement;
    const professionContainer = document.getElementById('professionCategories') as HTMLDivElement;
    const professionCount = document.getElementById('professionCount') as HTMLSpanElement;
    const errorMessage = document.getElementById('form-error') as HTMLParagraphElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

    const toast = document.getElementById('toast') as HTMLDivElement;
    const toastInner = document.getElementById('toast-inner') as HTMLDivElement;
    const toastIcon = document.getElementById('toast-icon') as HTMLSpanElement;
    const toastMsg = document.getElementById('toast-msg') as HTMLSpanElement;
    let toastTimeout: ReturnType<typeof setTimeout>;

    function showErrorModal(title: string, message: string) {
      const modal = document.getElementById('error-modal') as HTMLElement;
      const titleEl = document.getElementById('error-modal-title');
      const msgEl = document.getElementById('error-modal-message');
      if (titleEl) titleEl.textContent = title;
      if (msgEl) msgEl.textContent = message;
      modal?.classList.remove('hidden');
    }

    function hideErrorModal() {
      document.getElementById('error-modal')?.classList.add('hidden');
    }

    document.getElementById('error-modal-close')?.addEventListener('click', hideErrorModal);
    document.getElementById('error-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) hideErrorModal();
    });

    function showToast(message: string, type: 'success' | 'error' | 'warning' = 'success') {
      toastMsg.textContent = message;
      toastInner.className = 'flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm';
      if (type === 'success') {
        toastInner.classList.add('bg-primary-container', 'text-on-primary-container');
        toastIcon.textContent = 'check_circle';
      } else if (type === 'warning') {
        toastInner.classList.add('bg-secondary-container', 'text-on-secondary-container');
        toastIcon.textContent = 'warning';
      } else {
        toastInner.classList.add('bg-error-container', 'text-on-error-container');
        toastIcon.textContent = 'error';
      }
      toast.classList.remove('hidden');
      requestAnimationFrame(() => {
        toast.classList.remove('translate-y-[-1rem]', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
      });
      clearTimeout(toastTimeout);
      toastTimeout = setTimeout(() => {
        toast.classList.add('translate-y-[-1rem]', 'opacity-0');
        toast.classList.remove('translate-y-0', 'opacity-100');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, 3000);
    }

    function setError(message = '') {
      errorMessage.textContent = message;
      errorMessage.classList.toggle('hidden', message.length === 0);
    }

    function setLoading(isLoading: boolean) {
      submitBtn.disabled = isLoading;
      submitBtn.textContent = isLoading ? 'Guardando...' : 'Crear profesional';
    }

    function resetSelect(select: HTMLSelectElement, placeholder: string) {
      select.innerHTML = `<option value="">${placeholder}</option>`;
    }

    function populateOptions(select: HTMLSelectElement, items: Array<{ id: number; name: string }>) {
      items.forEach((item) => {
        const opt = document.createElement('option');
        opt.value = String(item.id);
        opt.textContent = item.name;
        select.appendChild(opt);
      });
    }

    function updateProfessionSelection() {
      const inputs = Array.from(
        professionContainer.querySelectorAll<HTMLInputElement>('input[type="checkbox"]'),
      );
      const checked = inputs.filter((input) => input.checked);
      professionCount.textContent = `${checked.length} / 3`;
      const limitReached = checked.length >= 3;
      inputs.forEach((input) => {
        if (!input.checked) input.disabled = limitReached;
      });
    }

    function renderProfessions(items: Array<{ id: number; name: string }>) {
      if (!items.length) {
        professionContainer.innerHTML = '<p class="text-sm text-on-surface-variant">No hay profesiones para este subrubro.</p>';
        professionCount.textContent = '0 / 3';
        return;
      }
      professionContainer.innerHTML = items
        .map(
          (item) => `
            <label class="flex items-center gap-2 rounded-lg border border-outline-variant/20 bg-surface-container-low px-3 py-2 text-sm text-on-surface font-medium">
              <input name="professionCategoryIds" type="checkbox" value="${item.id}" class="w-4 h-4 accent-primary rounded" />
              <span>${item.name}</span>
            </label>
          `,
        )
        .join('');

      professionContainer
        .querySelectorAll<HTMLInputElement>('input[type="checkbox"]')
        .forEach((input) => {
          input.addEventListener('change', updateProfessionSelection);
        });
      updateProfessionSelection();
    }

    async function initFilters() {
      try {
        const [countries, rubros] = await Promise.all([fetchCountries(), getRubros()]);
        populateOptions(countrySelect, countries);
        populateOptions(rubroSelect, rubros);
      } catch (error) {
        console.error('Error loading filters', error);
      }
    }

    countrySelect.addEventListener('change', async () => {
      resetSelect(provinceSelect, 'Seleccionar provincia');
      provinceSelect.disabled = true;
      const countryId = Number(countrySelect.value);
      if (!countryId) return;
      try {
        const provinces = await fetchProvinces(countryId);
        populateOptions(provinceSelect, provinces);
        provinceSelect.disabled = false;
      } catch {
        provinceSelect.disabled = true;
      }
    });

    rubroSelect.addEventListener('change', async () => {
      resetSelect(subrubroSelect, 'Seleccionar subrubro');
      subrubroSelect.disabled = true;
      professionContainer.innerHTML = '<p class="text-sm text-on-surface-variant">Seleccioná un subrubro para cargar profesiones.</p>';
      professionCount.textContent = '0 / 3';
      const rubroId = Number(rubroSelect.value);
      if (!rubroId) return;
      try {
        const subrubros = await getSubrubros(rubroId);
        populateOptions(subrubroSelect, subrubros);
        subrubroSelect.disabled = false;
      } catch {
        subrubroSelect.disabled = true;
      }
    });

    subrubroSelect.addEventListener('change', async () => {
      professionContainer.innerHTML = '<p class="text-sm text-on-surface-variant">Cargando profesiones...</p>';
      professionCount.textContent = '0 / 3';
      const subrubroId = Number(subrubroSelect.value);
      if (!subrubroId) {
        professionContainer.innerHTML = '<p class="text-sm text-on-surface-variant">Seleccioná un subrubro para cargar profesiones.</p>';
        return;
      }
      try {
        const profesiones = await getProfesiones(subrubroId);
        renderProfessions(profesiones);
      } catch {
        professionContainer.innerHTML = '<p class="text-sm text-on-surface-variant">No se pudieron cargar las profesiones.</p>';
      }
    });

    function getBodyErrorMessage(error: any): string | null {
      const body = error?.body;
      if (body && typeof body === 'object' && 'message' in body && typeof body.message === 'string') {
        return body.message;
      }
      if (typeof body === 'string') return body;
      return null;
    }

    function buildPayload(formEl: HTMLFormElement) {
      const fd = new FormData(formEl);
      const str = (key: string) => (fd.get(key) as string ?? '').trim();
      const strOrUndef = (key: string) => { const v = str(key); return v || undefined; };

      const professionCategoryIds = fd
        .getAll('professionCategoryIds')
        .map((v) => parseInt(String(v).trim(), 10))
        .filter((value) => !Number.isNaN(value));

      return {
        name: str('name'),
        email: str('email'),
        password: str('password'),
        city: str('city'),
        address: strOrUndef('address'),
        rubroId: parseInt(str('rubroId'), 10),
        countryId: parseInt(str('countryId'), 10),
        provinceId: parseInt(str('provinceId'), 10),
        document: str('document'),
        whatsapp: strOrUndef('whatsapp'),
        trialEndDate: strOrUndef('trialEndDate'),
        professionCategoryIds,
        emailVerified: fd.get('emailVerified') === 'on',
        profileStatus: str('profileStatus') || 'active',
      };
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      setError('');
      const payload = buildPayload(form);
      const errors: string[] = [];
      if (!payload.name) errors.push('El nombre es requerido');
      if (!payload.email) errors.push('El email es requerido');
      if (!payload.password || payload.password.length < 8) errors.push('La contraseña debe tener al menos 8 caracteres');
      if (!payload.countryId) errors.push('Seleccioná un país');
      if (!payload.provinceId) errors.push('Seleccioná una provincia');
      if (!payload.rubroId) errors.push('Seleccioná un rubro');
      if (payload.professionCategoryIds.length === 0) errors.push('Seleccioná al menos una profesión');
      if (errors.length > 0) {
        errorMessage.innerHTML = errors.map((error) => `<p>• ${error}</p>`).join('');
        errorMessage.classList.remove('hidden');
        return;
      }

      setLoading(true);
      try {
        const response = await registerProfessional(payload);
        const profileId = response.user.profile.id;

        const photoInput = document.getElementById('photo') as HTMLInputElement | null;
        const photoFile = photoInput?.files?.[0];
        if (photoFile) {
          try {
            await uploadProfessionalPhoto(profileId, photoFile);
          } catch (photoErr) {
            console.warn('Photo upload failed:', photoErr);
            const warningEl = document.getElementById('warning-message');
            if (warningEl) {
              warningEl.textContent =
                'El profesional fue creado pero no se pudo subir la foto. Podés agregarla desde el detalle.';
              warningEl.classList.remove('hidden');
            }
          }
        }

        window.location.href = '/admin/profesionales?created=1';
      } catch (error: any) {
        const status = error?.status;
        const backendMsg = error?.body?.message || error?.message || 'Error desconocido';
        const detail = Array.isArray(backendMsg) ? backendMsg.join('\n') : String(backendMsg);

        if (status === 409) {
          showErrorModal(
            'Email ya registrado',
            'El email ingresado ya está en uso por otro profesional. Por favor usá un email diferente.',
          );
        } else if (status === 400) {
          showErrorModal('Error de validación', detail);
        } else if (status === 401 || status === 403) {
          showErrorModal('Sin permisos', 'Tu sesión expiró o no tenés permisos para realizar esta acción.');
        } else {
          showErrorModal('Error inesperado', detail);
        }
      } finally {
        // Re-enable submit button so user can retry
        const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Registrar Profesional';
        }
      }
    });

    initFilters();
  </script>
</AdminLayout>

