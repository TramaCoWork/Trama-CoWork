---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminTable from '../../../components/admin/AdminTable.astro';
import TrialDateModal from '../../../components/TrialDateModal.astro';

const columns = [
  { key: 'name', label: 'Profesional' },
  { key: 'location', label: 'Ubicación' },
  { key: 'rubro', label: 'Rubro' },
  { key: 'status', label: 'Estado' },
  { key: 'actions', label: 'Acciones' },
];
---

<AdminLayout title="TRAMA Admin - Profesionales">

  <!-- Header -->
  <header class="mb-8">
    <p class="text-xs text-[var(--color-neutral-400)] uppercase tracking-widest mb-1">
      ADMIN <span class="mx-1">/</span> PROFESIONALES
    </p>
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-[var(--color-neutral-900)]">Gestión de Profesionales</h1>
      <a
        href="/admin/profesionales/nuevo"
        class="inline-flex items-center gap-2 bg-[var(--color-primary)] hover:bg-[var(--color-primary-alt)] text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors"
      >
        <span class="material-symbols-outlined text-base">person_add</span>
        AGREGAR PROFESIONAL
      </a>
    </div>
  </header>

  <!-- Filters -->
  <div class="bg-white border border-[var(--color-neutral-200)] rounded-2xl mb-6">
    <button id="filters-toggle" class="w-full flex items-center gap-2 px-5 py-4 text-sm font-semibold text-[var(--color-neutral-900)]">
      <span class="material-symbols-outlined text-base text-[var(--color-neutral-600)]">tune</span>
      Filtros de Búsqueda
      <span id="filters-chevron" class="material-symbols-outlined ml-auto text-base transition-transform">expand_more</span>
    </button>
    <div id="filters-body" class="px-5 pb-5">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 items-end">
        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-[var(--color-neutral-600)] mb-1">Estado</label>
          <select id="filter-status" class="w-full border border-[var(--color-neutral-200)] rounded-lg px-3 py-2 text-sm text-[var(--color-neutral-900)] bg-white">
            <option value="">Todos los estados</option>
            <option value="incomplete">Incompleto</option>
            <option value="onboarding">Onboarding</option>
            <option value="pending_review">Pendiente revisión</option>
            <option value="active">Activo</option>
            <option value="rejected">Rechazado</option>
            <option value="suspended">Suspendido</option>
            <option value="waiting_payment">Esperando pago</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-[var(--color-neutral-600)] mb-1">Acceso</label>
          <select id="filter-is-active" class="w-full border border-[var(--color-neutral-200)] rounded-lg px-3 py-2 text-sm text-[var(--color-neutral-900)] bg-white">
            <option value="">Todos</option>
            <option value="true">Activo</option>
            <option value="false">Inactivo</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-[var(--color-neutral-600)] mb-1">País</label>
          <select id="filter-country" class="w-full border border-[var(--color-neutral-200)] rounded-lg px-3 py-2 text-sm text-[var(--color-neutral-900)] bg-white">
            <option value="">Seleccionar País</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-[var(--color-neutral-600)] mb-1">Provincia</label>
          <select id="filter-province" class="w-full border border-[var(--color-neutral-200)] rounded-lg px-3 py-2 text-sm text-[var(--color-neutral-900)] bg-white" disabled>
            <option value="">Seleccionar Provincia</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-semibold uppercase tracking-widest text-[var(--color-neutral-600)] mb-1">Rubro</label>
          <select id="filter-rubro" class="w-full border border-[var(--color-neutral-200)] rounded-lg px-3 py-2 text-sm text-[var(--color-neutral-900)] bg-white">
            <option value="">Seleccionar Rubro</option>
          </select>
        </div>
      </div>
      <div class="flex items-center gap-3 mt-4">
        <button id="btn-search" class="inline-flex items-center gap-2 bg-[var(--color-primary)] hover:bg-[var(--color-primary-alt)] text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors">
          <span class="material-symbols-outlined text-base">search</span>
          BUSCAR
        </button>
        <button id="btn-reset" class="w-9 h-9 flex items-center justify-center border border-[var(--color-neutral-200)] rounded-full hover:bg-[var(--color-neutral-100)] transition-colors" title="Limpiar filtros">
          <span class="material-symbols-outlined text-base text-[var(--color-neutral-600)]">refresh</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Table -->
  <AdminTable title="Listado de Profesionales" columns={columns} showExportButtons={true} />

  <div id="metrics-footer" class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-2"></div>

  <script>
    import { restoreSession, getToken } from '../../../services/authService';
    import { api } from '../../../services/apiClient';
    import { fetchAllProfessionals } from '../../../services/adminService';
    import type { AdminProfessional, ProfessionalFilters } from '../../../services/adminService';
    import { fetchRubros } from '../../../services/professionCategoriesService';
    import { fetchCountries, fetchProvinces } from '../../../services/locationService';

    restoreSession();
    const token = getToken();
    if (token) api.setHeader('Authorization', `Bearer ${token}`);

    // ─── State ───────────────────────────────────────────────────
    let currentPage = 1;
    let totalPages = 1;
    const PAGE_SIZE = 15;

    const STATUS_LABELS: Record<string, string> = {
      incomplete: 'INCOMPLETO',
      onboarding: 'ONBOARDING',
      pending_review: 'PENDIENTE',
      active: 'ACTIVO',
      rejected: 'RECHAZADO',
      suspended: 'SUSPENDIDO',
      waiting_payment: 'PAGO PEND.',
    };
    const STATUS_CLASSES: Record<string, string> = {
      active: 'bg-green-100 text-green-700',
      suspended: 'bg-red-100 text-red-600',
      rejected: 'bg-red-100 text-red-600',
      pending_review: 'bg-yellow-100 text-yellow-700',
      onboarding: 'bg-blue-100 text-blue-700',
      incomplete: 'bg-gray-100 text-gray-500',
      waiting_payment: 'bg-orange-100 text-orange-600',
    };

    // ─── Populate filter dropdowns ──────────────────────────────
    async function populateFilters() {
      try {
        const [countries, rubros] = await Promise.all([fetchCountries(), fetchRubros()]);

        const countrySelect = document.getElementById('filter-country') as HTMLSelectElement;
        countries.forEach((c: any) => {
          const opt = document.createElement('option');
          opt.value = String(c.id);
          opt.textContent = c.name;
          countrySelect.appendChild(opt);
        });

        const rubroSelect = document.getElementById('filter-rubro') as HTMLSelectElement;
        rubros.forEach((r: any) => {
          const opt = document.createElement('option');
          opt.value = String(r.id);
          opt.textContent = r.name;
          rubroSelect.appendChild(opt);
        });

        // Country → Province cascade
        countrySelect.addEventListener('change', async () => {
          const provinceSelect = document.getElementById('filter-province') as HTMLSelectElement;
          provinceSelect.innerHTML = '<option value="">Seleccionar Provincia</option>';
          const countryId = countrySelect.value;
          if (!countryId) { provinceSelect.disabled = true; return; }

          try {
            const provinces = await fetchProvinces(Number(countryId));
            provinces.forEach((p: any) => {
              const opt = document.createElement('option');
              opt.value = String(p.id);
              opt.textContent = p.name;
              provinceSelect.appendChild(opt);
            });
            provinceSelect.disabled = false;
          } catch { provinceSelect.disabled = true; }
        });
      } catch (err) {
        console.error('Error loading filters:', err);
      }
    }

    // ─── Get current filters ─────────────────────────────────────
    function getFilters(): ProfessionalFilters {
      const filters: ProfessionalFilters = { sizePage: PAGE_SIZE, page: currentPage };
      const status = (document.getElementById('filter-status') as HTMLSelectElement).value;
      const isActive = (document.getElementById('filter-is-active') as HTMLSelectElement).value;
      const country = (document.getElementById('filter-country') as HTMLSelectElement).value;
      const province = (document.getElementById('filter-province') as HTMLSelectElement).value;
      const rubro = (document.getElementById('filter-rubro') as HTMLSelectElement).value;

      if (status) filters.profileStatus = status;
      if (isActive === 'true') filters.isActive = true;
      if (isActive === 'false') filters.isActive = false;
      if (country) filters.countryId = Number(country);
      if (province) filters.provinceId = Number(province);
      if (rubro) filters.rubroId = Number(rubro);
      return filters;
    }

    // ─── Render table ────────────────────────────────────────────
    function renderTable(data: AdminProfessional[], total: number, page: number, sizePage: number) {
      const tbody = document.getElementById('table-body')!;
      totalPages = Math.ceil(total / sizePage) || 1;

      if (data.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="5" class="text-center py-16 text-on-surface-variant">
              <span class="material-symbols-outlined text-4xl mb-3 block text-[var(--color-neutral-400)]" aria-hidden="true">search_off</span>
              <p class="text-sm font-medium">No se encontraron profesionales con los filtros aplicados.</p>
            </td>
          </tr>`;
      } else {
        tbody.innerHTML = data.map(p => {
          const avatarHtml = p.photo
            ? `<img src="${p.photo}" alt="${p.name}" class="w-10 h-10 rounded-full object-cover flex-shrink-0">`
            : `<div class="w-10 h-10 rounded-full bg-[var(--color-primary)] text-white flex items-center justify-center text-sm font-bold flex-shrink-0">${(p.name || '?')[0].toUpperCase()}</div>`;
          const emailDisplay = p.emailContact || p.user?.email || '';
          const location = [p.city, p.country?.name].filter(Boolean).join(', ') || '—';
          const statusLabel = STATUS_LABELS[p.profileStatus] || p.profileStatus || '—';
          const statusClass = STATUS_CLASSES[p.profileStatus] || 'bg-gray-100 text-gray-500';
          const accessBadge = p.isActive
            ? 'bg-teal-100 text-teal-800'
            : 'bg-neutral-100 text-neutral-600';
          const accessLabel = p.isActive ? 'Activo' : 'Inactivo';
          const isTrial = p.trialEndDate && new Date(p.trialEndDate) > new Date();
          const trialBadge = isTrial
            ? `<span class="ml-1 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold border border-gray-400 text-gray-500">TRIAL</span>`
            : '';

          return `
          <tr class="border-b border-outline-variant/10 hover:bg-surface-container/50 transition-colors">
            <td class="px-5 py-3">
              <div class="flex items-center gap-3">
                ${avatarHtml}
                <div>
                  <p class="font-semibold text-[var(--color-neutral-900)]">${p.name || '—'}</p>
                  <p class="text-xs text-[var(--color-neutral-400)]">${emailDisplay}</p>
                </div>
              </div>
            </td>
            <td class="px-5 py-3 text-[var(--color-neutral-600)] text-xs">${location}</td>
            <td class="px-5 py-3 text-[var(--color-neutral-600)] text-xs">${p.rubro?.name || '—'}</td>
            <td class="px-5 py-3">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold ${statusClass}">${statusLabel}</span>
              <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold ${accessBadge}">${accessLabel}</span>
              ${trialBadge}
            </td>
            <td class="px-5 py-3">
              <div class="flex items-center gap-1.5">
                <button
                  type="button"
                  class="inline-flex items-center gap-1.5 rounded-lg border border-primary/30 px-2.5 py-1.5 text-[11px] font-bold uppercase tracking-wider text-primary transition-colors hover:bg-primary/10"
                  title="Editar fecha de trial"
                  onclick="window.openTrialDateModal('${p.id}', ${p.trialEndDate ? `'${p.trialEndDate}'` : 'undefined'})"
                >
                  <svg viewBox="0 0 24 24" fill="none" class="h-3.5 w-3.5" aria-hidden="true">
                    <rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.8"></rect>
                    <path d="M8 3v4M16 3v4M3 10h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                    <path d="M12 13v3h2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                    <circle cx="12" cy="16" r="3.5" stroke="currentColor" stroke-width="1.8"></circle>
                  </svg>
                  Trial
                </button>
                ${p.profileStatus === 'pending_review' ? `
                  <a href="/admin/profesionales/detalle?id=${p.id}" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-secondary text-on-secondary hover:opacity-90 transition-all" title="Validar perfil">
                    <span class="material-symbols-outlined text-sm">verified_user</span>
                    Validar
                  </a>
                ` : ''}
                <a href="/admin/profesionales/detalle?id=${p.id}" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors" title="Editar profesional">
                  <span class="material-symbols-outlined text-sm">edit</span>
                  Editar
                </a>
              </div>
            </td>
          </tr>
        `;
        }).join('');
      }

      renderPagination(page, totalPages, total, sizePage);
    }

    function renderPagination(current: number, total: number, totalItems: number, pageSize: number) {
      const container = document.getElementById('pagination-container');
      if (!container) return;
      const from = total === 0 ? 0 : (current - 1) * pageSize + 1;
      const to = Math.min(current * pageSize, totalItems);

      const pages: (number | '...')[] = [];
      if (total <= 5) {
        for (let i = 1; i <= total; i++) pages.push(i);
      } else {
        pages.push(1);
        if (current > 3) pages.push('...');
        for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) pages.push(i);
        if (current < total - 2) pages.push('...');
        pages.push(total);
      }

      const pageButtons = pages.map(p =>
        p === '...'
          ? `<span class="px-2 py-1 text-sm text-[var(--color-neutral-400)]">…</span>`
          : `<button onclick="goToPage(${p})"
               class="w-8 h-8 flex items-center justify-center rounded text-sm font-medium transition-colors
                      ${p === current
                        ? 'bg-[var(--color-primary)] text-white'
                        : 'text-[var(--color-neutral-600)] hover:bg-[var(--color-neutral-100)]'}">${p}</button>`
      ).join('');

      container.innerHTML = `
        <span class="text-xs text-[var(--color-neutral-400)]">Mostrando ${from}–${to} de ${totalItems} profesionales</span>
        <div class="flex items-center gap-1">
          <button onclick="goToPage(${current - 1})" ${current === 1 ? 'disabled' : ''}
            class="w-8 h-8 flex items-center justify-center rounded hover:bg-[var(--color-neutral-100)] disabled:opacity-30">
            <span class="material-symbols-outlined text-base">chevron_left</span>
          </button>
          ${pageButtons}
          <button onclick="goToPage(${current + 1})" ${current === total ? 'disabled' : ''}
            class="w-8 h-8 flex items-center justify-center rounded hover:bg-[var(--color-neutral-100)] disabled:opacity-30">
            <span class="material-symbols-outlined text-base">chevron_right</span>
          </button>
        </div>
      `;
    }

    (window as any).goToPage = (page: number) => {
      if (page < 1 || page > totalPages) return;
      currentPage = page;
      loadData();
    };

    function renderMetrics(total: number, pendingCount: number) {
      const el = document.getElementById('metrics-footer');
      if (!el) return;
      el.innerHTML = `
        <div class="bg-white border border-[var(--color-neutral-200)] rounded-2xl p-5 flex items-center gap-4 border-l-4 border-l-[var(--color-primary)]">
          <span class="material-symbols-outlined text-3xl text-[var(--color-primary)]">group</span>
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-widest text-[var(--color-neutral-600)]">Total Profesionales</p>
            <p class="text-2xl font-bold text-[var(--color-neutral-900)]">${total.toLocaleString('es-AR')}</p>
          </div>
        </div>
        <div class="bg-white border border-[var(--color-neutral-200)] rounded-2xl p-5 flex items-center gap-4 border-l-4 border-l-[var(--color-warning)]">
          <span class="material-symbols-outlined text-3xl text-[var(--color-warning)]">assignment_turned_in</span>
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-widest text-[var(--color-neutral-600)]">Verificaciones Pendientes</p>
            <p class="text-2xl font-bold text-[var(--color-neutral-900)]">${pendingCount}</p>
          </div>
        </div>
        <div class="bg-white border border-[var(--color-neutral-200)] rounded-2xl p-5 flex items-center gap-4 border-l-4 border-l-[var(--color-accent-magenta)]">
          <span class="material-symbols-outlined text-3xl text-[var(--color-accent-magenta)]">trending_up</span>
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-widest text-[var(--color-neutral-600)]">Crecimiento Mensual</p>
            <p class="text-2xl font-bold text-[var(--color-neutral-900)]">+8.4%</p>
          </div>
        </div>
      `;
    }

    // ─── Load data ───────────────────────────────────────────────
    async function loadData() {
      const tbody = document.getElementById('table-body')!;
      tbody.innerHTML = `
        <tr>
          <td colspan="5" class="text-center py-12 text-on-surface-variant">
            <div class="flex flex-col items-center gap-3">
              <div class="w-8 h-8 border-3 border-primary/30 border-t-primary rounded-full animate-spin"></div>
              <span class="text-sm font-medium">Cargando...</span>
            </div>
          </td>
        </tr>`;

      try {
        const res = await fetchAllProfessionals(getFilters());
        renderTable(res.data, res.total, res.page, res.sizePage);
        const pendingCount = res.data.filter((p: AdminProfessional) => p.profileStatus === 'pending_review').length;
        renderMetrics(res.total ?? res.data.length, pendingCount);
      } catch (err: any) {
        tbody.innerHTML = `
          <tr>
            <td colspan="5" class="text-center py-12 text-error">
              <span class="material-symbols-outlined text-3xl mb-2 block" aria-hidden="true">error</span>
              <p class="text-sm font-bold">Error al cargar profesionales</p>
              <p class="text-xs mt-1">${err?.message || 'Error desconocido'}</p>
            </td>
          </tr>`;
      }
    }

    // ─── Wire events ─────────────────────────────────────────────
    const filtersToggle = document.getElementById('filters-toggle');
    const filtersBody = document.getElementById('filters-body');
    const filtersChevron = document.getElementById('filters-chevron') as HTMLSpanElement | null;
    filtersToggle?.addEventListener('click', () => {
      if (!filtersBody || !filtersChevron) return;
      const isOpen = !filtersBody.classList.contains('hidden');
      filtersBody.classList.toggle('hidden', isOpen);
      filtersChevron.style.transform = isOpen ? 'rotate(-90deg)' : '';
    });

    document.getElementById('btn-search')?.addEventListener('click', () => { currentPage = 1; loadData(); });
    document.getElementById('btn-reset')?.addEventListener('click', () => {
      (document.getElementById('filter-status') as HTMLSelectElement).value = '';
      (document.getElementById('filter-is-active') as HTMLSelectElement).value = '';
      (document.getElementById('filter-country') as HTMLSelectElement).value = '';
      (document.getElementById('filter-province') as HTMLSelectElement).value = '';
      (document.getElementById('filter-province') as HTMLSelectElement).disabled = true;
      (document.getElementById('filter-rubro') as HTMLSelectElement).value = '';
      currentPage = 1;
      loadData();
    });

    document.addEventListener('trial-date-updated', () => {
      loadData();
    });

    // ─── Init ────────────────────────────────────────────────────
    populateFilters();
    loadData();
  </script>

  <TrialDateModal />
</AdminLayout>

