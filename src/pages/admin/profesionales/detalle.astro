---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ImageOverlay from '../../../components/ImageOverlay.astro';
import ConfirmModal from '../../../components/ConfirmModal.astro';
---

<AdminLayout title="TRAMA Admin - Detalle profesional">

  <ImageOverlay />
  <ConfirmModal />

  <!-- Loading -->
  <div id="detail-loading" class="flex items-center justify-center py-24">
    <div class="flex flex-col items-center gap-4">
      <div class="w-10 h-10 border-3 border-primary/30 border-t-primary rounded-full animate-spin"></div>
      <p class="text-sm font-medium text-on-surface-variant">Cargando perfil...</p>
    </div>
  </div>

  <!-- Error -->
  <div id="detail-error" class="hidden">
    <div class="bg-error-container text-on-error-container rounded-3xl p-8 text-center">
      <span class="material-symbols-outlined text-4xl mb-4 block" aria-hidden="true">error</span>
      <h2 class="text-xl font-bold mb-2">Error al cargar el perfil</h2>
      <p id="detail-error-msg" class="text-sm opacity-80">No se pudo obtener la información.</p>
      <a href="/admin/profesionales" class="mt-6 inline-block bg-error text-on-error px-6 py-3 rounded-xl font-bold text-sm hover:opacity-90 transition-opacity">Volver al listado</a>
    </div>
  </div>

  <!-- Content -->
  <div id="detail-content" class="hidden">

    <!-- Back + Header -->
    <div class="flex items-center gap-4 mb-8">
      <a href="/admin/profesionales" class="w-10 h-10 rounded-xl bg-surface-container-low flex items-center justify-center hover:bg-surface-container-high transition-colors" title="Volver">
        <span class="material-symbols-outlined text-on-surface-variant">arrow_back</span>
      </a>
      <div class="flex-1">
        <h1 id="prof-name" class="text-3xl font-black text-on-surface tracking-tighter">—</h1>
        <div class="flex items-center gap-3 mt-1">
          <span id="prof-status-badge"></span>
          <span id="prof-email" class="text-sm text-on-surface-variant">—</span>
        </div>
      </div>
      <div id="prof-photo-wrap" class="shrink-0">
        <img id="prof-photo" src="/images/default-avatar.svg" alt="Foto" class="w-20 h-20 rounded-full object-cover border-4 border-surface-container-lowest shadow-lg" />
      </div>
    </div>

    <!-- Grid: Info panels -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

      <!-- Datos personales -->
      <div class="bg-surface-container-low rounded-2xl p-6 space-y-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="material-symbols-outlined text-primary" aria-hidden="true">person</span>
          <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Datos personales</h2>
        </div>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div><span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">DNI</span><span id="d-dni" class="text-on-surface font-medium">—</span></div>
          <div><span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Ciudad</span><span id="d-city" class="text-on-surface font-medium">—</span></div>
          <div><span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">País</span><span id="d-country" class="text-on-surface font-medium">—</span></div>
          <div><span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Provincia</span><span id="d-province" class="text-on-surface font-medium">—</span></div>
          <div><span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">WhatsApp</span><span id="d-whatsapp" class="text-on-surface font-medium">—</span></div>
          <div><span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">LinkedIn</span><span id="d-linkedin" class="text-on-surface font-medium break-all">—</span></div>
          <div><span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Modalidad</span><span id="d-modality" class="text-on-surface font-medium">—</span></div>
          <div><span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Completitud</span><span id="d-completion" class="text-on-surface font-medium">—</span></div>
        </div>
      </div>

      <!-- Perfil profesional -->
      <div class="bg-surface-container-low rounded-2xl p-6 space-y-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="material-symbols-outlined text-primary" aria-hidden="true">work</span>
          <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Perfil profesional</h2>
        </div>
        <div>
          <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Rubro</span>
          <span id="d-rubro" class="text-on-surface font-medium text-sm">—</span>
        </div>
        <div>
          <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Especialidades</span>
          <div id="d-professions" class="flex flex-wrap gap-1.5 mt-1"></div>
        </div>
        <div>
          <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Servicios</span>
          <div id="d-services" class="flex flex-wrap gap-1.5 mt-1"></div>
        </div>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div><span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Precio USD/h</span><span id="d-price-usd" class="text-on-surface font-medium">—</span></div>
          <div><span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Precio ARS/h</span><span id="d-price-ars" class="text-on-surface font-medium">—</span></div>
        </div>
        <div>
          <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Bio</span>
          <p id="d-bio" class="text-on-surface text-sm leading-relaxed">—</p>
        </div>
      </div>
    </div>

    <!-- Motivación -->
    <div class="bg-surface-container-low rounded-2xl p-6 mb-6">
      <div class="flex items-center gap-2 mb-3">
        <span class="material-symbols-outlined text-primary" aria-hidden="true">emoji_objects</span>
        <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Motivación</h2>
      </div>
      <p id="d-motivation" class="text-on-surface text-sm leading-relaxed">—</p>
    </div>

    <!-- Documentos -->
    <div class="bg-surface-container-low rounded-2xl p-6 mb-6">
      <div class="flex items-center gap-2 mb-4">
        <span class="material-symbols-outlined text-primary" aria-hidden="true">folder_open</span>
        <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Documentos</h2>
      </div>

      <!-- Identity (DNI) -->
      <div class="mb-4">
        <h3 class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-3">Documento de identidad</h3>
        <div id="d-identity" class="grid grid-cols-2 gap-4">
          <div class="border border-dashed border-outline-variant/30 rounded-xl p-4 text-center text-sm text-on-surface-variant">Sin documento frente</div>
          <div class="border border-dashed border-outline-variant/30 rounded-xl p-4 text-center text-sm text-on-surface-variant">Sin documento dorso</div>
        </div>
      </div>

      <!-- Other documents -->
      <h3 class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-3">Otros documentos (CV, títulos, certificados)</h3>
      <div class="rounded-xl overflow-hidden border border-outline-variant/10">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-outline-variant/15 bg-surface-container">
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Documento</th>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Tipo</th>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Fecha</th>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Estado</th>
                <th class="text-center px-5 py-3 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Acciones</th>
              </tr>
            </thead>
            <tbody id="d-documents">
              <tr>
                <td colspan="5" class="text-center py-8 text-on-surface-variant">
                  <div class="flex flex-col items-center gap-2">
                    <div class="w-6 h-6 border-2 border-primary/30 border-t-primary rounded-full animate-spin"></div>
                    <span class="text-xs font-medium">Cargando documentos...</span>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Historial de validaciones -->
    <div class="bg-surface-container-low rounded-2xl p-6 mb-6">
      <div class="flex items-center gap-2 mb-4">
        <span class="material-symbols-outlined text-primary" aria-hidden="true">history</span>
        <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Historial de validaciones</h2>
      </div>
      <div id="d-history" class="space-y-3">
        <p class="text-sm text-on-surface-variant py-3 text-center border border-dashed border-outline-variant/20 rounded-xl">Sin historial</p>
      </div>
    </div>

    <!-- Validation panel (only for pending_review) -->
    <div id="validation-panel" class="hidden bg-surface-container-low rounded-2xl p-6 mb-6 border-2 border-secondary/30">
      <div class="flex items-center gap-2 mb-4">
        <span class="material-symbols-outlined text-secondary" aria-hidden="true">verified_user</span>
        <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Validar perfil</h2>
      </div>

      <div class="mb-4">
        <label for="v-notes" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Notas de revisión</label>
        <textarea id="v-notes" rows="4" placeholder="Observaciones sobre el perfil, documentos revisados, motivo de rechazo..."
          class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface text-sm font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all resize-none"></textarea>
      </div>

      <div class="flex gap-3">
        <button id="btn-reject" type="button"
          class="flex-1 px-6 py-3 rounded-xl font-bold text-sm bg-error text-on-error hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-lg">cancel</span>
          Rechazar
        </button>
        <button id="btn-approve" type="button"
          class="flex-1 px-6 py-3 rounded-xl font-bold text-sm bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-lg">check_circle</span>
          Aprobar
        </button>
      </div>
    </div>

  </div>

  <!-- Toast -->
  <div id="toast" class="fixed top-6 right-6 z-[80] hidden transition-all duration-300 translate-y-[-1rem] opacity-0">
    <div id="toast-inner" class="flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm">
      <span id="toast-icon" class="material-symbols-outlined text-xl" aria-hidden="true"></span>
      <span id="toast-msg"></span>
    </div>
  </div>

  <script>
    import { restoreSession, getToken } from '../../../services/authService';
    import { api } from '../../../services/apiClient';
    import {
      fetchProfessionalDetail,
      fetchProfessionalDocuments,
      fetchValidationHistory,
      validateProfile,
      verifyDocument,
    } from '../../../services/adminService';
    import type { AdminProfessional, ProfessionalDocument, ValidationRecord } from '../../../services/adminService';
    import { getProfilePhotoUrl } from '../../../services/profileService';

    restoreSession();
    const token = getToken();
    if (token) api.setHeader('Authorization', `Bearer ${token}`);

    // Extract ID from query param: /admin/profesionales/detalle?id=xxx
    const profileId = new URLSearchParams(window.location.search).get('id') || '';

    const DEFAULT_AVATAR = '/images/default-avatar.svg';

    const STATUS_MAP: Record<string, { label: string; cls: string }> = {
      incomplete:      { label: 'Incompleto',    cls: 'bg-outline/10 text-outline' },
      onboarding:      { label: 'Onboarding',    cls: 'bg-tertiary-container text-on-tertiary-container' },
      pending_review:  { label: 'Pendiente',     cls: 'bg-secondary-container text-on-secondary-container' },
      active:          { label: 'Activo',         cls: 'bg-primary-container text-on-primary-container' },
      rejected:        { label: 'Rechazado',      cls: 'bg-error-container text-on-error-container' },
      suspended:       { label: 'Suspendido',     cls: 'bg-error/10 text-error' },
    };

    function statusBadge(status: string): string {
      const s = STATUS_MAP[status] || { label: status, cls: 'bg-outline/10 text-outline' };
      return `<span class="inline-block px-2.5 py-1 rounded-lg text-[11px] font-bold uppercase tracking-wider ${s.cls}">${s.label}</span>`;
    }

    function formatDate(iso: string): string {
      if (!iso) return '—';
      try {
        const d = new Date(iso);
        if (isNaN(d.getTime())) return '—';
        return d.toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
      } catch { return '—'; }
    }

    // ─── Toast ───────────────────────────────────────────────────
    let toastTimeout: ReturnType<typeof setTimeout>;
    function showToast(msg: string, type: 'success' | 'error' = 'success') {
      const toast = document.getElementById('toast')!;
      const inner = document.getElementById('toast-inner')!;
      const icon = document.getElementById('toast-icon')!;
      const msgEl = document.getElementById('toast-msg')!;

      inner.className = type === 'success'
        ? 'flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm bg-primary text-on-primary'
        : 'flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm bg-error text-on-error';
      icon.textContent = type === 'success' ? 'check_circle' : 'error';
      msgEl.textContent = msg;

      toast.classList.remove('hidden');
      requestAnimationFrame(() => { toast.classList.remove('translate-y-[-1rem]', 'opacity-0'); toast.classList.add('translate-y-0', 'opacity-100'); });
      clearTimeout(toastTimeout);
      toastTimeout = setTimeout(() => {
        toast.classList.add('translate-y-[-1rem]', 'opacity-0');
        toast.classList.remove('translate-y-0', 'opacity-100');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, 4000);
    }

    // ─── Populate detail ─────────────────────────────────────────
    function populateProfile(p: AdminProfessional) {
      document.getElementById('prof-name')!.textContent = p.name || '—';
      document.getElementById('prof-status-badge')!.innerHTML = statusBadge(p.profileStatus);
      document.getElementById('prof-email')!.textContent = p.user?.email || p.emailContact || '—';

      // Photo
      const photo = document.getElementById('prof-photo') as HTMLImageElement;
      if (p.photo) {
        const url = getProfilePhotoUrl(p.id);
        photo.onerror = () => { photo.onerror = null; photo.src = DEFAULT_AVATAR; };
        photo.src = url;
      }

      // Personal
      document.getElementById('d-dni')!.textContent = p.dni || '—';
      document.getElementById('d-city')!.textContent = p.city || '—';
      document.getElementById('d-country')!.textContent = p.country?.name || '—';
      document.getElementById('d-province')!.textContent = p.province?.name || '—';
      document.getElementById('d-whatsapp')!.textContent = p.whatsapp || '—';
      document.getElementById('d-linkedin')!.textContent = p.linkedin || '—';
      document.getElementById('d-modality')!.textContent = p.workModality || '—';
      document.getElementById('d-completion')!.textContent = `${p.completionPct}%`;

      // Professional
      document.getElementById('d-rubro')!.textContent = p.rubro?.name || '—';
      document.getElementById('d-bio')!.textContent = p.bio || '—';
      document.getElementById('d-price-usd')!.textContent = p.pricePerHour ? `U$ ${p.pricePerHour}` : '—';
      document.getElementById('d-price-ars')!.textContent = p.priceMin ? `$ ${p.priceMin}` : '—';
      document.getElementById('d-motivation')!.textContent = p.tramaMotivation || '—';

      // Professions
      const profsEl = document.getElementById('d-professions')!;
      if (p.professionCategories?.length) {
        profsEl.innerHTML = p.professionCategories.map(pc =>
          `<span class="inline-block px-2.5 py-1 rounded-lg text-[11px] font-bold bg-primary-container text-on-primary-container">${pc.name}</span>`
        ).join('');
      } else {
        profsEl.innerHTML = '<span class="text-sm text-on-surface-variant">—</span>';
      }

      // Services
      const servEl = document.getElementById('d-services')!;
      if (p.services?.length) {
        servEl.innerHTML = p.services.map(s =>
          `<span class="inline-block px-2.5 py-1 rounded-lg text-[11px] font-bold bg-secondary-container text-on-secondary-container">${s}</span>`
        ).join('');
      } else {
        servEl.innerHTML = '<span class="text-sm text-on-surface-variant">—</span>';
      }

      // Show validation panel only for pending_review
      if (p.profileStatus === 'pending_review') {
        document.getElementById('validation-panel')!.classList.remove('hidden');
      }
    }

    function populateIdentity(profileId: string, frontUrl: string | null, backUrl: string | null) {
      const container = document.getElementById('d-identity')!;
      const baseUrl = (import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:3000').replace(/\/+$/, '');

      const sides: { key: string; label: string; hasUrl: boolean }[] = [
        { key: 'front', label: 'Frente', hasUrl: !!frontUrl },
        { key: 'back', label: 'Dorso', hasUrl: !!backUrl },
      ];

      container.innerHTML = sides.map(s => `
        <div class="border border-outline-variant/20 rounded-xl p-3 text-center">
          <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">${s.label}</p>
          ${s.hasUrl
            ? `<div class="relative group">
                <div id="id-img-wrap-${s.key}" class="w-full h-36 flex items-center justify-center bg-surface-container rounded-lg overflow-hidden">
                  <div class="w-6 h-6 border-2 border-primary/30 border-t-primary rounded-full animate-spin"></div>
                </div>
                <div class="flex items-center justify-center gap-2 mt-2">
                  <button type="button" id="id-zoom-${s.key}" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors" disabled>
                    <span class="material-symbols-outlined text-sm">search</span> Ver
                  </button>
                  <button type="button" id="id-dl-${s.key}" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors" disabled>
                    <span class="material-symbols-outlined text-sm">download</span> Descargar
                  </button>
                </div>
              </div>`
            : '<p class="text-sm text-on-surface-variant py-6">No subido</p>'
          }
        </div>
      `).join('');

      // Load images with auth
      sides.filter(s => s.hasUrl).forEach(s => {
        const url = `${baseUrl}/uploads/identity/${profileId}/${s.key}`;
        fetchAuthBlob(url).then(({ blobUrl }) => {
          // Show thumbnail
          const wrap = document.getElementById(`id-img-wrap-${s.key}`)!;
          wrap.innerHTML = `<img src="${blobUrl}" alt="DNI ${s.label}" class="w-full h-36 object-cover rounded-lg cursor-pointer" />`;
          wrap.querySelector('img')!.addEventListener('click', () => {
            (window as any).openImageOverlay(blobUrl, `DNI ${s.label}`, `dni-${s.key}.jpg`);
          });

          // Enable buttons
          const zoomBtn = document.getElementById(`id-zoom-${s.key}`) as HTMLButtonElement;
          const dlBtn = document.getElementById(`id-dl-${s.key}`) as HTMLButtonElement;
          zoomBtn.disabled = false;
          dlBtn.disabled = false;

          zoomBtn.addEventListener('click', () => {
            (window as any).openImageOverlay(blobUrl, `DNI ${s.label}`, `dni-${s.key}.jpg`);
          });
          dlBtn.addEventListener('click', () => {
            const a = document.createElement('a');
            a.href = blobUrl;
            a.download = `dni-${s.key}.jpg`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          });
        }).catch(() => {
          const wrap = document.getElementById(`id-img-wrap-${s.key}`)!;
          wrap.innerHTML = '<p class="text-xs text-error py-4">Error al cargar imagen</p>';
        });
      });
    }

    async function fetchAuthBlob(url: string): Promise<{ blobUrl: string; mimeType: string }> {
      const res = await fetch(url, {
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!res.ok) throw new Error(`${res.status}`);
      const blob = await res.blob();
      return { blobUrl: URL.createObjectURL(blob), mimeType: blob.type };
    }

    function populateDocuments(docs: ProfessionalDocument[]) {
      const tbody = document.getElementById('d-documents')!;
      if (!docs.length) {
        tbody.innerHTML = `<tr><td colspan="5" class="text-center py-8 text-on-surface-variant text-sm">Sin documentos adicionales</td></tr>`;
        return;
      }

      const TYPE_LABELS: Record<string, string> = { cv: 'CV', title: 'Título', certificate: 'Certificado', dni: 'DNI' };
      const STATUS_LABELS: Record<string, { label: string; cls: string }> = {
        pending:  { label: 'Pendiente',  cls: 'bg-secondary-container text-on-secondary-container' },
        approved: { label: 'Aprobado',   cls: 'bg-primary-container text-on-primary-container' },
        rejected: { label: 'Rechazado',  cls: 'bg-error-container text-on-error-container' },
      };

      tbody.innerHTML = docs.map(doc => {
        const docStatus = doc.verificationStatus ?? doc.status ?? '';
        const ds = STATUS_LABELS[docStatus] || { label: 'Sin revisar', cls: 'bg-outline/10 text-outline' };
        const isCv = doc.type === 'cv';
        const canVerify = !isCv && docStatus !== 'approved' && docStatus !== 'rejected';

        return `
          <tr class="doc-row border-b border-outline-variant/10 hover:bg-surface-container/50 transition-all cursor-pointer" data-doc-row="${doc.id}">
            <td class="px-5 py-3">
              <div class="flex items-center gap-2.5">
                <span class="material-symbols-outlined text-primary text-lg shrink-0">description</span>
                <span class="font-bold text-on-surface text-sm truncate max-w-[220px]">${doc.originalName || TYPE_LABELS[doc.type] || doc.type}</span>
              </div>
            </td>
            <td class="px-5 py-3 text-on-surface-variant text-xs">${TYPE_LABELS[doc.type] || doc.type}</td>
            <td class="px-5 py-3 text-on-surface-variant text-xs">${formatDate(doc.createdAt)}</td>
            <td class="px-5 py-3">
              <span class="doc-status-badge inline-block px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider ${ds.cls}" data-status="${docStatus}">${ds.label}</span>
            </td>
            <td class="px-5 py-3">
              <div class="flex items-center justify-center gap-1.5">
                <button type="button" class="doc-view-btn w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center hover:bg-surface-container-high transition-colors" data-doc-id="${doc.id}" data-doc-name="${doc.originalName || doc.type}" title="Ver documento">
                  <span class="material-symbols-outlined text-on-surface-variant text-sm">visibility</span>
                </button>
                <button type="button" class="doc-dl-btn w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center hover:bg-surface-container-high transition-colors" data-doc-id="${doc.id}" data-doc-name="${doc.originalName || doc.type}" title="Descargar">
                  <span class="material-symbols-outlined text-on-surface-variant text-sm">download</span>
                </button>
                ${canVerify ? `
                  <button type="button" class="doc-approve-btn w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center hover:bg-primary/20 transition-colors" data-doc-id="${doc.id}" title="Aprobar">
                    <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
                  </button>
                  <button type="button" class="doc-reject-btn w-8 h-8 rounded-lg bg-error/10 flex items-center justify-center hover:bg-error/20 transition-colors" data-doc-id="${doc.id}" title="Rechazar">
                    <span class="material-symbols-outlined text-error text-sm">cancel</span>
                  </button>
                ` : ''}
              </div>
            </td>
          </tr>`;
      }).join('');

      // ─── Row highlight on any action ───────────────────────────
      function highlightRow(docId: string) {
        tbody.querySelectorAll('.doc-row').forEach(r => {
          r.classList.remove('bg-primary/5', 'border-l-4', 'border-l-primary');
        });
        const row = tbody.querySelector(`[data-doc-row="${docId}"]`);
        if (row) {
          row.classList.add('bg-primary/5', 'border-l-4', 'border-l-primary');
        }
      }

      // Also highlight on row click
      tbody.querySelectorAll('.doc-row').forEach(row => {
        row.addEventListener('click', (e) => {
          // Don't highlight if clicking a button (buttons handle their own highlight)
          if ((e.target as HTMLElement).closest('button')) return;
          const docId = row.getAttribute('data-doc-row')!;
          highlightRow(docId);
        });
      });

      // Wire view buttons
      tbody.querySelectorAll('.doc-view-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const docId = btn.getAttribute('data-doc-id')!;
          highlightRow(docId);
          handleDocView(docId, btn.getAttribute('data-doc-name')!);
        });
      });

      // Wire download buttons
      tbody.querySelectorAll('.doc-dl-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const docId = btn.getAttribute('data-doc-id')!;
          highlightRow(docId);
          handleDocDownload(docId, btn.getAttribute('data-doc-name')!);
        });
      });

      // Wire approve/reject buttons
      tbody.querySelectorAll('.doc-approve-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const docId = btn.getAttribute('data-doc-id')!;
          highlightRow(docId);
          handleDocVerify(docId, 'approved');
        });
      });
      tbody.querySelectorAll('.doc-reject-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const docId = btn.getAttribute('data-doc-id')!;
          highlightRow(docId);
          handleDocVerify(docId, 'rejected');
        });
      });
    }

    async function handleDocView(docId: string, docName: string) {
      const btn = document.querySelector(`.doc-view-btn[data-doc-id="${docId}"]`) as HTMLButtonElement;
      if (btn) btn.disabled = true;
      try {
        const { blobUrl, mimeType } = await fetchAuthBlob(`${baseUrl}/uploads/document/${docId}`);
        (window as any).openImageOverlay(blobUrl, docName, docName, mimeType);
      } catch {
        showToast('Error al cargar el documento', 'error');
      } finally {
        if (btn) btn.disabled = false;
      }
    }

    async function handleDocDownload(docId: string, docName: string) {
      const btn = document.querySelector(`.doc-dl-btn[data-doc-id="${docId}"]`) as HTMLButtonElement;
      if (btn) btn.disabled = true;
      try {
        const { blobUrl } = await fetchAuthBlob(`${baseUrl}/uploads/document/${docId}`);
        const a = document.createElement('a');
        a.href = blobUrl;
        a.download = docName;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      } catch {
        showToast('Error al descargar el documento', 'error');
      } finally {
        if (btn) btn.disabled = false;
      }
    }

    async function handleDocVerify(docId: string, status: 'approved' | 'rejected') {
      const row = document.querySelector(`[data-doc-row="${docId}"]`) as HTMLElement;
      if (!row) return;

      const btns = row.querySelectorAll('button') as NodeListOf<HTMLButtonElement>;
      btns.forEach(b => b.disabled = true);

      try {
        await verifyDocument(docId, { status });

        // Update badge
        const badge = row.querySelector('.doc-status-badge')!;
        if (status === 'approved') {
          badge.className = 'doc-status-badge inline-block px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-primary-container text-on-primary-container';
          badge.textContent = 'Aprobado';
          badge.setAttribute('data-status', 'approved');
        } else {
          badge.className = 'doc-status-badge inline-block px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-error-container text-on-error-container';
          badge.textContent = 'Rechazado';
          badge.setAttribute('data-status', 'rejected');
        }

        // Remove approve/reject buttons, re-enable view/download
        row.querySelectorAll('.doc-approve-btn, .doc-reject-btn').forEach(b => b.remove());
        row.querySelectorAll('.doc-view-btn, .doc-dl-btn').forEach(b => (b as HTMLButtonElement).disabled = false);

        showToast(status === 'approved' ? 'Documento aprobado' : 'Documento rechazado');
      } catch (err: any) {
        showToast(err?.body?.message || err?.message || 'Error al verificar documento', 'error');
        btns.forEach(b => b.disabled = false);
      }
    }

    function populateHistory(records: ValidationRecord[]) {
      const container = document.getElementById('d-history')!;
      if (!records.length) {
        container.innerHTML = '<p class="text-sm text-on-surface-variant py-3 text-center border border-dashed border-outline-variant/20 rounded-xl">Sin historial de validaciones</p>';
        return;
      }

      const V_STATUS: Record<string, { label: string; cls: string }> = {
        manual_approved: { label: 'Aprobado',  cls: 'text-primary' },
        manual_rejected: { label: 'Rechazado', cls: 'text-error' },
      };

      container.innerHTML = records.map(r => {
        const vs = V_STATUS[r.status] || { label: r.status, cls: 'text-on-surface' };
        return `
          <div class="p-3 bg-surface-container-lowest rounded-xl border border-outline-variant/10">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-bold ${vs.cls}">${vs.label}</span>
              <span class="text-[11px] text-on-surface-variant">${formatDate(r.createdAt)}</span>
            </div>
            ${r.reviewer ? `<p class="text-[11px] text-on-surface-variant">Por: ${r.reviewer.email}</p>` : ''}
            ${r.reviewNotes ? `<p class="text-sm text-on-surface mt-1">${r.reviewNotes}</p>` : ''}
          </div>`;
      }).join('');
    }

    // ─── Validation actions ──────────────────────────────────────
    async function doValidate(status: 'manual_approved' | 'manual_rejected') {
      const notes = (document.getElementById('v-notes') as HTMLTextAreaElement).value.trim();
      const btnApprove = document.getElementById('btn-approve') as HTMLButtonElement;
      const btnReject = document.getElementById('btn-reject') as HTMLButtonElement;
      btnApprove.disabled = true;
      btnReject.disabled = true;

      try {
        // Collect IDs of documents already verified (approved or rejected)
        const reviewedDocIds = Array.from(document.querySelectorAll('#d-documents .doc-status-badge'))
          .filter(badge => {
            const st = badge.getAttribute('data-status');
            return st === 'approved' || st === 'rejected';
          })
          .map(badge => badge.closest('tr')!.getAttribute('data-doc-row')!)
          .filter(Boolean);

        await validateProfile(profileId, {
          status,
          reviewNotes: notes || undefined,
          documentsReviewed: reviewedDocIds.length ? reviewedDocIds : undefined,
        });
        showToast(status === 'manual_approved' ? 'Perfil aprobado exitosamente' : 'Perfil rechazado', 'success');
        // Hide validation panel
        document.getElementById('validation-panel')!.classList.add('hidden');
        // Update status badge
        const newStatus = status === 'manual_approved' ? 'active' : 'rejected';
        document.getElementById('prof-status-badge')!.innerHTML = statusBadge(newStatus);
      } catch (err: any) {
        showToast(err?.body?.message || err?.message || 'Error al validar', 'error');
      } finally {
        btnApprove.disabled = false;
        btnReject.disabled = false;
      }
    }

    document.getElementById('btn-approve')?.addEventListener('click', () => {
      const profName = document.getElementById('prof-name')?.textContent || 'este profesional';
      (window as any).openConfirmModal({
        title: 'Confirmar aprobación',
        body: `¿Estás seguro de aprobar el perfil de ${profName}? El profesional será marcado como activo y visible en la plataforma.`,
        confirmText: 'Aprobar',
        cancelText: 'Cancelar',
        confirmStyle: 'primary',
        onConfirm: () => doValidate('manual_approved'),
      });
    });

    document.getElementById('btn-reject')?.addEventListener('click', () => {
      const profName = document.getElementById('prof-name')?.textContent || 'este profesional';
      (window as any).openConfirmModal({
        title: 'Confirmar rechazo',
        body: `¿Estás seguro de rechazar el perfil de ${profName}? El profesional será notificado y deberá corregir su perfil.`,
        confirmText: 'Rechazar',
        cancelText: 'Cancelar',
        confirmStyle: 'error',
        onConfirm: () => doValidate('manual_rejected'),
      });
    });

    // ─── Init ────────────────────────────────────────────────────
    async function init() {
      if (!profileId) {
        document.getElementById('detail-loading')!.classList.add('hidden');
        document.getElementById('detail-error')!.classList.remove('hidden');
        document.getElementById('detail-error-msg')!.textContent = 'ID de profesional no encontrado';
        return;
      }

      try {
        // Fetch profile, documents, history in parallel
        const [profile, docs, history] = await Promise.all([
          fetchProfessionalDetail(profileId),
          fetchProfessionalDocuments(profileId).catch(() => [] as ProfessionalDocument[]),
          fetchValidationHistory(profileId).catch(() => [] as ValidationRecord[]),
        ]);

        populateProfile(profile);
        populateIdentity(profileId, profile.identityFrontUrl, profile.identityBackUrl);
        populateDocuments(docs);
        populateHistory(history);

        document.getElementById('detail-loading')!.classList.add('hidden');
        document.getElementById('detail-content')!.classList.remove('hidden');
      } catch (err: any) {
        document.getElementById('detail-loading')!.classList.add('hidden');
        document.getElementById('detail-error')!.classList.remove('hidden');
        document.getElementById('detail-error-msg')!.textContent = err?.message || 'Error desconocido';
      }
    }

    init();
  </script>
</AdminLayout>
