---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ImageOverlay from '../../../components/ImageOverlay.astro';
import ConfirmModal from '../../../components/ConfirmModal.astro';
---

<AdminLayout title="TRAMA Admin - Detalle profesional">

  <ImageOverlay />
  <ConfirmModal />

  <!-- Loading -->
  <div id="detail-loading" class="flex items-center justify-center py-24">
    <div class="flex flex-col items-center gap-4">
      <div class="w-10 h-10 border-3 border-primary/30 border-t-primary rounded-full animate-spin"></div>
      <p class="text-sm font-medium text-on-surface-variant">Cargando perfil...</p>
    </div>
  </div>

  <!-- Error -->
  <div id="detail-error" class="hidden">
    <div class="bg-error-container text-on-error-container rounded-3xl p-8 text-center">
      <span class="material-symbols-outlined text-4xl mb-4 block" aria-hidden="true">error</span>
      <h2 class="text-xl font-bold mb-2">Error al cargar el perfil</h2>
      <p id="detail-error-msg" class="text-sm opacity-80">No se pudo obtener la información.</p>
      <a href="/admin/profesionales" class="mt-6 inline-block bg-error text-on-error px-6 py-3 rounded-xl font-bold text-sm hover:opacity-90 transition-opacity">Volver al listado</a>
    </div>
  </div>

  <!-- Content -->
  <div id="detail-content" class="hidden">

    <!-- Back + Header -->
    <div class="flex items-center gap-4 mb-8">
      <a href="/admin/profesionales" class="w-10 h-10 rounded-xl bg-surface-container-low flex items-center justify-center hover:bg-surface-container-high transition-colors" title="Volver">
        <span class="material-symbols-outlined text-on-surface-variant">arrow_back</span>
      </a>
      <div class="flex-1">
        <h1 id="prof-name" class="text-3xl font-black text-on-surface tracking-tighter">—</h1>
        <div class="flex items-center flex-wrap gap-x-3 gap-y-1 mt-1">
          <span id="prof-status-badge"></span>
          <span id="prof-email" class="text-sm text-on-surface-variant">—</span>
          <span id="prof-email-verified" class="hidden items-center gap-1 px-2 py-0.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-primary/10 text-primary">
            <span class="material-symbols-outlined text-sm" aria-hidden="true">verified</span>
            Verificado
          </span>
          <button
            id="btn-resend-verification"
            type="button"
            class="hidden items-center gap-1.5 px-2.5 py-1 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-tertiary-fixed text-on-tertiary-fixed-variant hover:opacity-90 active:scale-[0.98] transition-all disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span class="material-symbols-outlined text-sm" aria-hidden="true">mail</span>
            <span id="btn-resend-verification-text">Enviar email de confirmación</span>
          </button>
        </div>
      </div>
      <div id="prof-photo-wrap" class="shrink-0">
        <img id="prof-photo" src="/images/default-avatar.svg" alt="Foto" class="w-20 h-20 rounded-full object-cover border-4 border-surface-container-lowest shadow-lg" />
        <div class="mt-2 flex flex-col items-center gap-1">
          <input id="prof-photo-input" type="file" accept="image/*" class="hidden" />
          <button
            id="btn-change-photo"
            type="button"
            class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors"
          >
            <span class="material-symbols-outlined text-sm" aria-hidden="true">photo_camera</span>
            Cambiar foto
          </button>
          <span id="prof-photo-feedback" class="hidden text-[11px] text-on-surface-variant">Subiendo...</span>
        </div>
      </div>
      <div class="ml-2 flex items-center gap-2">
        <button
          id="btn-edit-mode"
          type="button"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl font-bold text-sm bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all"
        >
          <span class="material-symbols-outlined text-lg" aria-hidden="true">edit</span>
          Editar
        </button>
        <button
          id="btn-save-edit"
          type="button"
          class="hidden inline-flex items-center gap-2 px-4 py-2.5 rounded-xl font-bold text-sm bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all disabled:opacity-70 disabled:cursor-not-allowed"
        >
          <span class="material-symbols-outlined text-lg" aria-hidden="true">save</span>
          Guardar
        </button>
        <button
          id="btn-cancel-edit"
          type="button"
          class="hidden inline-flex items-center gap-2 px-4 py-2.5 rounded-xl font-bold text-sm bg-surface-container text-on-surface hover:bg-surface-container-high active:scale-[0.98] transition-all"
        >
          <span class="material-symbols-outlined text-lg" aria-hidden="true">close</span>
          Cancelar
        </button>
      </div>
    </div>

    <!-- Grid: Info panels -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

      <!-- Datos personales -->
      <div class="bg-surface-container-low rounded-2xl p-6 space-y-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="material-symbols-outlined text-primary" aria-hidden="true">person</span>
          <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Datos personales</h2>
        </div>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Nombre</span>
            <span id="d-firstName" class="display-field text-on-surface font-medium">—</span>
            <input id="e-firstName" type="text" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
          </div>
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Apellido</span>
            <span id="d-lastName" class="display-field text-on-surface font-medium">—</span>
            <input id="e-lastName" type="text" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
          </div>
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">DNI</span>
            <span id="d-dni" class="display-field text-on-surface font-medium">—</span>
            <input id="e-dni" type="text" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
          </div>
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Ciudad</span>
            <span id="d-city" class="display-field text-on-surface font-medium">—</span>
            <input id="e-city" type="text" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
          </div>
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">País</span>
            <span id="d-country" class="display-field text-on-surface font-medium">—</span>
            <select id="e-country" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20">
              <option value="">Seleccioná país</option>
            </select>
          </div>
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Provincia</span>
            <span id="d-province" class="display-field text-on-surface font-medium">—</span>
            <select id="e-province" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20">
              <option value="">Seleccioná provincia</option>
            </select>
          </div>
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">WhatsApp</span>
            <span id="d-whatsapp" class="display-field text-on-surface font-medium">—</span>
            <input id="e-whatsapp" type="text" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
          </div>
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">LinkedIn</span>
            <span id="d-linkedin" class="display-field text-on-surface font-medium break-all">—</span>
            <input id="e-linkedin" type="url" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
          </div>
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Modalidad</span>
            <span id="d-modality" class="display-field text-on-surface font-medium">—</span>
            <select id="e-modality" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20">
              <option value="">Seleccioná modalidad</option>
              <option value="presencial">Presencial</option>
              <option value="online">Online</option>
              <option value="ambas">Ambas</option>
            </select>
          </div>
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Completitud</span>
            <span id="d-completion" class="display-field text-on-surface font-medium">—</span>
          </div>
        </div>
      </div>

      <!-- Perfil profesional -->
      <div class="bg-surface-container-low rounded-2xl p-6 space-y-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="material-symbols-outlined text-primary" aria-hidden="true">work</span>
          <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Perfil profesional</h2>
        </div>
        <div>
          <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Rubro</span>
          <span id="d-rubro" class="display-field text-on-surface font-medium text-sm">—</span>
          <select id="e-rubro" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 mt-1">
            <option value="">Seleccioná rubro</option>
          </select>
        </div>
        <div>
          <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Especialidades</span>
          <div id="d-professions" class="display-field flex flex-wrap gap-1.5 mt-1"></div>
          <div id="e-professions-wrap" class="edit-input hidden space-y-2 mt-1">
            <p id="e-profession-count" class="text-xs text-on-surface-variant">0/5 seleccionadas</p>
            <div id="e-profession-groups" class="space-y-3 bg-surface-container-lowest border border-outline-variant/20 rounded-xl p-3"></div>
          </div>
        </div>
        <div>
          <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Servicios</span>
          <div id="d-services" class="display-field flex flex-wrap gap-1.5 mt-1"></div>
          <div id="e-services-wrap" class="edit-input hidden space-y-2 mt-1">
            <div id="e-services-chips" class="flex flex-wrap gap-1.5"></div>
            <input id="e-service-input" type="text" placeholder="Escribí un servicio y Enter" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
          </div>
        </div>
        <div class="grid grid-cols-1 gap-4 text-sm">
          <div>
            <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Precio por hora</span>
            <span id="d-price-usd" class="display-field text-on-surface font-medium">—</span>
            <input id="e-price-usd" type="number" min="0" step="0.01" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
          </div>
        </div>
        <div>
          <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-1">Bio</span>
          <p id="d-bio" class="display-field text-on-surface text-sm leading-relaxed">—</p>
          <textarea id="e-bio" rows="4" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 resize-y">—</textarea>
        </div>
      </div>
    </div>

    <!-- Motivación -->
    <div class="bg-surface-container-low rounded-2xl p-6 mb-6">
      <div class="flex items-center gap-2 mb-3">
        <span class="material-symbols-outlined text-primary" aria-hidden="true">emoji_objects</span>
        <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Motivación</h2>
      </div>
      <p id="d-motivation" class="display-field text-on-surface text-sm leading-relaxed">—</p>
      <textarea id="e-motivation" rows="4" class="edit-input hidden w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2 text-on-surface text-sm font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 resize-y"></textarea>
    </div>

    <!-- Estado de acceso -->
    <div class="bg-surface-container-low rounded-2xl p-6 mb-6">
      <div class="flex items-center gap-2 mb-3">
        <span class="material-symbols-outlined text-primary" aria-hidden="true">toggle_on</span>
        <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Estado de acceso</h2>
      </div>
      <div class="flex flex-wrap items-center justify-between gap-4">
        <p class="text-sm text-on-surface-variant">El profesional podrá acceder al sistema</p>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="is-active-toggle" class="sr-only peer" />
          <div
            class="w-11 h-6 bg-neutral-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#087781]"
          ></div>
          <span class="ml-3 text-sm font-medium text-neutral-900">Activo</span>
        </label>
      </div>
    </div>

    <!-- Documentos -->
    <div class="bg-surface-container-low rounded-2xl p-6 mb-6">
      <div class="flex items-center gap-2 mb-4">
        <span class="material-symbols-outlined text-primary" aria-hidden="true">folder_open</span>
        <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Documentos</h2>
      </div>

      <!-- Identity (DNI) -->
      <div class="mb-4">
        <h3 class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-3">Documento de identidad</h3>
        <div id="d-identity" class="grid grid-cols-2 gap-4">
          <div class="border border-dashed border-outline-variant/30 rounded-xl p-4 text-center text-sm text-on-surface-variant">Sin documento frente</div>
          <div class="border border-dashed border-outline-variant/30 rounded-xl p-4 text-center text-sm text-on-surface-variant">Sin documento dorso</div>
        </div>
      </div>

      <!-- Other documents -->
      <h3 class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-3">Otros documentos (CV, títulos, certificados)</h3>
      <div class="rounded-xl overflow-hidden border border-outline-variant/10">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-outline-variant/15 bg-surface-container">
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Documento</th>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Tipo</th>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Fecha</th>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Estado</th>
                <th class="text-center px-5 py-3 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Acciones</th>
              </tr>
            </thead>
            <tbody id="d-documents">
              <tr>
                <td colspan="5" class="text-center py-8 text-on-surface-variant">
                  <div class="flex flex-col items-center gap-2">
                    <div class="w-6 h-6 border-2 border-primary/30 border-t-primary rounded-full animate-spin"></div>
                    <span class="text-xs font-medium">Cargando documentos...</span>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Historial de validaciones -->
    <div class="bg-surface-container-low rounded-2xl p-6 mb-6">
      <div class="flex items-center gap-2 mb-4">
        <span class="material-symbols-outlined text-primary" aria-hidden="true">history</span>
        <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Historial de validaciones</h2>
      </div>
      <div id="d-history" class="space-y-3">
        <p class="text-sm text-on-surface-variant py-3 text-center border border-dashed border-outline-variant/20 rounded-xl">Sin historial</p>
      </div>
    </div>

    <!-- Validation panel (only for pending_review) -->
    <div id="validation-panel" class="hidden bg-surface-container-low rounded-2xl p-6 mb-6 border-2 border-secondary/30">
      <div class="flex items-center gap-2 mb-4">
        <span class="material-symbols-outlined text-secondary" aria-hidden="true">verified_user</span>
        <h2 class="text-lg font-extrabold text-on-surface tracking-tight">Validar perfil</h2>
      </div>

      <div class="mb-4">
        <label for="v-notes" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">Notas de revisión</label>
        <textarea id="v-notes" rows="4" placeholder="Observaciones sobre el perfil, documentos revisados, motivo de rechazo..."
          class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface text-sm font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all resize-none"></textarea>
      </div>

      <div class="flex gap-3">
        <button id="btn-reject" type="button"
          class="flex-1 px-6 py-3 rounded-xl font-bold text-sm bg-error text-on-error hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-lg">cancel</span>
          Rechazar
        </button>
        <button id="btn-approve" type="button"
          class="flex-1 px-6 py-3 rounded-xl font-bold text-sm bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-lg">check_circle</span>
          Aprobar
        </button>
      </div>
    </div>

  </div>

  <!-- Toast -->
  <div id="toast" class="fixed top-6 right-6 z-[80] hidden transition-all duration-300 translate-y-[-1rem] opacity-0">
    <div id="toast-inner" class="flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm">
      <span id="toast-icon" class="material-symbols-outlined text-xl" aria-hidden="true"></span>
      <span id="toast-msg"></span>
    </div>
  </div>

  <!-- Document review modal -->
  <div
    id="doc-review-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="doc-review-title"
  >
    <div class="w-full max-w-5xl max-h-[92vh] bg-surface-container-low rounded-2xl shadow-2xl overflow-hidden flex flex-col">
      <div class="px-6 py-4 border-b border-outline-variant/15 flex items-start justify-between gap-4">
        <div>
          <p id="doc-review-type" class="text-[11px] font-bold uppercase tracking-widest text-on-surface-variant">Documento</p>
          <h3 id="doc-review-title" class="text-lg font-extrabold text-on-surface tracking-tight break-all">—</h3>
        </div>
        <div class="flex items-center gap-3">
          <span id="doc-review-status-badge"></span>
          <button
            id="doc-review-close"
            type="button"
            class="w-9 h-9 rounded-lg bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors"
            aria-label="Cerrar modal"
          >
            <span class="material-symbols-outlined text-base" aria-hidden="true">close</span>
          </button>
        </div>
      </div>

      <div class="p-6 overflow-y-auto space-y-4 flex-1">
        <div id="doc-review-context" class="hidden rounded-xl p-4 text-xs text-on-surface space-y-2" style="background-color: var(--color-neutral-100);">
          <p class="text-[11px] font-bold uppercase tracking-widest text-on-surface-variant">Pertenece a</p>
          <div id="doc-review-context-items" class="space-y-1"></div>
        </div>

        <div id="doc-review-loading" class="h-[52vh] rounded-xl bg-surface-container flex items-center justify-center">
          <div class="w-8 h-8 border-2 border-primary/30 border-t-primary rounded-full animate-spin"></div>
        </div>

        <div id="doc-review-media" class="hidden space-y-3">
          <div id="doc-review-image-wrap" class="hidden h-[52vh] rounded-xl border border-outline-variant/15 bg-surface-container-lowest overflow-auto flex items-center justify-center p-4">
            <img id="doc-review-image" src="" alt="Documento" class="max-h-full w-auto max-w-none select-none transition-transform duration-150" draggable="false" />
          </div>

          <iframe id="doc-review-pdf" class="hidden w-full h-[52vh] rounded-xl border border-outline-variant/15 bg-white" title="Vista previa PDF"></iframe>

          <a
            id="doc-review-open-link"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden inline-flex items-center gap-1 text-xs font-bold text-primary hover:underline"
          >
            <span class="material-symbols-outlined text-sm" aria-hidden="true">open_in_new</span>
            Abrir documento en una nueva pestaña
          </a>

          <div id="doc-review-zoom-controls" class="hidden flex items-center gap-2 justify-end">
            <button id="doc-review-zoom-out" type="button" class="w-8 h-8 rounded-lg bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors" aria-label="Alejar">
              <span class="material-symbols-outlined text-sm" aria-hidden="true">remove</span>
            </button>
            <span id="doc-review-zoom-value" class="text-xs font-bold text-on-surface-variant min-w-12 text-center">100%</span>
            <button id="doc-review-zoom-in" type="button" class="w-8 h-8 rounded-lg bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors" aria-label="Acercar">
              <span class="material-symbols-outlined text-sm" aria-hidden="true">add</span>
            </button>
          </div>
        </div>

        <div id="doc-review-error" class="hidden h-[52vh] rounded-xl border border-error/20 bg-error/10 text-error flex items-center justify-center text-sm font-medium">
          Error al cargar el documento.
        </div>
      </div>

      <div class="px-6 py-4 border-t border-outline-variant/15 bg-surface-container-lowest space-y-3">
        <div>
          <label for="doc-review-notes" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant block mb-2">Notas de verificación (opcional)</label>
          <textarea id="doc-review-notes" rows="3" placeholder="Ej: Documento legible, datos consistentes..." class="w-full bg-surface border border-outline-variant/20 rounded-xl px-4 py-2.5 text-on-surface text-sm font-medium placeholder:text-outline focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 resize-y"></textarea>
        </div>
        <div class="flex flex-wrap items-center justify-end gap-2">
          <button id="doc-review-cancel" type="button" class="px-4 py-2.5 rounded-xl font-bold text-sm bg-surface-container text-on-surface hover:bg-surface-container-high transition-colors">Cerrar</button>
          <button id="doc-review-reject" type="button" class="px-4 py-2.5 rounded-xl font-bold text-sm text-white hover:opacity-90 transition-opacity" style="background-color: var(--color-error);">Rechazar</button>
          <button id="doc-review-approve" type="button" class="px-4 py-2.5 rounded-xl font-bold text-sm text-white hover:opacity-90 transition-opacity" style="background-color: var(--color-success);">Aprobar</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { restoreSession, getToken } from '../../../services/authService';
    import { api } from '../../../services/apiClient';
    import {
      fetchProfessionalDetail,
      fetchProfessionalDocuments,
      fetchValidationHistory,
      resendVerificationEmail,
      updateProfessional,
      uploadProfessionalPhoto,
      validateProfile,
      verifyDocument,
    } from '../../../services/adminService';
    import type { AdminUpdateProfessionalPayload } from '../../../services/adminService';
    import type { AdminProfessional, ProfessionalDocument, ValidationRecord } from '../../../services/adminService';
    import { getProfilePhotoUrl } from '../../../services/profileService';
    import { fetchCountries, fetchProvinces } from '../../../services/locationService';
    import { fetchRubros, fetchProfessionsByRubro } from '../../../services/professionCategoriesService';
    import { fetchCatalog, getCatalogLabel } from '../../../services/catalogService';

    restoreSession();
    const token = getToken();
    if (token) api.setHeader('Authorization', `Bearer ${token}`);

    // Extract ID from query param: /admin/profesionales/detalle?id=xxx
    const profileId = new URLSearchParams(window.location.search).get('id') || '';

    const DEFAULT_AVATAR = '/images/default-avatar.svg';
    const baseUrl = (import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:3000').replace(/\/+$/, '');
    const MAX_PROFS = 5;
    const DOC_TYPE_LABELS: Record<string, string> = { cv: 'CV', title: 'Título', certificate: 'Certificado', dni: 'DNI' };
    const DOC_STATUS_MAP: Record<string, { label: string; cls: string }> = {
      pending: { label: 'Pendiente', cls: 'badge-soft-warning' },
      approved: { label: 'Aprobado', cls: 'badge-soft-success' },
      rejected: { label: 'Rechazado', cls: 'badge-soft-error' },
    };
    const DOC_ZOOM_MIN = 0.5;
    const DOC_ZOOM_MAX = 3;
    const DOC_ZOOM_STEP = 0.25;

    let profData: AdminProfessional | null = null;
    let isEditMode = false;
    let editServices: string[] = [];
    let documentsState: ProfessionalDocument[] = [];
    let docReviewBlobUrl = '';
    let docReviewZoom = 1;
    let currentDocReviewId: string | null = null;

    const STATUS_MAP: Record<string, { label: string; cls: string }> = {
      incomplete:      { label: 'Incompleto',    cls: 'bg-outline/10 text-outline' },
      onboarding:      { label: 'Onboarding',    cls: 'bg-tertiary-container text-on-tertiary-container' },
      pending_review:  { label: 'Pendiente',     cls: 'bg-secondary-container text-on-secondary-container' },
      active:          { label: 'Activo',         cls: 'bg-primary-container text-on-primary-container' },
      rejected:        { label: 'Rechazado',      cls: 'bg-error-container text-on-error-container' },
      suspended:       { label: 'Suspendido',     cls: 'bg-error/10 text-error' },
    };

    function statusBadge(status: string): string {
      const s = STATUS_MAP[status] || { label: status, cls: 'bg-outline/10 text-outline' };
      return `<span class="inline-block px-2.5 py-1 rounded-lg text-[11px] font-bold uppercase tracking-wider ${s.cls}">${s.label}</span>`;
    }

    function formatDate(iso: string): string {
      if (!iso) return '—';
      try {
        const d = new Date(iso);
        if (isNaN(d.getTime())) return '—';
        return d.toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
      } catch { return '—'; }
    }

    // ─── Toast ───────────────────────────────────────────────────
    let toastTimeout: ReturnType<typeof setTimeout>;
    function showToast(msg: string, type: 'success' | 'error' = 'success') {
      const toast = document.getElementById('toast')!;
      const inner = document.getElementById('toast-inner')!;
      const icon = document.getElementById('toast-icon')!;
      const msgEl = document.getElementById('toast-msg')!;

      inner.className = type === 'success'
        ? 'flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm bg-primary text-on-primary'
        : 'flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm bg-error text-on-error';
      icon.textContent = type === 'success' ? 'check_circle' : 'error';
      msgEl.textContent = msg;

      toast.classList.remove('hidden');
      requestAnimationFrame(() => { toast.classList.remove('translate-y-[-1rem]', 'opacity-0'); toast.classList.add('translate-y-0', 'opacity-100'); });
      clearTimeout(toastTimeout);
      toastTimeout = setTimeout(() => {
        toast.classList.add('translate-y-[-1rem]', 'opacity-0');
        toast.classList.remove('translate-y-0', 'opacity-100');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, 4000);
    }

    // ─── Email verification UI ───────────────────────────────────
    function renderEmailVerification(verified: boolean) {
      const verifiedBadge = document.getElementById('prof-email-verified')!;
      const resendBtn = document.getElementById('btn-resend-verification')!;
      if (verified) {
        verifiedBadge.classList.remove('hidden');
        verifiedBadge.classList.add('inline-flex');
        resendBtn.classList.add('hidden');
        resendBtn.classList.remove('inline-flex');
      } else {
        verifiedBadge.classList.add('hidden');
        verifiedBadge.classList.remove('inline-flex');
        resendBtn.classList.remove('hidden');
        resendBtn.classList.add('inline-flex');
      }
    }

    // ─── Populate detail ─────────────────────────────────────────
    function populateProfile(p: AdminProfessional) {
      document.getElementById('prof-name')!.textContent = p.name || '—';
      document.getElementById('prof-status-badge')!.innerHTML = statusBadge(p.profileStatus);
      document.getElementById('prof-email')!.textContent = p.user?.email || p.emailContact || '—';

      // Email verification state
      renderEmailVerification(p.user?.emailVerified === true);

      // Photo
      const photo = document.getElementById('prof-photo') as HTMLImageElement;
      if (p.photo) {
        const url = getProfilePhotoUrl(p.photo, p.id);
        photo.onerror = () => { photo.onerror = null; photo.src = DEFAULT_AVATAR; };
        photo.src = url;
      } else {
        photo.src = DEFAULT_AVATAR;
      }

      const [firstName = '', ...restName] = (p.name || '').trim().split(/\s+/).filter(Boolean);
      const lastName = restName.join(' ');

      // Personal
      document.getElementById('d-firstName')!.textContent = firstName || '—';
      document.getElementById('d-lastName')!.textContent = lastName || '—';
      document.getElementById('d-dni')!.textContent = p.dni || '—';
      document.getElementById('d-city')!.textContent = p.city || '—';
      document.getElementById('d-country')!.textContent = p.country?.name || '—';
      document.getElementById('d-province')!.textContent = p.province?.name || '—';
      document.getElementById('d-whatsapp')!.textContent = p.whatsapp || '—';
      document.getElementById('d-linkedin')!.textContent = p.linkedin || '—';
      document.getElementById('d-modality')!.textContent = p.workModality ? getCatalogLabel('work-modalities', p.workModality) : '—';
      document.getElementById('d-completion')!.textContent = `${p.completionPct}%`;

      // Professional
      document.getElementById('d-rubro')!.textContent = p.rubro?.name || '—';
      document.getElementById('d-bio')!.textContent = p.bio || '—';
      document.getElementById('d-price-usd')!.textContent = p.pricePerHour != null ? `$ ${p.pricePerHour} /hr.` : '—';
      document.getElementById('d-motivation')!.textContent = p.tramaMotivation || '—';

      const toggleEl = document.getElementById('is-active-toggle') as HTMLInputElement | null;
      if (toggleEl) toggleEl.checked = p.isActive ?? false;

      // Professions
      const profsEl = document.getElementById('d-professions')!;
      if (p.professionCategories?.length) {
        profsEl.innerHTML = p.professionCategories.map(pc =>
          `<span class="inline-block px-2.5 py-1 rounded-lg text-[11px] font-bold bg-primary-container text-on-primary-container">${pc.name}</span>`
        ).join('');
      } else {
        profsEl.innerHTML = '<span class="text-sm text-on-surface-variant">—</span>';
      }

      // Services
      const servEl = document.getElementById('d-services')!;
      if (p.services?.length) {
        servEl.innerHTML = p.services.map(s =>
          `<span class="inline-block px-2.5 py-1 rounded-lg text-[11px] font-bold bg-secondary-container text-on-secondary-container">${s}</span>`
        ).join('');
      } else {
        servEl.innerHTML = '<span class="text-sm text-on-surface-variant">—</span>';
      }

      // Show validation panel only for pending_review
      if (p.profileStatus === 'pending_review') {
        document.getElementById('validation-panel')!.classList.remove('hidden');
      }
    }

    function splitName(name: string | null | undefined): { firstName: string; lastName: string } {
      const parts = (name || '').trim().split(/\s+/).filter(Boolean);
      if (!parts.length) return { firstName: '', lastName: '' };
      return { firstName: parts[0], lastName: parts.slice(1).join(' ') };
    }

    function asString(value: string | number | null | undefined): string {
      return value == null ? '' : String(value);
    }

    function normalizeString(value: string): string | undefined {
      const trimmed = value.trim();
      return trimmed ? trimmed : undefined;
    }

    function parseOptionalNumber(value: string): number | undefined {
      const trimmed = value.trim();
      if (!trimmed) return undefined;
      const parsed = Number(trimmed);
      return Number.isFinite(parsed) ? parsed : undefined;
    }

    async function loadCountriesInto(selectId: '#e-country', selectedId?: number | null) {
      const sel = document.querySelector(selectId) as HTMLSelectElement | null;
      if (!sel) return;
      sel.innerHTML = '<option value="">Seleccioná país</option>';
      try {
        const countries = await fetchCountries();
        sel.innerHTML += countries.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
        if (selectedId) sel.value = String(selectedId);
      } catch {
        sel.innerHTML = '<option value="">Error al cargar países</option>';
      }
    }

    async function loadProvincesInto(selectId: '#e-province', countryId?: number | null, selectedId?: number | null) {
      const sel = document.querySelector(selectId) as HTMLSelectElement | null;
      if (!sel) return;
      if (!countryId) {
        sel.innerHTML = '<option value="">Seleccioná provincia</option>';
        return;
      }
      sel.disabled = true;
      sel.innerHTML = '<option value="">Cargando...</option>';
      try {
        const provinces = await fetchProvinces(countryId);
        sel.innerHTML = '<option value="">Seleccioná provincia</option>' + provinces.map(p => `<option value="${p.id}">${p.name}</option>`).join('');
        if (selectedId) sel.value = String(selectedId);
      } catch {
        sel.innerHTML = '<option value="">Error al cargar provincias</option>';
      } finally {
        sel.disabled = false;
      }
    }

    async function loadRubrosInto(selectId: '#e-rubro', selectedId?: number | null) {
      const sel = document.querySelector(selectId) as HTMLSelectElement | null;
      if (!sel) return;
      sel.innerHTML = '<option value="">Seleccioná rubro</option>';
      try {
        const rubros = await fetchRubros();
        sel.innerHTML += rubros.map(r => `<option value="${r.id}">${r.name}</option>`).join('');
        if (selectedId) sel.value = String(selectedId);
      } catch {
        sel.innerHTML = '<option value="">Error al cargar rubros</option>';
      }
    }

    function getCheckedProfessionIds(): number[] {
      const container = document.getElementById('e-profession-groups');
      if (!container) return [];
      return Array.from(container.querySelectorAll<HTMLInputElement>('.prof-cb:checked')).map(cb => Number(cb.value));
    }

    function applyProfessionLimit(container: HTMLElement, countEl: HTMLElement) {
      const all = Array.from(container.querySelectorAll<HTMLInputElement>('.prof-cb'));
      const checkedCount = all.filter(cb => cb.checked).length;
      countEl.textContent = `${checkedCount}/${MAX_PROFS} seleccionadas`;
      all.forEach(cb => {
        const label = cb.closest('label');
        const disable = !cb.checked && checkedCount >= MAX_PROFS;
        cb.disabled = disable;
        label?.classList.toggle('opacity-50', disable);
      });
    }

    async function loadProfessionsInto(rubroId?: number | null, selectedIds: number[] = []) {
      const container = document.getElementById('e-profession-groups');
      const countEl = document.getElementById('e-profession-count');
      if (!container || !countEl) return;
      if (!rubroId) {
        container.innerHTML = '<p class="text-sm text-on-surface-variant">Seleccioná un rubro para cargar profesiones.</p>';
        countEl.textContent = `0/${MAX_PROFS} seleccionadas`;
        return;
      }
      try {
        const groups = await fetchProfessionsByRubro(rubroId);
        container.innerHTML = groups.map(group => `
          <div class="space-y-2">
            <h4 class="text-sm font-bold text-on-surface-variant uppercase tracking-wider">${group.name}</h4>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              ${(group.children || []).map(prof => `
                <label class="flex items-center gap-3 p-3 rounded-lg hover:bg-surface-container cursor-pointer transition-colors">
                  <input
                    type="checkbox"
                    value="${prof.id}"
                    class="prof-cb rounded-md border-outline-variant text-primary focus:ring-primary w-5 h-5"
                    ${selectedIds.includes(prof.id) ? 'checked' : ''}
                  />
                  <span class="text-sm font-medium text-on-surface">${prof.name}</span>
                </label>
              `).join('')}
            </div>
          </div>
        `).join('');
        const checkboxes = container.querySelectorAll<HTMLInputElement>('.prof-cb');
        checkboxes.forEach(cb => cb.addEventListener('change', () => applyProfessionLimit(container, countEl)));
        applyProfessionLimit(container, countEl);
      } catch {
        container.innerHTML = '<p class="text-sm text-error">Error al cargar profesiones</p>';
        countEl.textContent = `0/${MAX_PROFS} seleccionadas`;
      }
    }

    function renderServicesInto(containerId: '#e-services-wrap', services: string[]) {
      const wrap = document.querySelector(containerId) as HTMLElement | null;
      const chips = document.getElementById('e-services-chips');
      const input = document.getElementById('e-service-input') as HTMLInputElement | null;
      if (!wrap || !chips || !input) return;

      const render = () => {
        chips.innerHTML = services.length
          ? services.map((service, index) => `
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-[11px] font-bold bg-secondary-container text-on-secondary-container">
                ${service}
                <button type="button" data-rm="${index}" class="hover:text-error transition-colors" aria-label="Eliminar ${service}">
                  <span class="material-symbols-outlined text-sm" aria-hidden="true">close</span>
                </button>
              </span>
            `).join('')
          : '<span class="text-sm text-on-surface-variant">Sin servicios</span>';
        chips.querySelectorAll<HTMLButtonElement>('[data-rm]').forEach(btn => {
          btn.addEventListener('click', () => {
            services.splice(Number(btn.dataset.rm), 1);
            render();
          });
        });
      };

      input.onkeydown = (event: KeyboardEvent) => {
        if (event.key !== 'Enter') return;
        event.preventDefault();
        const value = input.value.trim();
        if (!value || services.includes(value)) {
          input.value = '';
          return;
        }
        services.push(value);
        input.value = '';
        render();
      };

      render();
    }

    async function toggleEditMode(on: boolean) {
      isEditMode = on;
      document.querySelectorAll<HTMLElement>('.edit-input').forEach(el => el.classList.toggle('hidden', !on));
      document.querySelectorAll<HTMLElement>('.display-field').forEach(el => el.classList.toggle('hidden', on));
      document.getElementById('btn-edit-mode')?.classList.toggle('hidden', on);
      document.getElementById('btn-save-edit')?.classList.toggle('hidden', !on);
      document.getElementById('btn-cancel-edit')?.classList.toggle('hidden', !on);

      if (!profData) return;

      if (on) {
        const { firstName, lastName } = splitName(profData.name);
        (document.getElementById('e-firstName') as HTMLInputElement).value = firstName;
        (document.getElementById('e-lastName') as HTMLInputElement).value = lastName;
        (document.getElementById('e-dni') as HTMLInputElement).value = profData.dni || '';
        (document.getElementById('e-city') as HTMLInputElement).value = profData.city || '';
        (document.getElementById('e-whatsapp') as HTMLInputElement).value = profData.whatsapp || '';
        (document.getElementById('e-linkedin') as HTMLInputElement).value = profData.linkedin || '';
        (document.getElementById('e-modality') as HTMLSelectElement).value = profData.workModality || '';
        (document.getElementById('e-price-usd') as HTMLInputElement).value = asString(profData.pricePerHour);
        (document.getElementById('e-bio') as HTMLTextAreaElement).value = profData.bio || '';
        (document.getElementById('e-motivation') as HTMLTextAreaElement).value = profData.tramaMotivation || '';
        editServices = [...(profData.services || [])];
        renderServicesInto('#e-services-wrap', editServices);

        await loadCountriesInto('#e-country', profData.countryId ?? undefined);
        await loadProvincesInto('#e-province', profData.countryId ?? undefined, profData.provinceId ?? undefined);
        await loadRubrosInto('#e-rubro', profData.rubroId ?? undefined);
        await loadProfessionsInto(profData.rubroId ?? undefined, (profData.professionCategories || []).map(p => p.id));
      } else {
        populateProfile(profData);
      }
    }

    async function saveEditForm() {
      if (!profData) return;
      const saveBtn = document.getElementById('btn-save-edit') as HTMLButtonElement | null;
      if (saveBtn) saveBtn.disabled = true;

      const firstName = normalizeString((document.getElementById('e-firstName') as HTMLInputElement).value) || '';
      const lastName = normalizeString((document.getElementById('e-lastName') as HTMLInputElement).value) || '';
      const fullName = [firstName, lastName].filter(Boolean).join(' ').trim();

      const payload: AdminUpdateProfessionalPayload = {
        name: fullName || undefined,
        firstName: firstName || undefined,
        lastName: lastName || undefined,
        dni: normalizeString((document.getElementById('e-dni') as HTMLInputElement).value),
        city: normalizeString((document.getElementById('e-city') as HTMLInputElement).value),
        countryId: parseOptionalNumber((document.getElementById('e-country') as HTMLSelectElement).value),
        provinceId: parseOptionalNumber((document.getElementById('e-province') as HTMLSelectElement).value),
        whatsapp: normalizeString((document.getElementById('e-whatsapp') as HTMLInputElement).value),
        linkedin: normalizeString((document.getElementById('e-linkedin') as HTMLInputElement).value),
        workModality: normalizeString((document.getElementById('e-modality') as HTMLSelectElement).value),
        rubroId: parseOptionalNumber((document.getElementById('e-rubro') as HTMLSelectElement).value),
        professionCategoryIds: getCheckedProfessionIds(),
        services: editServices,
        pricePerHour: normalizeString((document.getElementById('e-price-usd') as HTMLInputElement).value),
        bio: normalizeString((document.getElementById('e-bio') as HTMLTextAreaElement).value),
        tramaMotivation: normalizeString((document.getElementById('e-motivation') as HTMLTextAreaElement).value),
      };

      try {
        await updateProfessional(profData.id, payload);
        const updatedProfile = await fetchProfessionalDetail(profData.id);
        profData = updatedProfile;
        populateProfile(updatedProfile);
        await toggleEditMode(false);
        showToast('Cambios guardados', 'success');
      } catch (err: any) {
        showToast(err?.message || 'Error al guardar', 'error');
      } finally {
        if (saveBtn) saveBtn.disabled = false;
      }
    }

    function setPhotoUploadState(message: string | null, isError = false) {
      const feedback = document.getElementById('prof-photo-feedback');
      if (!feedback) return;
      if (!message) {
        feedback.textContent = '';
        feedback.classList.add('hidden');
        feedback.classList.remove('text-error');
        feedback.classList.add('text-on-surface-variant');
        return;
      }
      feedback.textContent = message;
      feedback.classList.remove('hidden');
      feedback.classList.toggle('text-error', isError);
      feedback.classList.toggle('text-on-surface-variant', !isError);
    }

    function wirePhotoUpload() {
      const trigger = document.getElementById('btn-change-photo') as HTMLButtonElement | null;
      const input = document.getElementById('prof-photo-input') as HTMLInputElement | null;
      const image = document.getElementById('prof-photo') as HTMLImageElement | null;
      if (!trigger || !input || !image) return;

      trigger.addEventListener('click', () => input.click());

      input.addEventListener('change', async () => {
        const file = input.files?.[0];
        if (!file || !profData) return;
        if (file.size > 2 * 1024 * 1024) {
          showToast('Max 2MB', 'error');
          setPhotoUploadState('Archivo demasiado grande', true);
          input.value = '';
          return;
        }

        const previewUrl = URL.createObjectURL(file);
        const previousSrc = image.src;
        image.src = previewUrl;
        trigger.disabled = true;
        setPhotoUploadState('Subiendo...');

        try {
          await uploadProfessionalPhoto(profData.id, file);
          image.src = `${getProfilePhotoUrl(profData.id)}?t=${Date.now()}`;
          setPhotoUploadState('Foto actualizada');
          showToast('Foto actualizada', 'success');
        } catch (err: any) {
          image.src = previousSrc;
          setPhotoUploadState(err?.message || 'Error al subir foto', true);
          showToast(err?.message || 'Error al subir foto', 'error');
        } finally {
          URL.revokeObjectURL(previewUrl);
          input.value = '';
          trigger.disabled = false;
        }
      });
    }

    function populateIdentity(profileId: string, frontUrl: string | null, backUrl: string | null) {
      const container = document.getElementById('d-identity')!;

      const sides: { key: string; label: string; hasUrl: boolean }[] = [
        { key: 'front', label: 'Frente', hasUrl: !!frontUrl },
        { key: 'back', label: 'Dorso', hasUrl: !!backUrl },
      ];

      container.innerHTML = sides.map(s => `
        <div class="border border-outline-variant/20 rounded-xl p-3 text-center">
          <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">${s.label}</p>
          ${s.hasUrl
            ? `<div class="relative group">
                <div id="id-img-wrap-${s.key}" class="w-full h-36 flex items-center justify-center bg-surface-container rounded-lg overflow-hidden">
                  <div class="w-6 h-6 border-2 border-primary/30 border-t-primary rounded-full animate-spin"></div>
                </div>
                <div class="flex items-center justify-center gap-2 mt-2">
                  <button type="button" id="id-zoom-${s.key}" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors" disabled>
                    <span class="material-symbols-outlined text-sm">search</span> Ver
                  </button>
                  <button type="button" id="id-dl-${s.key}" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-surface-container text-on-surface-variant hover:bg-surface-container-high transition-colors" disabled>
                    <span class="material-symbols-outlined text-sm">download</span> Descargar
                  </button>
                </div>
              </div>`
            : '<p class="text-sm text-on-surface-variant py-6">No subido</p>'
          }
        </div>
      `).join('');

      // Load images with auth
      sides.filter(s => s.hasUrl).forEach(s => {
        const url = `${baseUrl}/uploads/identity/${profileId}/${s.key}`;
        fetchAuthBlob(url).then(({ blobUrl }) => {
          // Show thumbnail
          const wrap = document.getElementById(`id-img-wrap-${s.key}`)!;
          wrap.innerHTML = `<img src="${blobUrl}" alt="DNI ${s.label}" class="w-full h-36 object-cover rounded-lg cursor-pointer" />`;
          wrap.querySelector('img')!.addEventListener('click', () => {
            (window as any).openImageOverlay(blobUrl, `DNI ${s.label}`, `dni-${s.key}.jpg`);
          });

          // Enable buttons
          const zoomBtn = document.getElementById(`id-zoom-${s.key}`) as HTMLButtonElement;
          const dlBtn = document.getElementById(`id-dl-${s.key}`) as HTMLButtonElement;
          zoomBtn.disabled = false;
          dlBtn.disabled = false;

          zoomBtn.addEventListener('click', () => {
            (window as any).openImageOverlay(blobUrl, `DNI ${s.label}`, `dni-${s.key}.jpg`);
          });
          dlBtn.addEventListener('click', () => {
            const a = document.createElement('a');
            a.href = blobUrl;
            a.download = `dni-${s.key}.jpg`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          });
        }).catch(() => {
          const wrap = document.getElementById(`id-img-wrap-${s.key}`)!;
          wrap.innerHTML = '<p class="text-xs text-error py-4">Error al cargar imagen</p>';
        });
      });
    }

    async function fetchAuthBlob(url: string): Promise<{ blobUrl: string; mimeType: string }> {
      const res = await fetch(url, {
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!res.ok) throw new Error(`${res.status}`);
      const blob = await res.blob();
      return { blobUrl: URL.createObjectURL(blob), mimeType: blob.type };
    }

    function getDocumentStatusMeta(doc: ProfessionalDocument): { key: string; label: string; cls: string } {
      const key = doc.verificationStatus ?? doc.status ?? '';
      const meta = DOC_STATUS_MAP[key] || { label: 'Sin revisar', cls: 'badge-neutral' };
      return { key, label: meta.label, cls: meta.cls };
    }

    function getDocumentStatusBadge(status: string): string {
      const meta = DOC_STATUS_MAP[status] || { label: 'Sin revisar', cls: 'badge-neutral' };
      return `<span class="badge ${meta.cls}" data-status="${status}">${meta.label}</span>`;
    }

    function buildDocContextItems(doc: ProfessionalDocument): string[] {
      const items: string[] = [];
      if (doc.professionName) items.push(`🏷 Profesión: ${doc.professionName}`);
      if (doc.educationTitle) items.push(`🎓 Título: ${doc.educationTitle}`);
      if (doc.educationInstitution) items.push(`🏛 Institución: ${doc.educationInstitution}`);
      if (doc.educationYear) items.push(`📅 Año: ${doc.educationYear}`);
      return items;
    }

    function setDocReviewZoom(scale: number) {
      const image = document.getElementById('doc-review-image') as HTMLImageElement | null;
      const zoomValue = document.getElementById('doc-review-zoom-value');
      if (!image || !zoomValue) return;
      docReviewZoom = Math.min(DOC_ZOOM_MAX, Math.max(DOC_ZOOM_MIN, scale));
      image.style.transform = `scale(${docReviewZoom})`;
      zoomValue.textContent = `${Math.round(docReviewZoom * 100)}%`;
    }

    function closeDocumentReviewModal() {
      const modal = document.getElementById('doc-review-modal');
      const image = document.getElementById('doc-review-image') as HTMLImageElement | null;
      const pdf = document.getElementById('doc-review-pdf') as HTMLIFrameElement | null;
      const openLink = document.getElementById('doc-review-open-link') as HTMLAnchorElement | null;
      const notes = document.getElementById('doc-review-notes') as HTMLTextAreaElement | null;
      const contextBox = document.getElementById('doc-review-context');
      const contextItems = document.getElementById('doc-review-context-items');
      if (!modal) return;

      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';

      if (image) {
        image.src = '';
        image.style.transform = 'scale(1)';
      }
      if (pdf) pdf.src = 'about:blank';
      if (openLink) {
        openLink.href = '#';
        openLink.classList.add('hidden');
      }
      if (docReviewBlobUrl) {
        URL.revokeObjectURL(docReviewBlobUrl);
        docReviewBlobUrl = '';
      }
      if (notes) notes.value = '';
      if (contextBox) contextBox.classList.add('hidden');
      if (contextItems) contextItems.innerHTML = '';
      currentDocReviewId = null;
      docReviewZoom = 1;
    }

    async function openDocumentReviewModal(doc: ProfessionalDocument) {
      const modal = document.getElementById('doc-review-modal');
      const loading = document.getElementById('doc-review-loading');
      const media = document.getElementById('doc-review-media');
      const error = document.getElementById('doc-review-error');
      const title = document.getElementById('doc-review-title');
      const type = document.getElementById('doc-review-type');
      const statusBadge = document.getElementById('doc-review-status-badge');
      const notes = document.getElementById('doc-review-notes') as HTMLTextAreaElement | null;
      const imageWrap = document.getElementById('doc-review-image-wrap');
      const image = document.getElementById('doc-review-image') as HTMLImageElement | null;
      const pdf = document.getElementById('doc-review-pdf') as HTMLIFrameElement | null;
      const openLink = document.getElementById('doc-review-open-link') as HTMLAnchorElement | null;
      const zoomControls = document.getElementById('doc-review-zoom-controls');
      const contextBox = document.getElementById('doc-review-context');
      const contextItems = document.getElementById('doc-review-context-items');
      const btn = document.querySelector(`.doc-view-btn[data-doc-id="${doc.id}"]`) as HTMLButtonElement | null;
      if (!modal || !loading || !media || !error || !title || !type || !statusBadge || !notes || !imageWrap || !image || !pdf || !openLink || !zoomControls || !contextBox || !contextItems) return;

      if (docReviewBlobUrl) {
        URL.revokeObjectURL(docReviewBlobUrl);
        docReviewBlobUrl = '';
      }

      const statusMeta = getDocumentStatusMeta(doc);
      currentDocReviewId = doc.id;
      title.textContent = doc.originalName || DOC_TYPE_LABELS[doc.type] || doc.type;
      type.textContent = DOC_TYPE_LABELS[doc.type] || doc.type;
      statusBadge.innerHTML = getDocumentStatusBadge(statusMeta.key);
      notes.value = doc.verificationNotes || '';
      const docContextItems = buildDocContextItems(doc);
      if (docContextItems.length) {
        contextItems.innerHTML = docContextItems.map(item => `<p class="text-xs text-on-surface-variant">${item}</p>`).join('');
        contextBox.classList.remove('hidden');
      } else {
        contextItems.innerHTML = '';
        contextBox.classList.add('hidden');
      }
      loading.classList.remove('hidden');
      media.classList.add('hidden');
      error.classList.add('hidden');

      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';

      if (btn) btn.disabled = true;
      try {
        const { blobUrl, mimeType } = await fetchAuthBlob(`${baseUrl}/uploads/document/${doc.id}`);
        docReviewBlobUrl = blobUrl;
        const fileName = (doc.originalName || '').toLowerCase();
        const isPdf = mimeType.includes('pdf') || fileName.endsWith('.pdf');

        if (isPdf) {
          imageWrap.classList.add('hidden');
          pdf.classList.remove('hidden');
          zoomControls.classList.add('hidden');
          pdf.src = blobUrl;
        } else {
          pdf.classList.add('hidden');
          imageWrap.classList.remove('hidden');
          zoomControls.classList.remove('hidden');
          image.src = blobUrl;
          image.alt = title.textContent || 'Documento';
          setDocReviewZoom(1);
        }

        openLink.href = blobUrl;
        openLink.classList.remove('hidden');

        loading.classList.add('hidden');
        media.classList.remove('hidden');
      } catch {
        loading.classList.add('hidden');
        error.classList.remove('hidden');
      } finally {
        if (btn) btn.disabled = false;
      }
    }

    function populateDocuments(docs: ProfessionalDocument[]) {
      const tbody = document.getElementById('d-documents')!;
      if (!docs.length) {
        tbody.innerHTML = `<tr><td colspan="5" class="text-center py-8 text-on-surface-variant text-sm">Sin documentos adicionales</td></tr>`;
        return;
      }

      const docMap = new Map(docs.map(doc => [doc.id, doc]));

      tbody.innerHTML = docs.map(doc => {
        const { key: docStatus, label, cls } = getDocumentStatusMeta(doc);

        return `
          <tr class="doc-row border-b border-outline-variant/10 hover:bg-surface-container/50 transition-all cursor-pointer" data-doc-row="${doc.id}">
            <td class="px-5 py-3">
              <div class="flex items-center gap-2.5">
                <span class="material-symbols-outlined text-primary text-lg shrink-0">description</span>
                <span class="font-bold text-on-surface text-sm truncate max-w-[220px]">${doc.originalName || DOC_TYPE_LABELS[doc.type] || doc.type}</span>
              </div>
            </td>
            <td class="px-5 py-3 text-on-surface-variant text-xs">${DOC_TYPE_LABELS[doc.type] || doc.type}</td>
            <td class="px-5 py-3 text-on-surface-variant text-xs">${formatDate(doc.createdAt)}</td>
            <td class="px-5 py-3">
              <span class="doc-status-badge badge ${cls}" data-status="${docStatus}">${label}</span>
            </td>
            <td class="px-5 py-3">
              <div class="flex items-center justify-center gap-1.5">
                <button type="button" class="doc-view-btn w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center hover:bg-surface-container-high transition-colors" data-doc-id="${doc.id}" data-doc-name="${doc.originalName || doc.type}" title="Ver documento">
                  <span class="material-symbols-outlined text-on-surface-variant text-sm">visibility</span>
                </button>
                <button type="button" class="doc-dl-btn w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center hover:bg-surface-container-high transition-colors" data-doc-id="${doc.id}" data-doc-name="${doc.originalName || doc.type}" title="Descargar">
                  <span class="material-symbols-outlined text-on-surface-variant text-sm">download</span>
                </button>
              </div>
            </td>
          </tr>`;
      }).join('');

      // ─── Row highlight on any action ───────────────────────────
      function highlightRow(docId: string) {
        tbody.querySelectorAll('.doc-row').forEach(r => {
          r.classList.remove('bg-primary/5', 'border-l-4', 'border-l-primary');
        });
        const row = tbody.querySelector(`[data-doc-row="${docId}"]`);
        if (row) {
          row.classList.add('bg-primary/5', 'border-l-4', 'border-l-primary');
        }
      }

      // Also highlight on row click
      tbody.querySelectorAll('.doc-row').forEach(row => {
        row.addEventListener('click', (e) => {
          // Don't highlight if clicking a button (buttons handle their own highlight)
          if ((e.target as HTMLElement).closest('button')) return;
          const docId = row.getAttribute('data-doc-row')!;
          highlightRow(docId);
        });
      });

      // Wire view buttons
      tbody.querySelectorAll('.doc-view-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const docId = btn.getAttribute('data-doc-id')!;
          highlightRow(docId);
          const doc = docMap.get(docId);
          if (!doc) return;
          openDocumentReviewModal(doc);
        });
      });

      // Wire download buttons
      tbody.querySelectorAll('.doc-dl-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const docId = btn.getAttribute('data-doc-id')!;
          highlightRow(docId);
          handleDocDownload(docId, btn.getAttribute('data-doc-name')!);
        });
      });

    }

    async function handleDocDownload(docId: string, docName: string) {
      const btn = document.querySelector(`.doc-dl-btn[data-doc-id="${docId}"]`) as HTMLButtonElement;
      if (btn) btn.disabled = true;
      try {
        const { blobUrl } = await fetchAuthBlob(`${baseUrl}/uploads/document/${docId}`);
        const a = document.createElement('a');
        a.href = blobUrl;
        a.download = docName;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      } catch {
        showToast('Error al descargar el documento', 'error');
      } finally {
        if (btn) btn.disabled = false;
      }
    }

    async function handleDocVerify(docId: string, status: 'approved' | 'rejected', verificationNotes: string) {
      const approveBtn = document.getElementById('doc-review-approve') as HTMLButtonElement | null;
      const rejectBtn = document.getElementById('doc-review-reject') as HTMLButtonElement | null;
      const closeBtn = document.getElementById('doc-review-cancel') as HTMLButtonElement | null;
      if (approveBtn) approveBtn.disabled = true;
      if (rejectBtn) rejectBtn.disabled = true;
      if (closeBtn) closeBtn.disabled = true;
      try {
        await verifyDocument(docId, {
          status,
          verificationNotes: verificationNotes.trim() || undefined,
        });
        documentsState = documentsState.map(doc => doc.id === docId
          ? { ...doc, verificationStatus: status, verificationNotes: verificationNotes.trim() || null }
          : doc);
        populateDocuments(documentsState);
        closeDocumentReviewModal();
        showToast(status === 'approved' ? 'Documento aprobado' : 'Documento rechazado');
      } catch (err: any) {
        showToast(err?.body?.message || err?.message || 'Error al verificar documento', 'error');
      } finally {
        if (approveBtn) approveBtn.disabled = false;
        if (rejectBtn) rejectBtn.disabled = false;
        if (closeBtn) closeBtn.disabled = false;
      }
    }

    function populateHistory(records: ValidationRecord[]) {
      const container = document.getElementById('d-history')!;
      if (!records.length) {
        container.innerHTML = '<p class="text-sm text-on-surface-variant py-3 text-center border border-dashed border-outline-variant/20 rounded-xl">Sin historial de validaciones</p>';
        return;
      }

      const V_STATUS: Record<string, { label: string; cls: string }> = {
        manual_approved: { label: 'Aprobado',  cls: 'text-primary' },
        manual_rejected: { label: 'Rechazado', cls: 'text-error' },
      };

      container.innerHTML = records.map(r => {
        const vs = V_STATUS[r.status] || { label: r.status, cls: 'text-on-surface' };
        return `
          <div class="p-3 bg-surface-container-lowest rounded-xl border border-outline-variant/10">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-bold ${vs.cls}">${vs.label}</span>
              <span class="text-[11px] text-on-surface-variant">${formatDate(r.createdAt)}</span>
            </div>
            ${r.reviewer ? `<p class="text-[11px] text-on-surface-variant">Por: ${r.reviewer.email}</p>` : ''}
            ${r.reviewNotes ? `<p class="text-sm text-on-surface mt-1">${r.reviewNotes}</p>` : ''}
          </div>`;
      }).join('');
    }

    // ─── Validation actions ──────────────────────────────────────
    async function doValidate(status: 'manual_approved' | 'manual_rejected') {
      const notes = (document.getElementById('v-notes') as HTMLTextAreaElement).value.trim();
      const btnApprove = document.getElementById('btn-approve') as HTMLButtonElement;
      const btnReject = document.getElementById('btn-reject') as HTMLButtonElement;
      btnApprove.disabled = true;
      btnReject.disabled = true;

      try {
        // Collect IDs of documents already verified (approved or rejected)
        const reviewedDocIds = Array.from(document.querySelectorAll('#d-documents .doc-status-badge'))
          .filter(badge => {
            const st = badge.getAttribute('data-status');
            return st === 'approved' || st === 'rejected';
          })
          .map(badge => badge.closest('tr')!.getAttribute('data-doc-row')!)
          .filter(Boolean);

        await validateProfile(profileId, {
          status,
          reviewNotes: notes || undefined,
          documentsReviewed: reviewedDocIds.length ? reviewedDocIds : undefined,
        });
        showToast(status === 'manual_approved' ? 'Perfil aprobado exitosamente' : 'Perfil rechazado', 'success');
        // Hide validation panel
        document.getElementById('validation-panel')!.classList.add('hidden');
        // Update status badge
        const newStatus = status === 'manual_approved' ? 'active' : 'rejected';
        document.getElementById('prof-status-badge')!.innerHTML = statusBadge(newStatus);
      } catch (err: any) {
        showToast(err?.body?.message || err?.message || 'Error al validar', 'error');
      } finally {
        btnApprove.disabled = false;
        btnReject.disabled = false;
      }
    }

    document.getElementById('btn-approve')?.addEventListener('click', () => {
      const profName = document.getElementById('prof-name')?.textContent || 'este profesional';
      (window as any).openConfirmModal({
        title: 'Confirmar aprobación',
        body: `¿Estás seguro de aprobar el perfil de ${profName}? El profesional será marcado como activo y visible en la plataforma.`,
        confirmText: 'Aprobar',
        cancelText: 'Cancelar',
        confirmStyle: 'primary',
        onConfirm: () => doValidate('manual_approved'),
      });
    });

    document.getElementById('btn-reject')?.addEventListener('click', () => {
      const profName = document.getElementById('prof-name')?.textContent || 'este profesional';
      (window as any).openConfirmModal({
        title: 'Confirmar rechazo',
        body: `¿Estás seguro de rechazar el perfil de ${profName}? El profesional será notificado y deberá corregir su perfil.`,
        confirmText: 'Rechazar',
        cancelText: 'Cancelar',
        confirmStyle: 'error',
        onConfirm: () => doValidate('manual_rejected'),
      });
    });

    document.getElementById('btn-edit-mode')?.addEventListener('click', () => {
      toggleEditMode(true);
    });
    document.getElementById('btn-cancel-edit')?.addEventListener('click', () => {
      toggleEditMode(false);
    });
    document.getElementById('btn-save-edit')?.addEventListener('click', () => {
      saveEditForm();
    });

    document.getElementById('doc-review-close')?.addEventListener('click', closeDocumentReviewModal);
    document.getElementById('doc-review-cancel')?.addEventListener('click', closeDocumentReviewModal);
    document.getElementById('doc-review-modal')?.addEventListener('click', (event) => {
      if (event.target === event.currentTarget) closeDocumentReviewModal();
    });
    document.addEventListener('keydown', (event) => {
      const modal = document.getElementById('doc-review-modal');
      if (event.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeDocumentReviewModal();
    });
    document.getElementById('doc-review-zoom-in')?.addEventListener('click', () => setDocReviewZoom(docReviewZoom + DOC_ZOOM_STEP));
    document.getElementById('doc-review-zoom-out')?.addEventListener('click', () => setDocReviewZoom(docReviewZoom - DOC_ZOOM_STEP));
    document.getElementById('doc-review-approve')?.addEventListener('click', () => {
      if (!currentDocReviewId) return;
      const notes = (document.getElementById('doc-review-notes') as HTMLTextAreaElement | null)?.value || '';
      handleDocVerify(currentDocReviewId, 'approved', notes);
    });
    document.getElementById('doc-review-reject')?.addEventListener('click', () => {
      if (!currentDocReviewId) return;
      const notes = (document.getElementById('doc-review-notes') as HTMLTextAreaElement | null)?.value || '';
      handleDocVerify(currentDocReviewId, 'rejected', notes);
    });

    const resendBtn = document.getElementById('btn-resend-verification') as HTMLButtonElement | null;
    const resendBtnText = document.getElementById('btn-resend-verification-text');
    resendBtn?.addEventListener('click', async () => {
      if (!profileId) return;
      const email = profData?.user?.email || profData?.emailContact || 'el profesional';
      resendBtn.disabled = true;
      if (resendBtnText) resendBtnText.textContent = 'Enviando...';
      try {
        await resendVerificationEmail(profileId);
        showToast(`Email de confirmación reenviado a ${email}`, 'success');
      } catch (err: any) {
        // 400 = el email ya estaba verificado: reflejarlo y ocultar el botón.
        if (err?.status === 400) {
          if (profData?.user) profData.user.emailVerified = true;
          renderEmailVerification(true);
          showToast('El email ya estaba verificado', 'success');
        } else {
          showToast(err?.body?.message || err?.message || 'No se pudo reenviar el email', 'error');
        }
      } finally {
        resendBtn.disabled = false;
        if (resendBtnText) resendBtnText.textContent = 'Enviar email de confirmación';
      }
    });

    document.getElementById('e-country')?.addEventListener('change', () => {
      const countryId = Number((document.getElementById('e-country') as HTMLSelectElement).value);
      loadProvincesInto('#e-province', countryId || undefined, undefined);
    });

    document.getElementById('e-rubro')?.addEventListener('change', () => {
      const rubroId = Number((document.getElementById('e-rubro') as HTMLSelectElement).value);
      loadProfessionsInto(rubroId || undefined, []);
    });

    const accessToggle = document.getElementById('is-active-toggle') as HTMLInputElement | null;
    accessToggle?.addEventListener('change', async () => {
      if (!profileId) return;
      const nextValue = accessToggle.checked;
      const previousValue = !nextValue;
      accessToggle.disabled = true;
      try {
        await updateProfessional(profileId, { isActive: nextValue });
        showToast('Estado de acceso actualizado', 'success');
      } catch {
        accessToggle.checked = previousValue;
        showToast('Error al actualizar estado', 'error');
      } finally {
        accessToggle.disabled = false;
      }
    });

    // ─── Init ────────────────────────────────────────────────────
    async function init() {
      if (!profileId) {
        document.getElementById('detail-loading')!.classList.add('hidden');
        document.getElementById('detail-error')!.classList.remove('hidden');
        document.getElementById('detail-error-msg')!.textContent = 'ID de profesional no encontrado';
        return;
      }

      try {
        // Fetch profile, documents, history in parallel
        const [profile, docs, history] = await Promise.all([
          fetchProfessionalDetail(profileId),
          fetchProfessionalDocuments(profileId).catch(() => [] as ProfessionalDocument[]),
          fetchValidationHistory(profileId).catch(() => [] as ValidationRecord[]),
        ]);

        profData = profile;
        documentsState = docs;
        populateProfile(profile);
        populateIdentity(profileId, profile.identityFrontUrl, profile.identityBackUrl);
        populateDocuments(documentsState);
        populateHistory(history);

        document.getElementById('detail-loading')!.classList.add('hidden');
        document.getElementById('detail-content')!.classList.remove('hidden');
      } catch (err: any) {
        document.getElementById('detail-loading')!.classList.add('hidden');
        document.getElementById('detail-error')!.classList.remove('hidden');
        document.getElementById('detail-error-msg')!.textContent = err?.message || 'Error desconocido';
      }
    }

    wirePhotoUpload();
    init();
  </script>
</AdminLayout>
