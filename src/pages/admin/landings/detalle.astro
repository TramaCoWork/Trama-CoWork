---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ConfirmModal from '../../../components/ConfirmModal.astro';
---

<AdminLayout title="Detalle de landing | TRAMA Admin">
  <ConfirmModal />

  <a
    href="/admin/landings"
    class="mb-6 inline-flex items-center gap-2 text-sm font-semibold text-primary transition-colors hover:text-primary/80"
  >
    <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_back</span>
    Volver a landings
  </a>

  <div id="landing-loading" class="flex items-center justify-center py-16">
    <div class="flex flex-col items-center gap-3 text-on-surface-variant">
      <div class="h-8 w-8 animate-spin rounded-full border-3 border-primary/30 border-t-primary"></div>
      <span class="text-sm font-medium">Cargando detalle de landing...</span>
    </div>
  </div>

  <p id="landing-inline-error" class="mb-6 hidden rounded-2xl border border-error/20 bg-error/10 p-6 text-error"></p>

  <section id="landing-content" class="hidden space-y-6">
    <article class="rounded-2xl border border-outline-variant/10 bg-surface-container-low p-6">
      <div class="mb-5 flex items-start justify-between gap-4">
        <div>
          <h1 id="landing-title" class="text-2xl font-black tracking-tight text-on-surface"></h1>
          <div class="mt-2 flex flex-wrap items-center gap-2">
            <span id="landing-status"></span>
            <span id="landing-validity" class="text-sm font-medium text-on-surface-variant"></span>
          </div>
        </div>
        <a
          id="btn-open-edit"
          href="#"
          class="rounded-xl bg-primary px-4 py-2 text-xs font-bold uppercase tracking-widest text-on-primary transition-all hover:opacity-90 active:scale-[0.98]"
        >
          Editar
        </a>
      </div>

      <div class="grid grid-cols-1 gap-4 text-sm md:grid-cols-2">
        <div>
          <p class="mb-1 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Creada</p>
          <p id="landing-created-at" class="text-on-surface"></p>
        </div>
        <div>
          <p class="mb-1 text-xs font-bold uppercase tracking-widest text-on-surface-variant">URL pública</p>
          <div class="flex flex-wrap items-center gap-2">
            <code id="landing-public-url" class="rounded-lg bg-surface-container px-2 py-1 text-xs text-on-surface"></code>
            <button
              id="copy-public-url"
              type="button"
              class="rounded-lg bg-surface-container px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider text-on-surface-variant transition-colors hover:bg-surface-container-high"
            >
              Copiar URL
            </button>
          </div>
        </div>
      </div>
    </article>

    <section class="rounded-2xl border border-outline-variant/10 bg-surface-container-low p-6">
      <div class="mb-4 flex items-center justify-between gap-3">
        <h2 class="text-xl font-extrabold tracking-tight text-on-surface">Campos</h2>
        <button
          id="btn-show-add-field"
          type="button"
          class="rounded-xl bg-primary px-4 py-2 text-xs font-bold uppercase tracking-widest text-on-primary transition-all hover:opacity-90 active:scale-[0.98]"
        >
          Agregar campo
        </button>
      </div>

      <p id="fields-inline-error" class="mb-4 hidden rounded-xl border border-error/20 bg-error/10 px-4 py-3 text-sm font-medium text-error"></p>

      <div id="fields-list" class="space-y-2"></div>

      <form id="field-editor-form" class="mt-5 hidden space-y-4 rounded-xl border border-outline-variant/20 bg-surface-container-lowest p-4">
        <h3 id="field-editor-title" class="text-sm font-bold uppercase tracking-widest text-on-surface-variant"></h3>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div>
            <label for="field-label" class="mb-1.5 block text-xs font-bold uppercase tracking-widest text-on-surface-variant">Etiqueta *</label>
            <input
              id="field-label"
              type="text"
              required
              class="w-full rounded-xl border border-outline-variant/20 bg-surface-container px-3 py-2.5 text-sm text-on-surface focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </div>
          <div>
            <label for="field-type" class="mb-1.5 block text-xs font-bold uppercase tracking-widest text-on-surface-variant">Tipo *</label>
            <select
              id="field-type"
              class="w-full rounded-xl border border-outline-variant/20 bg-surface-container px-3 py-2.5 text-sm text-on-surface focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            >
              <option value="text">Texto</option>
              <option value="email">Email</option>
              <option value="tel">Teléfono</option>
              <option value="textarea">Área de texto</option>
              <option value="number">Número</option>
              <option value="date">Fecha</option>
              <option value="select">Selector</option>
              <option value="checkbox">Checkbox</option>
            </select>
          </div>
          <div class="md:col-span-2">
            <label class="inline-flex items-center gap-2 text-sm text-on-surface-variant">
              <input id="field-required" type="checkbox" class="h-4 w-4 rounded border-outline-variant/40 accent-primary" />
              Campo requerido
            </label>
          </div>
          <div id="field-options-wrap" class="hidden md:col-span-2">
            <label for="field-options" class="mb-1.5 block text-xs font-bold uppercase tracking-widest text-on-surface-variant">Opciones (una por línea)</label>
            <textarea
              id="field-options"
              rows="4"
              class="w-full rounded-xl border border-outline-variant/20 bg-surface-container px-3 py-2.5 text-sm text-on-surface focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            ></textarea>
          </div>
        </div>

        <p id="field-editor-error" class="hidden rounded-xl border border-error/20 bg-error/10 px-4 py-3 text-sm font-medium text-error"></p>

        <div class="flex items-center gap-2">
          <button
            id="field-editor-submit"
            type="submit"
            class="rounded-xl bg-primary px-4 py-2 text-xs font-bold uppercase tracking-widest text-on-primary transition-all hover:opacity-90 active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-60"
          >
            Guardar
          </button>
          <button
            id="field-editor-cancel"
            type="button"
            class="rounded-xl bg-surface-container px-4 py-2 text-xs font-bold uppercase tracking-widest text-on-surface-variant transition-colors hover:bg-surface-container-high"
          >
            Cancelar
          </button>
        </div>
      </form>
    </section>

    <section class="rounded-2xl border border-outline-variant/10 bg-surface-container-low p-6">
      <div class="mb-4 flex items-center justify-between gap-3">
        <h2 class="text-xl font-extrabold tracking-tight text-on-surface">Envíos</h2>
      </div>

      <p id="submissions-inline-error" class="mb-4 hidden rounded-xl border border-error/20 bg-error/10 px-4 py-3 text-sm font-medium text-error"></p>

      <div class="overflow-x-auto rounded-xl border border-outline-variant/10">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-outline-variant/15 bg-surface-container">
              <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-on-surface-variant">ID</th>
              <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-on-surface-variant">Fecha</th>
              <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-on-surface-variant">Datos</th>
              <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-on-surface-variant">Acciones</th>
            </tr>
          </thead>
          <tbody id="submissions-table-body"></tbody>
        </table>
      </div>

      <div id="submissions-pagination" class="mt-4 flex flex-wrap items-center justify-between gap-3"></div>
    </section>
  </section>

  <script>
    import { isAdmin, isAuthenticated, restoreSession } from '../../../services/authService';
    import {
      addField,
      deleteField,
      deleteSubmission,
      getLanding,
      listSubmissions,
      reorderFields,
      updateField,
      type LandingField,
      type LandingPage,
      type LandingSubmission,
    } from '../../../services/landingsAdminService';

    const SUBMISSIONS_PAGE_SIZE = 20;
    const fieldTypeLabelMap: Record<LandingField['type'], string> = {
      text: 'Texto',
      email: 'Email',
      tel: 'Teléfono',
      textarea: 'Área de texto',
      number: 'Número',
      date: 'Fecha',
      select: 'Selector',
      checkbox: 'Checkbox',
    };

    let landingId = 0;
    let currentLanding: LandingPage | null = null;
    let submissionsPage = 1;
    let submissionsTotalPages = 1;
    let submissionsTotalItems = 0;
    let currentSubmissions: LandingSubmission[] = [];
    let editingFieldId: number | null = null;

    const loadingEl = document.getElementById('landing-loading') as HTMLDivElement;
    const contentEl = document.getElementById('landing-content') as HTMLElement;
    const inlineErrorEl = document.getElementById('landing-inline-error') as HTMLParagraphElement;

    const titleEl = document.getElementById('landing-title') as HTMLElement;
    const statusEl = document.getElementById('landing-status') as HTMLElement;
    const validityEl = document.getElementById('landing-validity') as HTMLElement;
    const createdAtEl = document.getElementById('landing-created-at') as HTMLElement;
    const publicUrlEl = document.getElementById('landing-public-url') as HTMLElement;
    const copyPublicUrlBtn = document.getElementById('copy-public-url') as HTMLButtonElement;
    const editBtn = document.getElementById('btn-open-edit') as HTMLAnchorElement;

    const fieldsListEl = document.getElementById('fields-list') as HTMLDivElement;
    const fieldsInlineErrorEl = document.getElementById('fields-inline-error') as HTMLParagraphElement;
    const showAddFieldBtn = document.getElementById('btn-show-add-field') as HTMLButtonElement;
    const fieldEditorForm = document.getElementById('field-editor-form') as HTMLFormElement;
    const fieldEditorTitle = document.getElementById('field-editor-title') as HTMLHeadingElement;
    const fieldEditorError = document.getElementById('field-editor-error') as HTMLParagraphElement;
    const fieldEditorSubmit = document.getElementById('field-editor-submit') as HTMLButtonElement;
    const fieldEditorCancel = document.getElementById('field-editor-cancel') as HTMLButtonElement;
    const fieldLabelInput = document.getElementById('field-label') as HTMLInputElement;
    const fieldTypeInput = document.getElementById('field-type') as HTMLSelectElement;
    const fieldRequiredInput = document.getElementById('field-required') as HTMLInputElement;
    const fieldOptionsWrap = document.getElementById('field-options-wrap') as HTMLDivElement;
    const fieldOptionsInput = document.getElementById('field-options') as HTMLTextAreaElement;

    const submissionsBody = document.getElementById('submissions-table-body') as HTMLTableSectionElement;
    const submissionsInlineError = document.getElementById('submissions-inline-error') as HTMLParagraphElement;
    const submissionsPagination = document.getElementById('submissions-pagination') as HTMLDivElement;

    function escapeHtml(value: string): string {
      return value
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function showPageError(message: string): void {
      inlineErrorEl.textContent = message;
      inlineErrorEl.classList.remove('hidden');
    }

    function hidePageError(): void {
      inlineErrorEl.textContent = '';
      inlineErrorEl.classList.add('hidden');
    }

    function showFieldsError(message: string): void {
      fieldsInlineErrorEl.textContent = message;
      fieldsInlineErrorEl.classList.remove('hidden');
    }

    function hideFieldsError(): void {
      fieldsInlineErrorEl.textContent = '';
      fieldsInlineErrorEl.classList.add('hidden');
    }

    function showSubmissionsError(message: string): void {
      submissionsInlineError.textContent = message;
      submissionsInlineError.classList.remove('hidden');
    }

    function hideSubmissionsError(): void {
      submissionsInlineError.textContent = '';
      submissionsInlineError.classList.add('hidden');
    }

    function showFieldEditorError(message: string): void {
      fieldEditorError.textContent = message;
      fieldEditorError.classList.remove('hidden');
    }

    function hideFieldEditorError(): void {
      fieldEditorError.textContent = '';
      fieldEditorError.classList.add('hidden');
    }

    function formatDate(value: string | null): string {
      if (!value) return '—';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '—';
      return new Intl.DateTimeFormat('es-AR', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
      }).format(date);
    }

    function formatVigencia(item: LandingPage): string {
      if (!item.validFrom && !item.validUntil) return 'Sin límite';
      return `${formatDate(item.validFrom)} – ${formatDate(item.validUntil)}`;
    }

    function statusBadge(isPublic: boolean): string {
      if (isPublic) {
        return '<span class="inline-flex items-center rounded-lg bg-success/15 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider text-success">Pública</span>';
      }
      return '<span class="inline-flex items-center rounded-lg bg-outline-variant/20 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider text-on-surface-variant">Privada</span>';
    }

    function getFieldOptionsFromTextarea(): string[] {
      return fieldOptionsInput.value
        .split('\n')
        .map((option) => option.trim())
        .filter((option) => option.length > 0);
    }

    function sortedFields(): LandingField[] {
      return [...(currentLanding?.fields || [])].sort((a, b) => a.order - b.order);
    }

    function setEditorMode(mode: 'create' | 'edit', field?: LandingField): void {
      editingFieldId = mode === 'edit' && field ? field.id : null;
      fieldEditorForm.classList.remove('hidden');
      hideFieldEditorError();

      if (mode === 'create') {
        fieldEditorTitle.textContent = 'Agregar campo';
        fieldEditorSubmit.textContent = 'Agregar';
        fieldLabelInput.value = '';
        fieldTypeInput.value = 'text';
        fieldRequiredInput.checked = false;
        fieldOptionsInput.value = '';
      } else if (field) {
        fieldEditorTitle.textContent = 'Editar campo';
        fieldEditorSubmit.textContent = 'Guardar';
        fieldLabelInput.value = field.label;
        fieldTypeInput.value = field.type;
        fieldRequiredInput.checked = field.required;
        fieldOptionsInput.value = (field.options || []).join('\n');
      }

      toggleFieldOptions();
      fieldEditorForm.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function closeEditor(): void {
      editingFieldId = null;
      fieldEditorForm.classList.add('hidden');
      hideFieldEditorError();
    }

    function toggleFieldOptions(): void {
      fieldOptionsWrap.classList.toggle('hidden', fieldTypeInput.value !== 'select');
    }

    function renderFieldRows(): void {
      const fields = sortedFields();
      if (fields.length === 0) {
        fieldsListEl.innerHTML = `
          <div class="rounded-xl border border-outline-variant/20 bg-surface-container-lowest p-4 text-sm text-on-surface-variant">
            Esta landing todavía no tiene campos configurados.
          </div>`;
        return;
      }

      fieldsListEl.innerHTML = fields
        .map(
          (field, index) => `
            <article class="rounded-xl border border-outline-variant/20 bg-surface-container-lowest p-4">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-on-surface">${escapeHtml(field.label)}</p>
                  <div class="mt-1 flex flex-wrap items-center gap-2">
                    <span class="inline-flex items-center rounded-lg bg-surface-container px-2 py-1 text-[11px] font-bold uppercase tracking-wider text-on-surface-variant">${escapeHtml(fieldTypeLabelMap[field.type])}</span>
                    ${field.required ? '<span class="inline-flex items-center rounded-lg bg-primary/15 px-2 py-1 text-[11px] font-bold uppercase tracking-wider text-primary">Requerido</span>' : ''}
                  </div>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  <button type="button" data-action="up" data-id="${field.id}" ${index === 0 ? 'disabled' : ''} class="rounded-lg bg-surface-container px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider text-on-surface-variant transition-colors hover:bg-surface-container-high disabled:cursor-not-allowed disabled:opacity-40">↑</button>
                  <button type="button" data-action="down" data-id="${field.id}" ${index === fields.length - 1 ? 'disabled' : ''} class="rounded-lg bg-surface-container px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider text-on-surface-variant transition-colors hover:bg-surface-container-high disabled:cursor-not-allowed disabled:opacity-40">↓</button>
                  <button type="button" data-action="edit" data-id="${field.id}" class="rounded-lg bg-surface-container px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider text-on-surface-variant transition-colors hover:bg-surface-container-high">Editar</button>
                  <button type="button" data-action="delete" data-id="${field.id}" class="rounded-lg bg-error-container px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider text-on-error-container transition-opacity hover:opacity-90">Eliminar</button>
                </div>
              </div>
            </article>`,
        )
        .join('');
    }

    function formatSubmissionData(data: Record<string, string>): string {
      const entries = Object.entries(data || {});
      if (entries.length === 0) {
        return '<span class="text-on-surface-variant">—</span>';
      }

      return entries
        .map(
          ([key, value]) =>
            `<span class="mr-1 mb-1 inline-flex rounded-lg bg-surface-container px-2 py-1 text-[11px] font-medium text-on-surface-variant"><strong class="mr-1 text-on-surface">${escapeHtml(key)}:</strong>${escapeHtml(value)}</span>`,
        )
        .join('');
    }

    function renderSubmissionsRows(): void {
      if (currentSubmissions.length === 0) {
        submissionsBody.innerHTML = `
          <tr>
            <td colspan="4" class="py-10 text-center text-sm text-on-surface-variant">Sin envíos registrados</td>
          </tr>`;
        return;
      }

      submissionsBody.innerHTML = currentSubmissions
        .map(
          (submission) => `
            <tr class="border-b border-outline-variant/10">
              <td class="px-4 py-3 text-on-surface-variant">${submission.id}</td>
              <td class="px-4 py-3 text-on-surface-variant">${escapeHtml(formatDate(submission.createdAt))}</td>
              <td class="px-4 py-3">${formatSubmissionData(submission.data)}</td>
              <td class="px-4 py-3">
                <button type="button" data-action="delete-submission" data-id="${submission.id}" class="rounded-lg bg-error-container px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider text-on-error-container transition-opacity hover:opacity-90">Eliminar</button>
              </td>
            </tr>`,
        )
        .join('');
    }

    function renderSubmissionsPagination(): void {
      if (submissionsTotalPages <= 1) {
        submissionsPagination.innerHTML = '';
        return;
      }

      const start = submissionsTotalItems === 0 ? 0 : (submissionsPage - 1) * SUBMISSIONS_PAGE_SIZE + 1;
      const end = Math.min(submissionsPage * SUBMISSIONS_PAGE_SIZE, submissionsTotalItems);

      submissionsPagination.innerHTML = `
        <span class="text-xs text-on-surface-variant">Mostrando ${start}–${end} de ${submissionsTotalItems} envíos</span>
        <div class="flex items-center gap-2">
          <button data-page="${submissionsPage - 1}" ${submissionsPage === 1 ? 'disabled' : ''}
            class="rounded-lg bg-surface-container px-3 py-1.5 text-xs font-bold text-on-surface-variant hover:bg-surface-container-high disabled:cursor-not-allowed disabled:opacity-40">
            Anterior
          </button>
          <span class="px-1 text-xs font-bold text-on-surface-variant">${submissionsPage} / ${submissionsTotalPages}</span>
          <button data-page="${submissionsPage + 1}" ${submissionsPage === submissionsTotalPages ? 'disabled' : ''}
            class="rounded-lg bg-surface-container px-3 py-1.5 text-xs font-bold text-on-surface-variant hover:bg-surface-container-high disabled:cursor-not-allowed disabled:opacity-40">
            Siguiente
          </button>
        </div>`;

      submissionsPagination.querySelectorAll<HTMLButtonElement>('button[data-page]').forEach((button) => {
        button.addEventListener('click', () => {
          const nextPage = Number(button.dataset.page);
          if (!Number.isFinite(nextPage) || nextPage < 1 || nextPage > submissionsTotalPages) return;
          submissionsPage = nextPage;
          loadSubmissions();
        });
      });
    }

    function renderLandingInfo(landing: LandingPage): void {
      const idSlug = `${landing.id}-${landing.uuid.slice(-5)}`;
      const publicUrl = `${window.location.origin}/landings?id=${idSlug}`;

      titleEl.textContent = landing.title;
      statusEl.innerHTML = statusBadge(landing.isPublic);
      validityEl.textContent = formatVigencia(landing);
      createdAtEl.textContent = formatDate(landing.createdAt);
      publicUrlEl.textContent = publicUrl;
      editBtn.href = `/admin/landings/editar?id=${encodeURIComponent(String(landing.id))}`;
      copyPublicUrlBtn.dataset.url = publicUrl;
    }

    async function loadLandingData(): Promise<boolean> {
      hidePageError();
      try {
        const landing = await getLanding(landingId);
        currentLanding = landing;
        renderLandingInfo(landing);
        renderFieldRows();
      } catch (error) {
        const apiError = error as Error & { status?: number };
        if (apiError.status === 404) {
          showPageError('La landing no existe o fue eliminada.');
          loadingEl.classList.add('hidden');
          contentEl.classList.add('hidden');
          return false;
        }
        showPageError('No se pudo cargar la landing. Intentá de nuevo.');
        loadingEl.classList.add('hidden');
        contentEl.classList.add('hidden');
        return false;
      }

      loadingEl.classList.add('hidden');
      contentEl.classList.remove('hidden');
      return true;
    }

    async function loadSubmissions(): Promise<void> {
      hideSubmissionsError();
      submissionsBody.innerHTML = `
        <tr>
          <td colspan="4" class="py-10 text-center text-on-surface-variant">
            <div class="flex flex-col items-center gap-3">
              <div class="h-7 w-7 animate-spin rounded-full border-3 border-primary/30 border-t-primary"></div>
              <span class="text-sm font-medium">Cargando envíos...</span>
            </div>
          </td>
        </tr>`;
      submissionsPagination.innerHTML = '';

      try {
        const response = await listSubmissions(landingId, submissionsPage, SUBMISSIONS_PAGE_SIZE);
        currentSubmissions = response.data;
        submissionsTotalItems = response.meta.total;
        submissionsTotalPages = response.meta.totalPages;
        renderSubmissionsRows();
        renderSubmissionsPagination();
      } catch {
        currentSubmissions = [];
        submissionsTotalItems = 0;
        submissionsTotalPages = 1;
        showSubmissionsError('No se pudieron cargar los envíos.');
        submissionsBody.innerHTML = `
          <tr>
            <td colspan="4" class="py-10 text-center text-sm font-semibold text-error">Error al cargar envíos.</td>
          </tr>`;
      }
    }

    async function persistFieldOrder(fields: LandingField[]): Promise<void> {
      const fieldIds = fields.map((field) => field.id);
      await reorderFields(landingId, fieldIds);
      await loadLandingData();
    }

    async function handleFieldSubmit(event: Event): Promise<void> {
      event.preventDefault();
      hideFieldEditorError();
      hideFieldsError();

      const label = fieldLabelInput.value.trim();
      const type = fieldTypeInput.value as LandingField['type'];
      const required = fieldRequiredInput.checked;
      const options = type === 'select' ? getFieldOptionsFromTextarea() : [];

      if (!label) {
        showFieldEditorError('La etiqueta es obligatoria.');
        return;
      }

      if (type === 'select' && options.length === 0) {
        showFieldEditorError('Para selector debés cargar al menos una opción.');
        return;
      }

      fieldEditorSubmit.disabled = true;
      try {
        if (editingFieldId === null) {
          const nextOrder = sortedFields().length + 1;
          await addField(landingId, { label, type, required, order: nextOrder, options });
        } else {
          await updateField(landingId, editingFieldId, { label, type, required, options });
        }

        closeEditor();
        await loadLandingData();
      } catch {
        showFieldEditorError('No se pudo guardar el campo.');
      } finally {
        fieldEditorSubmit.disabled = false;
      }
    }

    async function handleDeleteField(field: LandingField): Promise<void> {
      hideFieldsError();
      (window as any).openConfirmModal({
        title: '¿Eliminar este campo?',
        body: `Se eliminará el campo "${field.label}".`,
        confirmText: 'Eliminar',
        confirmStyle: 'error',
        cancelText: 'Cancelar',
        onConfirm: async () => {
          try {
            await deleteField(landingId, field.id);
            await loadLandingData();
          } catch {
            showFieldsError('No se pudo eliminar el campo.');
          }
        },
      });
    }

    async function handleMoveField(fieldId: number, direction: 'up' | 'down'): Promise<void> {
      hideFieldsError();
      const fields = sortedFields();
      const index = fields.findIndex((field) => field.id === fieldId);
      if (index === -1) return;

      const targetIndex = direction === 'up' ? index - 1 : index + 1;
      if (targetIndex < 0 || targetIndex >= fields.length) return;

      [fields[index], fields[targetIndex]] = [fields[targetIndex], fields[index]];

      try {
        await persistFieldOrder(fields);
      } catch {
        showFieldsError('No se pudo reordenar el campo.');
      }
    }

    async function handleDeleteSubmission(submission: LandingSubmission): Promise<void> {
      hideSubmissionsError();
      (window as any).openConfirmModal({
        title: '¿Eliminar este envío?',
        body: `Se eliminará el envío #${submission.id}.`,
        confirmText: 'Eliminar',
        confirmStyle: 'error',
        cancelText: 'Cancelar',
        onConfirm: async () => {
          try {
            await deleteSubmission(landingId, submission.id);
            if (submissionsPage > 1 && currentSubmissions.length === 1) {
              submissionsPage -= 1;
            }
            await loadSubmissions();
          } catch {
            showSubmissionsError('No se pudo eliminar el envío.');
          }
        },
      });
    }

    function setupLandingActions(): void {
      copyPublicUrlBtn.addEventListener('click', async () => {
        const url = copyPublicUrlBtn.dataset.url;
        if (!url) return;

        try {
          await navigator.clipboard.writeText(url);
          copyPublicUrlBtn.textContent = '¡Copiado!';
          setTimeout(() => {
            copyPublicUrlBtn.textContent = 'Copiar URL';
          }, 2000);
        } catch {
          showPageError('No se pudo copiar la URL pública.');
        }
      });

      showAddFieldBtn.addEventListener('click', () => {
        setEditorMode('create');
      });

      fieldTypeInput.addEventListener('change', toggleFieldOptions);
      fieldEditorCancel.addEventListener('click', closeEditor);
      fieldEditorForm.addEventListener('submit', handleFieldSubmit);

      fieldsListEl.addEventListener('click', async (event) => {
        const target = event.target as HTMLElement;
        const actionButton = target.closest<HTMLButtonElement>('button[data-action]');
        if (!actionButton) return;

        const fieldId = Number(actionButton.dataset.id);
        if (!Number.isFinite(fieldId)) return;

        const field = sortedFields().find((item) => item.id === fieldId);
        if (!field) return;

        const action = actionButton.dataset.action;
        if (action === 'edit') {
          setEditorMode('edit', field);
          return;
        }

        if (action === 'delete') {
          await handleDeleteField(field);
          return;
        }

        if (action === 'up') {
          await handleMoveField(field.id, 'up');
          return;
        }

        if (action === 'down') {
          await handleMoveField(field.id, 'down');
        }
      });

      submissionsBody.addEventListener('click', async (event) => {
        const target = event.target as HTMLElement;
        const button = target.closest<HTMLButtonElement>('button[data-action="delete-submission"]');
        if (!button) return;

        const submissionId = Number(button.dataset.id);
        if (!Number.isFinite(submissionId)) return;

        const submission = currentSubmissions.find((item) => item.id === submissionId);
        if (!submission) return;

        await handleDeleteSubmission(submission);
      });
    }

    async function init(): Promise<void> {
      restoreSession();
      if (!isAuthenticated()) {
        window.location.href = '/admin/login';
        return;
      }
      if (!isAdmin()) {
        window.location.href = '/dashboard';
        return;
      }

      const idParam = new URLSearchParams(window.location.search).get('id');
      if (!idParam) {
        window.location.href = '/admin/landings';
        return;
      }

      landingId = Number(idParam);
      if (!Number.isFinite(landingId) || landingId <= 0) {
        window.location.href = '/admin/landings';
        return;
      }

      setupLandingActions();
      const loaded = await loadLandingData();
      if (!loaded) return;
      await loadSubmissions();
    }

    init();
  </script>
</AdminLayout>
