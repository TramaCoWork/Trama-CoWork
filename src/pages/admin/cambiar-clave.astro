---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Cambiar clave | TRAMA Admin">
  <div class="max-w-md">
    <h1 class="text-2xl font-bold text-on-surface mb-2">Cambiar contrase&ntilde;a</h1>
    <p class="text-on-surface-variant text-sm mb-8">
      Ingres&aacute; tu contrase&ntilde;a actual y eleg&iacute; una nueva.
    </p>

    <!-- Mensajes -->
    <div
      id="msg-success"
      class="hidden mb-6 p-4 rounded-xl bg-primary-container text-on-primary-container text-sm font-semibold"
    ></div>
    <div
      id="msg-error"
      class="hidden mb-6 p-4 rounded-xl bg-error-container text-on-error-container text-sm font-semibold"
    ></div>

    <!-- Formulario -->
    <form id="change-password-form" class="space-y-5" novalidate>
      <div>
        <label for="currentPassword" class="block text-sm font-semibold text-on-surface mb-1.5">
          Contrase&ntilde;a actual
        </label>
        <input
          type="password"
          id="currentPassword"
          name="currentPassword"
          required
          class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface-container-lowest text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-sm"
          placeholder="Tu contrase&ntilde;a actual"
        />
      </div>

      <div>
        <label for="newPassword" class="block text-sm font-semibold text-on-surface mb-1.5">
          Nueva contrase&ntilde;a
        </label>
        <input
          type="password"
          id="newPassword"
          name="newPassword"
          required
          minlength="6"
          class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface-container-lowest text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-sm"
          placeholder="M&iacute;nimo 6 caracteres"
        />
      </div>

      <div>
        <label for="confirmPassword" class="block text-sm font-semibold text-on-surface mb-1.5">
          Repetir nueva contrase&ntilde;a
        </label>
        <input
          type="password"
          id="confirmPassword"
          name="confirmPassword"
          required
          minlength="6"
          class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface-container-lowest text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all text-sm"
          placeholder="Repet&iacute; la nueva contrase&ntilde;a"
        />
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full py-3 rounded-xl bg-primary text-on-primary font-bold text-sm hover:opacity-90 active:scale-[0.98] transition-all disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Cambiar contrase&ntilde;a
      </button>
    </form>
  </div>
</AdminLayout>

<script>
  import { getToken } from '../../services/authService';

  const BASE = import.meta.env.PUBLIC_API_BASE_URL;
  const form = document.getElementById('change-password-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const msgSuccess = document.getElementById('msg-success') as HTMLDivElement;
  const msgError = document.getElementById('msg-error') as HTMLDivElement;

  const currentPasswordInput = document.getElementById('currentPassword') as HTMLInputElement;
  const newPasswordInput = document.getElementById('newPassword') as HTMLInputElement;
  const confirmPasswordInput = document.getElementById('confirmPassword') as HTMLInputElement;

  function showError(msg: string) {
    msgSuccess.classList.add('hidden');
    msgError.textContent = msg;
    msgError.classList.remove('hidden');
  }

  function showSuccess(msg: string) {
    msgError.classList.add('hidden');
    msgSuccess.textContent = msg;
    msgSuccess.classList.remove('hidden');
  }

  function hideMessages() {
    msgSuccess.classList.add('hidden');
    msgError.classList.add('hidden');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideMessages();

    const currentPassword = currentPasswordInput.value.trim();
    const newPassword = newPasswordInput.value.trim();
    const confirmPassword = confirmPasswordInput.value.trim();

    if (!currentPassword || !newPassword || !confirmPassword) {
      showError('Todos los campos son obligatorios.');
      return;
    }

    if (newPassword.length < 6) {
      showError('La nueva contraseña debe tener al menos 6 caracteres.');
      return;
    }

    if (newPassword !== confirmPassword) {
      showError('Las contraseñas nuevas no coinciden.');
      return;
    }

    const token = getToken();
    if (!token) {
      showError('Sesión expirada. Por favor, volvé a iniciar sesión.');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Cambiando...';

    try {
      const res = await fetch(`${BASE}/auth/change-password`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify({ currentPassword, newPassword }),
      });

      if (res.ok) {
        showSuccess('Contraseña actualizada exitosamente.');
        form.reset();
      } else if (res.status === 401) {
        showError('La contraseña actual es incorrecta.');
      } else if (res.status === 404) {
        showError('Usuario no encontrado.');
      } else {
        const data = await res.json().catch(() => null);
        showError(data?.message || 'Error al cambiar la contraseña.');
      }
    } catch {
      showError('Error de conexión. Intentá nuevamente.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Cambiar contraseña';
    }
  });
</script>
