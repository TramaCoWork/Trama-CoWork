---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ConfirmModal from '../../../components/ConfirmModal.astro';
import EditorModal from '../../../components/EditorModal.astro';
---

<AdminLayout title="Trabajos | TRAMA Admin">
  <ConfirmModal />
  <EditorModal />

  <header class="mb-8 flex items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-black text-on-surface tracking-tighter">Trabajos</h1>
      <p class="text-on-surface-variant font-medium mt-1 text-sm">Gestioná publicaciones laborales para profesionales.</p>
    </div>

    <button
      id="btn-open-create"
      type="button"
      class="px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all"
    >
      Nuevo trabajo
    </button>
  </header>

  <section class="bg-surface-container-low rounded-2xl border border-outline-variant/10 p-6 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for="jobs-filter-status" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">
          Estado
        </label>
        <select
          id="jobs-filter-status"
          class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
        >
          <option value="">Todos</option>
          <option value="active">Activo</option>
          <option value="paused">Pausado</option>
        </select>
      </div>

      <div>
        <label for="jobs-filter-category" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">
          Rubro
        </label>
        <select
          id="jobs-filter-category"
          class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-3 py-2.5 text-sm text-on-surface font-medium focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
        >
          <option value="">Todos</option>
        </select>
      </div>
    </div>
  </section>

  <p id="jobs-inline-error" class="hidden mb-4 rounded-xl border border-error/20 bg-error/10 px-4 py-3 text-sm font-medium text-error"></p>

  <section class="bg-surface-container-low rounded-2xl overflow-hidden border border-outline-variant/10">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-outline-variant/15 bg-surface-container">
            <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Título</th>
            <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Empresa</th>
            <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Email</th>
            <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Estado</th>
            <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Vigencia</th>
            <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Postulaciones</th>
            <th class="text-left px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Acciones</th>
          </tr>
        </thead>
        <tbody id="jobs-table-body">
          <tr>
            <td colspan="7" class="text-center py-12 text-on-surface-variant">
              <div class="flex flex-col items-center gap-3">
                <div class="w-8 h-8 border-3 border-primary/30 border-t-primary rounded-full animate-spin"></div>
                <span class="text-sm font-medium">Cargando trabajos...</span>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <div id="jobs-pagination" class="mt-4 flex items-center justify-between gap-3 flex-wrap"></div>

  <div
    id="job-modal"
    class="fixed inset-0 z-[90] hidden items-center justify-center bg-black/30 backdrop-blur-sm p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="job-modal-title"
  >
    <div class="w-full max-w-3xl rounded-2xl bg-surface-container-low border border-outline-variant/15 shadow-2xl max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between border-b border-outline-variant/15 px-6 py-4 sticky top-0 bg-surface-container-low">
        <h2 id="job-modal-title" class="text-lg font-extrabold text-on-surface tracking-tight">Nuevo trabajo</h2>
        <button id="job-modal-close" type="button" class="text-on-surface-variant hover:text-on-surface" aria-label="Cerrar">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>

      <form id="job-form" class="p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label for="job-title" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Título *</label>
          <input id="job-title" type="text" required class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-2.5 text-sm" />
        </div>

        <div class="md:col-span-2">
          <input id="job-description" type="hidden" />
          <div class="flex items-center justify-between gap-2 mb-1.5">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Descripción *</p>
            <button
              id="job-description-edit"
              type="button"
              class="px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-surface-container text-on-surface-variant hover:bg-surface-container-high"
            >
              Editar descripción
            </button>
          </div>
          <div id="job-description-preview" class="rounded-xl border border-outline-variant/20 bg-surface-container-lowest px-4 py-3 text-sm text-on-surface-variant">
            Sin descripción.
          </div>
        </div>

        <div>
          <label for="job-email" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Email *</label>
          <input id="job-email" type="email" required class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-2.5 text-sm" />
        </div>

        <div>
          <label for="job-status" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Estado</label>
          <select id="job-status" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-2.5 text-sm">
            <option value="active">Activo</option>
            <option value="paused">Pausado</option>
          </select>
        </div>

        <div>
          <label for="job-valid-from" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Válido desde</label>
          <input id="job-valid-from" type="date" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-2.5 text-sm" />
        </div>

        <div>
          <label for="job-valid-until" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Válido hasta</label>
          <input id="job-valid-until" type="date" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-2.5 text-sm" />
        </div>

        <div>
          <label for="job-company-name" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Empresa</label>
          <input id="job-company-name" type="text" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-2.5 text-sm" />
        </div>

        <div>
          <label for="job-company-logo" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1.5 block">Logo (URL)</label>
          <input id="job-company-logo" type="url" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-2.5 text-sm" />
        </div>

        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Rubros</p>
          <div id="job-category-checkboxes" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2"></div>
        </div>

        <div id="job-modal-error" class="hidden md:col-span-2 rounded-lg border border-error/20 bg-error/10 px-3 py-2 text-sm font-medium text-error"></div>

        <div class="md:col-span-2 flex justify-end gap-3">
          <button id="job-modal-cancel" type="button" class="px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest text-on-surface-variant bg-surface-container hover:bg-surface-container-high transition-colors">Cancelar</button>
          <button id="job-modal-submit" type="submit" class="px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest bg-primary text-on-primary hover:opacity-90 active:scale-[0.98] transition-all">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { isAdmin, isAuthenticated, restoreSession } from '../../../services/authService';
    import { getRubros, type ProfessionCategory } from '../../../services/adminProfessionCategoriesService';
    import {
      listWorks,
      getWork,
      createWork,
      updateWork,
      updateWorkStatus,
      deleteWork,
      type Work,
      type CreateWorkPayload,
      type UpdateWorkPayload,
    } from '../../../services/workAdminService';

    type ModalMode = 'create' | 'edit';

    const PAGE_SIZE = 20;
    let currentPage = 1;
    let totalPages = 1;
    let totalItems = 0;
    let currentJobs: Work[] = [];
    let rubros: ProfessionCategory[] = [];
    let modalMode: ModalMode = 'create';
    let editingId: string | null = null;

    const tbody = document.getElementById('jobs-table-body') as HTMLTableSectionElement;
    const paginationEl = document.getElementById('jobs-pagination') as HTMLDivElement;
    const inlineError = document.getElementById('jobs-inline-error') as HTMLParagraphElement;
    const statusFilter = document.getElementById('jobs-filter-status') as HTMLSelectElement;
    const categoryFilter = document.getElementById('jobs-filter-category') as HTMLSelectElement;

    const modal = document.getElementById('job-modal') as HTMLDivElement;
    const modalTitle = document.getElementById('job-modal-title') as HTMLHeadingElement;
    const modalError = document.getElementById('job-modal-error') as HTMLDivElement;
    const form = document.getElementById('job-form') as HTMLFormElement;
    const submitButton = document.getElementById('job-modal-submit') as HTMLButtonElement;
    const categoryCheckboxes = document.getElementById('job-category-checkboxes') as HTMLDivElement;

    const titleInput = document.getElementById('job-title') as HTMLInputElement;
    const descriptionInput = document.getElementById('job-description') as HTMLInputElement;
    const descriptionPreview = document.getElementById('job-description-preview') as HTMLDivElement;
    const descriptionEditButton = document.getElementById('job-description-edit') as HTMLButtonElement;
    const emailInput = document.getElementById('job-email') as HTMLInputElement;
    const statusInput = document.getElementById('job-status') as HTMLSelectElement;
    const validFromInput = document.getElementById('job-valid-from') as HTMLInputElement;
    const validUntilInput = document.getElementById('job-valid-until') as HTMLInputElement;
    const companyNameInput = document.getElementById('job-company-name') as HTMLInputElement;
    const companyLogoInput = document.getElementById('job-company-logo') as HTMLInputElement;

    function escapeHtml(value: string): string {
      return value
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function showInlineError(message: string): void {
      inlineError.textContent = message;
      inlineError.classList.remove('hidden');
    }

    function hideInlineError(): void {
      inlineError.textContent = '';
      inlineError.classList.add('hidden');
    }

    function showModalError(message: string): void {
      modalError.textContent = message;
      modalError.classList.remove('hidden');
    }

    function hideModalError(): void {
      modalError.textContent = '';
      modalError.classList.add('hidden');
    }

    function formatDate(value: string | null): string {
      if (!value) return '—';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '—';
      return new Intl.DateTimeFormat('es-AR', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
        timeZone: 'UTC',
      }).format(date);
    }

    function formatVigencia(job: Work): string {
      if (!job.validFrom && !job.validUntil) return 'Sin límite';
      return `${formatDate(job.validFrom)} – ${formatDate(job.validUntil)}`;
    }

    function renderStatusBadge(status: 'active' | 'paused'): string {
      if (status === 'active') {
        return '<span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-success/15 text-success">Activo</span>';
      }
      return '<span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-warning/15 text-warning">Pausado</span>';
    }

    function toInputDate(value: string | null): string {
      if (!value) return '';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '';
      return date.toISOString().slice(0, 10);
    }

    function toIsoDate(value: string): string {
      return `${value}T00:00:00.000Z`;
    }

    function truncateDescription(value: string): string {
      if (value.length <= 80) return value;
      return `${value.slice(0, 79)}…`;
    }

    function updateDescriptionPreview(value: string): void {
      const normalized = value.trim();
      descriptionPreview.textContent = normalized ? truncateDescription(normalized) : 'Sin descripción.';
    }

    function openDescriptionEditor(): void {
      document.dispatchEvent(
        new CustomEvent('open-editor-modal', {
          detail: {
            title: 'Descripción del trabajo',
            placeholder: 'Describí el trabajo...',
            maxlength: 5000,
            context: 'job-description',
          },
        }),
      );

      document.dispatchEvent(
        new CustomEvent('mdx-editor-set-content', {
          detail: { markdown: descriptionInput.value || '' },
        }),
      );
    }

    function getCheckedCategoryIds(): number[] {
      return Array.from(categoryCheckboxes.querySelectorAll<HTMLInputElement>('input[type="checkbox"]:checked'))
        .map((input) => Number(input.value))
        .filter((value) => Number.isFinite(value));
    }

    function getFilters(): { status?: string; categoryId?: number } {
      const status = statusFilter.value || undefined;
      const categoryId = categoryFilter.value ? Number(categoryFilter.value) : undefined;
      return { status, categoryId };
    }

    function renderCategoryFilterOptions(): void {
      categoryFilter.innerHTML = '<option value="">Todos</option>';
      rubros.forEach((rubro) => {
        const option = document.createElement('option');
        option.value = String(rubro.id);
        option.textContent = rubro.name;
        categoryFilter.appendChild(option);
      });
    }

    function renderCategoryCheckboxes(selectedIds: number[] = []): void {
      if (rubros.length === 0) {
        categoryCheckboxes.innerHTML = '<p class="text-sm text-on-surface-variant">No hay rubros disponibles.</p>';
        return;
      }

      categoryCheckboxes.innerHTML = rubros
        .map(
          (rubro) => `
            <label class="flex items-center gap-2 rounded-lg border border-outline-variant/20 px-3 py-2 text-sm text-on-surface">
              <input
                type="checkbox"
                value="${rubro.id}"
                ${selectedIds.includes(rubro.id) ? 'checked' : ''}
                class="h-4 w-4 rounded border-outline-variant/30 text-primary focus:ring-primary/20"
              />
              <span>${escapeHtml(rubro.name)}</span>
            </label>`,
        )
        .join('');
    }

    function renderLoading(): void {
      tbody.innerHTML = `
        <tr>
          <td colspan="7" class="text-center py-12 text-on-surface-variant">
            <div class="flex flex-col items-center gap-3">
              <div class="w-8 h-8 border-3 border-primary/30 border-t-primary rounded-full animate-spin"></div>
              <span class="text-sm font-medium">Cargando trabajos...</span>
            </div>
          </td>
        </tr>`;
      paginationEl.innerHTML = '';
    }

    function renderEmpty(): void {
      tbody.innerHTML = `
        <tr>
          <td colspan="7" class="text-center py-16 text-on-surface-variant">
            <span class="material-symbols-outlined text-4xl mb-3 block text-outline" aria-hidden="true">work_off</span>
            <p class="text-sm font-medium">No hay trabajos para los filtros seleccionados.</p>
          </td>
        </tr>`;
    }

    function renderRows(): void {
      if (currentJobs.length === 0) {
        renderEmpty();
        return;
      }

      tbody.innerHTML = currentJobs
        .map(
          (job) => `
            <tr data-row-id="${job.id}" class="border-b border-outline-variant/10 hover:bg-surface-container/50 transition-colors cursor-pointer">
              <td class="px-5 py-3.5 text-sm font-semibold text-on-surface">${escapeHtml(job.title)}</td>
              <td class="px-5 py-3.5 text-sm text-on-surface-variant">${escapeHtml(job.companyName || '—')}</td>
              <td class="px-5 py-3.5 text-sm text-on-surface-variant">${escapeHtml(job.email)}</td>
              <td class="px-5 py-3.5">${renderStatusBadge(job.status)}</td>
              <td class="px-5 py-3.5 text-sm text-on-surface-variant">${escapeHtml(formatVigencia(job))}</td>
              <td class="px-5 py-3.5 text-sm text-on-surface-variant">${job._count?.applications ?? '—'}</td>
              <td class="px-5 py-3.5">
                <div class="flex items-center gap-2 flex-wrap">
                  <button type="button" data-action="edit" data-id="${job.id}" class="px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-surface-container text-on-surface-variant hover:bg-surface-container-high">Editar</button>
                  <button type="button" data-action="toggle" data-id="${job.id}" class="px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-warning/15 text-warning hover:opacity-90">${job.status === 'active' ? 'Pausar' : 'Activar'}</button>
                  <button type="button" data-action="delete" data-id="${job.id}" class="px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider bg-error-container text-on-error-container hover:opacity-90">Eliminar</button>
                </div>
              </td>
            </tr>`,
        )
        .join('');
    }

    function renderPagination(): void {
      if (totalPages <= 1) {
        paginationEl.innerHTML = '';
        return;
      }

      const start = totalItems === 0 ? 0 : (currentPage - 1) * PAGE_SIZE + 1;
      const end = Math.min(currentPage * PAGE_SIZE, totalItems);

      paginationEl.innerHTML = `
        <span class="text-xs text-on-surface-variant">Mostrando ${start}–${end} de ${totalItems} trabajos</span>
        <div class="flex items-center gap-2">
          <button data-page="${currentPage - 1}" ${currentPage === 1 ? 'disabled' : ''}
            class="px-3 py-1.5 rounded-lg text-xs font-bold bg-surface-container text-on-surface-variant hover:bg-surface-container-high disabled:opacity-40 disabled:cursor-not-allowed">
            Anterior
          </button>
          <span class="text-xs font-bold text-on-surface-variant px-1">${currentPage} / ${totalPages}</span>
          <button data-page="${currentPage + 1}" ${currentPage === totalPages ? 'disabled' : ''}
            class="px-3 py-1.5 rounded-lg text-xs font-bold bg-surface-container text-on-surface-variant hover:bg-surface-container-high disabled:opacity-40 disabled:cursor-not-allowed">
            Siguiente
          </button>
        </div>`;

      paginationEl.querySelectorAll<HTMLButtonElement>('button[data-page]').forEach((button) => {
        button.addEventListener('click', () => {
          const page = Number(button.dataset.page);
          if (!Number.isFinite(page) || page < 1 || page > totalPages) return;
          currentPage = page;
          loadJobs();
        });
      });
    }

    async function loadRubros(): Promise<void> {
      rubros = await getRubros();
      renderCategoryFilterOptions();
      renderCategoryCheckboxes();
    }

    async function loadJobs(): Promise<void> {
      hideInlineError();
      renderLoading();
      try {
        const filters = getFilters();
        const response = await listWorks(currentPage, PAGE_SIZE, filters.status, filters.categoryId);
        currentJobs = response.data;
        totalItems = response.meta.total;
        totalPages = response.meta.totalPages;
        renderRows();
        renderPagination();
      } catch {
        currentJobs = [];
        totalItems = 0;
        totalPages = 1;
        showInlineError('No se pudieron cargar los trabajos. Intentá de nuevo.');
        tbody.innerHTML = `
          <tr>
            <td colspan="7" class="text-center py-12 text-error">
              <span class="material-symbols-outlined text-3xl mb-2 block" aria-hidden="true">error</span>
              <p class="text-sm font-bold">Error al cargar trabajos.</p>
            </td>
          </tr>`;
        paginationEl.innerHTML = '';
      }
    }

    function openModal(mode: ModalMode, job?: Work): void {
      modalMode = mode;
      editingId = job?.id || null;
      hideModalError();

      if (mode === 'create') {
        modalTitle.textContent = 'Nuevo trabajo';
        submitButton.textContent = 'Guardar';
        form.reset();
        descriptionInput.value = '';
        updateDescriptionPreview('');
        statusInput.value = 'active';
        renderCategoryCheckboxes();
      } else {
        modalTitle.textContent = 'Editar trabajo';
        submitButton.textContent = 'Guardar cambios';
        titleInput.value = job?.title || '';
        descriptionInput.value = job?.description || '';
        updateDescriptionPreview(descriptionInput.value);
        document.dispatchEvent(
          new CustomEvent('mdx-editor-set-content', {
            detail: { markdown: descriptionInput.value },
          }),
        );
        emailInput.value = job?.email || '';
        statusInput.value = job?.status || 'active';
        validFromInput.value = toInputDate(job?.validFrom || null);
        validUntilInput.value = toInputDate(job?.validUntil || null);
        companyNameInput.value = job?.companyName || '';
        companyLogoInput.value = job?.companyLogo || '';
        renderCategoryCheckboxes(job?.categoryIds || []);
      }

      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeModal(): void {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
      hideModalError();
      form.reset();
      descriptionInput.value = '';
      updateDescriptionPreview('');
      editingId = null;
      modalMode = 'create';
    }

    function buildPayload(): CreateWorkPayload {
      const categoryIds = getCheckedCategoryIds();
      return {
        title: titleInput.value.trim(),
        description: descriptionInput.value.trim(),
        email: emailInput.value.trim(),
        status: statusInput.value as 'active' | 'paused',
        validFrom: validFromInput.value ? toIsoDate(validFromInput.value) : null,
        validUntil: validUntilInput.value ? toIsoDate(validUntilInput.value) : null,
        companyName: companyNameInput.value.trim() || null,
        companyLogo: companyLogoInput.value.trim() || null,
        categoryIds,
      };
    }

    function validatePayload(payload: CreateWorkPayload): string | null {
      if (!payload.title) return 'El título es obligatorio.';
      if (!payload.description) return 'La descripción es obligatoria.';
      if (!payload.email) return 'El email es obligatorio.';
      if (payload.validFrom && payload.validUntil && new Date(payload.validFrom) >= new Date(payload.validUntil)) {
        return 'La fecha de inicio debe ser anterior a la de fin';
      }
      return null;
    }

    async function submitForm(event: Event): Promise<void> {
      event.preventDefault();
      hideModalError();

      const payload = buildPayload();
      const validationError = validatePayload(payload);
      if (validationError) {
        showModalError(validationError);
        return;
      }

      submitButton.disabled = true;
      try {
        if (modalMode === 'create') {
          await createWork(payload);
          currentPage = 1;
        } else if (editingId) {
          await updateWork(editingId, payload as UpdateWorkPayload);
        }
        closeModal();
        await loadJobs();
      } catch {
        showModalError('No se pudo guardar el trabajo.');
      } finally {
        submitButton.disabled = false;
      }
    }

    async function handleToggleStatus(job: Work): Promise<void> {
      const nextStatus = job.status === 'active' ? 'paused' : 'active';
      (window as any).openConfirmModal({
        title: '¿Cambiar estado del trabajo?',
        body: `El trabajo pasará a estado ${nextStatus === 'active' ? 'Activo' : 'Pausado'}.`,
        confirmText: 'Confirmar',
        cancelText: 'Cancelar',
        onConfirm: async () => {
          try {
            await updateWorkStatus(job.id, nextStatus);
            await loadJobs();
          } catch {
            showInlineError('No se pudo actualizar el estado del trabajo.');
          }
        },
      });
    }

    async function handleDelete(job: Work): Promise<void> {
      (window as any).openConfirmModal({
        title: '¿Eliminar este trabajo? Esta acción no se puede deshacer.',
        body: `Se eliminará el trabajo "${job.title}".`,
        confirmText: 'Eliminar',
        confirmStyle: 'error',
        cancelText: 'Cancelar',
        onConfirm: async () => {
          try {
            await deleteWork(job.id);
            if (currentPage > 1 && currentJobs.length === 1) {
              currentPage -= 1;
            }
            await loadJobs();
          } catch {
            showInlineError('No se pudo eliminar el trabajo.');
          }
        },
      });
    }

    function setupTableInteractions(): void {
      tbody.addEventListener('click', async (event) => {
        const target = event.target as HTMLElement;
        const button = target.closest<HTMLButtonElement>('button[data-action]');
        if (button) {
          event.stopPropagation();
          const jobId = button.dataset.id;
          if (!jobId) return;
          const job = currentJobs.find((item) => item.id === jobId);
          if (!job) return;

          if (button.dataset.action === 'edit') {
            try {
              const fullJob = await getWork(job.id);
              openModal('edit', fullJob);
            } catch {
              showInlineError('No se pudo cargar el trabajo para editar.');
            }
            return;
          }

          if (button.dataset.action === 'toggle') {
            await handleToggleStatus(job);
            return;
          }

          if (button.dataset.action === 'delete') {
            await handleDelete(job);
          }
          return;
        }

        const row = target.closest<HTMLTableRowElement>('tr[data-row-id]');
        if (!row) return;
        const id = row.dataset.rowId;
        if (!id) return;
        window.location.href = `/admin/trabajos/detalle?id=${encodeURIComponent(id)}`;
      });
    }

    function setupEvents(): void {
      statusFilter.addEventListener('change', () => {
        currentPage = 1;
        loadJobs();
      });

      categoryFilter.addEventListener('change', () => {
        currentPage = 1;
        loadJobs();
      });

      document.getElementById('btn-open-create')?.addEventListener('click', () => openModal('create'));
      descriptionEditButton.addEventListener('click', openDescriptionEditor);
      document.getElementById('job-modal-close')?.addEventListener('click', closeModal);
      document.getElementById('job-modal-cancel')?.addEventListener('click', closeModal);
      document.addEventListener('editor-modal-submit', (event) => {
        const customEvent = event as CustomEvent<{ content?: string; context?: string }>;
        if (customEvent.detail?.context !== 'job-description') {
          return;
        }

        descriptionInput.value = customEvent.detail.content || '';
        updateDescriptionPreview(descriptionInput.value);
      });
      modal.addEventListener('click', (event) => {
        if (event.target === modal) {
          closeModal();
        }
      });
      form.addEventListener('submit', submitForm);
      setupTableInteractions();
    }

    async function init(): Promise<void> {
      restoreSession();
      if (!isAuthenticated()) {
        window.location.href = '/admin/login';
        return;
      }
      if (!isAdmin()) {
        window.location.href = '/dashboard';
        return;
      }

      setupEvents();

      try {
        await loadRubros();
      } catch {
        rubros = [];
        renderCategoryFilterOptions();
        renderCategoryCheckboxes();
      }

      await loadJobs();
    }

    init();
  </script>
</AdminLayout>

