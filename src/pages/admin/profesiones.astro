---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="TRAMA Admin - Profesiones">
  <div
    id="errorState"
    class="hidden flex flex-col items-center justify-center py-24 text-center"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-16 h-16 text-neutral-300 mb-4"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"
      ></path>
    </svg>
    <h2 class="text-xl font-bold text-neutral-700 mb-2">
      Subrubro no especificado
    </h2>
    <p class="text-sm text-neutral-500 mb-6">
      Accedé a esta página desde la lista de subrubros.
    </p>
    <a
      href="/admin/categorias"
      class="px-4 py-2 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary-alt transition-colors"
    >
      ← Volver a Categorías
    </a>
  </div>

  <div id="mainContent" class="hidden">
    <nav
      class="text-xs font-semibold text-neutral-400 uppercase tracking-wide mb-2 flex items-center gap-1.5 flex-wrap"
    >
      <a href="/admin/categorias" class="hover:text-primary transition-colors"
        >INICIO</a
      >
      <span>›</span>
      <a href="/admin/categorias" class="hover:text-primary transition-colors"
        >CATEGORÍAS</a
      >
      <span>›</span>
      <a
        id="breadcrumbRubro"
        href="#"
        class="hover:text-primary transition-colors">...</a
      >
      <span>›</span>
      <span id="breadcrumbSubrubro" class="text-primary">...</span>
    </nav>
    <div class="flex items-start justify-between mb-8">
      <div>
        <h1
          id="pageTitle"
          class="text-3xl font-black tracking-tight text-neutral-900 mb-1"
        >
          Profesiones
        </h1>
        <p class="text-sm text-neutral-500">
          Administre las profesiones de este subrubro.
        </p>
      </div>
      <button
        id="btnAgregarProfesion"
        class="flex items-center gap-2 px-4 py-2.5 bg-primary hover:bg-primary-alt text-white text-sm font-semibold rounded-lg transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 4.5v15m7.5-7.5h-15"></path>
        </svg>
        + AGREGAR PROFESIÓN
      </button>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
      <div class="bg-white rounded-2xl shadow-sm p-5 border border-neutral-100">
        <p
          class="text-xs font-semibold text-neutral-400 uppercase tracking-wide mb-3"
        >
          Total Profesiones
        </p>
        <p id="metricTotal" class="text-4xl font-black text-neutral-900">—</p>
        <p class="text-xs text-neutral-400 mt-1">Dominios especializados</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm p-5 border border-neutral-100">
        <p
          class="text-xs font-semibold text-neutral-400 uppercase tracking-wide mb-3"
        >
          Profesiones Activas
        </p>
        <p id="metricActivas" class="text-4xl font-black text-primary">—</p>
        <p class="text-xs text-neutral-400 mt-1">Disponibles actualmente</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm p-5 border border-neutral-100">
        <p
          class="text-xs font-semibold text-neutral-400 uppercase tracking-wide mb-3"
        >
          Subrubro Padre
        </p>
        <p
          id="metricSubrubro"
          class="text-xl font-black text-neutral-700 leading-tight"
        >
          —
        </p>
        <p class="text-xs text-neutral-400 mt-1">Categoría contenedora</p>
      </div>
    </div>

    <div
      class="bg-white rounded-2xl shadow-sm border border-neutral-100 overflow-hidden"
    >
      <div
        class="flex items-center justify-between px-6 py-4 border-b border-neutral-100"
      >
        <div class="flex items-center gap-3">
          <h2 class="text-base font-bold text-neutral-900">Professions List</h2>
          <span
            id="tableCount"
            class="px-2 py-0.5 bg-primary/10 text-primary text-xs font-bold rounded-full"
          >
            0 ENTRIES
          </span>
        </div>
        <div class="flex items-center gap-2">
          <div class="relative">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 text-neutral-400 absolute left-3 top-1/2 -translate-y-1/2"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input
              id="searchInput"
              type="text"
              placeholder="Search profession..."
              class="pl-9 pr-4 py-2 text-sm border border-neutral-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary w-56 transition"
            />
          </div>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b-2 border-neutral-100">
              <th
                class="text-left px-6 py-3 text-xs font-semibold text-neutral-400 uppercase tracking-wider"
              >
                Profession Name
              </th>
              <th
                class="text-left px-6 py-3 text-xs font-semibold text-neutral-400 uppercase tracking-wider"
              >
                Slug
              </th>
              <th
                class="text-center px-6 py-3 text-xs font-semibold text-neutral-400 uppercase tracking-wider"
              >
                Orden
              </th>
              <th
                class="text-center px-6 py-3 text-xs font-semibold text-neutral-400 uppercase tracking-wider"
              >
                Status
              </th>
              <th
                class="text-center px-6 py-3 text-xs font-semibold text-neutral-400 uppercase tracking-wider"
              >
                Actions
              </th>
            </tr>
          </thead>
          <tbody id="tableBody"></tbody>
        </table>
      </div>

      <div
        class="flex items-center justify-between px-6 py-4 border-t border-neutral-100"
      >
        <p id="paginationInfo" class="text-sm text-neutral-500">
          Showing 0 to 0 of 0 professions
        </p>
        <div id="paginationButtons" class="flex items-center gap-1"></div>
      </div>
    </div>
  </div>

  <div
    id="profesionModalOverlay"
    class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  >
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
      <div
        class="flex items-center justify-between px-6 py-4 border-b border-neutral-100"
      >
        <h3 id="profesionModalTitle" class="text-lg font-bold text-neutral-900">
          Agregar Profesión
        </h3>
        <button
          id="profesionModalClose"
          class="p-1 rounded-lg text-neutral-400 hover:text-neutral-600 hover:bg-neutral-100 transition-colors"
          aria-label="Cerrar"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <form id="profesionForm" class="px-6 py-5 space-y-4">
        <input type="hidden" id="profesionId" />
        <input type="hidden" id="profesionSlug" />
        <input type="hidden" id="profesionSubrubroId" />
        <div>
          <label
            class="block text-xs font-semibold text-neutral-500 uppercase tracking-wide mb-1.5"
            >Nombre *</label
          >
          <input
            type="text"
            id="profesionNombre"
            required
            class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition"
          />
        </div>
        <div>
          <label
            class="block text-xs font-semibold text-neutral-500 uppercase tracking-wide mb-1.5"
            >Orden</label
          >
          <input
            type="number"
            id="profesionOrden"
            value="0"
            class="w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition"
          />
        </div>
        <div class="flex items-center gap-2">
          <input
            type="checkbox"
            id="profesionActivo"
            checked
            class="w-4 h-4 accent-primary rounded"
          />
          <label for="profesionActivo" class="text-sm text-neutral-700"
            >Activo</label
          >
        </div>
      </form>
      <div class="flex justify-end gap-3 px-6 py-4 border-t border-neutral-100">
        <button
          id="profesionModalCancelBtn"
          type="button"
          class="px-4 py-2 text-sm font-semibold text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100 rounded-lg transition-colors"
        >
          CANCELAR
        </button>
        <button
          id="profesionModalSaveBtn"
          type="button"
          class="px-4 py-2 text-sm font-semibold text-white bg-primary hover:bg-primary-alt rounded-lg transition-colors"
        >
          GUARDAR
        </button>
      </div>
    </div>
  </div>

  <div
    id="profesionConfirmOverlay"
    class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  >
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm">
      <div class="px-6 py-5">
        <h3 class="text-base font-bold text-neutral-900 mb-2">
          ¿Desactivar profesión?
        </h3>
        <p id="profesionConfirmMessage" class="text-sm text-neutral-500"></p>
      </div>
      <div class="flex justify-end gap-3 px-6 py-4 border-t border-neutral-100">
        <button
          id="profesionConfirmCancelBtn"
          class="px-4 py-2 text-sm font-semibold text-neutral-600 hover:bg-neutral-100 rounded-lg transition-colors"
        >
          Cancelar
        </button>
        <button
          id="profesionConfirmDeleteBtn"
          class="px-4 py-2 text-sm font-semibold text-white bg-error hover:bg-red-700 rounded-lg transition-colors"
        >
          Desactivar
        </button>
      </div>
    </div>
  </div>

  <div
    id="toast"
    class="fixed top-6 right-6 z-[80] hidden transition-all duration-300 translate-y-[-1rem] opacity-0"
  >
    <div
      id="toast-inner"
      class="flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm"
    >
      <span
        id="toast-icon"
        class="material-symbols-outlined text-xl"
        aria-hidden="true"></span>
      <span id="toast-msg"></span>
    </div>
  </div>

  <script>
    import { getToken, restoreSession } from "../../services/authService";
    import { api } from "../../services/apiClient";
    import { escapeHtml } from "../../utils/helpers";
    import {
      createProfesion,
      deleteProfesion,
      getProfesiones,
      getSubrubro,
      updateProfesion,
      type CreateProfesionPayload,
      type ProfessionCategory,
      type ProfessionCategoryDetail,
      type UpdateProfesionPayload,
    } from "../../services/adminProfessionCategoriesService";

    restoreSession();
    const token = getToken();
    if (token) api.setHeader("Authorization", `Bearer ${token}`);

    const errorState = document.getElementById("errorState") as HTMLDivElement;
    const mainContent = document.getElementById(
      "mainContent",
    ) as HTMLDivElement;
    const breadcrumbRubro = document.getElementById(
      "breadcrumbRubro",
    ) as HTMLAnchorElement;
    const breadcrumbSubrubro = document.getElementById(
      "breadcrumbSubrubro",
    ) as HTMLSpanElement;
    const pageTitle = document.getElementById(
      "pageTitle",
    ) as HTMLHeadingElement;
    const metricTotal = document.getElementById(
      "metricTotal",
    ) as HTMLParagraphElement;
    const metricActivas = document.getElementById(
      "metricActivas",
    ) as HTMLParagraphElement;
    const metricSubrubro = document.getElementById(
      "metricSubrubro",
    ) as HTMLParagraphElement;
    const tableBody = document.getElementById(
      "tableBody",
    ) as HTMLTableSectionElement;
    const tableCount = document.getElementById("tableCount") as HTMLSpanElement;
    const searchInput = document.getElementById(
      "searchInput",
    ) as HTMLInputElement;
    const paginationInfo = document.getElementById(
      "paginationInfo",
    ) as HTMLParagraphElement;
    const paginationButtons = document.getElementById(
      "paginationButtons",
    ) as HTMLDivElement;
    const addButton = document.getElementById(
      "btnAgregarProfesion",
    ) as HTMLButtonElement;
    const modalOverlay = document.getElementById(
      "profesionModalOverlay",
    ) as HTMLDivElement;
    const modalTitle = document.getElementById(
      "profesionModalTitle",
    ) as HTMLHeadingElement;
    const modalClose = document.getElementById(
      "profesionModalClose",
    ) as HTMLButtonElement;
    const modalCancel = document.getElementById(
      "profesionModalCancelBtn",
    ) as HTMLButtonElement;
    const modalSave = document.getElementById(
      "profesionModalSaveBtn",
    ) as HTMLButtonElement;
    const form = document.getElementById("profesionForm") as HTMLFormElement;
    const idInput = document.getElementById("profesionId") as HTMLInputElement;
    const slugInput = document.getElementById(
      "profesionSlug",
    ) as HTMLInputElement;
    const subrubroInput = document.getElementById(
      "profesionSubrubroId",
    ) as HTMLInputElement;
    const nameInput = document.getElementById(
      "profesionNombre",
    ) as HTMLInputElement;
    const orderInput = document.getElementById(
      "profesionOrden",
    ) as HTMLInputElement;
    const isActiveInput = document.getElementById(
      "profesionActivo",
    ) as HTMLInputElement;
    const confirmOverlay = document.getElementById(
      "profesionConfirmOverlay",
    ) as HTMLDivElement;
    const confirmMessage = document.getElementById(
      "profesionConfirmMessage",
    ) as HTMLParagraphElement;
    const confirmCancel = document.getElementById(
      "profesionConfirmCancelBtn",
    ) as HTMLButtonElement;
    const confirmDelete = document.getElementById(
      "profesionConfirmDeleteBtn",
    ) as HTMLButtonElement;
    const toast = document.getElementById("toast") as HTMLDivElement;
    const toastInner = document.getElementById("toast-inner") as HTMLDivElement;
    const toastIcon = document.getElementById("toast-icon") as HTMLSpanElement;
    const toastMsg = document.getElementById("toast-msg") as HTMLSpanElement;

    const params = new URLSearchParams(window.location.search);
    const subrubroId = Number(params.get("subrubroId"));

    let profesiones: ProfessionCategory[] = [];
    let filtered: ProfessionCategory[] = [];
    let currentSubrubro: ProfessionCategoryDetail | null = null;
    let currentPage = 1;
    const PAGE_SIZE = 10;
    let pendingDeleteId: number | null = null;
    let editingId: number | null = null;
    let toastTimeout: ReturnType<typeof setTimeout>;

    function showToast(message: string, type: "success" | "error" = "success") {
      toastMsg.textContent = message;
      toastInner.className =
        "flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-bold text-sm";
      if (type === "success") {
        toastInner.classList.add(
          "bg-primary-container",
          "text-on-primary-container",
        );
        toastIcon.textContent = "check_circle";
      } else {
        toastInner.classList.add(
          "bg-error-container",
          "text-on-error-container",
        );
        toastIcon.textContent = "error";
      }
      toast.classList.remove("hidden");
      requestAnimationFrame(() => {
        toast.classList.remove("translate-y-[-1rem]", "opacity-0");
        toast.classList.add("translate-y-0", "opacity-100");
      });
      clearTimeout(toastTimeout);
      toastTimeout = setTimeout(() => {
        toast.classList.add("translate-y-[-1rem]", "opacity-0");
        toast.classList.remove("translate-y-0", "opacity-100");
        setTimeout(() => toast.classList.add("hidden"), 300);
      }, 3000);
    }

    function generateSlug(text: string) {
      const stopwords = new Set([
        "de",
        "del",
        "la",
        "las",
        "el",
        "los",
        "un",
        "una",
        "unos",
        "unas",
        "y",
        "e",
        "o",
        "u",
        "a",
        "ante",
        "bajo",
        "con",
        "en",
        "entre",
        "hacia",
        "hasta",
        "para",
        "por",
        "sin",
        "sobre",
        "tras",
        "al",
        "lo",
      ]);
      return text
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9\s-]/g, "")
        .trim()
        .split(/\s+/)
        .filter((word) => word.length > 0 && !stopwords.has(word))
        .join("-");
    }

    function setLoadingTable(message: string) {
      tableBody.innerHTML = `
        <tr>
          <td colspan="5" class="px-6 py-12 text-center text-sm text-neutral-400">
            <div class="flex flex-col items-center gap-3">
              <div class="w-8 h-8 border-3 border-primary/30 border-t-primary rounded-full animate-spin"></div>
              <span>${message}</span>
            </div>
          </td>
        </tr>`;
    }

    function getErrorMessage(error: any): string | null {
      const body = error?.body;
      if (
        body &&
        typeof body === "object" &&
        "message" in body &&
        typeof body.message === "string"
      ) {
        return body.message;
      }
      if (typeof body === "string") return body;
      return null;
    }

    async function init() {
      try {
        const subrubro = await getSubrubro(subrubroId);
        currentSubrubro = subrubro;
        breadcrumbSubrubro.textContent = subrubro.name.toUpperCase();
        pageTitle.textContent = subrubro.name;
        metricSubrubro.textContent = subrubro.name;
        if (subrubro.parent) {
          breadcrumbRubro.textContent = subrubro.parent.name.toUpperCase();
          breadcrumbRubro.href = `/admin/subrubros?rubroId=${subrubro.parent.id}`;
        } else {
          breadcrumbRubro.textContent = "CATEGORÍAS";
          breadcrumbRubro.href = "/admin/categorias";
        }

        setLoadingTable("Cargando profesiones...");
        profesiones = await getProfesiones(subrubroId);
        filtered = [...profesiones];
        updateMetrics();
        renderTable();
      } catch (error: any) {
        showToast("Error al cargar los datos", "error");
      }
    }

    function updateMetrics() {
      metricTotal.textContent = String(profesiones.length);
      metricActivas.textContent = String(
        profesiones.filter((item) => item.isActive).length,
      );
      tableCount.textContent = `${filtered.length} ENTRIES`;
    }

    function renderTable() {
      const start = (currentPage - 1) * PAGE_SIZE;
      const page = filtered.slice(start, start + PAGE_SIZE);

      if (!page.length) {
        tableBody.innerHTML = `
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-sm text-neutral-400">No se encontraron profesiones.</td>
          </tr>`;
      } else {
        tableBody.innerHTML = page
          .map((profesion) => {
            const safeName = escapeHtml(profesion.name);
            const safeSlug = escapeHtml(profesion.slug);
            const nameForJs = profesion.name
              .replace(/\\/g, "\\\\")
              .replace(/'/g, "\\'");
            return `
              <tr class="border-b border-neutral-100 hover:bg-neutral-50 transition-colors">
                <td class="px-6 py-4">
                  <div class="font-semibold text-neutral-900 text-sm">${safeName}</div>
                  <div class="text-xs text-neutral-400 font-mono">${safeSlug}</div>
                </td>
                <td class="px-6 py-4">
                  <span class="text-xs font-mono text-neutral-500 bg-neutral-100 px-2 py-1 rounded">${safeSlug}</span>
                </td>
                <td class="px-6 py-4 text-center text-sm text-neutral-600">${profesion.order ?? 0}</td>
                <td class="px-6 py-4 text-center">
                  ${
                    profesion.isActive
                      ? `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-success/10 text-success"><span class="w-1.5 h-1.5 rounded-full bg-success"></span>ACTIVO</span>`
                      : `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-neutral-100 text-neutral-400"><span class="w-1.5 h-1.5 rounded-full bg-neutral-400"></span>INACTIVO</span>`
                  }
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center justify-center gap-1">
                    <button
                      onclick="openEditModal(${profesion.id})"
                      class="p-1.5 rounded-lg text-neutral-400 hover:text-primary hover:bg-primary/10 transition-colors"
                      title="Editar"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125" />
                      </svg>
                    </button>
                    <button
                      onclick="openConfirm(${profesion.id}, '${nameForJs}')"
                      class="p-1.5 rounded-lg text-neutral-400 hover:text-error hover:bg-error/10 transition-colors"
                      title="Desactivar"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.021-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>`;
          })
          .join("");
      }

      renderPagination();
    }

    function renderPagination() {
      const total = filtered.length;
      const totalPages = Math.ceil(total / PAGE_SIZE);
      const start = Math.min((currentPage - 1) * PAGE_SIZE + 1, total);
      const end = Math.min(currentPage * PAGE_SIZE, total);

      paginationInfo.textContent = `Showing ${total ? start : 0} to ${end} of ${total} professions`;

      const btnClass = (active: boolean) =>
        active
          ? "px-3 py-1.5 text-sm font-semibold text-white bg-primary rounded-lg"
          : "px-3 py-1.5 text-sm font-semibold text-neutral-600 hover:bg-neutral-100 rounded-lg transition-colors";

      let html = `<button onclick="goPage(${currentPage - 1})" ${currentPage === 1 ? "disabled" : ""} class="px-3 py-1.5 text-sm font-semibold text-neutral-600 hover:bg-neutral-100 rounded-lg transition-colors disabled:opacity-40">Previous</button>`;
      let startPage = Math.max(1, currentPage - 2);
      let endPage = Math.min(totalPages, startPage + 4);
      if (endPage - startPage < 4) {
        startPage = Math.max(1, endPage - 4);
      }
      for (let i = startPage; i <= endPage; i += 1) {
        html += `<button onclick="goPage(${i})" class="${btnClass(i === currentPage)}">${i}</button>`;
      }
      html += `<button onclick="goPage(${currentPage + 1})" ${currentPage === totalPages || totalPages === 0 ? "disabled" : ""} class="px-3 py-1.5 text-sm font-semibold text-neutral-600 hover:bg-neutral-100 rounded-lg transition-colors disabled:opacity-40">Next</button>`;
      paginationButtons.innerHTML = html;
    }

    function goPage(page: number) {
      const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
      if (page < 1 || page > totalPages) return;
      currentPage = page;
      renderTable();
    }

    window.goPage = goPage;

    function openCreateModal() {
      editingId = null;
      form.reset();
      idInput.value = "";
      slugInput.value = "";
      orderInput.value = "0";
      isActiveInput.checked = true;
      subrubroInput.value = String(subrubroId);
      modalTitle.textContent = "Agregar Profesión";
      modalOverlay.classList.remove("hidden");
      document.body.style.overflow = "hidden";
      nameInput.focus();
    }

    function openEditModal(id: number) {
      const profesion = profesiones.find((item) => item.id === id);
      if (!profesion) return;
      editingId = id;
      idInput.value = String(profesion.id);
      nameInput.value = profesion.name;
      slugInput.value = profesion.slug;
      orderInput.value = String(profesion.order ?? 0);
      isActiveInput.checked = profesion.isActive;
      subrubroInput.value = String(subrubroId);
      modalTitle.textContent = "Editar Profesión";
      modalOverlay.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }

    window.openEditModal = openEditModal;

    function closeModal() {
      modalOverlay.classList.add("hidden");
      document.body.style.overflow = "";
    }

    function openConfirm(id: number, name: string) {
      pendingDeleteId = id;
      confirmMessage.textContent = `¿Desactivar la profesión "${name}"? Esta acción puede revertirse con PATCH isActive: true.`;
      confirmOverlay.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }

    window.openConfirm = openConfirm;

    function closeConfirm() {
      pendingDeleteId = null;
      confirmOverlay.classList.add("hidden");
      document.body.style.overflow = "";
    }

    async function reloadProfesiones() {
      profesiones = await getProfesiones(subrubroId);
      filtered = [...profesiones];
      currentPage = 1;
      updateMetrics();
      renderTable();
    }

    async function handleSubmit() {
      const nombre = nameInput.value.trim();
      if (!nombre) {
        showToast("El nombre es requerido", "error");
        return;
      }
      const slug = slugInput.value.trim();
      const orden = Number(orderInput.value || 0);
      const activo = isActiveInput.checked;

      try {
        if (editingId) {
          const payload: UpdateProfesionPayload = {
            name: nombre,
            order: orden,
            isActive: activo,
          };
          if (slug) payload.slug = slug;
          await updateProfesion(editingId, payload);
          showToast("Profesión actualizada correctamente", "success");
        } else {
          const payload: CreateProfesionPayload = {
            name: nombre,
            subrubroId,
            order: orden,
            isActive: activo,
          };
          if (slug) payload.slug = slug;
          await createProfesion(payload);
          showToast("Profesión creada correctamente", "success");
        }
        closeModal();
        await reloadProfesiones();
      } catch (error: any) {
        if (
          error?.status === 409 ||
          String(error?.message || "").includes("409")
        ) {
          showToast("El slug ya existe", "error");
          return;
        }
        showToast("Error al guardar la profesión", "error");
      }
    }

    async function handleDelete() {
      if (!pendingDeleteId) return;
      try {
        await deleteProfesion(pendingDeleteId);
        closeConfirm();
        showToast("Profesión desactivada correctamente", "success");
        await reloadProfesiones();
      } catch (error: any) {
        closeConfirm();
        if (error?.status === 400) {
          const message =
            getErrorMessage(error) ||
            "No se puede desactivar: tiene profesionales o documentos asociados";
          showToast(message, "error");
          return;
        }
        showToast("Error al desactivar", "error");
      }
    }

    if (Number.isNaN(subrubroId)) {
      errorState.classList.remove("hidden");
    } else {
      mainContent.classList.remove("hidden");
      void init();
    }

    searchInput.addEventListener("input", () => {
      const q = searchInput.value.toLowerCase().trim();
      filtered = q
        ? profesiones.filter(
            (item) =>
              item.name.toLowerCase().includes(q) ||
              item.slug.toLowerCase().includes(q),
          )
        : [...profesiones];
      currentPage = 1;
      tableCount.textContent = `${filtered.length} ENTRIES`;
      renderTable();
    });

    nameInput.addEventListener("input", () => {
      if (!editingId) {
        slugInput.value = generateSlug(nameInput.value);
      }
    });

    addButton.addEventListener("click", openCreateModal);
    modalClose.addEventListener("click", closeModal);
    modalCancel.addEventListener("click", closeModal);
    modalOverlay.addEventListener("click", (event) => {
      if (event.target === modalOverlay) closeModal();
    });
    modalSave.addEventListener("click", () => form.requestSubmit());
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      void handleSubmit();
    });

    confirmCancel.addEventListener("click", closeConfirm);
    confirmOverlay.addEventListener("click", (event) => {
      if (event.target === confirmOverlay) closeConfirm();
    });
    confirmDelete.addEventListener("click", () => void handleDelete());
  </script>
</AdminLayout>
